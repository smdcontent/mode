            handle = View(ctx)
            bg = GradientDrawable()
            bg.setCornerRadius(float(AndroidUtilities.dp(3)))
            bg.setColor(self._jcolor((int(sub_color) & 0x66FFFFFF) or 0x66AAB4C2))
            handle.setBackground(bg)
            handle_wrap.addView(handle, LinearLayout.LayoutParams(AndroidUtilities.dp(42), AndroidUtilities.dp(6)))
            lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp.bottomMargin = AndroidUtilities.dp(18)
            outer.addView(handle_wrap, lp)

            title = TextView(ctx)
            title.setText(self._tr("panel_menu_shortcuts"))
            title.setTextSize(22)
            title.setTypeface(None, 1)
            title.setTextColor(int(title_color))
            title.setGravity(Gravity.CENTER_HORIZONTAL)
            outer.addView(title)

            desc = TextView(ctx)
            desc.setText(self._tr("panel_menu_shortcuts_desc"))
            desc.setTextSize(14)
            desc.setTextColor(int(sub_color))
            desc.setGravity(Gravity.CENTER_HORIZONTAL)
            desc_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            desc_lp.topMargin = AndroidUtilities.dp(8)
            desc_lp.bottomMargin = AndroidUtilities.dp(12)
            outer.addView(desc, desc_lp)

            row = LinearLayout(ctx)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(8), AndroidUtilities.dp(14), AndroidUtilities.dp(8))

            mw = LinearLayout(ctx)
            mw.setGravity(Gravity.CENTER_VERTICAL)
            try:
                miv = ImageView(ctx)
                res = ApplicationLoader.applicationContext.getResources()
                pkg = ApplicationLoader.applicationContext.getPackageName()
                mid = res.getIdentifier("msg_list", "drawable", pkg)
                if not mid:
                    mid = res.getIdentifier("menu_archive", "drawable", pkg)
                if mid:
                    miv.setImageResource(int(mid))
                    miv.setColorFilter(int(title_color), PorterDuff.Mode.SRC_IN)
                mw.addView(miv, LinearLayout.LayoutParams(AndroidUtilities.dp(22), AndroidUtilities.dp(22)))
            except Exception:
                pass
            row.addView(mw)

            info = LinearLayout(ctx)
            info.setOrientation(LinearLayout.VERTICAL)
            info_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            info_lp.leftMargin = AndroidUtilities.dp(8)

            t1 = TextView(ctx)
            t1.setText(self._tr("panel_menu_shortcuts_enabled"))
            t1.setTextSize(15)
            t1.setTypeface(None, 1)
            t1.setTextColor(int(title_color))
            info.addView(t1)

            t2 = TextView(ctx)
            t2.setText(self._tr("panel_menu_shortcuts_enabled_desc"))
            t2.setTextSize(11)
            t2.setPadding(0, AndroidUtilities.dp(2), 0, 0)
            t2.setTextColor(int(sub_color))
            info.addView(t2)
            row.addView(info, info_lp)

            plugin = self
            try:
                Switch = jclass("android.widget.Switch")
                ms_sw = Switch(ctx)
                ms_sw_ign = [False]

                def _sync_ms_sw():
                    ms_sw_ign[0] = True
                    try:
                        ms_sw.setChecked(bool(plugin._menu_shortcuts_enabled()))
                    finally:
                        ms_sw_ign[0] = False

                _sync_ms_sw()
                CC = jclass("android.widget.CompoundButton$OnCheckedChangeListener")

                class _MsSw(dynamic_proxy(CC)):
                    def onCheckedChanged(self_obj, _button_view, is_checked):
                        if ms_sw_ign[0]:
                            return
                        try:
                            plugin._set_menu_shortcuts_enabled(bool(is_checked))
                            try:
                                plugin._ensure_dialogs_menu_item()
                                plugin._ensure_chat_menu_item()
                            except Exception:
                                pass
                        except Exception as e:
                            plugin._trace("menu shortcuts switch fail: {0}".format(e), "ERROR")

                ms_sw.setOnCheckedChangeListener(_MsSw())
                row.addView(ms_sw, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            except Exception:
                pass

            outer.addView(row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            scroll.addView(outer)
            sheet.setCustomView(scroll)
            sheet.show()
            self._menu_shortcuts_sheet = sheet
        except Exception as e:
            self._trace("show menu shortcuts sheet fail: {0}".format(e), "ERROR")
            self._show_error_sheet("Menu shortcuts panel render failed:\n{0}".format(e))

