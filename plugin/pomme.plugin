class PommeNotificationHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            args = list(param.args or [])
            if len(args) < 1:
                return
            event_id = int(args[0] or 0)
            self.plugin._handle_notification_event(event_id, args[1:])
        except Exception as e:
            self.plugin._trace("notification hook fail: {0}".format(e), "ERROR")


class PommeShowDialogHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            dialog = param.args[0]
                                                  
            if dialog is not None and "AudioPlayerAlert" in str(dialog.getClass().getName() or ""):
                if self.plugin._is_current_pomme_track():
                    self.plugin._trace("Intercepting showDialog(AudioPlayerAlert)", "INFO")
                    param.setResult(None)                        
                    
                                                 
                    mc = jclass("org.telegram.messenger.MediaController").getInstance()
                    msg_obj = mc.getPlayingMessageObject()
                    if msg_obj:
                        doc = msg_obj.messageOwner.media.document
                        title, performer = "", ""
                        for attr in self.plugin._iter_java_list(getattr(doc, "attributes", None)):
                            if self.plugin._is_tl_document_attribute_audio(attr):
                                title, performer = str(attr.title or ""), str(attr.performer or "")
                                break
                        new_item = {
                            "title": title, "author": performer,
                            "thumbnail": self.plugin._last_started_item.get("thumbnail") if self.plugin._last_started_item else ""
                        }
                        run_on_ui_thread(lambda: self.plugin._show_custom_player_overlay(new_item))
        except Exception as e:
            self.plugin._trace("showDialog hook fail: {0}".format(e), "ERROR")


class PommePlayerAlertCreateHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
                                                                                 
                                                                                       
            pass
        except Exception: pass

    def after_hooked_method(self, param):
        try:
                                            
            if self.plugin._is_current_pomme_track():
                alert_obj = param.thisObject
                if alert_obj is not None:
                                                                                         
                                                                                                               
                    def _safe_dismiss():
                        try:
                                                                        
                            alert_obj.setDimBehind(False)
                                                                                
                            container = get_private_field(alert_obj, "container")
                            if container:
                                container.setVisibility(View.INVISIBLE)
                                                       
                            alert_obj.dismiss()
                        except Exception: pass
                    run_on_ui_thread(_safe_dismiss)
                    
                                                 
                    mc = jclass("org.telegram.messenger.MediaController").getInstance()
                    msg_obj = mc.getPlayingMessageObject()
                    if msg_obj:
                        doc = msg_obj.messageOwner.media.document
                        title, performer = "", ""
                        for attr in self.plugin._iter_java_list(getattr(doc, "attributes", None)):
                            if self.plugin._is_tl_document_attribute_audio(attr):
                                title, performer = str(attr.title or ""), str(attr.performer or "")
                                break
                        new_item = {
                            "title": title, "author": performer,
                            "thumbnail": self.plugin._last_started_item.get("thumbnail") if self.plugin._last_started_item else ""
                        }
                        run_on_ui_thread(lambda: self.plugin._show_custom_player_overlay(new_item))

            self.plugin._ensure_player_menu_item(param.thisObject)
        except Exception as e:
            self.plugin._trace("player alert hook fail: {0}".format(e), "ERROR")


