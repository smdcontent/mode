            add_btn.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(10), AndroidUtilities.dp(14), AndroidUtilities.dp(10))
            listener_cls = find_class("android.view.View$OnClickListener")
            if listener_cls is not None:
                plugin = self
                class _OpenAdd(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        plugin._open_track_playlist_editor()
                add_btn.setOnClickListener(_OpenAdd())
            lp_add = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_add.topMargin = AndroidUtilities.dp(12)
            lp_add.gravity = Gravity.END
            wrap.addView(add_btn, lp_add)

            for entry in self._user_saved_playlists():
                name = str(entry.get("name") or "").strip()
                card = LinearLayout(ctx)
                card.setOrientation(LinearLayout.HORIZONTAL)
                card.setGravity(Gravity.CENTER_VERTICAL)
                card.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
                try:
                    bg = GradientDrawable()
                    bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                    bg.setColor(int(Theme.getColor(Theme.key_dialogBackgroundGray)))
                    card.setBackground(bg)
                except Exception:
                    pass
                texts = LinearLayout(ctx)
                texts.setOrientation(LinearLayout.VERTICAL)
                lp_texts = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                t1 = TextView(ctx)
                t1.setText(name)
                t1.setTextSize(16)
                t1.setTypeface(None, 1)
                try:
                    t1.setTextColor(int(Theme.getColor(Theme.key_dialogTextBlack)))
                except Exception:
                    pass
                texts.addView(t1)
                t2 = TextView(ctx)
                already = self._track_in_named_playlist(name, self._current_track_item())
                count_text = self._tr("track_count_fmt").format(self._track_count_for_named_playlist(name))
                if already:
                    t2.setText("{0} | {1}".format(count_text, self._tr("track_already_in_playlist")))
                else:
                    t2.setText(count_text)
                t2.setTextSize(12)
                try:
                    t2.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
                except Exception:
                    pass
                texts.addView(t2)
                card.addView(texts, lp_texts)

                play_chip = TextView(ctx)
                play_chip.setText("Add")
                play_chip.setGravity(Gravity.CENTER)
                play_chip.setTextSize(13)
                play_chip.setTypeface(None, 1)
                try:
                    play_chip.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                    chip_bg = GradientDrawable()
                    chip_bg.setCornerRadius(float(AndroidUtilities.dp(999)))
                    chip_bg.setColor(int(Theme.getColor(Theme.key_dialogBackground)))
                    chip_bg.setStroke(AndroidUtilities.dp(1), int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                    play_chip.setBackground(chip_bg)
                except Exception:
                    pass
                play_chip.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(7), AndroidUtilities.dp(12), AndroidUtilities.dp(7))
                if listener_cls is not None:
                    plugin = self
                    class _AddClick(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v, playlist_name=name):
                            changed = plugin._save_current_track_to_named_playlist(playlist_name)
                            try:
                                if plugin._track_playlist_sheet is not None:
                                    plugin._track_playlist_sheet.dismiss()
                            except Exception:
                                pass
                            plugin._show_track_playlist_sheet()
                    play_chip.setOnClickListener(_AddClick())
                card.addView(play_chip)
                lp_card = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_card.topMargin = AndroidUtilities.dp(10)
                wrap.addView(card, lp_card)

            sheet.setCustomView(wrap)
            sheet.show()
            self._track_playlist_sheet = sheet
            return True
        except Exception as e:
            self._trace("show track playlist sheet fail: {0}".format(e), "ERROR")
            return False

    def _ensure_player_action_row(self, alert_obj, save_btn):
        try:
            if alert_obj is None or save_btn is None:
                return False
            visible = bool(self._is_current_pomme_track())
            parent = save_btn.getParent()
            if parent is None:
                return False
            row = None
            try:
                if str(parent.getTag() or "") == "pomme_action_row":
                    row = parent
            except Exception:
                row = None
            if row is None:
                old_lp = save_btn.getLayoutParams()
                parent.removeView(save_btn)
                row = LinearLayout(save_btn.getContext())
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                try:
                    row.setTag("pomme_action_row")
                except Exception:
                    pass
                try:
                    row.setPadding(0, 0, 0, 0)
                except Exception:
                    pass
                parent.addView(row, old_lp)
                lp_primary = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                lp_primary.leftMargin = AndroidUtilities.dp(8)
                lp_primary.rightMargin = AndroidUtilities.dp(8)
                row.addView(save_btn, lp_primary)
            else:
                try:
                    for idx in range(int(row.getChildCount())):
                        child = row.getChildAt(idx)
                        if child is save_btn:
                            lp_existing = child.getLayoutParams()
                            if lp_existing is not None:
                                lp_existing.width = 0
                                lp_existing.height = LinearLayout.LayoutParams.WRAP_CONTENT
                                lp_existing.weight = 1.0
                                try:
                                    lp_existing.leftMargin = AndroidUtilities.dp(8)
                                    lp_existing.rightMargin = AndroidUtilities.dp(8)
                                except Exception:
                                    pass
                                child.setLayoutParams(lp_existing)
                            break
                except Exception:
                    pass

            def _find_tag(target_tag):
                try:
                    for idx in range(int(row.getChildCount())):
                        child = row.getChildAt(idx)
                        try:
                            if str(child.getTag() or "") == str(target_tag):
                                return child
                        except Exception:
                            pass
                except Exception:
                    pass
                return None

            listener_cls = find_class("android.view.View$OnClickListener")
            ButtonWithCounterView = None
            resources_provider = None
            try:
                ButtonWithCounterView = jclass("org.telegram.ui.Stories.recorder.ButtonWithCounterView")
                resources_provider = get_private_field(alert_obj, "resourcesProvider")
            except Exception:
                ButtonWithCounterView = None
                resources_provider = None

            def _native_button(tag_name, text_key):
                btn = None
                if ButtonWithCounterView is not None:
                    try:
                        btn = ButtonWithCounterView(save_btn.getContext(), resources_provider).setRound()
                        btn.setText(self._tr(text_key), False)
                    except Exception:
                        btn = None
                if btn is None:
                    btn = TextView(save_btn.getContext())
                    btn.setText(self._tr(text_key))
                    btn.setGravity(Gravity.CENTER)
                    btn.setTextSize(16)
                    try:
                        btn.setTypeface(None, 1)
                        btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                        bg = GradientDrawable()
                        bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                        bg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                        btn.setBackground(bg)
                        btn.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(10), AndroidUtilities.dp(16), AndroidUtilities.dp(10))
                    except Exception:
                        pass
                try:
                    btn.setTag(tag_name)
                except Exception:
                    pass
                return btn

            def _icon_button(tag_name, icon_name, click_cb):
                btn = _find_tag(tag_name)
                if btn is None:
                    ImageView = jclass("android.widget.ImageView")
                    btn = ImageView(save_btn.getContext())
                    try:
                        btn.setTag(tag_name)
                        pkg = ApplicationLoader.applicationContext.getPackageName()
                        icon_id = ApplicationLoader.applicationContext.getResources().getIdentifier(str(icon_name), "drawable", pkg)
                        if icon_id:
                            btn.setImageResource(int(icon_id))
                        btn.setScaleType(ImageView.ScaleType.CENTER)
                        btn.setColorFilter(PorterDuffColorFilter(int(Theme.getColor(Theme.key_player_button)), PorterDuff.Mode.MULTIPLY))
                        btn.setBackground(Theme.createSelectorDrawable(int(Theme.getColor(Theme.key_listSelector)), 1, AndroidUtilities.dp(18)))
                    except Exception:
                        pass
                if listener_cls is not None:
                    class _Click(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            try:
                                click_cb()
                            except Exception:
                                pass
                    try:
                        if str(btn.getContentDescription() or "") != "{0}_bound".format(tag_name):
                            btn.setOnClickListener(_Click())
                            btn.setContentDescription("{0}_bound".format(tag_name))
                    except Exception:
                        pass
                return btn

            save_track_btn = _find_tag("pomme_track_playlist_inline_button")
            if save_track_btn is None:
                plugin = self
                save_track_btn = _icon_button("pomme_track_playlist_inline_button", "outline_saved_24", lambda: plugin._show_track_playlist_sheet())

            panel_btn = _find_tag("pomme_panel_inline_button")
            if panel_btn is None:
                plugin = self
                panel_btn = _icon_button("pomme_panel_inline_button", "msg_mini_customize_solar", lambda: plugin._show_about_sheet())

            song_btn = _find_tag("pomme_songlink_button")
            if song_btn is None:
                song_btn = _native_button("pomme_songlink_button", "song_link_button")
                if listener_cls is not None:
                    plugin = self
                    class _SongLinkClick(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            plugin._open_current_song_link()
                    try:
                        song_btn.setOnClickListener(_SongLinkClick())
                    except Exception:
                        pass
                row.addView(song_btn, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))
            else:
                try:
                    lp = song_btn.getLayoutParams()
                    if lp is not None:
                        lp.width = 0
                        lp.height = LinearLayout.LayoutParams.WRAP_CONTENT
                        lp.weight = 1.0
                        song_btn.setLayoutParams(lp)
                except Exception:
                    pass
            def _tag_of(view_obj):
                try:
                    return str(view_obj.getTag() or "")
                except Exception:
                    return ""

            desired_mode = "pomme" if visible else "native"
            current_mode = ""
            try:
                current_mode = str(row.getContentDescription() or "")
            except Exception:
                current_mode = ""
            
                                                                     
            force_refresh = (current_mode != desired_mode)
            if not force_refresh and visible:
                                                                 
                for btn in (save_track_btn, panel_btn, save_btn, song_btn):
                    if btn is not None and btn.getParent() is None:
                        force_refresh = True
                        break

            if force_refresh:
                for child in (save_btn, song_btn, panel_btn, save_track_btn):
                    try:
                        if child is not None:
                            row.removeView(child)
                    except Exception:
                        pass
                if visible:
                    icon_lp = LinearLayout.LayoutParams(AndroidUtilities.dp(48), AndroidUtilities.dp(42))
                    icon_lp.rightMargin = AndroidUtilities.dp(8)
                    if save_track_btn is not None:
                        row.addView(save_track_btn, 0, icon_lp)
                    
                    panel_lp = LinearLayout.LayoutParams(AndroidUtilities.dp(48), AndroidUtilities.dp(42))
                    panel_lp.rightMargin = AndroidUtilities.dp(8)
                    if panel_btn is not None:
                        row.addView(panel_btn, 1, panel_lp)
                    
                    lyrics_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                    lyrics_lp.rightMargin = AndroidUtilities.dp(8)
                    if save_btn is not None:
                        row.addView(save_btn, 2, lyrics_lp)
                    
                    link_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                    if song_btn is not None:
                        row.addView(song_btn, 3, link_lp)
                else:
                    native_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    if save_btn is not None:
                        row.addView(save_btn, 0, native_lp)
                try:
                    row.setContentDescription(desired_mode)
                except Exception:
                    pass
            for target in (save_track_btn, panel_btn, save_btn, song_btn):
                try:
                    if target is not None:
                        if target is save_btn:
                            target.setVisibility(View.VISIBLE)
                        else:
                            target.setVisibility(View.VISIBLE if visible else View.GONE)
                except Exception:
                    pass
            return True
        except Exception as e:
            self._trace("ensure player action row fail: {0}".format(e), "ERROR")
            return False

    def _restore_native_player_ui(self, alert_obj):
        try:
            if alert_obj is None:
                return False
            listener_cls = find_class("android.view.View$OnClickListener")
            save_btn = get_private_field(alert_obj, "saveToProfileButton")
            if save_btn is not None:
                try:
                    save_btn.setVisibility(View.VISIBLE)
                    save_btn.setEnabled(True)
                    save_btn.setClickable(True)
                    save_btn.setAlpha(1.0)
                except Exception:
                    pass
                try:
                    if str(save_btn.getTag() or "") == "pomme_primary_button":
                        self._ensure_player_action_row(alert_obj, save_btn)
                except Exception:
                    pass
            repeat_button = get_private_field(alert_obj, "repeatButton")
            if repeat_button is not None:
                try:
                    repeat_button.setVisibility(View.VISIBLE)
                    repeat_button.setAlpha(1.0)
                    repeat_button.setEnabled(True)
                    repeat_button.setClickable(True)
                except Exception:
                    pass
                try:
                    repeat_button.setLongClickEnabled(False)
                    repeat_button.setShowSubmenuByMove(False)
                except Exception:
                    pass
                if listener_cls is not None:
                    class _RepeatClick(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            try:
                                repeat_button.toggleSubMenu()
                            except Exception:
                                pass
                    try:
                        repeat_button.setOnClickListener(_RepeatClick())
                    except Exception:
                        pass
            options_button = get_private_field(alert_obj, "optionsButton")
            if options_button is not None:
                try:
                    options_button.setVisibility(View.VISIBLE)
                    options_button.setAlpha(1.0)
                    options_button.setEnabled(True)
                    options_button.setClickable(True)
                except Exception:
                    pass
                if listener_cls is not None:
                    class _OptionsClick(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            try:
                                options_button.toggleSubMenu()
                            except Exception:
                                pass
                    try:
                        options_button.setOnClickListener(_OptionsClick())
                    except Exception:
                        pass
                try:
                    parent = options_button.getParent()
                    if parent is not None:
                        for idx in range(int(parent.getChildCount())):
                            child = parent.getChildAt(idx)
                            try:
                                if str(child.getTag() or "") == "pomme_like_button":
                                    child.setVisibility(View.GONE)
                            except Exception:
                                pass
                except Exception:
                    pass
            try:
                player_layout = get_private_field(alert_obj, "playerLayout")
                if player_layout is not None:
                    for idx in range(int(player_layout.getChildCount())):
                        child = player_layout.getChildAt(idx)
                        try:
                            if str(child.getTag() or "") in ("pomme_top_save_button",):
                                child.setVisibility(View.GONE)
                        except Exception:
                            pass
            except Exception:
                pass
            return True
        except Exception as e:
            self._trace("restore native player ui fail: {0}".format(e), "ERROR")
            return False

    def _ensure_player_track_save_button(self, alert_obj):
        try:
            if alert_obj is None:
                return False
            action_bar = get_private_field(alert_obj, "actionBar")
            if action_bar is None:
                return False
            menu = None
            try:
                menu = action_bar.createMenu()
            except Exception:
                try:
                    menu = get_private_field(action_bar, "menu")
                except Exception:
                    menu = None
            if menu is not None:
                try:
                    for idx in range(int(menu.getChildCount())):
                        child = menu.getChildAt(idx)
                        try:
                            if str(child.getTag() or "") == "pomme_top_save_button":
                                child.setVisibility(View.GONE)
                                child.setAlpha(0.0)
                                child.setEnabled(False)
                                child.setClickable(False)
                        except Exception:
                            pass
                except Exception:
                    pass
            return True
        except Exception as e:
            self._trace("ensure player track save button fail: {0}".format(e), "ERROR")
            return False

    def _show_player_about_sheet(self):
        try:
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return False
            self._ensure_about_assets(sync=True)
            sheet = BottomSheet(ctx, True)
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))
            try:
                root_bg = GradientDrawable()
                root_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                root_bg.setColor(int(Theme.getColor(Theme.key_dialogBackground)))
                root.setBackground(root_bg)
            except Exception:
                pass

            row = LinearLayout(ctx)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            row.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))

            ImageView = jclass("android.widget.ImageView")
            ViewOutlineProvider = jclass("android.view.ViewOutlineProvider")
            BitmapFactory = jclass("android.graphics.BitmapFactory")
            def _decode_remote_bitmap(url, cache_key):
                try:
                    data = self._cached_remote_bytes(url, cache_key=cache_key)
                    if not data:
                        return None
                    return BitmapFactory.decodeByteArray(data, 0, len(data))
                except Exception:
                    return None

            avatar = ImageView(ctx)
            try:
                avatar.setScaleType(ImageView.ScaleType.CENTER_CROP)
                av_bg = GradientDrawable()
                av_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                av_bg.setColor(0x00000000)
                avatar.setBackground(av_bg)
                avatar.setClipToOutline(True)
                avatar.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
                avatar_file = self._about_avatar_cache_file()
                if avatar_file and os.path.exists(avatar_file):
                    bmp = BitmapFactory.decodeFile(avatar_file)
                    if bmp is not None:
                        avatar.setImageBitmap(bmp)
                if avatar.getDrawable() is None:
                    bmp = _decode_remote_bitmap(ABOUT_AVATAR_URL, "pomme_about_avatar")
                    if bmp is not None:
                        avatar.setImageBitmap(bmp)
                avatar.setCameraDistance(float(AndroidUtilities.dp(800)))
                avatar.setAlpha(0.0)
                avatar.setTranslationY(float(AndroidUtilities.dp(26)))
                avatar.setRotationY(-120.0)
            except Exception:
                pass
            row.addView(avatar, LinearLayout.LayoutParams(AndroidUtilities.dp(72), AndroidUtilities.dp(72)))

            desc = TextView(ctx)
            desc.setText(self._tr("about_desc"))
            desc.setTextSize(15)
            try:
                desc.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            except Exception:
                pass
            lp_desc = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            lp_desc.leftMargin = AndroidUtilities.dp(10)
            row.addView(desc, lp_desc)
            root.addView(row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            actions = LinearLayout(ctx)
            actions.setOrientation(LinearLayout.HORIZONTAL)
            actions.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
            lp_actions = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_actions.topMargin = AndroidUtilities.dp(10)

            ext = ImageView(ctx)
            try:
                ext.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
                is_dark = bool(Theme.isCurrentThemeDark())
                icon_path = self._about_ext_icon_cache_file(is_dark)
                if icon_path and os.path.exists(icon_path):
                    bmp_ext = BitmapFactory.decodeFile(icon_path)
                    if bmp_ext is not None:
                        ext.setImageBitmap(bmp_ext)
                if ext.getDrawable() is None:
                    bmp_ext = _decode_remote_bitmap(
                        EXTENDED_ICON_URL_DARK if is_dark else EXTENDED_ICON_URL_LIGHT,
                        "pomme_about_ext_{0}".format("dark" if is_dark else "light"),
                    )
                    if bmp_ext is not None:
                        ext.setImageBitmap(bmp_ext)
                ext.setPadding(AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4))
            except Exception:
                pass
            lp_ext = LinearLayout.LayoutParams(AndroidUtilities.dp(36), AndroidUtilities.dp(36))
            lp_ext.rightMargin = AndroidUtilities.dp(8)
            actions.addView(ext, lp_ext)

            btn = TextView(ctx)
            btn.setText("Say hello")
            btn.setGravity(Gravity.CENTER)
            btn.setTextSize(16)
            try:
                btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                btn_bg = GradientDrawable()
                btn_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                btn_bg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                btn.setBackground(btn_bg)
                btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            except Exception:
                pass

            listener_cls = find_class("android.view.View$OnClickListener")
            if listener_cls is not None:
                plugin = self

                class _OpenApple(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        try:
                            get_messages_controller().openByUserName("AGeekApple", get_last_fragment(), 1)
                        except Exception:
                            plugin._open_url("https://t.me/AGeekApple")
                        try:
                            sheet.dismiss()
                        except Exception:
                            pass

                class _OpenPost(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        try:
                            plugin._open_url(ABOUT_POST_URL)
                        except Exception:
                            pass

                btn.setOnClickListener(_OpenApple())
                ext.setOnClickListener(_OpenPost())

            actions.addView(btn, LinearLayout.LayoutParams(AndroidUtilities.dp(140), LinearLayout.LayoutParams.WRAP_CONTENT))
            root.addView(actions, lp_actions)
            outer.addView(root, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            sheet.setCustomView(outer)
            sheet.show()
            try:
                avatar.post(lambda: avatar.animate().translationY(0.0).alpha(1.0).rotationY(0.0).setDuration(620).start())
            except Exception:
                try:
                    avatar.animate().translationY(0.0).alpha(1.0).rotationY(0.0).setDuration(620).start()
                except Exception:
                    pass
            return True
        except Exception as e:
            self._trace("show player about fail: {0}".format(e), "ERROR")
            return False

    def _request_player_close(self):
        try:
            if not self._is_current_pomme_track():
                return False
            self._trace("explicit player close requested", "INFO")
            self._arm_manual_close_guard(4.0)
            self._activate_hard_stop(5.0)
            self._manual_stop_requested = True
            self._autoplay_blocked = True
            self._queue_running = False
            self._waiting_for_track_change = False
            self._continue_token += 1
            self._queue_items = []
            self._history_items = []
            self._active_play_ctx = None
            self._last_started_item = None
            try:
                self._track_playlist_sheet = None
                self._track_playlist_detail_sheet = None
            except Exception:
                pass
            try:
                MediaController = jclass("org.telegram.messenger.MediaController")
                media = MediaController.getInstance()
                try:
                    playlist = get_private_field(media, "playlist")
                    if playlist is not None:
                        playlist.clear()
                except Exception:
                    pass
                try:
                    shuffled = get_private_field(media, "shuffledPlaylist")
                    if shuffled is not None:
                        shuffled.clear()
                except Exception:
                    pass
                try:
                    set_private_field(media, "currentPlaylistNum", -1)
                except Exception:
                    pass
                try:
                    set_private_field(media, "forceLoopCurrentPlaylist", False)
                except Exception:
                    pass
                try:
                    current = media.getPlayingMessageObject()
                    if current is not None:
                        media.pauseMessage(current)
                except Exception:
                    pass
                try:
                    media.cleanupPlayer(True, True)
                except Exception:
                    media.cleanup()
            except Exception as stop_error:
                self._trace("explicit player close cleanup fail: {0}".format(stop_error), "WARN")
            return True
        except Exception as e:
            self._trace("request player close fail: {0}".format(e), "ERROR")
            return False

    def _bind_player_actionbar(self, alert_obj):
        try:
            if alert_obj is None:
                return False
            try:
                alert_key = int(alert_obj.hashCode())
            except Exception:
                alert_key = id(alert_obj)
            if alert_key in self._player_actionbar_bound:
                return True
            action_bar = get_private_field(alert_obj, "actionBar")
            if action_bar is None:
                return False
            try:
                BaseMenuClick = jclass("org.telegram.ui.ActionBar.ActionBar$ActionBarMenuOnItemClick")
            except Exception:
                BaseMenuClick = None
            if BaseMenuClick is None:
                return False
            plugin = self

            class _ActionClick(dynamic_proxy(BaseMenuClick)):
                def onItemClick(self_obj, item_id):
                    try:
                        iid = int(item_id)
                        if iid == -1:
                            plugin._trace("player close clicked from action bar", "INFO")
                            plugin._arm_manual_close_guard(4.0)
                            plugin._manual_stop_requested = True
                            plugin._autoplay_blocked = True
                            plugin._waiting_for_track_change = False
                            plugin._queue_running = False
                            plugin._continue_token += 1
                            plugin._explicit_close_alert_key = alert_key
                            try:
                                plugin._request_player_close()
                            except Exception as close_err:
                                plugin._trace("player close immediate stop fail: {0}".format(close_err), "WARN")
                            alert_obj.dismiss()
                            return
                        if iid == 99041:
                            plugin._show_track_playlist_sheet()
                            return
                        try:
                            method = alert_obj.getClass().getDeclaredMethod("onSubItemClick", jint)
                            method.setAccessible(True)
                            method.invoke(alert_obj, jint(iid))
                        except Exception as sub_err:
                            plugin._trace("player action dispatch fail: {0}".format(sub_err), "WARN")
                    except Exception as e:
                        plugin._trace("player actionbar click fail: {0}".format(e), "ERROR")

            action_bar.setActionBarMenuOnItemClick(_ActionClick())
            self._player_actionbar_bound.add(alert_key)
            return True
        except Exception as e:
            self._trace("bind player actionbar fail: {0}".format(e), "ERROR")
            return False

    def _ensure_player_menu_item(self, alert_obj):
        try:
            if alert_obj is None:
                return False
            self._last_player_alert = alert_obj
            if not self._is_current_pomme_track():
                if not self._player_alert_has_pomme_ui(alert_obj):
                    return False
                return self._restore_native_player_ui(alert_obj)
            self._bind_player_actionbar(alert_obj)
            repeat_button = get_private_field(alert_obj, "repeatButton")
            if repeat_button is not None:
                try:
                    pkg = ApplicationLoader.applicationContext.getPackageName()
                    icon_id = ApplicationLoader.applicationContext.getResources().getIdentifier("device_phone_ios", "drawable", pkg)
                    if icon_id:
                        repeat_button.setIcon(int(icon_id))
                    repeat_button.closeSubMenu()
                    repeat_button.setLongClickEnabled(False)
                    try:
                        repeat_button.setDelegate(lambda _id: None)
                    except Exception:
                        pass
                except Exception:
                    pass
                listener_cls = find_class("android.view.View$OnClickListener")
                if listener_cls is not None:
                    plugin = self

                    class _OpenAbout(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            try:
                                plugin._show_player_about_sheet()
                            except Exception as e:
                                plugin._trace("open player about fail: {0}".format(e), "ERROR")

                    try:
                        repeat_button.setOnClickListener(_OpenAbout())
                    except Exception:
                        pass
            options_button = get_private_field(alert_obj, "optionsButton")
            if options_button is not None:
                try:
                    options_button.closeSubMenu()
                    options_button.setVisibility(View.GONE)
                    options_button.setAlpha(0.0)
                    options_button.setEnabled(False)
                    options_button.setClickable(False)
                    try:
                        options_button.setDelegate(lambda _id: None)
                    except Exception:
                        pass
                    for sub_id in (1, 2, 4, 5, 6, 7):
                        try:
                            options_button.hideSubItem(int(sub_id))
                        except Exception:
                            pass
                    try:
                        parent = options_button.getParent()
                        if parent is not None:
                            for idx in range(int(parent.getChildCount())):
                                child = parent.getChildAt(idx)
                                try:
                                    tag = str(child.getTag() or "")
                                    if tag == "pomme_like_button":
                                        child.setVisibility(View.GONE)
                                        child.setAlpha(0.0)
                                        child.setEnabled(False)
                                        child.setClickable(False)
                                                                                                 
                                    elif tag in ("faveButton", "favoriteButton", "save_button", "saveToProfileButton"):
                                        child.setVisibility(View.GONE)
                                        child.setAlpha(0.0)
                                        child.setEnabled(False)
                                        child.setClickable(False)
                                except Exception:
                                    pass
                    except Exception:
                        pass
                except Exception:
                    pass
                                                                                   
            for field_name in ("faveButton", "favoriteButton", "save_button", "saveToProfileButton"):
                try:
                    native_heart = get_private_field(alert_obj, field_name)
                    if native_heart is not None:
                        native_heart.setVisibility(View.GONE)
                        native_heart.setAlpha(0.0)
                        native_heart.setEnabled(False)
                        native_heart.setClickable(False)
                                                                                      
                        try:
                            class _NoOp(dynamic_proxy(OnClickListener)):
                                def onClick(self_obj, v): pass
                            native_heart.setOnClickListener(_NoOp())
                        except Exception:
                            pass
                except Exception:
                    pass
            
                                                                                
            try:
                def _deep_disable(v):
                    try:
                        name = str(v.getClass().getName() or "")
                                                                                             
                                                                                
                        if "ButtonWithCounterView" in name or "LikeButton" in name or "Heart" in name:
                            v.setVisibility(View.GONE)
                            v.setAlpha(0.0)
                            v.setEnabled(False)
                            v.setClickable(False)
                            try:
                                v.setOnClickListener(None)
                            except Exception:
                                pass
                            try:
                                class _NoOpDeep(dynamic_proxy(OnClickListener)):
                                    def onClick(self_obj, v): 
                                        try:
                                                                          
                                            pass
                                        except Exception: pass
                                v.setOnClickListener(_NoOpDeep())
                            except Exception:
                                pass
                        if hasattr(v, "getChildCount"):
                            for i in range(int(v.getChildCount())):
                                _deep_disable(v.getChildAt(i))
                    except Exception:
                        pass
                
                player_layout = get_private_field(alert_obj, "playerLayout")
                if player_layout is not None:
                    _deep_disable(player_layout)
                
                                                                     
                action_bar = get_private_field(alert_obj, "actionBar")
                if action_bar is not None:
                    menu = get_private_field(action_bar, "menu")
                    if menu is not None:
                        _deep_disable(menu)
            except Exception:
                pass

            self._bind_player_save_button(alert_obj)
            self._ensure_player_track_save_button(alert_obj)
            return True
        except Exception as e:
            self._trace("ensure player menu item fail: {0}".format(e), "ERROR")
            return False

    def _open_playlist_input(self):
        return self._open_playlist_editor()

    def _show_search_prompt(self, forced_ctx=None):
        try:
            def _ui():
                self._show_search_prompt_ui(forced_ctx)

            run_on_ui_thread(_ui)
            return True
        except Exception as e:
            self._trace("show search prompt fail: {0}".format(e), "ERROR")
            return False

    def _show_search_prompt_ui(self, forced_ctx=None):
        try:
            frag = get_last_fragment()
            if frag is not None:
                self._fragment_ref = frag
            ctx = forced_ctx or (frag.getParentActivity() if frag and frag.getParentActivity() else None)
            if ctx is None:
                return False
            try:
                if getattr(self, "_search_prompt_sheet", None) is not None:
                    self._search_prompt_sheet.dismiss()
            except Exception:
                pass
            self._search_prompt_sheet = None

            plugin = self
            EditText = jclass("android.widget.EditText")
            query_inp = EditText(ctx)
            query_inp.setSingleLine(True)
            query_inp.setHint(self._tr("search_prompt_hint"))
            try:
                query_inp.setTextColor(int(Theme.getColor(Theme.key_dialogTextBlack)))
                query_inp.setHintTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            except Exception:
                pass

            sheet = BottomSheet(ctx, True)
            try:
                sheet.setBackgroundColor(0)
            except Exception:
                pass
            wrap = LinearLayout(ctx)
            wrap.setOrientation(LinearLayout.VERTICAL)
            wrap.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(12), AndroidUtilities.dp(20), AndroidUtilities.dp(22))
            try:
                is_dark_sheet = bool(Theme.isCurrentThemeDark())
            except Exception:
                is_dark_sheet = True
            prompt_bg_primary = self._jcolor(0xFF2C2326 if is_dark_sheet else 0xFFFFF1F2)
            prompt_bg_secondary = self._jcolor(0xFF201F22 if is_dark_sheet else 0xFFF8F4F3)
            prompt_card_fill = self._jcolor(0x16FFFFFF if is_dark_sheet else 0xFFF2EFF1)
            action_chip_fill = self._jcolor(0x10FFFFFF if is_dark_sheet else 0xFFF3F0F2)
            action_chip_stroke = self._jcolor(0x1FFFFFFF if is_dark_sheet else 0x18EB3F44)
            primary_c = self._jcolor(0xFFEB3F44 if is_dark_sheet else 0xFFEB3F44)
            btn_txt = self._contrast_text_color(int(primary_c))
            try:
                title_c = int(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception:
                title_c = int(self._jcolor(0xFFF4F4F7 if is_dark_sheet else 0xFF161616))
            try:
                sub_c = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            except Exception:
                sub_c = int(self._jcolor(0xFF9A9AA1 if is_dark_sheet else 0xFF7D7D86))
            prompt_bg = GradientDrawable(GradientDrawable.Orientation.TL_BR, [prompt_bg_primary, prompt_bg_secondary])
            try:
                radius = float(AndroidUtilities.dp(24))
                prompt_bg.setCornerRadii([radius, radius, radius, radius, radius, radius, radius, radius])
            except Exception:
                pass
            wrap.setBackground(prompt_bg)

            title_tv = TextView(ctx)
            title_tv.setText(self._tr("search_prompt_title"))
            title_tv.setTextSize(18)
            title_tv.setTypeface(None, 1)
            title_tv.setGravity(Gravity.CENTER_HORIZONTAL)
            title_tv.setTextColor(int(title_c))
            title_tv.setPadding(0, 0, 0, AndroidUtilities.dp(12))
            wrap.addView(title_tv)

            inp_wrap_bg = GradientDrawable()
            inp_wrap_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
            inp_wrap_bg.setColor(prompt_card_fill)
            try:
                inp_wrap_bg.setStroke(AndroidUtilities.dp(1), action_chip_stroke)
            except Exception:
                pass
            query_inp.setBackground(inp_wrap_bg)
            pad_in = AndroidUtilities.dp(14)
            query_inp.setPadding(pad_in, pad_in, pad_in, pad_in)
            wrap.addView(query_inp, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            btn_row = LinearLayout(ctx)
            btn_row.setOrientation(LinearLayout.HORIZONTAL)
            btn_row.setGravity(Gravity.CENTER_VERTICAL)
            btn_row.setPadding(0, AndroidUtilities.dp(18), 0, 0)

            panel_tv = TextView(ctx)
            panel_tv.setText(self._tr("search_prompt_panel"))
            panel_tv.setTextSize(14)
            panel_tv.setTypeface(None, 1)
            panel_tv.setTextColor(int(title_c))
            panel_tv.setGravity(Gravity.CENTER)
            panel_tv.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(10), AndroidUtilities.dp(16), AndroidUtilities.dp(10))
            panel_bg = GradientDrawable()
            panel_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
            panel_bg.setColor(action_chip_fill)
            panel_bg.setStroke(AndroidUtilities.dp(1), action_chip_stroke)
            panel_tv.setBackground(panel_bg)

            spacer = View(ctx)
            btn_row.addView(panel_tv)
            btn_row.addView(spacer, LinearLayout.LayoutParams(0, 1, 1.0))

            cancel_tv = TextView(ctx)
            cancel_tv.setText(self._tr("cancel"))
            cancel_tv.setTextSize(14)
            cancel_tv.setTypeface(None, 1)
            cancel_tv.setTextColor(int(title_c))
            cancel_tv.setGravity(Gravity.CENTER)
            cancel_tv.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(10), AndroidUtilities.dp(16), AndroidUtilities.dp(10))
            cancel_bg = GradientDrawable()
            cancel_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
            cancel_bg.setColor(action_chip_fill)
            cancel_bg.setStroke(AndroidUtilities.dp(1), action_chip_stroke)
            cancel_tv.setBackground(cancel_bg)

            search_tv = TextView(ctx)
            search_tv.setText(self._tr("search_prompt_button"))
            search_tv.setTextSize(15)
            search_tv.setTypeface(None, 1)
            search_tv.setTextColor(int(btn_txt))
            search_tv.setGravity(Gravity.CENTER)
            s_pad_h = AndroidUtilities.dp(20)
            s_pad_v = AndroidUtilities.dp(10)
            search_tv.setPadding(s_pad_h, s_pad_v, s_pad_h, s_pad_v)
            s_bg = GradientDrawable()
            s_bg.setCornerRadius(float(AndroidUtilities.dp(22)))
            s_bg.setColor(int(primary_c))
            search_tv.setBackground(s_bg)

            btn_row.addView(cancel_tv)
            gap = View(ctx)
            btn_row.addView(gap, LinearLayout.LayoutParams(AndroidUtilities.dp(10), 1))
            btn_row.addView(search_tv)

            wrap.addView(btn_row)

            listener_cls = find_class("android.view.View$OnClickListener")

            def _run_search():
                try:
                    query = str(query_inp.getText().toString() if query_inp.getText() is not None else "")
                    query = re.sub(r"[\r\n\t]+", "", query).strip()
                    if not query:
                        return
                    plugin._touch_activity()
                    plugin._ensure_idle_watch()
                    plugin._clear_hard_stop()
                    try:
                        sheet.dismiss()
                    except Exception:
                        pass
                    plugin._search_prompt_sheet = None
                    plugin._results_page = 0
                    try:
                        run_on_ui_thread(lambda: plugin._show_loading_sheet())
                    except Exception:
                        run_on_ui_thread(lambda: plugin._show_loading_sheet())
                    plugin._search_youtube_async(query)
                except Exception as e:
                    plugin._trace("menu search start fail: {0}".format(e), "ERROR")

            def _open_panel():
                try:
                    try:
                        sheet.dismiss()
                    except Exception:
                        pass
                    plugin._search_prompt_sheet = None
                    plugin._show_about_sheet()
                except Exception as e:
                    plugin._trace("search prompt panel open fail: {0}".format(e), "ERROR")

            if listener_cls is not None:

                class _Panel(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        _open_panel()

                class _Cancel(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        try:
                            sheet.dismiss()
                        except Exception:
                            pass
                        plugin._search_prompt_sheet = None

                class _Search(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        _run_search()

                panel_tv.setOnClickListener(_Panel())
                cancel_tv.setOnClickListener(_Cancel())
                search_tv.setOnClickListener(_Search())

            sheet.setCustomView(wrap)
            sheet.show()
            self._search_prompt_sheet = sheet

            def _kbd():
                try:
                    query_inp.requestFocus()
                    AndroidUtilities.showKeyboard(query_inp)
                except Exception:
                    pass

            try:
                query_inp.post(_kbd)
            except Exception:
                run_on_ui_thread(_kbd)

            return True
        except Exception as e:
            self._trace("show search prompt ui fail: {0}".format(e), "ERROR")
            return False

    def _ensure_dialogs_menu_item(self, frag=None):
        try:
            host = frag or get_last_fragment()
            if host is None or "DialogsActivity" not in str(host.getClass().getName() or ""):
                return False
            action_bar = get_private_field(host, "actionBar")
            if action_bar is None:
                return False
            menu = None
            try:
                menu = action_bar.createMenu()
            except Exception:
                try:
                    menu = get_private_field(action_bar, "menu")
                except Exception:
                    menu = None
            if menu is None:
                return False
            item = None
            try:
                for idx in range(int(menu.getChildCount())):
                    child = menu.getChildAt(idx)
                    if str(child.getTag() or "") == "pomme_dialogs_menu_button":
                        item = child
                        break
            except Exception:
                item = None
            if item is None:
                try:
                    res = ApplicationLoader.applicationContext.getResources()
                    pkg = ApplicationLoader.applicationContext.getPackageName()
                    icon_id = res.getIdentifier("msg_tone_add_solar", "drawable", pkg)
                    item = menu.addItem(int(POMME_DIALOGS_MENU_ITEM_ID), int(icon_id))
                    item.setTag("pomme_dialogs_menu_button")
                    item.setContentDescription("Pomme")
                except Exception as e:
                    self._trace("create dialogs menu item fail: {0}".format(e), "ERROR")
                    return False
            try:
                if not self._menu_shortcuts_enabled():
                    item.setVisibility(View.GONE)
                    item.setEnabled(False)
                    item.setClickable(False)
                    return True
                item.setVisibility(View.VISIBLE)
                item.setEnabled(True)
                item.setClickable(True)
            except Exception:
                pass
            listener_cls = find_class("android.view.View$OnClickListener")
            long_listener_cls = find_class("android.view.View$OnLongClickListener")
            if listener_cls is not None:
                plugin = self
                class _Click(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        plugin._show_search_prompt()
                try:
                    item.setOnClickListener(_Click())
                except Exception:
                    pass
                
                if long_listener_cls is not None:
                    class _LongClick(dynamic_proxy(long_listener_cls)):
                        def onLongClick(self_obj, _v):
                            if plugin._is_anything_playing():
                                track = plugin._last_started_item or (plugin._active_play_ctx or {}).get("item")
                                if track:
                                    plugin._show_custom_player_overlay(track)
                                else:
                                    plugin._show_about_sheet()
                            else:
                                plugin._show_about_sheet()
                            return True
                    try:
                        item.setOnLongClickListener(_LongClick())
                    except Exception:
                        pass
            return True
        except Exception as e:
            self._trace("ensure dialogs menu item fail: {0}".format(e), "ERROR")
            return False

    def _ensure_chat_menu_item(self, frag=None):
        try:
            host = frag or get_last_fragment()
            if host is None or "ChatActivity" not in str(host.getClass().getName() or ""):
                return False
            header_item = get_private_field(host, "headerItem")
            if header_item is None:
                return False
            
                                                                    
                                                                 
            try:
                if header_item.hasSubItem(int(POMME_CHAT_MENU_ITEM_ID)):
                    try:
                        header_item.showSubItem(int(POMME_CHAT_MENU_ITEM_ID), True)
                    except Exception: pass
                    return True
            except Exception: pass
            try:
                item = header_item.lazilyAddSubItem(int(POMME_CHAT_MENU_ITEM_ID), int(ApplicationLoader.applicationContext.getResources().getIdentifier("msg_tone_add_solar", "drawable", ApplicationLoader.applicationContext.getPackageName())), "Pomme")
            except Exception as e:
                self._trace("create chat menu item fail: {0}".format(e), "ERROR")
                return False
            listener_cls = find_class("android.view.View$OnClickListener")
            long_listener_cls = find_class("android.view.View$OnLongClickListener")
            if listener_cls is not None and item is not None:
                plugin = self
                class _Click(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        try:
                            header_item.closeSubMenu()
                        except Exception:
                            pass
                        plugin._show_search_prompt()
                try:
                    item.setOnClickListener(_Click())
                except Exception:
                    pass
                
                if long_listener_cls is not None:
                    class _LongClick(dynamic_proxy(long_listener_cls)):
                        def onLongClick(self_obj, _v):
                            try:
                                header_item.closeSubMenu()
                                if plugin._is_anything_playing():
                                    item = plugin._last_started_item or (plugin._active_play_ctx or {}).get("item")
                                    if item:
                                        plugin._show_custom_player_overlay(item)
                                    else:
                                        plugin._show_about_sheet()
                                else:
                                    plugin._show_about_sheet()
                                return True
                            except Exception:
                                return False
                    try:
                        item.setOnLongClickListener(_LongClick())
                    except Exception:
                        pass
            return True
        except Exception as e:
            self._trace("ensure chat menu item fail: {0}".format(e), "ERROR")
            return False

    def _open_playlist_editor(self, existing=None, edit_index=None):
        try:
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return False
            EditText = jclass("android.widget.EditText")
            name_inp = EditText(ctx)
            link_inp = EditText(ctx)
            name_inp.setSingleLine(True)
            link_inp.setSingleLine(True)
            name_inp.setHint(self._tr("playlist_name_hint"))
            link_inp.setHint(self._tr("panel_playlist_hint"))
            holder = LinearLayout(ctx)
            holder.setOrientation(LinearLayout.VERTICAL)
            try:
                holder.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(6))
            except Exception:
                pass
            try:
                current = dict(existing or {})
                name_inp.setText(str(current.get("name") or ""))
                link_inp.setText(str(current.get("url") or ""))
            except Exception:
                pass
            try:
                name_inp.setTextColor(int(Theme.getColor(Theme.key_dialogTextBlack)))
                link_inp.setTextColor(int(Theme.getColor(Theme.key_dialogTextBlack)))
            except Exception:
                pass
            try:
                name_inp.setHintTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
                link_inp.setHintTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            except Exception:
                pass
            def _style_input(view):
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                bg.setColor(int(Theme.getColor(Theme.key_dialogBackgroundGray)))
                view.setBackground(bg)
                pad = AndroidUtilities.dp(14)
                view.setPadding(pad, pad, pad, pad)
            try:
                _style_input(name_inp)
                _style_input(link_inp)
                lp1 = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp2 = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp1.leftMargin = AndroidUtilities.dp(2)
                lp1.rightMargin = AndroidUtilities.dp(2)
                lp2.leftMargin = AndroidUtilities.dp(2)
                lp2.rightMargin = AndroidUtilities.dp(2)
                lp2.topMargin = AndroidUtilities.dp(10)
                holder.addView(name_inp, lp1)
                holder.addView(link_inp, lp2)
            except Exception:
                pass
            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("playlist_panel_title"))
            try:
                b.set_view(holder)
            except Exception:
                try:
                    b.set_custom_view(holder)
                except Exception:
                    pass
            def _save(dialog, _which):
                try:
                    current = dict(existing or {})
                    name = str(name_inp.getText().toString() if name_inp.getText() is not None else "").strip()
                    url = self._clean_external_link_input(str(link_inp.getText().toString() if link_inp.getText() is not None else ""))
                    if not url:
                        BulletinHelper.show_info(self._tr("playlist_import_empty"))
                        return
                    inferred_name = ""
                    spotify_ref = self._parse_spotify_reference(url)
                    youtube_playlist_ref = self._parse_youtube_playlist_reference(url)
                    if spotify_ref is not None:
                        inferred_name = self._spotify_collection_name(url)
                    elif youtube_playlist_ref is not None:
                        inferred_name = self._youtube_collection_name(url)
                    if not name:
                        name = str(inferred_name or current.get("name") or "Playlist").strip() or "Playlist"
                    items = self._playlists()
                    payload = {"name": name or "Playlist", "url": url}
                    if int(edit_index if edit_index is not None else -1) >= 0 and int(edit_index) < len(items):
                        items[int(edit_index)] = payload
                    else:
                        items.append(payload)
                    self._set_playlists(items)
                    dialog.dismiss()
                    try:
                        if self._playlist_sheet is not None:
                            self._playlist_sheet.dismiss()
                    except Exception:
                        pass
                    self._playlist_sheet = None
                    def _reopen_playlist_sheet(_ok=False):
                        try:
                            BulletinHelper.show_success(self._tr("playlist_save_done"))
                        except Exception:
                            pass
                        try:
                            self._show_playlist_sheet()
                        except Exception:
                            pass
                    if not self._warm_playlist_cache_async(payload, on_done=_reopen_playlist_sheet):
                        _reopen_playlist_sheet(False)
                except Exception:
                    pass
            b.set_positive_button("Save", _save)
            b.set_negative_button("Cancel", lambda d, _w: d.dismiss())
            b.show()
            return True
        except Exception as e:
            self._trace("playlist input fail: {0}".format(e), "ERROR")
            return False

    def _build_settings_switch_row(self, ctx, title_color, sub_color, icon_name, title_text, desc_text, checked_value, on_change, row_fill=None, icon_fill=None, icon_tint=None, text_tint=None, desc_tint=None):
        row = LinearLayout(ctx)
        row.setOrientation(LinearLayout.HORIZONTAL)
        row.setGravity(Gravity.CENTER_VERTICAL)
        row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(10), AndroidUtilities.dp(14), AndroidUtilities.dp(10))
        try:
            row_bg = GradientDrawable()
            row_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
            row_bg.setColor(int(row_fill if row_fill is not None else Theme.getColor(Theme.key_dialogBackgroundGray)))
            row.setBackground(row_bg)
        except Exception:
            pass

        iw = LinearLayout(ctx)
        iw.setGravity(Gravity.CENTER)
        if icon_fill is not None:
            try:
                iw_bg = GradientDrawable()
                iw_bg.setCornerRadius(float(AndroidUtilities.dp(999)))
                iw_bg.setColor(int(icon_fill))
                iw.setBackground(iw_bg)
                iw.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
            except Exception:
                pass
        try:
            iv = ImageView(ctx)
            res = ApplicationLoader.applicationContext.getResources()
            pkg = ApplicationLoader.applicationContext.getPackageName()
            iid = res.getIdentifier(str(icon_name or ""), "drawable", pkg)
            if iid:
                iv.setImageResource(int(iid))
                iv.setColorFilter(int(icon_tint if icon_tint is not None else title_color), PorterDuff.Mode.SRC_IN)
            iw.addView(iv, LinearLayout.LayoutParams(AndroidUtilities.dp(22), AndroidUtilities.dp(22)))
        except Exception:
            pass
        icon_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
        icon_lp.rightMargin = AndroidUtilities.dp(10)
        row.addView(iw, icon_lp)

        info = LinearLayout(ctx)
        info.setOrientation(LinearLayout.VERTICAL)
        info_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
        info_lp.leftMargin = AndroidUtilities.dp(8)

        t1 = TextView(ctx)
        t1.setText(str(title_text or ""))
        t1.setTextSize(15)
        t1.setTypeface(None, 1)
        t1.setTextColor(int(text_tint if text_tint is not None else title_color))
        info.addView(t1)

        t2 = TextView(ctx)
        t2.setText(str(desc_text or ""))
        t2.setTextSize(11)
        t2.setPadding(0, AndroidUtilities.dp(2), 0, 0)
        t2.setTextColor(int(desc_tint if desc_tint is not None else sub_color))
        info.addView(t2)
        row.addView(info, info_lp)

        try:
            Switch = jclass("android.widget.Switch")
            sw = Switch(ctx)
            sw_ign = [False]
            try:
                sw.setVisibility(View.VISIBLE)
                sw.setEnabled(True)
                sw.setClickable(True)
                try:
                    sw.setShowText(False)
                except Exception:
                    pass
                try:
                    sw.setMinWidth(AndroidUtilities.dp(36))
                except Exception:
                    pass
                try:
                    sw.setMinimumWidth(AndroidUtilities.dp(36))
                except Exception:
                    pass
                try:
                    sw.setSwitchMinWidth(AndroidUtilities.dp(36))
                except Exception:
                    pass
                try:
                    sw.setPadding(0, 0, 0, 0)
                except Exception:
                    pass
            except Exception:
                pass
            sw_ign[0] = True
            try:
                sw.setChecked(bool(checked_value))
            finally:
                sw_ign[0] = False
            CC = jclass("android.widget.CompoundButton$OnCheckedChangeListener")

            class _Sw(dynamic_proxy(CC)):
                def onCheckedChanged(self_obj, _button_view, is_checked):
                    if sw_ign[0]:
                        return
                    try:
                        on_change(bool(is_checked), sw, sw_ign)
                    except Exception:
                        pass

            sw.setOnCheckedChangeListener(_Sw())
            row.addView(sw, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
        except Exception as e:
            try:
                self._trace("settings switch row fail: {0}".format(e), "ERROR")
            except Exception:
                pass
        return row

    def _backup_dir(self):
        try:
            base = self._cache_dir()
            if not base:
                return None
            path = os.path.join(base, "backups")
            os.makedirs(path, exist_ok=True)
            return path
        except Exception:
            return None

    def _backup_filename_stamp(self):
        try:
            return time.strftime("%d%m-%H%M")
        except Exception:
            return str(int(time.time()))

    def _backup_timestamp(self):
        try:
            return time.strftime("%d/%m/%Y %H:%M")
        except Exception:
            return ""

    def _backup_settings_keys(self):
        return [
            "pomme_enabled",
            "pomme_language",
            "pomme_auto_play",
            "pomme_smart_cache_enabled",
            "pomme_auto_cache_enabled",
            "pomme_quick_dismiss",
            "pomme_notifications_enabled",
            "pomme_safe_mode_enabled",
            "pomme_menu_shortcuts_enabled",
            "pomme_compose_button_enabled",
            "pomme_network_compat_enabled",
            "pomme_pocket_mode",
            "pomme_panel_right_side",
            "pomme_music_panel_resize_enabled",
            "pomme_music_panel_scale",
            "pomme_color_title",
            "pomme_color_controls",
            "pomme_color_bg",
            "pomme_live_log",
            "pomme_live_log_collapsed",
            "pomme_live_log_rm",
            "pomme_live_log_tm",
        ]

    def _backup_track_payload(self, track):
        try:
            item = dict(track or {})
            item_id = str(item.get("id") or self._extract_video_id(item) or "").strip()
            if not item_id:
                return None
            length_sec = self._parse_duration_seconds(item.get("length"), self._parse_duration_seconds(item.get("duration"), 0))
            payload = {
                "id": item_id,
                "title": str(item.get("title") or "Track").strip() or "Track",
                "author": str(item.get("author") or "YouTube").strip() or "YouTube",
                "length": int(length_sec or 0),
                "thumbnail": str(item.get("thumbnail") or "").strip(),
                "cover_url": str(item.get("cover_url") or "").strip(),
                "url": str(item.get("url") or "").strip(),
            }
            if int(length_sec or 0) > 0:
                payload["duration"] = int(length_sec or 0)
            return payload
        except Exception:
            return None

    def _backup_playlist_payload(self, entry):
        try:
            item = dict(entry or {})
            name = str(item.get("name") or "").strip()
            if not name:
                return None
            payload = {"name": name}
            system_key = str(item.get("system") or "").strip().lower()
            if system_key in ("liked", "auto_cache"):
                payload["system"] = system_key
            url = str(item.get("url") or "").strip()
            if url:
                payload["url"] = url
            tracks = []
            seen = set()
            for track in list(item.get("tracks") or []):
                clean = self._backup_track_payload(track)
                if not isinstance(clean, dict):
                    continue
                track_id = str(clean.get("id") or "").strip()
                if not track_id or track_id in seen:
                    continue
                seen.add(track_id)
                tracks.append(clean)
            if tracks:
                payload["tracks"] = tracks
            return payload
        except Exception:
            return None

    def _backup_source_playlist_payload(self, entry):
        try:
            item = dict(entry or {})
            url = self._clean_external_link_input(str(item.get("url") or ""))
            if not url:
                return None
            payload = {
                "name": self._playlist_saved_name(url, str(item.get("name") or "Playlist")),
                "url": url,
                "service": str(self._playlist_service_kind(url) or "").strip(),
            }
            tracks = []
            seen = set()
            for track in list(self._source_playlist_tracks(url) or []):
                clean = self._backup_track_payload(track)
                if not isinstance(clean, dict):
                    continue
                track_id = str(clean.get("id") or "").strip()
                if not track_id or track_id in seen:
                    continue
                seen.add(track_id)
                tracks.append(clean)
            if tracks:
                payload["tracks"] = tracks
            return payload
        except Exception:
            return None

    def _collect_backup_settings(self):
        try:
            data = {}
            for key in self._backup_settings_keys():
                try:
                    value = self.get_setting(key, None)
                    if value is not None:
                        data[str(key)] = value
                except Exception:
                    continue
            return data
        except Exception:
            return {}

    def _collect_backup_payload(self):
        try:
            user_playlists = []
            for entry in self._user_saved_playlists():
                clean = self._backup_playlist_payload(entry)
                if isinstance(clean, dict):
                    user_playlists.append(clean)
            source_playlists = []
            for entry in self._playlists():
                clean = self._backup_source_playlist_payload(entry)
                if isinstance(clean, dict):
                    source_playlists.append(clean)
            payload = {
                "version": "1.1",
                "timestamp": self._backup_timestamp(),
                "plugin_name": "pomme",
                "settings": self._collect_backup_settings(),
                "playlists": {
                    "user": user_playlists,
                    "sources": source_playlists,
                },
                "meta": {
                    "user_playlist_count": len(user_playlists),
                    "source_playlist_count": len(source_playlists),
                    "smart_cache_enabled": bool(self._smart_cache_enabled()),
                    "network_rescue_enabled": bool(self._network_compat_enabled()),
                }
            }
            return payload
        except Exception as e:
            self._trace("collect backup payload fail: {0}".format(e), "ERROR")
            return {}

    def _write_backup_file(self):
        try:
            backup_dir = self._backup_dir()
            if not backup_dir:
                return ""
            payload = self._collect_backup_payload()
            if not isinstance(payload, dict) or (not payload.get("settings") and not payload.get("playlists")):
                return ""
            filename = "backup-{0}.pomme".format(self._backup_filename_stamp())
            path = os.path.join(backup_dir, filename)
            with open(path, "w", encoding="utf-8") as fh:
                json.dump(payload, fh, indent=2, ensure_ascii=False)
            return path if os.path.isfile(path) else ""
        except Exception as e:
            self._trace("write backup file fail: {0}".format(e), "ERROR")
            return ""

    def _send_backup_document(self, file_path):
        try:
            path = str(file_path or "").strip()
            if not path or not os.path.isfile(path):
                return False
            if send_document is None:
                return False
            frag = get_last_fragment() or self._fragment_ref
            peer = frag.getDialogId() if frag and hasattr(frag, "getDialogId") else None
            if not peer:
                return False
            send_document(peer, path, caption=self._tr("panel_data_backup_sent_caption"))
            return True
        except Exception as e:
            self._trace("send backup document fail: {0}".format(e), "WARN")
            return False

    def _backup_restore_external_playlists(self, entries):
        try:
            if not self._smart_cache_enabled():
                return False
            todo = [dict(x or {}) for x in list(entries or []) if isinstance(x, dict)]
            if not todo:
                return False

            def _worker():
                for entry in todo:
                    try:
                        playlist_url = str(entry.get("url") or "").strip()
                        playlist_name = str(entry.get("name") or "Playlist").strip() or "Playlist"
                        if not playlist_url:
                            continue
                        self._trace("backup restore prefetch | playlist={0}".format(playlist_name), "INFO")
                        items = [dict(x or {}) for x in list(entry.get("tracks") or []) if isinstance(x, dict)]
                        if not items:
                            items = self._resolve_playlist_entries(playlist_url)
                        if not items:
                            continue
                        self._remember_playlist_listing(playlist_url, items, playlist_name)
                        self._prefetch_playlist_cache({
                            "playlist": True,
                            "playlist_name": playlist_name,
                            "playlist_url": playlist_url,
                            "results": items,
                        })
                        time.sleep(0.6)
                    except Exception as entry_error:
                        self._trace("backup restore playlist skip: {0}".format(entry_error), "WARN")
                        continue

            threading.Thread(target=_worker, daemon=True).start()
            return True
        except Exception as e:
            self._trace("backup restore external playlists fail: {0}".format(e), "ERROR")
            return False

    def _apply_restored_settings(self, settings):
        try:
            restored = 0
            payload = dict(settings or {})
            allowed = set(self._backup_settings_keys())
            for key, value in payload.items():
                if str(key) not in allowed:
                    continue
                try:
                    self.set_setting(str(key), value)
                    restored += 1
                except Exception:
                    continue
            return restored
        except Exception:
            return 0

    def _validate_backup_payload(self, data):
        try:
            if not isinstance(data, dict):
                return False
            if str(data.get("plugin_name") or "").strip().lower() != "pomme":
                return False
            if not isinstance(data.get("settings") or {}, dict):
                return False
            playlists = dict(data.get("playlists") or {})
            if not isinstance(playlists.get("user") or [], list):
                return False
            if not isinstance(playlists.get("sources") or [], list):
                return False
            return True
        except Exception:
            return False

    def _restore_backup_payload(self, data, source_name=""):
        try:
            payload = dict(data or {})
            if not self._validate_backup_payload(payload):
                BulletinHelper.show_info(self._tr("panel_data_backup_invalid"))
                return False

            restored_settings = self._apply_restored_settings(payload.get("settings") or {})

            source_rows = []
            source_overrides = {}
            for entry in list((payload.get("playlists") or {}).get("sources") or []):
                clean = self._backup_source_playlist_payload(entry) or self._backup_playlist_payload(entry)
                if isinstance(clean, dict) and str(clean.get("url") or "").strip():
                    clean_url = self._clean_external_link_input(str(clean.get("url") or ""))
                    clean_name = str(clean.get("name") or "Playlist").strip() or "Playlist"
                    source_rows.append({
                        "name": clean_name,
                        "url": clean_url,
                    })
                    clean_tracks = [dict(x or {}) for x in list(clean.get("tracks") or []) if isinstance(x, dict)]
                    if clean_url and clean_tracks:
                        source_overrides[clean_url] = {
                            "name": clean_name,
                            "tracks": clean_tracks,
                            "updated_at": int(time.time()),
                        }
            self._set_playlists(source_rows)
            self._set_source_playlist_overrides(source_overrides)
            for playlist_url, override in dict(source_overrides or {}).items():
                try:
                    self._remember_playlist_listing(playlist_url, list(override.get("tracks") or []), str(override.get("name") or "Playlist"))
                except Exception:
                    pass

            user_rows = []
            for entry in list((payload.get("playlists") or {}).get("user") or []):
                clean = self._backup_playlist_payload(entry)
                if isinstance(clean, dict):
                    user_rows.append(clean)
            self._set_user_saved_playlists(user_rows)
            self._sync_user_playlists_to_cache()

            try:
                self._spotify_cc_cache = None
            except Exception:
                pass
            try:
                with self._statsfm_index_lock:
                    self._statsfm_index_by_key = None
                    self._statsfm_index_meta = None
            except Exception:
                pass

            self._backup_restore_external_playlists(source_rows)
            BulletinHelper.show_success(self._tr("panel_data_backup_restored"))
            self._trace(
                "backup restored | file={0} settings={1} user_playlists={2} source_playlists={3}".format(
                    str(source_name or "").strip() or "memory",
                    int(restored_settings or 0),
                    len(user_rows),
                    len(source_rows),
                ),
                "INFO",
            )
            return True
        except Exception as e:
            self._trace("restore backup payload fail: {0}".format(e), "ERROR")
            BulletinHelper.show_info(self._tr("panel_data_backup_restore_failed"))
            return False

    def _handle_backup_file(self, path):
        try:
            file_path = str(path or "").strip()
            if not file_path or not os.path.isfile(file_path):
                BulletinHelper.show_info(self._tr("panel_data_backup_invalid"))
                return False
            with open(file_path, "r", encoding="utf-8") as fh:
                data = json.load(fh)
            if not self._validate_backup_payload(data):
                BulletinHelper.show_info(self._tr("panel_data_backup_invalid"))
                return False
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            total_user = len(list((data.get("playlists") or {}).get("user") or []))
            total_source = len(list((data.get("playlists") or {}).get("sources") or []))
            message = self._tr("panel_data_backup_restore_confirm").format(total_user, total_source)
            if ctx is None:
                return self._restore_backup_payload(data, os.path.basename(file_path))
            return self._confirm_action(
                ctx,
                self._tr("panel_data_backup_import"),
                message,
                lambda: self._restore_backup_payload(data, os.path.basename(file_path)),
            )
        except Exception as e:
            self._trace("handle backup file fail: {0}".format(e), "ERROR")
            BulletinHelper.show_info(self._tr("panel_data_backup_restore_failed"))
            return False

    def _ensure_backup_picker_hook(self):
        if getattr(self, "_backup_picker_hook", None):
            return
        try:
            hooks = []
            target_classes = [
                "android.app.Activity",
                "com.exteragram.messenger.plugins.ui.PluginSettingsActivity",
            ]
            hook_impl = PommeBackupPickerHook(self)
            for cls_name in target_classes:
                try:
                    cls = JClass.forName(cls_name)
                    if not cls:
                        continue
                    method = cls.getDeclaredMethod("onActivityResult", Integer.TYPE, Integer.TYPE, Intent)
                    hook = self.hook_method(method, hook_impl)
                    if hook:
                        hooks.append(hook)
                        try:
                            self._hooks.append(hook)
                        except Exception:
                            pass
                except Exception:
                    continue
            if hooks:
                self._backup_picker_hook = hooks[0]
                self._backup_picker_hooks = hooks
        except Exception as e:
            self._trace("backup picker hook fail: {0}".format(e), "WARN")

    def _open_backup_import_picker(self):
        try:
            now_ts = time.time()
            if bool(getattr(self, "_backup_picker_active", False)):
                started_at = float(getattr(self, "_backup_picker_started_at", 0.0) or 0.0)
                if started_at > 0 and (now_ts - started_at) < 20.0:
                    return False
                self._backup_picker_active = False
            frag = get_last_fragment() or self._fragment_ref
            if not frag:
                return False
            activity = frag.getParentActivity()
            if not activity:
                return False
            self._backup_picker_active = True
            self._backup_picker_started_at = now_ts
            self._ensure_backup_picker_hook()
            intent = Intent(Intent.ACTION_OPEN_DOCUMENT)
            intent.addCategory(Intent.CATEGORY_OPENABLE)
            intent.setType("*/*")
            try:
                intent.putExtra(Intent.EXTRA_MIME_TYPES, [
                    "application/json",
                    "text/plain",
                    "application/octet-stream",
                ])
            except Exception:
                pass
            try:
                intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
            except Exception:
                pass
            started = False
            try:
                frag.startActivityForResult(intent, int(self._backup_picker_request))
                started = True
            except Exception:
                started = False
            if not started:
                activity.startActivityForResult(intent, int(self._backup_picker_request))
            return True
        except Exception as e:
            self._trace("open backup import picker fail: {0}".format(e), "ERROR")
            self._backup_picker_active = False
            self._backup_picker_started_at = 0.0
            return False

    def _handle_backup_picker_result(self, res_code, data):
        try:
            self._backup_picker_active = False
            self._backup_picker_started_at = 0.0
            if res_code == Activity.RESULT_OK and data and data.getData():
                run_on_queue(lambda: self._handle_backup_uri(data.getData()))
            else:
                BulletinHelper.show_info(self._tr("panel_data_backup_pick_cancelled"))
        except Exception:
            self._backup_picker_active = False
            self._backup_picker_started_at = 0.0

    def _handle_backup_uri(self, uri):
        istream = None
        ostream = None
        try:
            resolver = ApplicationLoader.applicationContext.getContentResolver()
            istream = resolver.openInputStream(uri)
            if not istream:
                raise IOError("stream")
            name = None
            try:
                cursor = resolver.query(uri, [OpenableColumns.DISPLAY_NAME], None, None, None)
                if cursor:
                    try:
                        if cursor.moveToFirst():
                            name = cursor.getString(0)
                    finally:
                        cursor.close()
            except Exception:
                name = None
            if not name:
                try:
                    name = uri.getLastPathSegment()
                except Exception:
                    name = None
            name = str(name or "").strip()
            if "/" in name:
                name = name.split("/")[-1]
            if ":" in name:
                name = name.split(":")[-1]
            if not str(name or "").lower().endswith(".pomme"):
                name = "{0}.pomme".format(name or "backup-{0}".format(self._backup_filename_stamp()))
            backup_dir = self._backup_dir()
            if not backup_dir:
                raise IOError("backup_dir")
            dest_path = os.path.join(backup_dir, name)
            if os.path.exists(dest_path):
                stem, ext = os.path.splitext(name)
                idx = 1
                while os.path.exists(os.path.join(backup_dir, "{0}-{1}{2}".format(stem, idx, ext))):
                    idx += 1
                dest_path = os.path.join(backup_dir, "{0}-{1}{2}".format(stem, idx, ext))
            ostream = FileOutputStream(dest_path)
            buffer = jarray(jbyte)(8192)
            read = istream.read(buffer)
            while read != -1:
                ostream.write(buffer, 0, read)
                read = istream.read(buffer)
            ostream.flush()
            self._handle_backup_file(dest_path)
            return True
        except Exception as e:
            self._trace("handle backup uri fail: {0}".format(e), "ERROR")
            BulletinHelper.show_info(self._tr("panel_data_backup_restore_failed"))
            return False
        finally:
            try:
                if istream:
                    istream.close()
            except Exception:
                pass
            try:
                if ostream:
                    ostream.close()
            except Exception:
                pass
            self._backup_picker_active = False
            self._backup_picker_started_at = 0.0

    def _show_data_sheet(self):
        try:
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return False
            listener_cls = find_class("android.view.View$OnClickListener")
            if listener_cls is None:
                return False
            sheet = BottomSheet(ctx, True)
            try:
                sheet.setBackgroundColor(0)
            except Exception:
                pass
            scroll = jclass("android.widget.ScrollView")(ctx)
            try:
                scroll.setFillViewport(True)
            except Exception:
                pass
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(12), AndroidUtilities.dp(18), AndroidUtilities.dp(20))
            try:
                is_dark_sheet = bool(Theme.isCurrentThemeDark())
            except Exception:
                is_dark_sheet = True
            sheet_bg_primary = self._jcolor(0xFF2F2026 if is_dark_sheet else 0xFFFFF0F2)
            sheet_bg_secondary = self._jcolor(0xFF212226 if is_dark_sheet else 0xFFF8F4F3)
            card_fill = self._jcolor(0x1CFFFFFF if is_dark_sheet else 0xCCFFFFFF)
            card_stroke = self._jcolor(0x20FFFFFF if is_dark_sheet else 0x14EB3F44)
            input_fill = int(Theme.getColor(Theme.key_dialogBackground))
            sheet_bg = GradientDrawable(GradientDrawable.Orientation.TL_BR, [sheet_bg_primary, sheet_bg_secondary])
            try:
                radius = float(AndroidUtilities.dp(24))
                sheet_bg.setCornerRadii([radius, radius, radius, radius, radius, radius, radius, radius])
            except Exception:
                pass
            try:
                scroll.setBackground(sheet_bg)
