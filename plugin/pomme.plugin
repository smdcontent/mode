            sub_color = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            input_stroke = (int(sub_color) & 0x00FFFFFF) | 0x33000000
            button_fill = int(Theme.getColor(Theme.key_featuredStickers_addButton))
            button_text = int(Theme.getColor(Theme.key_featuredStickers_buttonText))

            handle_wrap = LinearLayout(ctx)
            handle_wrap.setGravity(Gravity.CENTER_HORIZONTAL)
            handle = View(ctx)
            h_bg = GradientDrawable()
            h_bg.setCornerRadius(float(AndroidUtilities.dp(3)))
            h_bg.setColor(self._jcolor((sub_color & 0x66FFFFFF) or 0x66AAB4C2))
            handle.setBackground(h_bg)
            handle_wrap.addView(handle, LinearLayout.LayoutParams(AndroidUtilities.dp(42), AndroidUtilities.dp(6)))
            h_lp = LinearLayout.LayoutParams(-1, -2)
            h_lp.bottomMargin = AndroidUtilities.dp(18)
            outer.addView(handle_wrap, h_lp)

            header = TextView(ctx)
            header.setText(self._tr("panel_data"))
            header.setTextSize(22)
            header.setTypeface(None, 1)
            header.setTextColor(title_color)
            header.setGravity(Gravity.CENTER_HORIZONTAL)
            outer.addView(header)

            hint = TextView(ctx)
            hint.setText(self._tr("panel_data_desc"))
            hint.setTextSize(14)
            hint.setTextColor(sub_color)
            hint.setGravity(Gravity.CENTER_HORIZONTAL)
            hint_lp = LinearLayout.LayoutParams(-1, -2)
            hint_lp.topMargin = AndroidUtilities.dp(6)
            hint_lp.bottomMargin = AndroidUtilities.dp(18)
            outer.addView(hint, hint_lp)

            def _label(text, top_margin=0, small=False):
                tv = TextView(ctx)
                tv.setText(str(text or ""))
                tv.setTextColor(sub_color if small else title_color)
                tv.setTextSize(12 if small else 13)
                if not small:
                    tv.setTypeface(None, 1)
                lp0 = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp0.topMargin = AndroidUtilities.dp(top_margin)
