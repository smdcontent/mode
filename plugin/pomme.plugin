    def _playlists(self):
        try:
            raw = self.get_setting("pomme_playlists", None)
            items = []
            if isinstance(raw, list):
                items = list(raw)
            elif isinstance(raw, str) and raw.strip():
                try:
                    parsed = json.loads(raw)
                    if isinstance(parsed, list):
                        items = parsed
                except Exception:
                    pass
            if not items:
                legacy = self._playlist_url()
                if legacy:
                    items = [{"name": "Playlist", "url": legacy}]
            out = []
            for item in items:
                if not isinstance(item, dict):
                    continue
                name = str(item.get("name") or "").strip()
                url = str(item.get("url") or "").strip()
                if not url:
                    continue
                out.append({"name": name or "Playlist", "url": url})
            return out
        except Exception:
            return []

    def _set_playlists(self, items):
        try:
            clean = []
            for item in list(items or []):
                if not isinstance(item, dict):
                    continue
                name = str(item.get("name") or "").strip()
                url = str(item.get("url") or "").strip()
                if not url:
                    continue
                clean.append({"name": name or "Playlist", "url": url})
            self.set_setting("pomme_playlists", clean)
            if clean:
                self._set_playlist_url(str(clean[0].get("url") or ""))
            else:
                self._set_playlist_url("")
        except Exception:
            pass

    def _source_playlist_overrides(self):
        try:
            raw = self.get_setting("pomme_source_playlist_overrides", {})
            if isinstance(raw, dict):
                return dict(raw)
            if isinstance(raw, str) and raw.strip():
                parsed = json.loads(raw)
                if isinstance(parsed, dict):
                    return dict(parsed)
            return {}
        except Exception:
            return {}

    def _set_source_playlist_overrides(self, data):
        try:
            self.set_setting("pomme_source_playlist_overrides", dict(data or {}))
            return True
        except Exception:
            return False

    def _source_playlist_override(self, playlist_url):
        try:
            url = self._clean_external_link_input(playlist_url)
            if not url:
                return {}
            return dict((self._source_playlist_overrides().get(url) or {}))
        except Exception:
            return {}

    def _source_playlist_tracks(self, playlist_url):
        try:
            override = self._source_playlist_override(playlist_url)
            tracks = [dict(x or {}) for x in list(override.get("tracks") or []) if isinstance(x, dict)]
            if tracks:
                return tracks
            tracks = self._playlist_listing_items(playlist_url)
            if tracks:
                return [dict(x or {}) for x in list(tracks or []) if isinstance(x, dict)]
            return []
        except Exception:
            return []

    def _save_source_playlist_override(self, playlist_url, playlist_name, tracks):
        try:
            url = self._clean_external_link_input(playlist_url)
            if not url:
                return False
            overrides = self._source_playlist_overrides()
            overrides[url] = {
                "name": str(playlist_name or "Playlist").strip() or "Playlist",
                "tracks": [dict(x or {}) for x in list(tracks or []) if isinstance(x, dict)],
                "updated_at": int(time.time()),
            }
            self._set_source_playlist_overrides(overrides)
            self._remember_playlist_listing(url, overrides[url].get("tracks") or [], overrides[url].get("name"))
            return True
        except Exception as e:
            self._trace("save source playlist override fail: {0}".format(e), "ERROR")
            return False

    def _playlist_saved_name(self, playlist_url, fallback_name="Playlist"):
        try:
            url = self._clean_external_link_input(playlist_url)
            override = self._source_playlist_override(url)
            name = str(override.get("name") or "").strip()
            if name:
                return name
            for entry in self._playlists():
                if str(entry.get("url") or "").strip() == url:
                    return str(entry.get("name") or fallback_name or "Playlist").strip() or "Playlist"
            return str(fallback_name or "Playlist").strip() or "Playlist"
        except Exception:
            return str(fallback_name or "Playlist").strip() or "Playlist"

    def _playlist_name_is_placeholder(self, name):
        try:
            text = str(name or "").strip()
            if not text:
                return True
            return text.lower() == "playlist"
        except Exception:
            return True

    def _resolve_playlist_display_name(self, playlist_url, fallback_name=None, existing_name=None):
        try:
            fallback = str(fallback_name or "").strip()
            existing = str(existing_name or "").strip()
            if fallback and not self._playlist_name_is_placeholder(fallback):
                return fallback
            if existing and not self._playlist_name_is_placeholder(existing):
                return existing
            url = str(playlist_url or "").strip()
            if url:
                try:
                    saved = str(self._playlist_saved_name(url, "") or "").strip()
                    if saved and not self._playlist_name_is_placeholder(saved):
                        return saved
                except Exception:
                    pass
                try:
                    for entry in list(self._user_saved_playlists() or []):
                        if not isinstance(entry, dict):
                            continue
                        candidate = str(entry.get("name") or "").strip()
                        if not candidate:
                            continue
                        if str(self._user_playlist_cache_url(candidate) or "").strip() == url:
                            return candidate
                except Exception:
                    pass
            if existing:
                return existing
            if fallback:
                return fallback
            return "Playlist"
        except Exception:
            text = str(existing_name or fallback_name or "Playlist").strip()
            return text or "Playlist"

    def _playlist_service_kind(self, playlist_url):
        try:
            url = str(playlist_url or "").strip().lower()
            if not url:
                return ""
            if "spotify.com/" in url or url.startswith("spotify:"):
                return "spotify"
            if "youtube.com/" in url or "youtu.be/" in url or "music.youtube.com/" in url:
                return "youtube"
            return "link"
        except Exception:
            return ""

    def _playlist_service_icon_name(self, playlist_url):
        try:
            kind = self._playlist_service_kind(playlist_url)
            if kind == "spotify":
                return "spotify_logo_services"
            if kind == "youtube":
                return "logo_youtube"
            return "msg_link"
        except Exception:
            return "msg_link"

    def _playlist_service_remote_icon_name(self, playlist_url, is_dark_theme=True):
        try:
            kind = self._playlist_service_kind(playlist_url)
            if kind == "spotify":
                return "Spcy.png" if bool(is_dark_theme) else "Spcy_black.png"
            if kind == "youtube":
                return "yt.png" if bool(is_dark_theme) else "yt_black.png"
            return "link.png"
        except Exception:
            return "link.png"

    def _playlist_service_remote_bitmap(self, playlist_url, size_dp=15, is_dark_theme=True):
        try:
            icon_name = str(self._playlist_service_remote_icon_name(playlist_url, is_dark_theme) or "").strip()
            if not icon_name:
                return None
            url = "https://coreupdates.meyankut.workers.dev/{0}".format(icon_name)
            cache = getattr(self, "_playlist_service_asset_memo", None)
            if cache is None:
                cache = {}
                self._playlist_service_asset_memo = cache
            cache_key = "{0}|{1}|{2}".format(url, int(size_dp or 15), "dark" if bool(is_dark_theme) else "light")
            memo = cache.get(cache_key)
            if memo is not None:
                return memo
            data = self._cached_remote_bytes(url, cache_key="playlist_logo::{0}".format(icon_name))
            if not data:
                return None
            BitmapFactory = jclass("android.graphics.BitmapFactory")
            Bitmap = jclass("android.graphics.Bitmap")
            bmp = BitmapFactory.decodeByteArray(data, 0, len(data))
            if bmp is None:
                return None
            size_px = int(max(AndroidUtilities.dp(int(size_dp or 15)), 1))
            try:
                if int(bmp.getWidth()) != size_px or int(bmp.getHeight()) != size_px:
                    bmp = Bitmap.createScaledBitmap(bmp, size_px, size_px, True)
            except Exception:
                pass
            cache[cache_key] = bmp
            return bmp
        except Exception:
            return None

    def _playlist_service_display_bitmap(self, playlist_url, size_dp=15, is_dark_theme=False):
        try:
            base_bmp = self._playlist_service_remote_bitmap(playlist_url, size_dp, is_dark_theme)
            if base_bmp is None or bool(is_dark_theme):
                return base_bmp
            return base_bmp
        except Exception:
            return self._playlist_service_remote_bitmap(playlist_url, size_dp, is_dark_theme)

    def _playlist_service_icon_candidates(self, playlist_url):
        try:
            kind = self._playlist_service_kind(playlist_url)
            if kind == "spotify":
                return [
                    "spotify_logo_services",
                    "msg_music",
                    "msg_audio",
                    "msg_disc",
                    "msg_link",
                ]
            if kind == "youtube":
                return [
                    "logo_youtube",
                    "filled_playvideo",
                    "msg_play",
                    "msg_video",
                    "msg_link",
                ]
            return ["msg_link", "msg_webview", "msg_url"]
        except Exception:
            return ["msg_link"]

    def _playlist_service_badge_text(self, playlist_url):
        try:
            kind = self._playlist_service_kind(playlist_url)
            if kind == "spotify":
                return "SP"
            if kind == "youtube":
                return "YT"
            return "URL"
        except Exception:
            return "URL"

    def _playlist_service_chip_fill(self, playlist_url, is_dark_theme=False):
        try:
            kind = self._playlist_service_kind(playlist_url)
            if kind == "spotify":
                return self._jcolor(0x2232C766 if not is_dark_theme else 0x2640C057)
            if kind == "youtube":
                return self._jcolor(0x22FF3B30 if not is_dark_theme else 0x26FF4E45)
            return self._jcolor(0x14000000 if not is_dark_theme else 0x18000000)
        except Exception:
            return self._jcolor(0x14000000 if not is_dark_theme else 0x18000000)

    def _playlist_service_chip_stroke(self, playlist_url, is_dark_theme=False):
        try:
            kind = self._playlist_service_kind(playlist_url)
            if kind == "spotify":
                return self._jcolor(0x6632C766 if not is_dark_theme else 0x7A40C057)
            if kind == "youtube":
                return self._jcolor(0x66FF3B30 if not is_dark_theme else 0x7AFF4E45)
            return self._jcolor(0x1C000000 if not is_dark_theme else 0x26FFFFFF)
        except Exception:
            return self._jcolor(0x1C000000 if not is_dark_theme else 0x26FFFFFF)

    def _playlist_service_icon_drawable_id(self, playlist_url):
        try:
            ctx = ApplicationLoader.applicationContext
            if ctx is None:
                return 0
            res = ctx.getResources()
            pkg = ctx.getPackageName()
            for name in self._playlist_service_icon_candidates(playlist_url):
                for kind in ("drawable", "mipmap"):
                    rid = res.getIdentifier(str(name or "").strip(), kind, pkg)
                    if rid:
                        return int(rid)
            return 0
        except Exception:
            return 0

    def _rename_source_playlist(self, playlist_url, new_name):
        try:
            url = self._clean_external_link_input(playlist_url)
            name = str(new_name or "").strip()
            if not url or not name:
                return False
            items = list(self._playlists() or [])
            changed = False
            for entry in items:
                if str(entry.get("url") or "").strip() == url:
                    entry["name"] = name
                    changed = True
                    break
            if not changed:
                return False
            self._set_playlists(items)
            override = self._source_playlist_override(url)
            if override:
                self._save_source_playlist_override(url, name, list(override.get("tracks") or []))
            else:
                listed = self._playlist_listing_items(url)
                if listed:
                    self._remember_playlist_listing(url, listed, name)
            return True
        except Exception as e:
            self._trace("rename source playlist fail: {0}".format(e), "ERROR")
            return False

    def _remove_track_from_source_playlist(self, playlist_url, item):
        try:
            url = self._clean_external_link_input(playlist_url)
            if not url:
                return False
            current = list(self._source_playlist_tracks(url) or [])
            if not current:
                return False
            item_id = str((item or {}).get("id") or "").strip()
            target_title = self._lyrics_norm((item or {}).get("title"))
            target_author = self._lyrics_norm((item or {}).get("author"))
            new_tracks = []
            removed = False
            for entry in current:
                if removed:
                    new_tracks.append(dict(entry or {}))
                    continue
                eid = str((entry or {}).get("id") or "").strip()
                if item_id and eid and eid == item_id:
                    removed = True
                    continue
                if (not item_id) and self._lyrics_norm((entry or {}).get("title")) == target_title and self._lyrics_norm((entry or {}).get("author")) == target_author:
                    removed = True
                    continue
                new_tracks.append(dict(entry or {}))
            if not removed:
                return False
            self._save_source_playlist_override(url, self._playlist_saved_name(url), new_tracks)
            return True
        except Exception as e:
            self._trace("remove source playlist track fail: {0}".format(e), "ERROR")
            return False

    def _save_external_playlist_entry(self, playlist_name, playlist_url):
        try:
            name = str(playlist_name or "Playlist").strip() or "Playlist"
            url = self._clean_external_link_input(playlist_url)
            if not url:
                return False
            items = list(self._playlists() or [])
            replaced = False
            for idx, entry in enumerate(items):
                if str((entry or {}).get("url") or "").strip() == url:
                    items[idx] = {"name": name, "url": url}
                    replaced = True
                    break
            if not replaced:
                items.append({"name": name, "url": url})
            self._set_playlists(items)
            try:
                self._warm_playlist_cache_async({"name": name, "url": url})
            except Exception:
                pass
            return True
        except Exception as e:
            self._trace("save external playlist entry fail: {0}".format(e), "ERROR")
            return False

    def _smart_cache_index(self):
        try:
                                                                                 
            now_ts = time.time()
            if hasattr(self, "_cached_smart_cache_index") and (now_ts - getattr(self, "_cached_smart_cache_ts", 0)) < 2.0:
                return self._cached_smart_cache_index

            raw = self.get_setting("pomme_smart_cache_index", {"playlists": {}})

                                                                                              
                                                            
            if isinstance(raw, dict):
                self._cached_smart_cache_index = raw
                self._cached_smart_cache_ts = now_ts
                return raw

            if isinstance(raw, str) and raw.strip():
                                                                        
                if hasattr(self, "_cached_smart_cache_raw_str") and raw == self._cached_smart_cache_raw_str:
                    self._cached_smart_cache_ts = now_ts
                    return self._cached_smart_cache_index
                
                data = json.loads(raw)
                self._cached_smart_cache_index = data
                self._cached_smart_cache_raw_str = raw
                self._cached_smart_cache_ts = now_ts
                return data

            return {"playlists": {}}
        except Exception:
            return {"playlists": {}}

    def _set_smart_cache_index(self, index):
        try:
                                                    
            data = index if isinstance(index, dict) else {"playlists": {}}
            playlists = data.get("playlists") or {}
            if len(playlists) > SMART_CACHE_MAX_PLAYLISTS:
                                            
                sorted_keys = sorted(playlists.keys(), key=lambda k: int((playlists[k] or {}).get("updated_at") or 0), reverse=True)
                playlists = {k: playlists[k] for k in sorted_keys[:SMART_CACHE_MAX_PLAYLISTS]}
                data["playlists"] = playlists

            try:
                self.set_setting("pomme_smart_cache_index", data)
            except Exception:
                self.set_setting("pomme_smart_cache_index", json.dumps(data, ensure_ascii=True))
                              
            if hasattr(self, "_cached_smart_cache_ts"):
                self._cached_smart_cache_ts = 0
            
                                                                       
            try:
                if hasattr(self, "_cached_summary_data"):
                    delattr(self, "_cached_summary_data")
            except Exception: pass
            
            return True
        except Exception:
            return False

    def _playlist_cache_key(self, playlist_url):
        try:
            return hashlib.md5(str(playlist_url or "").strip().encode("utf-8")).hexdigest()
        except Exception:
            return ""

    def _migrate_smart_cache_playlist_rename(self, old_name, new_name):
        try:
            if not self._smart_cache_enabled():
                return
            on = str(old_name or "").strip()
            nn = str(new_name or "").strip()
            if not on or not nn or on == nn:
                return
            old_url = self._user_playlist_cache_url(on)
            new_url = self._user_playlist_cache_url(nn)
            ok = self._playlist_cache_key(old_url)
            nk = self._playlist_cache_key(new_url)
            if not ok or not nk or ok == nk:
                return
            index = self._smart_cache_index()
            playlists = dict(index.get("playlists") or {})
            entry = dict(playlists.get(ok) or {})
            if not entry:
                return
            playlists.pop(ok, None)
            entry["url"] = new_url
            entry["name"] = nn
            entry["updated_at"] = int(time.time())
            playlists[nk] = entry
            index["playlists"] = playlists
            self._set_smart_cache_index(index)
        except Exception as e:
            self._trace("smart cache rename migrate fail: {0}".format(e), "WARN")

    def _remember_playlist_listing(self, playlist_url, items, playlist_name=None):
        try:
            if not self._smart_cache_enabled():
                return False
            url = str(playlist_url or "").strip()
            key = self._playlist_cache_key(url)
            if not key:
                return False
            index = self._smart_cache_index()
            playlists = dict(index.get("playlists") or {})
            previous = dict(playlists.get(key) or {})
            previous_tracks = {str((t or {}).get("id") or ""): dict(t or {}) for t in (previous.get("tracks") or [])}
            tracks = []
            seen = set()
            for item in (items or []):
                if not isinstance(item, dict):
                    continue
                tid = str(item.get("id") or "").strip()
                if not tid:
                    tid = str(self._extract_video_id(item) or "").strip()
                if not tid or tid in seen:
                    continue
                seen.add(tid)
                old = previous_tracks.get(tid, {})
                file_path = str(item.get("file_path") or item.get("cached_file") or old.get("file_path") or old.get("cached_file") or "").strip()
                len_sec = self._parse_duration_seconds(item.get("length") if item.get("length") is not None else old.get("length"), 0)
                dur_sec = self._parse_duration_seconds(item.get("duration") if item.get("duration") is not None else old.get("duration"), len_sec)
                tracks.append({
                    "id": tid,
                    "title": str(item.get("title") or old.get("title") or "Track").strip() or "Track",
                    "author": str(item.get("author") or old.get("author") or "YouTube").strip() or "YouTube",
                    "length": len_sec,
                    "thumbnail": str(item.get("thumbnail") or old.get("thumbnail") or "").strip(),
                    "cover_url": str(item.get("cover_url") or old.get("cover_url") or "").strip(),
                    "url": str(item.get("url") or old.get("url") or "").strip(),
                    "file_path": file_path,
                    "cached_file": file_path,
                    "mime": str(item.get("mime") or old.get("mime") or "").strip(),
                    "duration": dur_sec,
                    "bitrate": self._safe_int(item.get("bitrate") if item.get("bitrate") is not None else old.get("bitrate"), 0),
                })
                if len(tracks) >= SMART_CACHE_MAX_TRACKS:
                    break
            playlists[key] = {
                "name": self._resolve_playlist_display_name(url, playlist_name, previous.get("name")),
                "url": url,
                "tracks": tracks,
                "updated_at": int(time.time()),
            }
            index["playlists"] = playlists
            self._set_smart_cache_index(index)
            return True
        except Exception as e:
            self._trace("remember playlist listing fail: {0}".format(e), "ERROR")
            return False

    def _playlist_listing_items(self, playlist_url):
        try:
            key = self._playlist_cache_key(playlist_url)
            entry = dict((self._smart_cache_index().get("playlists") or {}).get(key) or {})
            items = []
            tracks = list(entry.get("tracks") or [])
            for track in tracks:
                if not isinstance(track, dict):
                    continue
                len_sec = self._parse_duration_seconds(track.get("length") if track.get("length") is not None else track.get("duration"), 0)
                dur_sec = self._parse_duration_seconds(track.get("duration"), len_sec)
                item = {
                    "id": str(track.get("id") or "").strip(),
                    "title": str(track.get("title") or "Track").strip() or "Track",
                    "author": str(track.get("author") or "YouTube").strip() or "YouTube",
                    "length": len_sec,
                    "thumbnail": str(track.get("thumbnail") or "").strip(),
                    "cover_url": str(track.get("cover_url") or "").strip(),
                    "url": str(track.get("url") or "").strip(),
                }
                file_path = str(track.get("file_path") or "").strip()
                                                                                          
                                                    
                if file_path:
                    item["cached_file"] = file_path
                    item["cached_stream"] = {
                        "mime": str(track.get("mime") or "").strip(),
                        "duration": dur_sec,
                        "bitrate": self._safe_int(track.get("bitrate"), 0),
                        "video_id": str(track.get("id") or "").strip(),
                    }
                items.append(item)
            return items
        except Exception:
            return []

    def _remember_playlist_track_cache(self, play_ctx, item, file_path, stream_info):
        try:
            if not self._smart_cache_enabled():
                return False
            ctx = dict(play_ctx or {})
            if not bool(ctx.get("playlist")):
                return False
            url = str(ctx.get("playlist_url") or "").strip()
            key = self._playlist_cache_key(url)
            if not key:
                return False
            index = self._smart_cache_index()
            playlists = dict(index.get("playlists") or {})
            entry = dict(playlists.get(key) or {})
            tracks = list(entry.get("tracks") or [])
            target_id = str((item or {}).get("id") or "").strip()
            changed = False
            for track in tracks:
                if str(track.get("id") or "") != target_id:
                    continue
                resolved_path = str(file_path or "").strip()
                track["file_path"] = resolved_path
                track["cached_file"] = resolved_path
                track["mime"] = str((stream_info or {}).get("mime") or "").strip()
                track["duration"] = self._parse_duration_seconds(
                    (stream_info or {}).get("duration") if (stream_info or {}).get("duration") is not None else track.get("duration"),
                    self._parse_duration_seconds(track.get("length"), 0),
                )
                track["bitrate"] = self._safe_int(
                    (stream_info or {}).get("bitrate") if (stream_info or {}).get("bitrate") is not None else track.get("bitrate"),
                    0,
                )
                cover_cached_file = str((item or {}).get("cover_cached_file") or "").strip()
                if cover_cached_file:
                    track["cover_cached_file"] = cover_cached_file
                changed = True
                break
            if not changed and target_id:
                len_sec = self._parse_duration_seconds((item or {}).get("length"), 0)
                tracks.append({
                    "id": target_id,
                    "title": str((item or {}).get("title") or "Track").strip() or "Track",
                    "author": str((item or {}).get("author") or "YouTube").strip() or "YouTube",
                    "length": len_sec,
                    "thumbnail": str((item or {}).get("thumbnail") or "").strip(),
                    "cover_url": str((item or {}).get("cover_url") or "").strip(),
                    "cover_cached_file": str((item or {}).get("cover_cached_file") or "").strip(),
                    "url": str((item or {}).get("url") or "").strip(),
                    "file_path": str(file_path or "").strip(),
                    "cached_file": str(file_path or "").strip(),
                    "mime": str((stream_info or {}).get("mime") or "").strip(),
                    "duration": self._parse_duration_seconds((stream_info or {}).get("duration"), len_sec),
                    "bitrate": self._safe_int((stream_info or {}).get("bitrate"), 0),
                })
                if len(tracks) > SMART_CACHE_MAX_TRACKS:
                    tracks = tracks[-SMART_CACHE_MAX_TRACKS:]
            entry["name"] = self._resolve_playlist_display_name(
                url,
                ctx.get("playlist_name"),
                entry.get("name"),
            )
            entry["url"] = url
            entry["tracks"] = tracks
            entry["updated_at"] = int(time.time())
            playlists[key] = entry
            index["playlists"] = playlists
            self._set_smart_cache_index(index)
            return True
        except Exception as e:
            self._trace("remember playlist cache fail: {0}".format(e), "ERROR")
            return False

    def _cached_playlist_items(self, playlist_url):
        try:
            key = self._playlist_cache_key(playlist_url)
            entry = dict((self._smart_cache_index().get("playlists") or {}).get(key) or {})
            cached = []
            for track in (entry.get("tracks") or []):
                path = str(track.get("file_path") or "").strip()
                if not path or not os.path.exists(path):
                    continue
                len_sec = self._parse_duration_seconds(track.get("length") if track.get("length") is not None else track.get("duration"), 0)
                dur_sec = self._parse_duration_seconds(track.get("duration"), len_sec)
                cached.append({
                    "id": str(track.get("id") or "").strip(),
                    "title": str(track.get("title") or "Track").strip() or "Track",
                    "author": str(track.get("author") or "YouTube").strip() or "YouTube",
                    "length": len_sec,
                    "thumbnail": str(track.get("thumbnail") or "").strip(),
                    "cover_url": str(track.get("cover_url") or "").strip(),
                    "cover_cached_file": str(track.get("cover_cached_file") or "").strip(),
                    "url": str(track.get("url") or "").strip(),
                    "cached_file": path,
                    "cached_stream": {
                        "mime": str(track.get("mime") or "").strip(),
                        "duration": dur_sec,
                        "bitrate": self._safe_int(track.get("bitrate"), 0),
                        "video_id": str(track.get("id") or "").strip(),
                    },
                })
            return cached
        except Exception:
            return []

    def _hydrate_cached_playlist_item(self, play_ctx):
        try:
            ctx = dict(play_ctx or {})
            if not bool(ctx.get("playlist")):
                return ctx
            item = dict(ctx.get("item") or {})
            playlist_url = str(ctx.get("playlist_url") or "").strip()
            item_id = str(item.get("id") or "").strip()
            if not playlist_url or not item_id:
                return ctx
            for cached in self._cached_playlist_items(playlist_url):
                if str(cached.get("id") or "") != item_id:
                    continue
                item["cached_file"] = str(cached.get("cached_file") or "").strip()
                item["cached_stream"] = dict(cached.get("cached_stream") or {})
                if str(cached.get("cover_cached_file") or "").strip():
                    item["cover_cached_file"] = str(cached.get("cover_cached_file") or "").strip()
                if str(cached.get("cover_url") or "").strip():
                    item["cover_url"] = str(cached.get("cover_url") or "").strip()
                if not item.get("thumbnail"):
                    item["thumbnail"] = str(cached.get("thumbnail") or "").strip()
                if not item.get("url"):
                    item["url"] = str(cached.get("url") or "").strip()
                ctx["item"] = item
                return ctx
            return ctx
        except Exception as e:
            self._trace("hydrate cached playlist item fail: {0}".format(e), "ERROR")
            return dict(play_ctx or {})

    def _smart_cache_summary(self):
        try:
                                                                                    
            now = time.time()
            if hasattr(self, "_cached_summary_data") and (now - getattr(self, "_cached_summary_ts", 0)) < 5.0:
                return self._cached_summary_data

            index = self._smart_cache_index()
            playlists = index.get("playlists") or {}
            user_map = {}
            try:
                for entry in self._user_saved_playlists():
                    if not isinstance(entry, dict):
                        continue
                    pname = str(entry.get("name") or "").strip()
                    if not pname:
                        continue
                    tracks = [dict(t or {}) for t in list(entry.get("tracks") or []) if isinstance(t, dict)]
                    user_map[pname] = tracks
            except Exception:
                user_map = {}
            rows = []
            keys_in_rows = set()
            for key, entry in playlists.items():
                all_tracks = list(entry.get("tracks") or [])
                playlist_url = str(entry.get("url") or "").strip()
                playlist_name = self._resolve_playlist_display_name(
                    playlist_url,
                    entry.get("name"),
                    entry.get("name"),
                )
                                                                                                          
                if (not all_tracks) and playlist_name in user_map:
                    all_tracks = list(user_map.get(playlist_name) or [])
                                                                
                cached_tracks = []
                total_bytes = 0
                for t in all_tracks:
                    path = str((t or {}).get("file_path") or (t or {}).get("cached_file") or "").strip()
                    if path and os.path.exists(path):
                        cached_tracks.append(t)
                        try:
                            total_bytes += int(os.path.getsize(path))
                        except Exception:
                            pass
                                                                          
                if (not all_tracks) and playlist_url.startswith("pomme://playlist/"):
                    inferred = list(user_map.get(playlist_name) or [])
                    if inferred:
                        all_tracks = inferred
                        cached_tracks = []
                        total_bytes = 0
                        for t in all_tracks:
                            path = str((t or {}).get("cached_file") or (t or {}).get("file_path") or "").strip()
                            if path and os.path.exists(path):
                                cached_tracks.append(t)
                                try:
                                    total_bytes += int(os.path.getsize(path))
                                except Exception:
                                    pass
                
                                                               
                rows.append({
                    "key": str(key),
                    "name": playlist_name,
                    "url": playlist_url,
                    "count": len(cached_tracks),
                    "total": len(all_tracks),
                    "bytes": int(total_bytes),
                })
                keys_in_rows.add(str(key))
            if user_map:
                for pname, utracks in user_map.items():
                    playlist_name = str(pname or "").strip()
                    if not playlist_name:
                        continue
                    playlist_url = str(self._user_playlist_cache_url(playlist_name) or "").strip()
                    vk = self._playlist_cache_key(playlist_url)
                    if vk and vk in keys_in_rows:
                        continue
                    all_tracks = [dict(t or {}) for t in list(utracks or []) if isinstance(t, dict)]
                    cached_tracks = []
                    total_bytes = 0
                    for t in all_tracks:
                        path = str((t or {}).get("file_path") or (t or {}).get("cached_file") or "").strip()
                        if path and os.path.exists(path):
                            cached_tracks.append(t)
                            try:
                                total_bytes += int(os.path.getsize(path))
                            except Exception:
                                pass
                    rows.append({
                        "key": str(vk or ""),
                        "name": playlist_name,
                        "url": playlist_url,
                        "count": len(cached_tracks),
                        "total": len(all_tracks),
                        "bytes": int(total_bytes),
                    })
                    if vk:
                        keys_in_rows.add(str(vk))
            rows.sort(key=lambda x: x["name"].lower())
            
            self._cached_summary_data = rows
            self._cached_summary_ts = now
            return rows
        except Exception as e:
            self._trace("get cache summary fail: {0}".format(e), "WARN")
            return []

    def _format_cache_size(self, total_bytes):
        try:
            size = float(total_bytes or 0)
            units = ["B", "KB", "MB", "GB"]
            idx = 0
            while size >= 1024.0 and idx < len(units) - 1:
                size /= 1024.0
                idx += 1
            if idx == 0:
                return "{0} {1}".format(int(size), units[idx])
            return "{0:.1f} {1}".format(size, units[idx])
        except Exception:
            return "0 B"

    def _prefetch_playlist_cache(self, play_ctx, progress_cb=None):
        try:
            ctx = dict(play_ctx or {})
            if not self._smart_cache_enabled() or not bool(ctx.get("playlist")):
                return False
            items = list(ctx.get("results") or [])
            if not items:
                return False
            offline_only = bool(self._offline_listening_enabled())

            def _worker():
                cached_by_id = {}
                playlist_url = str(ctx.get("playlist_url") or "")
                for entry in self._cached_playlist_items(playlist_url):
                    track_id = str(entry.get("id") or "").strip()
                    if track_id:
                        cached_by_id[track_id] = entry
                
                total_items = len(items)
                for idx, track in enumerate(items):
                    try:
                                                                
                        if progress_cb:
                            p = int((float(idx) / float(total_items)) * 100.0)
                            progress_cb(p)

                        try:
                            self._prefetch_cover(track)
                        except Exception:
                            pass
                        file_path = str((track or {}).get("cached_file") or "").strip()
                        if file_path and os.path.exists(file_path):
                            self._remember_playlist_track_cache(ctx, track, file_path, dict((track or {}).get("cached_stream") or {}))
                            continue
                        track_id = str((track or {}).get("id") or "").strip()
                        hit = cached_by_id.get(track_id)
                        if hit and os.path.exists(str(hit.get("cached_file") or "").strip()):
                            self._remember_playlist_track_cache(ctx, track, str(hit.get("cached_file") or "").strip(), dict(hit.get("cached_stream") or {}))
                            continue
                        if offline_only:
                            self._trace("playlist cache prefetch offline skip: uncached track", "DEBUG")
                            continue
                        stream_info = self._resolve_audio_stream(track)
                        path = self._download_audio_file(track, stream_info)
                        self._remember_playlist_track_cache(ctx, track, path, stream_info)
                        if track_id:
                            cached_by_id[track_id] = {
                                "id": track_id,
                                "cached_file": path,
                                "cached_stream": dict(stream_info or {}),
                            }
                    except Exception as e:
                        self._trace("playlist cache prefetch skip: {0}".format(e), "WARN")
                        continue
                
                                   
                if progress_cb: progress_cb(100)

            threading.Thread(target=_worker, daemon=True).start()
            return True
        except Exception as e:
            self._trace("playlist cache prefetch fail: {0}".format(e), "ERROR")
            return False

    def _clear_all_smart_cache(self):
        try:
            base = self._cache_dir()
            if base and os.path.isdir(base):
                for entry in os.listdir(base):
                    path = os.path.join(base, entry)
                    try:
                        if os.path.isdir(path):
                            shutil.rmtree(path, ignore_errors=True)
                        elif os.path.exists(path):
                            os.remove(path)
                    except Exception:
                        pass
            self._set_smart_cache_index({"playlists": {}})
            BulletinHelper.show_success(self._tr("smart_cache_clear_done"))
            return True
        except Exception as e:
            self._trace("clear all smart cache fail: {0}".format(e), "ERROR")
            return False

    def _clear_playlist_cache(self, cache_key):
        try:
            key = str(cache_key or "").strip()
            if not key:
                return False
            index = self._smart_cache_index()
            playlists = dict(index.get("playlists") or {})
            target = dict(playlists.get(key) or {})
            other_refs = set()
            for other_key, entry in playlists.items():
                if str(other_key) == key:
                    continue
                for track in list((entry or {}).get("tracks") or []):
                    path = str((track or {}).get("file_path") or "").strip()
                    if path:
                        other_refs.add(path)
            for track in list(target.get("tracks") or []):
                path = str((track or {}).get("file_path") or "").strip()
                if not path or path in other_refs:
                    continue
                try:
                    if os.path.exists(path):
                        os.remove(path)
                except Exception:
                    pass
            playlists.pop(key, None)
            index["playlists"] = playlists
            self._set_smart_cache_index(index)
            BulletinHelper.show_success(self._tr("smart_cache_playlist_cleared"))
            return True
        except Exception as e:
            self._trace("clear playlist cache fail: {0}".format(e), "ERROR")
            return False

    def _confirm_action(self, ctx, title, message, on_confirm):
        try:
            if ctx is None:
                return False
            b = AlertDialogBuilder(ctx)
            b.set_title(str(title or "Confirm"))
            b.set_message(str(message or ""))
            b.set_positive_button("Confirm", lambda dialog, _w: (dialog.dismiss(), on_confirm()))
            b.set_negative_button("Cancel", lambda dialog, _w: dialog.dismiss())
            b.show()
            return True
        except Exception as e:
            self._trace("confirm action fail: {0}".format(e), "ERROR")
            try:
                on_confirm()
            except Exception:
                pass
            return False

    def _present_native_fragment(self, fragment):
        try:
            host = get_last_fragment()
            if host is None or fragment is None:
                return False
            host.presentFragment(fragment)
            return True
        except Exception:
            return False

    def _open_dialog(self, dialog_id):
        try:
            did = int(dialog_id or 0)
            if did == 0:
                return False
            ChatActivity = jclass("org.telegram.ui.ChatActivity")
            Bundle = jclass("android.os.Bundle")
            args = Bundle()
            if did < 0:
                args.putLong("chat_id", abs(int(did)))
            else:
                args.putLong("user_id", int(did))
            return self._present_native_fragment(ChatActivity(args))
        except Exception as e:
            self._trace("open dialog fail: {0}".format(e), "ERROR")
            return False

    def _current_playing_audio_path(self, message_object=None):
        try:
            msg_obj = message_object
            if msg_obj is None:
                MediaController = jclass("org.telegram.messenger.MediaController")
                msg_obj = MediaController.getInstance().getPlayingMessageObject()
            if msg_obj is None:
                return None
            try:
                attach_path = str(getattr(msg_obj.messageOwner, "attachPath", "") or "").strip()
                if attach_path and os.path.exists(attach_path):
                    return attach_path
            except Exception:
                pass
            try:
                FL = jclass("org.telegram.messenger.FileLoader")
                UC = jclass("org.telegram.messenger.UserConfig")
                account = int(getattr(UC, "selectedAccount", 0) or 0)
                path_obj = FL.getInstance(account).getPathToMessage(msg_obj.messageOwner)
                if path_obj is not None:
                    path = str(path_obj.toString() or "").strip()
                    if path and os.path.exists(path):
                        return path
            except Exception:
                pass
            return None
        except Exception:
            return None

    def _is_current_pomme_track(self):
        try:
                                                                           
            if self._active_play_ctx is not None:
                return True
            
                                                                
            path = self._current_playing_audio_path()
            if path:
                path = str(path)
                if "Pomme_Temp" in path:
                    return True
            
                                                        
            try:
                MediaController = jclass("org.telegram.messenger.MediaController")
                current = MediaController.getInstance().getPlayingMessageObject()
                if current and self._last_started_item:
                    native_title = str(current.getMusicTitle() or "").strip().lower()
                    native_author = str(current.getMusicAuthor() or "").strip().lower()
                    last_title = str(self._last_started_item.get("title") or "").strip().lower()
                    last_author = str(self._last_started_item.get("author") or "").strip().lower()
                    if native_title == last_title and (not last_author or native_author == last_author):
                        return True
            except Exception: pass

                                                                      
            try:
                MediaController = jclass("org.telegram.messenger.MediaController")
                current = MediaController.getInstance().getPlayingMessageObject()
                if current and int(current.getId()) >= 2000000000:
                    return True
            except Exception: pass
            
            return False
        except Exception:
            return self._active_play_ctx is not None

    def _player_alert_has_pomme_ui(self, alert_obj):
        try:
            if alert_obj is None:
                return False
            save_btn = get_private_field(alert_obj, "saveToProfileButton")
            if save_btn is not None:
                try:
                    if str(save_btn.getTag() or "") == "pomme_primary_button":
                        return True
                except Exception:
                    pass
                parent = save_btn.getParent()
                try:
                    if parent is not None and str(parent.getTag() or "") == "pomme_action_row":
                        return True
                except Exception:
                    pass
            return False
        except Exception:
            return False

    def _bind_player_save_button(self, alert_obj):
        try:
            if alert_obj is None:
                return False
            self._last_player_alert = alert_obj
            save_btn = get_private_field(alert_obj, "saveToProfileButton")
            if save_btn is None:
                return False
            visible = bool(self._is_current_pomme_track())
            if not visible:
                if self._enabled:
                                                                                              
                    try:
                        save_btn.setVisibility(View.VISIBLE)
                        save_btn.setEnabled(True)
                        save_btn.setClickable(True)
                        save_btn.setAlpha(1.0)
                    except Exception:
                        pass
                if not self._player_alert_has_pomme_ui(alert_obj):
                    return False
                try:
                    save_btn.setVisibility(View.VISIBLE)
                    save_btn.setEnabled(True)
                    save_btn.setClickable(True)
                    save_btn.setAlpha(1.0)
                except Exception:
                    pass
                try:
                    self._ensure_player_action_row(alert_obj, save_btn)
                except Exception:
                    pass
                return True
            try:
                save_btn.setVisibility(View.VISIBLE)
            except Exception:
                pass
            try:
                if str(save_btn.getTag() or "") != "pomme_primary_button":
                    save_btn.setTag("pomme_primary_button")
            except Exception:
                pass
            try:
                                                                                       
                save_btn.setText(self._tr("lyrics_button"))
            except Exception:
                try:
                    save_btn.setText(self._tr("lyrics_button"), False)
                except Exception:
                    pass
            
            options_btn = get_private_field(alert_obj, "optionsButton")
            if options_btn is not None:
                                                                             
                                                                       
                pass
            
                                                                                
            try:
                def _deep_disable(v):
                    try:
                        name = str(v.getClass().getName() or "")
                                                                                             
                                                                                
                        if "ButtonWithCounterView" in name or "LikeButton" in name or "Heart" in name:
                            v.setVisibility(View.GONE)
                            v.setAlpha(0.0)
                            v.setEnabled(False)
                            v.setClickable(False)
                            try:
                                v.setOnClickListener(None)
                            except Exception:
                                pass
                            try:
                                class _NoOpDeep(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                                    def onClick(self_obj, v): 
                                        try:
                                                                          
                                            pass
                                        except Exception: pass
                                v.setOnClickListener(_NoOpDeep())
                            except Exception:
                                pass
                        if hasattr(v, "getChildCount"):
                            for i in range(int(v.getChildCount())):
                                _deep_disable(v.getChildAt(i))
                    except Exception:
                        pass
                
                player_layout = get_private_field(alert_obj, "playerLayout")
                if player_layout is not None:
                    _deep_disable(player_layout)
                
                                                                     
                action_bar = get_private_field(alert_obj, "actionBar")
                if action_bar is not None:
                    menu = get_private_field(action_bar, "menu")
                    if menu is not None:
                        _deep_disable(menu)
            except Exception:
                pass

            try:
                save_btn.setTypeface(None, 1)
            except Exception:
                pass
            try:
                save_btn.setEnabled(True)
                save_btn.setClickable(True)
                save_btn.setAlpha(1.0)
            except Exception:
                pass
            listener_cls = find_class("android.view.View$OnClickListener")
            if listener_cls is None:
                return True
            try:
                plugin = self

                class _SaveClick(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        try:
                            plugin._show_about_sheet()
                        except Exception as e:
                            plugin._trace("save button click fail: {0}".format(e), "ERROR")

                                                                                 
                save_btn.setOnClickListener(_SaveClick())
                save_btn.setContentDescription("pomme_primary_button_bound")
            except Exception:
                pass
            try:
                self._ensure_player_action_row(alert_obj, save_btn)
            except Exception as song_btn_error:
                self._trace("ensure player action row fail: {0}".format(song_btn_error), "WARN")
            return True
        except Exception as e:
            self._trace("bind player save button fail: {0}".format(e), "ERROR")
            return False

    def _is_hard_stop_active(self):
        try:
            if not bool(getattr(self, "_hard_stop_active", False)):
                return False
            until_ts = float(getattr(self, "_hard_stop_epoch", 0.0) or 0.0)
            if until_ts > 0.0 and float(time.time()) > until_ts:
                self._hard_stop_active = False
                self._hard_stop_epoch = 0.0
                return False
            return True
        except Exception:
            return False

    def _activate_hard_stop(self, hold_seconds=4.0):
        try:
            self._hard_stop_active = True
            self._hard_stop_epoch = float(time.time()) + max(0.75, float(hold_seconds or 0.0))
            self._play_request_token += 1
            self._continue_token += 1
            self._manual_stop_requested = True
            self._autoplay_blocked = True
            self._queue_items = []
            self._active_play_ctx = None
            self._history_items = []
            return True
        except Exception:
            return False

    def _arm_manual_close_guard(self, seconds=3.5):
        try:
            self._manual_close_guard_until = float(time.time()) + max(0.5, float(seconds or 0.0))
            return True
        except Exception:
            return False

    def _manual_close_guard_active(self):
        try:
            return float(getattr(self, "_manual_close_guard_until", 0.0) or 0.0) > float(time.time())
        except Exception:
            return False

    def _clear_manual_close_guard(self):
        try:
            self._manual_close_guard_until = 0.0
            return True
        except Exception:
            return False

    def _clear_hard_stop(self):
        try:
            self._hard_stop_active = False
            self._hard_stop_epoch = 0.0
            return True
        except Exception:
            return False

    def _current_song_link_url(self):
        try:
            item = dict((self._active_play_ctx or {}).get("item") or {})
            video_id = self._extract_video_id(item)
            watch_url = "https://www.youtube.com/watch?v={0}".format(video_id) if video_id else str(item.get("url") or "").strip()
            if not watch_url:
                title, artist = self._current_track_meta()
                query = urllib.parse.quote_plus("{0} {1}".format(str(title or ""), str(artist or "")).strip())
                return "https://song.link/search?q={0}".format(query)
            api_url = "https://api.song.link/v1-alpha.1/links?url={0}".format(urllib.parse.quote(watch_url, safe=""))
            req = Request(api_url, headers={"User-Agent": "Mozilla/5.0", "Accept": "application/json"})
            with urlopen(req, timeout=8) as resp:
                raw = resp.read()
            data = json.loads(raw.decode("utf-8", "ignore")) if raw else {}
            page_url = str((data or {}).get("pageUrl") or "").strip()
            if page_url:
                return page_url
            title, artist = self._current_track_meta()
            query = urllib.parse.quote_plus("{0} {1}".format(str(title or ""), str(artist or "")).strip())
            return "https://song.link/search?q={0}".format(query) if query else "https://song.link/"
        except Exception:
            try:
                title, artist = self._current_track_meta()
                query = urllib.parse.quote_plus("{0} {1}".format(str(title or ""), str(artist or "")).strip())
                if query:
                    return "https://song.link/search?q={0}".format(query)
            except Exception:
                pass
            return "https://song.link/"

    def _open_current_song_link(self):
        try:
            BulletinHelper.show_info(self._tr("song_link_loading"))
            def _worker():
                try:
                    final_url = self._current_song_link_url()
                    if not final_url:
                        raise Exception("empty song.link url")
                    run_on_ui_thread(lambda: self._open_url(final_url))
                except Exception as e:
                    self._trace("song.link open fail: {0}".format(e), "ERROR")
                    run_on_ui_thread(lambda: BulletinHelper.show_error(self._tr("song_link_error")))
            threading.Thread(target=_worker, daemon=True).start()
            return True
        except Exception as e:
            self._trace("song.link bootstrap fail: {0}".format(e), "ERROR")
            return False

    def _user_saved_playlists(self):
        try:
            raw = self.get_setting("pomme_user_track_playlists", [])
            raw_key = raw if isinstance(raw, str) else json.dumps(raw or [], ensure_ascii=False, sort_keys=True, separators=(",", ":"))
            now = time.time()
            if (
                self._user_playlists_cache is not None
                and raw_key == self._user_playlists_cache_raw
                and (now - float(self._user_playlists_cache_ts or 0.0)) < USER_PLAYLISTS_CACHE_TTL_SEC
            ):
                return json.loads(json.dumps(self._user_playlists_cache))
            items = raw if isinstance(raw, list) else []
            clean = []
            for entry in items:
                if not isinstance(entry, dict):
                    continue
                name = str(entry.get("name") or "").strip()
                if not name:
                    continue
                tracks = []
                for track in (entry.get("tracks") or []):
                    if not isinstance(track, dict):
                        continue
                    item_id = str(track.get("id") or "").strip()
                    if not item_id:
                        continue
                    tracks.append(dict(track))
                payload = {"name": name, "tracks": tracks}
                if self._is_liked_playlist_entry(entry):
                    payload["system"] = "liked"
                elif self._is_auto_cache_playlist_entry(entry):
                    payload["system"] = "auto_cache"
                clean.append(payload)
            self._user_playlists_cache = clean
            self._user_playlists_cache_ts = now
            self._user_playlists_cache_raw = raw_key
            return json.loads(json.dumps(clean))
        except Exception:
            return []

    def _set_user_saved_playlists(self, items):
        try:
            payload = list(items or [])
            serialized = json.dumps(payload, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
            if serialized == self._user_playlists_cache_raw:
                return True
            self._user_playlists_cache = json.loads(serialized)
            self._user_playlists_cache_ts = time.time()
            self._user_playlists_cache_raw = serialized
            self.set_setting("pomme_user_track_playlists", self._user_playlists_cache)
                                                                       
            try:
                if hasattr(self, "_cached_summary_data"):
                    delattr(self, "_cached_summary_data")
            except Exception: pass
            return True
        except Exception:
            return False

    def _liked_playlist_name(self):
        try:
            return str(self._tr("liked_playlist_name") or "Liked Songs").strip() or "Liked Songs"
        except Exception:
            return "Liked Songs"

    def _auto_cache_playlist_name(self):
        try:
            return str(self._tr("auto_cache_playlist_name") or "Auto Cache").strip() or "Auto Cache"
        except Exception:
            return "Auto Cache"

    def _liked_playlist_aliases(self):
        try:
            aliases = {
                "Liked Songs",
                "Curtidas",
                "Любимые",
                str(self._liked_playlist_name() or "").strip(),
            }
            return {str(x or "").strip() for x in aliases if str(x or "").strip()}
        except Exception:
            return {"Liked Songs", "Curtidas", "Любимые"}

    def _is_liked_playlist_entry(self, playlist):
        try:
            if isinstance(playlist, dict):
                if str(playlist.get("system") or "").strip().lower() == "liked":
                    return True
                playlist = playlist.get("name")
            return str(playlist or "").strip() in self._liked_playlist_aliases()
        except Exception:
            return False

    def _auto_cache_playlist_aliases(self):
        try:
            aliases = {
                "Auto Cache",
                str(self._auto_cache_playlist_name() or "").strip(),
            }
            return {str(x or "").strip() for x in aliases if str(x or "").strip()}
        except Exception:
            return {"Auto Cache"}

    def _is_auto_cache_playlist_entry(self, playlist):
        try:
            if isinstance(playlist, dict):
                if str(playlist.get("system") or "").strip().lower() == "auto_cache":
                    return True
                playlist = playlist.get("name")
            return str(playlist or "").strip() in self._auto_cache_playlist_aliases()
        except Exception:
            return False

    def _is_fixed_playlist_entry(self, playlist):
        try:
            return bool(self._is_liked_playlist_entry(playlist) or self._is_auto_cache_playlist_entry(playlist))
        except Exception:
            return False

    def _sync_user_playlists_to_cache(self):
        try:
            items = self._ensure_liked_playlist()
            items = self._ensure_auto_cache_playlist()
            changed = False
            
                                                            
                                                               
            clean_items = []
            for entry in items:
                name = str(entry.get("name") or "").strip()
                if name == "Playlist em Smart Cache" or name == "Smart Cache":
                    changed = True
                    continue
                clean_items.append(entry)
            
            if changed:
                self._set_user_saved_playlists(clean_items)
            else:
                clean_items = items

            if not self._smart_cache_enabled():
                return False

                                                                                               
            for entry in clean_items:
                if not isinstance(entry, dict):
                    continue
                name = str(entry.get("name") or "").strip()
                if not name:
                    continue
                tracks = [dict(x or {}) for x in (entry.get("tracks") or []) if isinstance(x, dict)]
                url = self._user_playlist_cache_url(name)
                if not url:
                    continue
                self._remember_playlist_listing(url, tracks, name)
                if tracks:
                    self._prefetch_playlist_cache({
                        "playlist": True,
                        "playlist_name": name,
                        "playlist_url": url,
                        "results": tracks,
                    })
            return True
        except Exception:
            return False

    def _user_playlist_cache_url(self, playlist_name):
        try:
            name = str(playlist_name or "").strip()
            if not name:
                return ""
            if self._is_liked_playlist_entry(name):
                return "pomme://playlist/liked"
            if self._is_auto_cache_playlist_entry(name):
                return "pomme://playlist/auto_cache"
            key = hashlib.md5(name.lower().encode("utf-8")).hexdigest()
            return "pomme://playlist/{0}".format(key)
        except Exception:
            return ""

    def _ensure_liked_playlist(self):
        try:
            items = self._user_saved_playlists()
            liked_name = self._liked_playlist_name()
            merged_tracks = []
            seen_ids = set()
            liked_entry = None
            other_items = []
            changed = False
            for entry in items:
                if not isinstance(entry, dict):
                    continue
                if self._is_liked_playlist_entry(entry):
                    if liked_entry is None:
                        liked_entry = dict(entry)
                    elif not changed:
                        changed = True
                    for track in list(entry.get("tracks") or []):
                        if not isinstance(track, dict):
                            continue
                        item_id = str(track.get("id") or "").strip()
                        if not item_id or item_id in seen_ids:
                            continue
                        seen_ids.add(item_id)
                        merged_tracks.append(dict(track))
                else:
                    other_items.append(entry)
            if liked_entry is None:
                liked_entry = {"name": liked_name, "tracks": [], "system": "liked"}
                changed = True
            if str(liked_entry.get("name") or "").strip() != liked_name:
                liked_entry["name"] = liked_name
                changed = True
            if str(liked_entry.get("system") or "").strip().lower() != "liked":
                liked_entry["system"] = "liked"
                changed = True
            current_tracks = list(liked_entry.get("tracks") or [])
            if len(current_tracks) != len(merged_tracks) or any(str((a or {}).get("id") or "").strip() != str((b or {}).get("id") or "").strip() for a, b in zip(current_tracks, merged_tracks)):
                liked_entry["tracks"] = merged_tracks
                changed = True
            items = [liked_entry] + other_items
            if changed:
                self._set_user_saved_playlists(items)
                try:
                    self._migrate_smart_cache_playlist_rename("Liked Songs", liked_name)
                    self._migrate_smart_cache_playlist_rename("Curtidas", liked_name)
                    self._migrate_smart_cache_playlist_rename("Любимые", liked_name)
                except Exception:
                    pass
            return items
        except Exception:
            return self._user_saved_playlists()

    def _ensure_auto_cache_playlist(self):
        try:
            items = self._user_saved_playlists()
            cache_name = self._auto_cache_playlist_name()
            merged_tracks = []
            seen_ids = set()
            cache_entry = None
            other_items = []
            changed = False
            for entry in items:
                if not isinstance(entry, dict):
                    continue
                if self._is_auto_cache_playlist_entry(entry):
                    if cache_entry is None:
                        cache_entry = dict(entry)
                    elif not changed:
                        changed = True
                    for track in list(entry.get("tracks") or []):
                        if not isinstance(track, dict):
                            continue
                        item_id = str(track.get("id") or "").strip()
                        if not item_id or item_id in seen_ids:
                            continue
                        seen_ids.add(item_id)
                        merged_tracks.append(dict(track))
                else:
                    other_items.append(entry)
            if cache_entry is None:
                cache_entry = {"name": cache_name, "tracks": [], "system": "auto_cache"}
                changed = True
            if str(cache_entry.get("name") or "").strip() != cache_name:
                cache_entry["name"] = cache_name
                changed = True
            if str(cache_entry.get("system") or "").strip().lower() != "auto_cache":
                cache_entry["system"] = "auto_cache"
                changed = True
            current_tracks = list(cache_entry.get("tracks") or [])
            if len(current_tracks) != len(merged_tracks) or any(str((a or {}).get("id") or "").strip() != str((b or {}).get("id") or "").strip() for a, b in zip(current_tracks, merged_tracks)):
                cache_entry["tracks"] = merged_tracks
                changed = True
            items = [entry for entry in other_items if not self._is_liked_playlist_entry(entry)]
            liked_entry = None
            for entry in self._user_saved_playlists():
                if self._is_liked_playlist_entry(entry):
                    liked_entry = dict(entry)
                    break
            ordered = []
            if liked_entry is not None:
                ordered.append(liked_entry)
            ordered.append(cache_entry)
            for entry in other_items:
                if self._is_liked_playlist_entry(entry) or self._is_auto_cache_playlist_entry(entry):
                    continue
                ordered.append(entry)
            if changed:
                self._set_user_saved_playlists(ordered)
                try:
                    self._migrate_smart_cache_playlist_rename("Auto Cache", cache_name)
                except Exception:
                    pass
            return ordered
        except Exception:
            return self._user_saved_playlists()

    def _ensure_chat_compose_button(self, fragment, from_retry=False):
        try:
            if fragment is None: return
            enter_view = get_private_field(fragment, "chatActivityEnterView")
            if enter_view is None:
                if not from_retry:
                    self._schedule_chat_compose_button_retry(fragment)
                return
            
                                          
            host = None
            for fname in ("attachLayout", "sendButtonContainer", "messageEditTextContainer", "textFieldContainer", "messageContainer"):
                try:
                    cand = get_private_field(enter_view, fname)
                    if cand is not None:
                                                 
                        if hasattr(cand, "addView"):
                            host = cand
                            break
                except Exception: pass
            
            if host is None:
                if not from_retry:
                    self._schedule_chat_compose_button_retry(fragment)
                return
            
                                    
            try:
                if host.getVisibility() != 0:                    
                    host.setVisibility(0)
            except Exception: pass

                                     
            tag = "__pomme_compose_btn__"
            existing = host.findViewWithTag(tag)
            if not self._compose_button_enabled():
                try:
                    if existing is not None:
                        host.removeView(existing)
                except Exception:
                    pass
                return
            if existing is not None: return

            ctx = host.getContext()
            btn = FrameLayout(ctx)
            btn.setTag(tag)
            
                                                         
            icon = ImageView(ctx)
            icon_id = 0
            try:
                pkg = ApplicationLoader.applicationContext.getPackageName()
                res = ApplicationLoader.applicationContext.getResources()
                icon_id = res.getIdentifier("msg_tone_add_solar", "drawable", pkg)
                if not icon_id:
                    icon_id = res.getIdentifier("msg_search", "drawable", pkg)
                if icon_id:
                    icon.setImageResource(int(icon_id))
            except Exception: pass
            
                                             
            if not icon_id:
                try:
                                                                 
                    icon_id = ApplicationLoader.applicationContext.getResources().getIdentifier("msg_add", "drawable", ApplicationLoader.applicationContext.getPackageName())
                    if icon_id: icon.setImageResource(int(icon_id))
                except Exception: pass

                                                    
            icon.setScaleType(jclass("android.widget.ImageView$ScaleType").CENTER_INSIDE)
            
                                       
            try:
                icon_color = int(Theme.getColor(Theme.key_chat_messagePanelIcons))
                icon.setColorFilter(icon_color, PorterDuff.Mode.SRC_IN)
            except Exception: pass
            
                           
            btn.addView(icon, FrameLayout.LayoutParams(AndroidUtilities.dp(24), AndroidUtilities.dp(24), Gravity.CENTER))
            
                             
            plugin = self
            class _Click(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                def onClick(self_obj, v):
                    plugin._show_about_sheet()

            class _LongClick(dynamic_proxy(find_class("android.view.View$OnLongClickListener"))):
                def onLongClick(self_obj, v):
                    plugin._show_search_prompt()
                    return True

            btn.setOnClickListener(_Click())
            btn.setOnLongClickListener(_LongClick())

                                                    
            if isinstance(host, LinearLayout):
                lp = LinearLayout.LayoutParams(AndroidUtilities.dp(28), AndroidUtilities.dp(28))
                lp.gravity = Gravity.CENTER_VERTICAL
                lp.leftMargin = AndroidUtilities.dp(2)
                lp.rightMargin = AndroidUtilities.dp(2)
                host.addView(btn, lp)
            else:
                host.addView(btn)
                
            self._trace("Pomme compose button attached to {0}".format(host.getClass().getSimpleName()), "INFO")
        except Exception as e:
            self._trace("attach compose button fail: {0}".format(e), "ERROR")

    def _refresh_chat_compose_button_visibility(self):
        try:
            seen = set()
            for frag in (get_last_fragment(), getattr(self, "_fragment_ref", None)):
                if frag is None:
                    continue
                key = id(frag)
                if key in seen:
                    continue
                seen.add(key)
                try:
                    self._ensure_chat_compose_button(frag, from_retry=True)
                except Exception:
                    pass
            return True
        except Exception:
            return False

    def _schedule_chat_compose_button_retry(self, fragment):
        try:
            if fragment is None: return
            key = str(id(fragment))
            if key in self._attach_retry_keys: return
            self._attach_retry_keys.add(key)
            
            def _worker():
                try:
                    for _ in range(5):
                        time.sleep(0.5)
                        done = {"ok": False}
                        def _try():
                            try:
                                self._ensure_chat_compose_button(fragment, from_retry=True)
                                                            
                                enter_view = get_private_field(fragment, "chatActivityEnterView")
                                if enter_view:
                                    for fname in ("attachLayout", "sendButtonContainer"):
                                        host = get_private_field(enter_view, fname)
                                        if host and host.findViewWithTag("__pomme_compose_btn__"):
                                            done["ok"] = True
                                            break
                            except Exception: pass
                        run_on_ui_thread(_try)
                        if done["ok"]: break
                finally:
                    try: self._attach_retry_keys.discard(key)
                    except Exception: pass
            
            threading.Thread(target=_worker, daemon=True).start()
        except Exception: pass

    def _show_track_playlist_sheet(self):
        run_on_ui_thread(self._show_track_playlist_sheet_ui)

    def _show_track_playlist_sheet_ui(self):
        try:
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return False
            try:
                if self._track_playlist_sheet is not None:
                    self._track_playlist_sheet.dismiss()
            except Exception:
                pass
            self._track_playlist_sheet = None
            sheet = BottomSheet(ctx, False)
            wrap = LinearLayout(ctx)
            wrap.setOrientation(LinearLayout.VERTICAL)
            wrap.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(10), AndroidUtilities.dp(16), AndroidUtilities.dp(14))
            title = TextView(ctx)
            title.setText(self._tr("track_playlist_title"))
            title.setTextSize(22)
            title.setTypeface(None, 1)
            try:
                title.setTextColor(self._jcolor(Theme.getColor(Theme.key_dialogTextBlack)))
            except Exception:
                pass
            wrap.addView(title)
            desc = TextView(ctx)
            desc.setText(self._tr("track_playlist_desc"))
            desc.setTextSize(13)
            try:
                desc.setTextColor(self._jcolor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            except Exception:
                pass
            lp_desc = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_desc.topMargin = AndroidUtilities.dp(6)
            wrap.addView(desc, lp_desc)

            add_btn = TextView(ctx)
            add_btn.setText(self._tr("track_playlist_add_new"))
            add_btn.setTextSize(15)
            add_btn.setTypeface(None, 1)
            add_btn.setGravity(Gravity.CENTER)
            try:
                add_btn.setTextColor(self._jcolor(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                bg.setColor(self._jcolor(Theme.getColor(Theme.key_featuredStickers_addButton)))
                add_btn.setBackground(bg)
            except Exception:
                pass
            add_btn.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(10), AndroidUtilities.dp(14), AndroidUtilities.dp(10))
            listener_cls = find_class("android.view.View$OnClickListener")
            if listener_cls is not None:
                plugin = self
                class _OpenAdd(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        plugin._open_track_playlist_editor()
                add_btn.setOnClickListener(_OpenAdd())
            lp_add = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_add.topMargin = AndroidUtilities.dp(12)
            lp_add.gravity = Gravity.END
            wrap.addView(add_btn, lp_add)

                                                       
            liked_name = self._liked_playlist_name()
            
            def _playlist_row(name, is_user_playlist=True):
                card = LinearLayout(ctx)
                card.setOrientation(LinearLayout.HORIZONTAL)
                card.setGravity(Gravity.CENTER_VERTICAL)
                card.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
                try:
                    bg = GradientDrawable()
                    bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                    bg.setColor(self._jcolor(Theme.getColor(Theme.key_dialogBackgroundGray)))
                    card.setBackground(bg)
                except Exception: pass
                
                texts = LinearLayout(ctx)
                texts.setOrientation(LinearLayout.VERTICAL)
                lp_texts = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                
                t1 = TextView(ctx)
                t1.setText(name)
                t1.setTextSize(16)
                t1.setTypeface(None, 1)
                try: t1.setTextColor(self._jcolor(Theme.getColor(Theme.key_dialogTextBlack)))
                except Exception: pass
                texts.addView(t1)
                
                t2 = TextView(ctx)
                already = self._track_in_named_playlist(name, self._current_track_item())
                count_text = self._tr("track_count_fmt").format(self._track_count_for_named_playlist(name))
                if already:
                    t2.setText("{0} | {1}".format(count_text, self._tr("track_already_in_playlist")))
                else:
                    t2.setText(count_text)
                t2.setTextSize(12)
                try: t2.setTextColor(self._jcolor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
                except Exception: pass
                texts.addView(t2)
                card.addView(texts, lp_texts)
                
                if listener_cls is not None:
                    class _PlaylistClick(dynamic_proxy(listener_cls)):
                        def __init__(self_obj, playlist_name):
                            super().__init__()
                            self_obj.playlist_name = playlist_name
                        def onClick(self_obj, _v):
                            plugin._add_track_to_named_playlist(self_obj.playlist_name, plugin._current_track_item())
                            sheet.dismiss()
                    card.setOnClickListener(_PlaylistClick(name))
                
                lp_card = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp_card.topMargin = AndroidUtilities.dp(8)
                wrap.addView(card, lp_card)

                                   
            _playlist_row(liked_name)

            for entry in self._user_saved_playlists():
                name = str(entry.get("name") or "").strip()
                if self._is_liked_playlist_entry(entry): continue
                _playlist_row(name)

            sheet.setCustomView(wrap)
            sheet.show()
            self._track_playlist_sheet = sheet
            return True
        except Exception as e:
            self._trace("show track playlist fail: {0}".format(e), "ERROR")
            return False

    def _add_track_to_named_playlist(self, playlist_name, item):
        try:
            target_name = str(playlist_name or "").strip()
            if not target_name or not item:
                return False
            
                                                                      
            playlists = self._user_saved_playlists()
            found = False
            item_id = str((item or {}).get("id") or "").strip()
            
            for entry in playlists:
                if str(entry.get("name") or "").strip() != target_name:
                    continue
                found = True
                tracks = list(entry.get("tracks") or [])
                if any(str((track or {}).get("id") or "").strip() == item_id for track in tracks):
                    self._notify_info(self._tr("track_already_in_playlist"))
                    return False
                
                               
                try:
                    file_path = self._resolve_stable_audio_file_for_send(item)
                    if file_path and os.path.exists(file_path):
                        item["cached_file"] = file_path
                        self._remember_playlist_track_cache(
                            {
                                "playlist": True,
                                "playlist_name": target_name,
                                "playlist_url": self._user_playlist_cache_url(target_name),
                                "results": [],
                                "item": dict(item),
                            },
                            item,
                            file_path,
                            dict(item.get("cached_stream") or {}),
                        )
                except Exception: pass
                
                tracks.append(dict(item))
                entry["tracks"] = tracks
                break
            
            if found:
                self._set_user_saved_playlists(playlists)
                try:
                    for entry in playlists:
                        if str(entry.get("name") or "").strip() == target_name:
                            tracks_for_cache = [dict(x or {}) for x in list(entry.get("tracks") or []) if isinstance(x, dict)]
                            self._remember_playlist_listing(self._user_playlist_cache_url(target_name), tracks_for_cache, target_name)
                            self._prefetch_playlist_cache({
                                "playlist": True,
                                "playlist_name": target_name,
                                "playlist_url": self._user_playlist_cache_url(target_name),
                                "results": tracks_for_cache,
                            })
                            break
                except Exception as e:
                    self._trace("named playlist dynamic cache refresh fail: {0}".format(e), "WARN")
                self._notify_success(self._tr("liked_track_added"))
                return True
            return False
        except Exception as e:
            self._trace("add track to named playlist fail: {0}".format(e), "ERROR")
            return False

    def _current_track_item(self):
        try:
            item = dict((self._active_play_ctx or {}).get("item") or {})
            if item:
                return item
            item = dict(getattr(self, "_last_started_item", {}) or {})
            if item:
                return item
            title, artist = self._current_track_meta()
            path = self._current_playing_audio_path()
            if not title and not path:
                return {}
            fallback = {
                "id": hashlib.sha1("{0}|{1}|{2}".format(title or "", artist or "", path or "").encode("utf-8", "ignore")).hexdigest()[:16],
                "title": str(title or "Track"),
                "author": str(artist or "Unknown"),
                "url": "",
            }
            if path:
                fallback["cached_file"] = path
            return fallback
        except Exception:
            return {}

    def _saved_messages_peer_id(self):
        try:
            UserConfig = jclass("org.telegram.messenger.UserConfig")
            frag = get_last_fragment() or self._fragment_ref
            account = int(frag.getCurrentAccount()) if frag is not None else int(getattr(UserConfig, "selectedAccount", 0) or 0)
            return int(UserConfig.getInstance(account).getClientUserId())
        except Exception:
            return 0

    def _export_current_audio_for_send(self, item=None):
        try:
            item = dict(item or self._current_track_item() or {})
            src_path = str(item.get("cached_file") or "").strip()
            if not src_path or not os.path.exists(src_path):
                src_path = self._current_playing_audio_path()
            if not src_path or not os.path.exists(src_path):
                return None
            export_dir = os.path.join(self._get_temp_dir(), "exports")
            if not os.path.isdir(export_dir):
                os.makedirs(export_dir)
            ext = os.path.splitext(src_path)[1] or ".m4a"
            base = re.sub(r'[^A-Za-z0-9._ -]+', '', str(item.get("title") or "Track")).strip() or "Track"
            out_path = os.path.join(export_dir, "{0}-{1}{2}".format(base[:64], uuid.uuid4().hex[:10], ext))
            shutil.copyfile(src_path, out_path)
            return out_path
        except Exception as e:
            self._trace("export current audio fail: {0}".format(e), "ERROR")
            return None

    def _resolve_stable_audio_file_for_send(self, item):
        try:
            track = dict(item or {})
            cached_file = str(track.get("cached_file") or "").strip()
            if cached_file and os.path.exists(cached_file) and os.path.getsize(cached_file) > 0:
                return cached_file
            current_path = self._current_playing_audio_path()
            if current_path and os.path.exists(current_path) and os.path.getsize(current_path) > 0:
                track["cached_file"] = current_path
                return current_path
            stream_info = dict(track.get("cached_stream") or {})
            if not stream_info or not str(stream_info.get("url") or "").strip():
                stream_info = self._resolve_audio_stream(track)
            file_path = self._download_audio_file(track, stream_info)
            if not file_path or not os.path.exists(file_path):
                return None
            track["cached_file"] = file_path
            track["cached_stream"] = dict(stream_info or {})
            return file_path
        except Exception as e:
            self._trace("resolve stable audio for send fail: {0}".format(e), "ERROR")
            return None

    def _save_current_track_to_saved_messages(self):
        self._trace("save to Saved Messages disabled for Pomme", "INFO")
        return False

    def _save_current_track_to_liked_playlist(self):
        try:
            self._touch_activity()
            item = dict(self._current_track_item() or {})
            item_id = str(item.get("id") or "").strip()
            if not item_id:
                return False
            liked_name = self._liked_playlist_name()
            playlists = self._ensure_liked_playlist()
            target = None
            for entry in playlists:
                if self._is_liked_playlist_entry(entry):
                    target = entry
                    break
            if target is None:
                target = {"name": liked_name, "tracks": [], "system": "liked"}
                playlists.insert(0, target)
            tracks = list(target.get("tracks") or [])
            if any(str((track or {}).get("id") or "").strip() == item_id for track in tracks):
                self._notify_info(self._tr("liked_track_exists"))
                return False

            try:
                self._prefetch_cover(item)
                file_path = self._resolve_stable_audio_file_for_send(item)
                if file_path and os.path.exists(file_path):
                    item["cached_file"] = file_path
                    stream_info = dict(item.get("cached_stream") or {})
                    if not stream_info:
                        stream_info = {
                            "video_id": self._extract_video_id(item),
                            "mime": mimetypes.guess_type(file_path)[0] or "audio/mp4",
                            "duration": self._parse_duration_seconds(item.get("length"), 0),
                            "bitrate": 0,
                            "size": int(os.path.getsize(file_path) if os.path.exists(file_path) else 0),
                        }
                        item["cached_stream"] = dict(stream_info)
                    self._remember_playlist_track_cache(
                        {
                            "playlist": True,
                            "playlist_name": liked_name,
                            "playlist_url": self._user_playlist_cache_url(liked_name),
                            "results": [],
                            "item": dict(item),
                        },
                        item,
                        file_path,
                        dict(stream_info or {}),
                    )
            except Exception as cache_error:
                self._trace("liked playlist cache warm fail: {0}".format(cache_error), "WARN")

            tracks.append(dict(item))
            target["tracks"] = tracks
            target["name"] = liked_name
            target["system"] = "liked"
            playlists = [entry for entry in playlists if not self._is_liked_playlist_entry(entry)]
            playlists.insert(0, target)
            self._set_user_saved_playlists(playlists)
                                                                                    
            try:
                self._remember_playlist_listing(self._user_playlist_cache_url(liked_name), tracks, liked_name)
            except Exception:
                pass
                                                                                             
            try:
                self._sync_user_playlists_to_cache()
                self._prefetch_playlist_cache({
                    "playlist": True,
                    "playlist_name": liked_name,
                    "playlist_url": self._user_playlist_cache_url(liked_name),
                    "results": [dict(x or {}) for x in tracks if isinstance(x, dict)],
                })
            except Exception as e:
                self._trace("liked dynamic cache refresh fail: {0}".format(e), "WARN")
            self._notify_success(self._tr("liked_track_added"))
            try:
                if self._playlist_sheet is not None:
                    self._playlist_sheet.dismiss()
                    self._playlist_sheet = None
                    self._playlist_page = 0
                    self._show_playlist_sheet()
            except Exception:
                pass
            try:
                if self._track_playlist_sheet is not None:
                    self._track_playlist_sheet.dismiss()
            except Exception:
                pass
            return True
        except Exception as e:
            self._trace("save current track to liked playlist fail: {0}".format(e), "ERROR")
            return False

    def _remove_global_track_cache_entry(self, item_id):
        try:
            target_id = str(item_id or "").strip()
            if not target_id:
                return False
            data = self._track_index_read()
            if target_id not in data:
                return False
            data.pop(target_id, None)
            return self._track_index_write(data)
        except Exception:
            return False

    def _purge_cached_track_file_if_unreferenced(self, item_id, file_path, protected_playlist_name=""):
        try:
            target_id = str(item_id or "").strip()
            path = str(file_path or "").strip()
            protected = str(protected_playlist_name or "").strip()
            if not target_id or not path:
                return False
            for entry in self._user_saved_playlists():
                if not isinstance(entry, dict):
                    continue
                if protected and str(entry.get("name") or "").strip() == protected:
                    continue
                for track in list(entry.get("tracks") or []):
                    if str((track or {}).get("id") or "").strip() != target_id:
                        continue
                    ref_path = str((track or {}).get("cached_file") or (track or {}).get("file_path") or "").strip()
                    if ref_path and ref_path == path:
                        return False
            if os.path.exists(path):
                try:
                    os.remove(path)
                except Exception:
                    pass
            self._remove_global_track_cache_entry(target_id)
            return True
        except Exception:
            return False

    def _remove_track_from_named_playlist(self, playlist_name, item, remove_cache_file=False):
        try:
            owner_name = str(playlist_name or "").strip()
            payload = dict(item or {})
            target_id = str(payload.get("id") or "").strip()
            if not owner_name or not target_id:
                return False
            items = self._user_saved_playlists()
            changed = False
            removed_path = ""
            for block in items:
                if str(block.get("name") or "").strip() != owner_name:
                    continue
                before_tracks = [dict(x or {}) for x in list(block.get("tracks") or []) if isinstance(x, dict)]
                kept = []
                for track in before_tracks:
                    if str((track or {}).get("id") or "").strip() == target_id:
                        removed_path = str((track or {}).get("cached_file") or (track or {}).get("file_path") or "").strip()
                        changed = True
                        continue
                    kept.append(track)
                block["tracks"] = kept
                break
            if not changed:
                return False
            self._set_user_saved_playlists(items)
            try:
                tracks_for_cache = []
                for entry in items:
                    if str(entry.get("name") or "").strip() == owner_name:
                        tracks_for_cache = [dict(x or {}) for x in list(entry.get("tracks") or []) if isinstance(x, dict)]
                        break
                self._remember_playlist_listing(self._user_playlist_cache_url(owner_name), tracks_for_cache, owner_name)
            except Exception:
                pass
            if remove_cache_file and removed_path:
                self._purge_cached_track_file_if_unreferenced(target_id, removed_path, owner_name)
            return True
        except Exception as e:
            self._trace("remove track from named playlist fail: {0}".format(e), "ERROR")
            return False

    def _save_track_to_auto_cache(self, item, file_path="", stream_info=None):
        try:
            if not self._auto_cache_enabled():
                return False
            track = dict(item or {})
            item_id = str(track.get("id") or self._extract_video_id(track) or "").strip()
            if not item_id:
                return False
            playlist_name = self._auto_cache_playlist_name()
            playlists = self._ensure_auto_cache_playlist()
            target = None
            for entry in playlists:
                if self._is_auto_cache_playlist_entry(entry):
                    target = entry
                    break
            if target is None:
                target = {"name": playlist_name, "tracks": [], "system": "auto_cache"}
                playlists.insert(1 if playlists and self._is_liked_playlist_entry(playlists[0]) else 0, target)
            tracks = list(target.get("tracks") or [])
            if any(str((track_item or {}).get("id") or "").strip() == item_id for track_item in tracks):
                return False
            path = str(file_path or track.get("cached_file") or "").strip()
            if path and os.path.exists(path):
                track["cached_file"] = path
                if not isinstance(stream_info, dict):
                    stream_info = dict(track.get("cached_stream") or {})
                if not stream_info:
                    stream_info = {
                        "video_id": self._extract_video_id(track),
                        "mime": mimetypes.guess_type(path)[0] or "audio/mp4",
                        "duration": self._parse_duration_seconds(track.get("length"), 0),
                        "bitrate": 0,
                        "size": int(os.path.getsize(path) if os.path.exists(path) else 0),
                    }
                track["cached_stream"] = dict(stream_info or {})
                self._remember_playlist_track_cache(
                    {
                        "playlist": True,
                        "playlist_name": playlist_name,
                        "playlist_url": self._user_playlist_cache_url(playlist_name),
                        "results": [],
                        "item": dict(track),
                    },
                    track,
                    path,
                    dict(stream_info or {}),
                )
                self._remember_global_track_cache(track, path, dict(stream_info or {}))
            tracks.append(dict(track))
            target["name"] = playlist_name
            target["system"] = "auto_cache"
            target["tracks"] = tracks
            clean_items = [entry for entry in playlists if not self._is_auto_cache_playlist_entry(entry)]
            insert_at = 1 if clean_items and self._is_liked_playlist_entry(clean_items[0]) else 0
            clean_items.insert(insert_at, target)
            self._set_user_saved_playlists(clean_items)
            try:
                self._remember_playlist_listing(self._user_playlist_cache_url(playlist_name), tracks, playlist_name)
            except Exception:
                pass
            return True
        except Exception as e:
            self._trace("save track to auto cache fail: {0}".format(e), "ERROR")
            return False

    def _track_in_named_playlist(self, playlist_name, item):
        try:
            target_name = str(playlist_name or "").strip()
            item_id = str((item or {}).get("id") or "").strip()
            if not target_name or not item_id:
                return False
            for entry in self._user_saved_playlists():
                if str(entry.get("name") or "").strip() != target_name:
                    continue
                for track in list(entry.get("tracks") or []):
                    if str((track or {}).get("id") or "").strip() == item_id:
                        return True
            return False
        except Exception:
            return False

    def _save_current_track_to_named_playlist(self, playlist_name):
        try:
            item = dict(self._current_track_item() or {})
            item_id = str(item.get("id") or "").strip()
            target_name = str(playlist_name or "").strip()
            if not item_id or not target_name:
                return False
            try:
                self._prefetch_cover(item)
                file_path = self._resolve_stable_audio_file_for_send(item)
                if file_path and os.path.exists(file_path):
                    item["cached_file"] = file_path
                    stream_info = dict(item.get("cached_stream") or {})
                    if not stream_info:
                        stream_info = {
                            "video_id": self._extract_video_id(item),
                            "mime": mimetypes.guess_type(file_path)[0] or "audio/mp4",
                            "duration": self._parse_duration_seconds(item.get("length"), 0),
                            "bitrate": 0,
                            "size": int(os.path.getsize(file_path) if os.path.exists(file_path) else 0),
                        }
                        item["cached_stream"] = dict(stream_info)
                    self._remember_playlist_track_cache(
                        {
                            "playlist": True,
                            "playlist_name": target_name,
                            "playlist_url": self._user_playlist_cache_url(target_name),
                            "results": [],
                            "item": dict(item),
                        },
                        item,
                        file_path,
                        dict(stream_info or {}),
                    )
            except Exception as cache_error:
                self._trace("named playlist cache warm fail: {0}".format(cache_error), "WARN")
            playlists = self._user_saved_playlists()
            changed = False
            found = False
            for entry in playlists:
                if str(entry.get("name") or "").strip() != target_name:
                    continue
                found = True
                tracks = list(entry.get("tracks") or [])
                if any(str((track or {}).get("id") or "").strip() == item_id for track in tracks):
                    self._notify_info(self._tr("track_already_in_playlist"))
                    return False
                try:
                    self._prefetch_cover(item)
                except Exception:
                    pass
                tracks.append(dict(item))
                entry["tracks"] = tracks
                changed = True
                break
            if not found:
                try:
                    self._prefetch_cover(item)
                except Exception:
                    pass
                playlists.append({"name": target_name, "tracks": [dict(item)]})
                changed = True
            if changed:
                self._set_user_saved_playlists(playlists)
                try:
                    tracks_for_cache = []
                    for entry in playlists:
                        if str(entry.get("name") or "").strip() == target_name:
                            tracks_for_cache = [dict(x or {}) for x in list(entry.get("tracks") or []) if isinstance(x, dict)]
                            break
                    self._remember_playlist_listing(self._user_playlist_cache_url(target_name), tracks_for_cache, target_name)
                except Exception:
                    pass
                self._notify_success(self._tr("track_added_to_playlist"))
            return changed
        except Exception as e:
            self._trace("save current track to playlist fail: {0}".format(e), "ERROR")
            return False

    def _track_count_for_named_playlist(self, playlist_name):
        try:
            target_name = str(playlist_name or "").strip()
            if not target_name:
                return 0
            for entry in self._user_saved_playlists():
                if str(entry.get("name") or "").strip() == target_name:
                    return int(len(list(entry.get("tracks") or [])))
            return 0
        except Exception:
            return 0

    def _rename_user_saved_playlist(self, old_name, new_name):
        try:
            old_name = str(old_name or "").strip()
            new_name = str(new_name or "").strip()
            if not old_name or not new_name:
                return False
            items = self._user_saved_playlists()
            if any(str(entry.get("name") or "").strip() == new_name for entry in items if str(entry.get("name") or "").strip() != old_name):
                return False
            changed = False
            for entry in items:
                if str(entry.get("name") or "").strip() == old_name:
                    entry["name"] = new_name
                    changed = True
                    break
            if changed:
                self._set_user_saved_playlists(items)
                try:
                    self._migrate_smart_cache_playlist_rename(old_name, new_name)
                except Exception:
                    pass
            return changed
        except Exception as e:
            self._trace("rename user playlist fail: {0}".format(e), "ERROR")
            return False

    def _remove_user_saved_playlist(self, playlist_name):
        try:
            target_name = str(playlist_name or "").strip()
            if not target_name or self._is_fixed_playlist_entry(target_name):
                return False
            items = self._user_saved_playlists()
            new_items = [entry for entry in items if str(entry.get("name") or "").strip() != target_name]
            if len(new_items) == len(items):
                return False
            self._set_user_saved_playlists(new_items)
            try:
                self._clear_playlist_cache(self._playlist_cache_key(self._user_playlist_cache_url(target_name)))
            except Exception:
                pass
            return True
        except Exception as e:
            self._trace("remove user playlist fail: {0}".format(e), "ERROR")
            return False

    def _open_user_playlist_rename_editor(self, playlist_name):
        try:
            if self._is_fixed_playlist_entry(playlist_name):
                return False
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return False
            EditText = jclass("android.widget.EditText")
            inp = EditText(ctx)
            inp.setSingleLine(True)
            inp.setHint(self._tr("track_playlist_name_hint"))
            inp.setText(str(playlist_name or ""))
            try:
                inp.setTextColor(self._jcolor(Theme.getColor(Theme.key_dialogTextBlack)))
                inp.setHintTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                bg.setColor(int(Theme.getColor(Theme.key_dialogBackgroundGray)))
                inp.setBackground(bg)
                pad = AndroidUtilities.dp(14)
                inp.setPadding(pad, pad, pad, pad)
            except Exception:
                pass
            holder = LinearLayout(ctx)
            holder.setOrientation(LinearLayout.VERTICAL)
            holder.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(6))
            lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            holder.addView(inp, lp)
            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("track_playlist_title"))
            b.set_view(holder)
            b.set_negative_button("Cancel", lambda dialog, _w: dialog.dismiss())
            
                                                                                                   
            self._loading_dialog = b
            
            def _save(dialog, _w):
                try:
                    new_name = str(inp.getText().toString() or "").strip()
                    if not new_name:
                        return
                    if self._rename_user_saved_playlist(playlist_name, new_name):
                        dialog.dismiss()
                        try:
                            if self._track_playlist_detail_sheet is not None:
                                self._track_playlist_detail_sheet.dismiss()
                        except Exception:
                            pass
                        self._show_user_playlist_tracks_sheet(new_name)
                except Exception as e:
                    self._trace("rename playlist editor save fail: {0}".format(e), "ERROR")

            b.set_positive_button("Save", _save)
            b.show()
            return True
        except Exception as e:
            self._trace("open user playlist rename editor fail: {0}".format(e), "ERROR")
            return False

    def _open_source_playlist_rename_editor(self, playlist_name, playlist_url):
        try:
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return False
            EditText = jclass("android.widget.EditText")
            inp = EditText(ctx)
            inp.setSingleLine(True)
            inp.setHint(self._tr("playlist_name_hint"))
            inp.setText(str(playlist_name or ""))
            try:
                inp.setTextColor(self._jcolor(Theme.getColor(Theme.key_dialogTextBlack)))
                inp.setHintTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                bg.setColor(int(Theme.getColor(Theme.key_dialogBackgroundGray)))
                inp.setBackground(bg)
                pad = AndroidUtilities.dp(14)
                inp.setPadding(pad, pad, pad, pad)
            except Exception:
                pass
            holder = LinearLayout(ctx)
            holder.setOrientation(LinearLayout.VERTICAL)
            holder.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(6))
            holder.addView(inp, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("playlist_panel_title"))
            b.set_view(holder)
            b.set_negative_button("Cancel", lambda dialog, _w: dialog.dismiss())

            def _save(dialog, _w):
                try:
                    new_name = str(inp.getText().toString() or "").strip()
                    if not new_name:
                        return
                    if self._rename_source_playlist(playlist_url, new_name):
                        dialog.dismiss()
                        try:
                            if self._track_playlist_detail_sheet is not None:
                                self._track_playlist_detail_sheet.dismiss()
                        except Exception:
                            pass
                        self._notify_success(self._tr("playlist_save_done"))
                        self._show_source_playlist_tracks_sheet(new_name, playlist_url)
                except Exception as e:
                    self._trace("rename source playlist editor save fail: {0}".format(e), "ERROR")

            b.set_positive_button("Save", _save)
            b.show()
            return True
        except Exception as e:
            self._trace("open source playlist rename editor fail: {0}".format(e), "ERROR")
            return False

    def _show_source_playlist_tracks_sheet(self, playlist_name, playlist_url):
        try:
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return False
            try:
                if self._track_playlist_detail_sheet is not None:
                    self._track_playlist_detail_sheet.dismiss()
            except Exception:
                pass
            self._track_playlist_detail_sheet = None
            listener_cls = find_class("android.view.View$OnClickListener")
            long_listener_cls = find_class("android.view.View$OnLongClickListener")
            sheet = BottomSheet(ctx, True)
            wrap = LinearLayout(ctx)
            wrap.setOrientation(LinearLayout.VERTICAL)
            wrap.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(16))
            head = LinearLayout(ctx)
            head.setOrientation(LinearLayout.HORIZONTAL)
            head.setGravity(Gravity.CENTER_VERTICAL)
            title = TextView(ctx)
            title.setText(str(playlist_name or "Playlist"))
            title.setTextSize(20)
            title.setTypeface(None, 1)
            try:
                title.setTextColor(int(Theme.getColor(Theme.key_dialogTextBlack)))
            except Exception:
                pass
            head.addView(title, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))
            plugin = self
            shuffle_btn = TextView(ctx)
            shuffle_btn.setText("Shuffle")
            shuffle_btn.setGravity(Gravity.CENTER)
            shuffle_btn.setTextSize(14)
            shuffle_btn.setTypeface(None, 1)
            try:
                shuffle_btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                s_bg = GradientDrawable()
                s_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                s_bg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                shuffle_btn.setBackground(s_bg)
                shuffle_btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8), AndroidUtilities.dp(12), AndroidUtilities.dp(8))
            except Exception:
                pass
            if listener_cls is not None:
                class _ShuffleAll(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        plugin._play_saved_playlist(playlist_url, shuffle=True)
                shuffle_btn.setOnClickListener(_ShuffleAll())
            head.addView(shuffle_btn)
            spacer = View(ctx)
            head.addView(spacer, LinearLayout.LayoutParams(AndroidUtilities.dp(8), 1))
            edit_btn = TextView(ctx)
            edit_btn.setText("Edit")
            edit_btn.setGravity(Gravity.CENTER)
            edit_btn.setTextSize(14)
            edit_btn.setTypeface(None, 1)
            try:
                edit_btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                btn_bg = GradientDrawable()
                btn_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                btn_bg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                edit_btn.setBackground(btn_bg)
                edit_btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8), AndroidUtilities.dp(12), AndroidUtilities.dp(8))
            except Exception:
                pass
            if listener_cls is not None:
                class _EditName(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        plugin._open_source_playlist_rename_editor(playlist_name, playlist_url)
                edit_btn.setOnClickListener(_EditName())
            head.addView(edit_btn)
            wrap.addView(head)

            tracks_list = list(self._source_playlist_tracks(playlist_url) or [])
            if not tracks_list:
                tracks_list = list(self._resolve_playlist_entries(playlist_url) or [])
                if tracks_list:
                    self._remember_playlist_listing(playlist_url, tracks_list, playlist_name)
            PAGE_SIZE = 5
            tracks_area = LinearLayout(ctx)
            tracks_area.setOrientation(LinearLayout.VERTICAL)
            scroll_tracks = AndroidScrollView(ctx)
            scroll_tracks.addView(tracks_area, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            wrap.addView(scroll_tracks, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            page_idx = [0]
            nav_row = LinearLayout(ctx)
            nav_row.setOrientation(LinearLayout.HORIZONTAL)
            nav_row.setGravity(Gravity.CENTER_VERTICAL)
            nav_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            nav_lp.topMargin = AndroidUtilities.dp(12)
            page_lbl = TextView(ctx)
            page_lbl.setTextSize(13)
            try:
                page_lbl.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            except Exception:
                pass
            nav_row.addView(page_lbl, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))
            prev_btn = TextView(ctx)
            prev_btn.setText("Back")
            prev_btn.setGravity(Gravity.CENTER)
            prev_btn.setTextSize(14)
            prev_btn.setTypeface(None, 1)
            next_btn = TextView(ctx)
            next_btn.setText("Next")
            next_btn.setGravity(Gravity.CENTER)
            next_btn.setTextSize(14)
            next_btn.setTypeface(None, 1)
            try:
                nav_txt = int(Theme.getColor(Theme.key_featuredStickers_buttonText))
                nav_bg = GradientDrawable()
                nav_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                nav_bg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                pad_nav = AndroidUtilities.dp(12)
                for nb in (prev_btn, next_btn):
                    nb.setTextColor(nav_txt)
                    nb.setBackground(nav_bg)
                    nb.setPadding(pad_nav, AndroidUtilities.dp(8), pad_nav, AndroidUtilities.dp(8))
            except Exception:
                pass

            def _repaginate():
                try:
                    tracks_area.removeAllViews()
                except Exception:
                    return
                ntot = len(tracks_list)
                start = int(page_idx[0]) * PAGE_SIZE
                chunk = tracks_list[start:start + PAGE_SIZE]
                for i_local, item in enumerate(chunk):
                    gidx = start + i_local
                    row = LinearLayout(ctx)
                    row.setOrientation(LinearLayout.VERTICAL)
                    row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
                    try:
                        bg = GradientDrawable()
                        bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                        bg.setColor(int(Theme.getColor(Theme.key_dialogBackgroundGray)))
                        row.setBackground(bg)
                    except Exception:
                        pass
                    t1 = TextView(ctx)
                    t1.setText(str(item.get("title") or "Track"))
                    t1.setTextSize(15)
                    t1.setTypeface(None, 1)
                    try:
                        t1.setTextColor(int(Theme.getColor(Theme.key_dialogTextBlack)))
                    except Exception:
                        pass
                    row.addView(t1)
                    t2 = TextView(ctx)
                    t2.setText(str(item.get("author") or ""))
                    t2.setTextSize(12)
                    try:
                        t2.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
                    except Exception:
                        pass
                    row.addView(t2)
                    if listener_cls is not None:
                        class _PlayTrack(dynamic_proxy(listener_cls)):
                            def onClick(self_obj, _v, sid=gidx):
                                plugin._play_saved_playlist(playlist_url, shuffle=False, start_index=int(sid))
                        row.setOnClickListener(_PlayTrack())
                    if long_listener_cls is not None:
                        class _RemoveTrack(dynamic_proxy(long_listener_cls)):
                            def onLongClick(self_obj, _v, payload=item):
                                try:
                                    changed = plugin._remove_track_from_source_playlist(playlist_url, payload)
                                    if changed:
                                        plugin._notify_success(plugin._tr("playlist_remove_done"))
                                        try:
                                            sheet.dismiss()
                                        except Exception:
                                            pass
                                        plugin._show_source_playlist_tracks_sheet(plugin._playlist_saved_name(playlist_url, playlist_name), playlist_url)
                                    return True
                                except Exception as inner:
                                    plugin._trace("remove source playlist track fail: {0}".format(inner), "ERROR")
                                    return True
                        row.setOnLongClickListener(_RemoveTrack())
                    lp_row = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    lp_row.topMargin = AndroidUtilities.dp(10)
                    tracks_area.addView(row, lp_row)
                if ntot == 0:
                    page_lbl.setText("0 / 0")
                else:
                    end = start + len(chunk)
                    page_lbl.setText("{0}–{1} / {2}".format(start + 1, end, ntot))
                prev_btn.setEnabled(bool(ntot > 0 and page_idx[0] > 0))
                next_btn.setEnabled(bool(ntot > 0 and start + PAGE_SIZE < ntot))

            nav_row.addView(View(ctx), LinearLayout.LayoutParams(AndroidUtilities.dp(8), 1))
            nav_row.addView(prev_btn)
            nav_row.addView(View(ctx), LinearLayout.LayoutParams(AndroidUtilities.dp(8), 1))
            nav_row.addView(next_btn)
            wrap.addView(nav_row, nav_lp)
            if listener_cls is not None:
                class _PagePrev(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        page_idx[0] = max(0, int(page_idx[0]) - 1)
                        _repaginate()
                class _PageNext(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        page_idx[0] = int(page_idx[0]) + 1
                        _repaginate()
                prev_btn.setOnClickListener(_PagePrev())
                next_btn.setOnClickListener(_PageNext())
            _repaginate()
            sheet.setCustomView(wrap)
            sheet.show()
            self._track_playlist_detail_sheet = sheet
            return True
        except Exception as e:
            self._trace("show source playlist tracks sheet fail: {0}".format(e), "ERROR")
            return False

    def _dismiss_all_pomme_ui(self, keep_loading=False):
        try:
            for attr_name in ("_playlist_sheet", "_smart_cache_sheet", "_panel_sheet", "_results_sheet", "_track_playlist_sheet", "_track_playlist_detail_sheet", "_notifications_sheet", "_menu_shortcuts_sheet", "_search_prompt_sheet", "_data_sheet", "_settings_sheet", "_pocket_mode_sheet"):
                try:
                    if keep_loading and attr_name == "_pocket_mode_sheet":
                        continue
                    sheet_obj = getattr(self, attr_name, None)
                    if sheet_obj is not None:
                        sheet_obj.dismiss()
                except Exception:
                    pass
                try:
                    setattr(self, attr_name, None)
                except Exception:
                    pass
            
            if not bool(keep_loading):
                                                       
                try:
                    if hasattr(self, "_loading_dialog") and self._loading_dialog:
                        self._loading_dialog.dismiss()
                        self._loading_dialog = None
                except Exception:
                    pass
        except Exception as e:
            self._trace("dismiss all pomme ui fail: {0}".format(e), "WARN")

    def _play_user_saved_playlist(self, playlist_name, shuffle=False, start_index=0):
        try:
            target_name = str(playlist_name or "").strip()
            if not target_name:
                return False
            tracks = []
            for entry in self._user_saved_playlists():
                if str(entry.get("name") or "").strip() == target_name:
                    tracks = [dict(x or {}) for x in list(entry.get("tracks") or []) if isinstance(x, dict)]
                    break
            if not tracks:
                self._notify_info(self._tr("empty"))
                return False
            prepared = []
            seen = set()
            for track in tracks:
                item_id = str(track.get("id") or self._extract_video_id(track) or "").strip()
                if not item_id or item_id in seen:
                    continue
                seen.add(item_id)
                normalized = dict(track)
                normalized["id"] = item_id
                if "thumbnail" not in normalized:
                    normalized["thumbnail"] = "https://i.ytimg.com/vi/{0}/sddefault.jpg".format(item_id)
                prepared.append(normalized)
            if not prepared:
                self._notify_info(self._tr("empty"))
                return False
            
                                                                             
            shuffle_seed = 0
            si = int(start_index or 0)
            si = max(0, min(si, len(prepared) - 1))
            if shuffle:
                import random
                shuffle_seed = random.getrandbits(31)
                rng = random.Random(shuffle_seed)
                                                                                     
                                                                                       
                rng.shuffle(prepared)
                si = 0
            
                                                
            run_on_ui_thread(self._dismiss_all_pomme_ui)
                                                                     
            run_on_ui_thread(lambda: self._show_loading_sheet(title_key="playlist_preparing"))
            
            self._queue_items = []
            self._continue_token += 1
            self._clear_hard_stop()
            ctx = {
                "playlist": True,
                "playlist_name": target_name,
                "playlist_url": self._user_playlist_cache_url(target_name),
                "results": prepared,
                "index": si,
                "item": dict(prepared[si]),
                "query": target_name,
                "shuffle": shuffle,
                "play_seed": shuffle_seed if shuffle else 0,
            }
            try:
                self._remember_playlist_listing(self._user_playlist_cache_url(target_name), prepared, target_name)
            except Exception:
                pass
                                                                                          
            try:
                ctx = self._hydrate_cached_playlist_item(ctx)
            except Exception:
                pass
            try:
                self._prefetch_playlist_cache(ctx)
            except Exception:
                pass
            start_item = dict((ctx.get("item") or prepared[si]) or prepared[si])
            self._start_music_player(start_item, play_ctx=ctx, present_player=True, user_initiated=True)
            return True
        except Exception as e:
            self._trace("play user saved playlist fail: {0}".format(e), "ERROR")
            return False

    def _show_user_playlist_tracks_sheet(self, playlist_name):
        try:
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return False
            try:
                if self._track_playlist_detail_sheet is not None:
                    self._track_playlist_detail_sheet.dismiss()
