            self._hooks.append(self.hook_method(m, PommeChatResumeHook(self)))
        except Exception as e:
            self._trace("hook chat onResume fail: {0}".format(e))

    def _register_widget_pill(self):
        try:
            if not self.PillRegistry or not self.PillInfo or not self.PillCreator or not self.WeatherPill:
                self._trace("pill classes unavailable")
                return

            plugin = self
            tag_key = jint(0x45544759)

            class Creator(dynamic_proxy(self.PillCreator)):
                def create(self_obj, context, resourcesProvider):
                    try:
                        pill = plugin.WeatherPill(context, resourcesProvider)
                        pill.setTag(tag_key, jint(POMME_WIDGET_PILL_ID))
                        plugin._active_pills.add(pill)
                        plugin._update_pill_ui(pill)
                        return pill
                    except Exception as e:
                        plugin._trace("pill create fail: {0}".format(e))
                        return None

            ctx = ApplicationLoader.applicationContext
            if ctx is None:
                return

            res = ctx.getResources()
            icon_res = res.getIdentifier("msg_tone_add_solar", "drawable", ctx.getPackageName())

            pill_info = self.PillInfo(
                jint(POMME_WIDGET_PILL_ID),
                self._tr("pill_title"),
                jint(icon_res),
                jint(-11565578),
                jint(-13276952),
                Creator()
            )

            try:
                self.PillRegistry.register(pill_info)
            except Exception as e:
                self._trace("pill register fail: {0}".format(e))

            class GetIdHook(MethodHook):
                def before_hooked_method(self_obj, param):
                    try:
                        tag = param.thisObject.getTag(tag_key)
                        if tag and int(tag) == POMME_WIDGET_PILL_ID:
                            plugin._active_pills.add(param.thisObject)
                            param.setResult(jint(POMME_WIDGET_PILL_ID))
                    except Exception:
                        pass

            class InteractionHook(MethodHook):
                def before_hooked_method(self_obj, param):
                    try:
                        tag = param.thisObject.getTag(tag_key)
                        if not tag or int(tag) != POMME_WIDGET_PILL_ID:
                            return

                        plugin._active_pills.add(param.thisObject)
                        method_name = str(param.method.getName())
                        plugin._trace("Pill Event: {0}".format(method_name), "DEBUG")

                        if method_name == "onPillClicked":
                            now = time.time()
                            if hasattr(plugin, "_last_pill_click_ts") and (now - plugin._last_pill_click_ts) < 1.0:
                                plugin._trace("Pill click debounced", "DEBUG")
                                param.setResult(None)
                                return
                            plugin._last_pill_click_ts = now
                            plugin._trace("Pill click: toggling native search mode", "INFO")
                            plugin._toggle_search_from_widget()
                            param.setResult(None)
                        elif method_name == "onPillLongClicked":
                            plugin._trace("Pill hold: opening main panel", "INFO")
                            plugin._show_about_sheet()
                            param.setResult(True)
                        elif method_name in ["onUpdateData", "setData"]:
                            plugin._update_pill_ui(param.thisObject)
                            param.setResult(None)
                    except Exception as e:
                        plugin._trace("pill interaction fail: {0}".format(e))

            self.hook_all_methods(self.WeatherPill, "getPillId", GetIdHook())
            self.hook_all_methods(self.WeatherPill, "onPillClicked", InteractionHook())
            self.hook_all_methods(self.WeatherPill, "onPillLongClicked", InteractionHook())
            self.hook_all_methods(self.WeatherPill, "onUpdateData", InteractionHook())
            self.hook_all_methods(self.WeatherPill, "setData", InteractionHook())

            self._ensure_widget_pill_enabled()
        except Exception as e:
            self._trace("register widget pill fail: {0}".format(e))

    def _ensure_widget_pill_enabled(self):
        try:
            if self.PillStackConfig is None:
                return
            active = self.PillStackConfig.activePills
            found = False
            for i in range(active.size()):
                if int(active.get(i)) == int(POMME_WIDGET_PILL_ID):
                    found = True
                    break
            if not found:
                active.add(jint(POMME_WIDGET_PILL_ID))
                self.PillStackConfig.savePillsLayout()
                run_on_ui_thread(self.PillStackConfig.notifySettingsChanged)
        except Exception as e:
            self._trace("ensure widget pill fail: {0}".format(e))

    def _is_dialogs(self, frag):
        try:
            return frag is not None and "DialogsActivity" in str(frag.getClass().getName() or "")
        except Exception:
            return False

    def _attach_or_refresh(self, frag):
        if not self._is_dialogs(frag):
            self._detach_state()
            return

        self._fragment_ref = frag

        try:
            fragment_search = get_private_field(frag, "fragmentSearchField")
        except Exception:
            fragment_search = None
        if fragment_search is None:
            return

        try:
            edit = getattr(fragment_search, "editText", None)
        except Exception:
            edit = None
        if edit is None:
            return

        self._edit_ref = edit
        self._capture_native_style(edit)
        self._apply_hint(edit)
        self._apply_native_search_mode(edit, frag)
        self._wire_editor_action(edit)
        self._wire_touch_action(edit)

        if self._enabled:
            self._hide_native_results(frag)

    def _detach_state(self):
        self._fragment_ref = None
        self._edit_ref = None
        self._attached_edit = None
        self._editor_proxy = None
        self._touch_edit = None
        self._touch_proxy = None

    def _push_on_dialogs_shown(self, frag):
        try:
            self._push_dialogs_fragment = frag
            self._push_dialogs_visible = True
            self._push_refresh_ui()
            self._push_fetch_if_needed(force=True)
            self._push_schedule_poll(immediate=False)
        except Exception as e:
            self._trace("push dialogs shown fail: {0}".format(e))

    def _push_on_dialogs_hidden(self):
        try:
            self._push_dialogs_visible = False
            self._push_cancel_poll()
            self._push_hide_view()
        except Exception as e:
            self._trace("push dialogs hidden fail: {0}".format(e))

    def _push_get_seen_ids(self):
        try:
            return set(json.loads(str(self.get_setting("pomme_push_seen_ids", "[]") or "[]")))
        except Exception:
            return set()

    def _push_set_seen_ids(self, seen_ids):
        try:
            self.set_setting("pomme_push_seen_ids", json.dumps(sorted(set(str(x) for x in (seen_ids or set()) if str(x or "").strip())), ensure_ascii=True))
        except Exception:
            pass

    def _push_mark_seen(self, push_id):
        try:
            seen = self._push_get_seen_ids()
            seen.add(str(push_id or "").strip())
            self._push_set_seen_ids(seen)
        except Exception:
            pass

    def _push_is_supported_dialogs_context(self, fragment):
        try:
            if fragment is None:
                return False
            if int(get_private_field(fragment, "folderId") or 0) != 0:
                return False
        except Exception:
            pass
        try:
            cls = fragment.getClass()
            while cls is not None:
                try:
                    method = cls.getDeclaredMethod("getRightSlidingProgress")
                    method.setAccessible(True)
                    return float(method.invoke(fragment) or 0.0) <= 0.85
                except Exception:
                    cls = cls.getSuperclass()
        except Exception:
            pass
        return True

    def _push_cancel_poll(self):
        try:
            if self._push_poll_timer is not None:
                self._push_poll_timer.cancel()
            self._push_poll_timer = None
        except Exception:
            pass

    def _push_schedule_poll(self):
        try:
            self._push_cancel_poll()
            if not self._push_dialogs_visible:
                return
            timer = threading.Timer(float(POMME_PUSH_FETCH_TTL_SEC), self._push_poll_tick)
            timer.daemon = True
            self._push_poll_timer = timer
            timer.start()
        except Exception:
            pass

    def _push_poll_tick(self):
        try:
            if self._push_dialogs_visible:
                self._push_fetch_if_needed(force=True)
        finally:
            self._push_schedule_poll()

    def _push_fetch_if_needed(self, force=False):
        try:
            if self._push_fetch_inflight:
                return
            if not force and (time.time() - float(self._push_last_fetch_ts or 0.0)) < float(POMME_PUSH_FETCH_TTL_SEC):
                self._push_refresh_ui()
                return
            self._push_fetch_inflight = True
            def _worker():
                try:
                    req = Request(POMME_PUSH_FEED_URL, headers={"User-Agent": "PommePush/1.0", "Cache-Control": "no-cache"})
                    with urlopen(req, timeout=8) as resp:
                        parsed = json.loads(resp.read().decode("utf-8", errors="replace") or "{}")
                    items = parsed.get("items") if isinstance(parsed, dict) else parsed
                    out = []
                    if isinstance(items, list):
                        for item in items:
                            if not isinstance(item, dict):
                                continue
                            push_id = str(item.get("id", "") or "").strip()
                            title = str(item.get("title", "") or "").strip()
                            description = str(item.get("description", "") or "").strip()
                            if push_id and title and description:
                                out.append({
                                    "id": push_id,
                                    "title": title,
                                    "description": description,
                                    "primary_text": str(item.get("primary_text", "Open") or "Open").strip(),
                                    "primary_url": str(item.get("primary_url", "") or "").strip(),
                                    "primary_clickable": bool(item.get("primary_clickable", bool(item.get("primary_url")))),
                                    "secondary_text": str(item.get("secondary_text", "Ok, thanks!") or "Ok, thanks!").strip(),
                                })
                    self._push_items = out
                    self._push_last_error = ""
                except Exception as e:
                    self._push_last_error = str(e)
                    self._trace("push fetch fail: {0}".format(e))
                finally:
                    self._push_fetch_inflight = False
                    self._push_last_fetch_ts = time.time()
                    self._push_refresh_ui()
            threading.Thread(target=_worker, daemon=True).start()
        except Exception as e:
            self._push_fetch_inflight = False
            self._trace("push fetch gate fail: {0}".format(e))

    def _push_next_item(self):
        seen = self._push_get_seen_ids()
        for item in reversed(list(self._push_items or [])):
            if str(item.get("id", "") or "").strip() not in seen:
                return item
        return None

    def _push_refresh_ui(self):
        try:
            run_on_ui_thread(self._push_refresh_ui_impl)
        except Exception:
            self._push_refresh_ui_impl()

    def _push_refresh_ui_impl(self):
        try:
            fragment = self._push_dialogs_fragment
            if fragment is None or not self._push_dialogs_visible or not self._push_is_supported_dialogs_context(fragment):
                return self._push_hide_view_impl()
            top_panel = get_private_field(fragment, "topPanelLayout")
            item = self._push_next_item()
            if top_panel is None or item is None:
                return self._push_hide_view_impl()
            if self._push_view is None or self._push_top_panel != top_panel:
                self._push_hide_view_impl()
                self._push_top_panel = top_panel
                self._push_view = self._push_build_view(top_panel.getContext())
                try:
                    layout_helper_cls = JClass.forName("org.telegram.ui.Components.LayoutHelper")
                    params = layout_helper_cls.createLinear(int(getattr(layout_helper_cls, "MATCH_PARENT")), int(getattr(layout_helper_cls, "WRAP_CONTENT")))
                    top_panel.addView(self._push_view, params)
                except Exception:
                    top_panel.addView(self._push_view)
            self._push_bind_item(item)
            self._push_set_top_panel_visible(top_panel, self._push_view, True)
        except Exception as e:
            self._trace("push refresh fail: {0}".format(e))

    def _push_hide_view(self):
        try:
            run_on_ui_thread(self._push_hide_view_impl)
        except Exception:
            self._push_hide_view_impl()

    def _push_hide_view_impl(self):
        try:
            if self._push_view is not None:
                parent = self._push_view.getParent()
                if parent is not None:
                    parent.removeView(self._push_view)
        except Exception:
            pass
        self._push_view = None
        self._push_top_panel = None

    def _push_set_top_panel_visible(self, top_panel, view, visible):
        try:
            top_panel.setViewVisible(view, bool(visible))
        except Exception:
            try:
                view.setVisibility(View.VISIBLE if visible else View.GONE)
            except Exception:
                pass

    def _push_build_view(self, context):
        root = LinearLayout(context)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setPadding(int(AndroidUtilities.dp(18)), int(AndroidUtilities.dp(12)), int(AndroidUtilities.dp(18)), int(AndroidUtilities.dp(8)))
        bg = GradientDrawable()
        bg.setColor(0)
        bg.setCornerRadius(float(AndroidUtilities.dp(18)))
        root.setBackground(bg)
        for tag_name, size, color_key in (
            ("title", 14, Theme.key_windowBackgroundWhiteBlackText),
            ("description", 13, Theme.key_windowBackgroundWhiteGrayText),
        ):
            tv = TextView(context)
            tv.setTag(tag_name)
            tv.setGravity(Gravity.CENTER)
            tv.setTextSize(1, size)
            tv.setTextColor(int(Theme.getColor(color_key)))
            if tag_name == "title":
                try:
                    tv.setTypeface(AndroidUtilities.bold())
                except Exception:
                    pass
            else:
                try:
                    tv.setLineSpacing(float(AndroidUtilities.dp(2)), 1.0)
                except Exception:
                    pass
            lp = LinearLayout.LayoutParams(-1, -2)
            if tag_name == "description":
                lp.topMargin = int(AndroidUtilities.dp(4))
            root.addView(tv, lp)
        buttons = LinearLayout(context)
        buttons.setOrientation(LinearLayout.HORIZONTAL)
        buttons.setGravity(Gravity.CENTER)
        lp_buttons = LinearLayout.LayoutParams(-1, -2)
        lp_buttons.topMargin = int(AndroidUtilities.dp(8))
        root.addView(buttons, lp_buttons)
        buttons.addView(View(context), LinearLayout.LayoutParams(0, 1, 1.0))
        for tag_name, color_key in (("primary", Theme.key_windowBackgroundWhiteBlueText4), ("secondary", Theme.key_text_RedBold)):
            tv = TextView(context)
            tv.setTag(tag_name)
            tv.setPadding(int(AndroidUtilities.dp(10)), int(AndroidUtilities.dp(5)), int(AndroidUtilities.dp(10)), int(AndroidUtilities.dp(7)))
            tv.setTextSize(1, 14.22)
            tv.setTextColor(int(Theme.getColor(color_key)))
            try:
                tv.setTypeface(AndroidUtilities.bold())
            except Exception:
                pass
            buttons.addView(tv, LinearLayout.LayoutParams(-2, int(AndroidUtilities.dp(30))))
            buttons.addView(View(context), LinearLayout.LayoutParams(0, 1, 1.0))
        return root

    def _push_find_tagged_child(self, root, tag_name):
        try:
            if str(root.getTag() or "") == str(tag_name):
                return root
        except Exception:
            pass
        try:
            for idx in range(int(root.getChildCount() or 0)):
                found = self._push_find_tagged_child(root.getChildAt(idx), tag_name)
                if found is not None:
                    return found
        except Exception:
            pass
        return None

    def _push_bind_item(self, item):
        try:
            for tag_name, value in (
                ("title", item.get("title", "")),
                ("description", item.get("description", "")),
                ("primary", item.get("primary_text", "Open")),
                ("secondary", item.get("secondary_text", "Ok, thanks!")),
            ):
                view = self._push_find_tagged_child(self._push_view, tag_name)
                if view is not None:
                    view.setText(str(value or ""))
            primary = self._push_find_tagged_child(self._push_view, "primary")
            secondary = self._push_find_tagged_child(self._push_view, "secondary")
            if primary is not None:
                primary.setOnClickListener(OnClickListener(lambda _v=None: self._push_on_primary(item)))
            if secondary is not None:
                secondary.setOnClickListener(OnClickListener(lambda _v=None: self._push_on_secondary(item)))
        except Exception as e:
            self._trace("push bind fail: {0}".format(e))

    def _push_open_external_url(self, url):
        try:
            target_url = str(url or "").strip()
            try:
                lowered = target_url.lower()
                if lowered.startswith("https://t.me/") or lowered.startswith("http://t.me/") or lowered.startswith("https://telegram.me/") or lowered.startswith("http://telegram.me/"):
                    parsed = urllib.parse.urlsplit(target_url)
                    parts = [p for p in str(parsed.path or "").split("/") if p]
                    if len(parts) >= 2 and parts[0] == "c" and str(parts[1]).isdigit():
                        post = str(parts[2]) if len(parts) >= 3 and str(parts[2]).isdigit() else ""
                        if post:
                            target_url = "tg://privatepost?channel={0}&post={1}".format(parts[1], post)
                    elif parts:
                        domain = urllib.parse.quote(str(parts[0]), safe="")
                        post = str(parts[1]) if len(parts) >= 2 and str(parts[1]).isdigit() else ""
                        if post:
                            target_url = "tg://resolve?domain={0}&post={1}".format(domain, post)
                        else:
                            target_url = "tg://resolve?domain={0}".format(domain)
            except Exception:
                pass
            fragment = self._push_dialogs_fragment
            activity = fragment.getParentActivity() if fragment is not None and hasattr(fragment, "getParentActivity") else None
            if activity is not None:
                try:
                    activity.startActivity(Intent(Intent.ACTION_VIEW, Uri.parse(target_url)))
                    return True
                except Exception:
                    pass
            self.open_url(target_url)
            return True
        except Exception:
            return False

    def _push_consume_and_refresh(self, push_id):
        self._push_mark_seen(push_id)
        self._push_refresh_ui()

    def _push_on_primary(self, item):
        try:
            if bool(item.get("primary_clickable", False)) and str(item.get("primary_url", "") or "").strip():
                self._push_open_external_url(str(item.get("primary_url", "") or ""))
            self._push_consume_and_refresh(str(item.get("id", "") or ""))
        except Exception as e:
            self._trace("push primary fail: {0}".format(e))

    def _push_on_secondary(self, item):
        try:
            self._push_consume_and_refresh(str(item.get("id", "") or ""))
        except Exception as e:
            self._trace("push secondary fail: {0}".format(e))

    def _capture_native_style(self, edit):
        try:
            if self._native_hint_text is None:
                h = edit.getHint()
                if h is not None:
                    self._native_hint_text = str(h)
            if self._native_hint_color is None:
                self._native_hint_color = int(edit.getCurrentHintTextColor())
        except Exception:
            pass

    def _apply_hint(self, edit):
        try:
            hint = self._tr("search_hint_youtube") if self._enabled else (self._native_hint_text or "Search")
            edit.setHint(hint)
            try:
                active_color = self._jcolor(Theme.getColor(Theme.key_featuredStickers_addButton))
            except Exception:
                active_color = 0xFF3DA5FF
            color = active_color if self._enabled else (self._native_hint_color if self._native_hint_color is not None else active_color)
            try:
                edit.setHintTextColor(int(color))
            except Exception:
                pass
            try:
                edit.setContentDescription(hint)
            except Exception:
                pass
            
                                       
            try:
                search_icon = get_private_field(edit.getParent(), "searchIcon")
                if search_icon is not None:
                    plugin = self
                    class _SearchIconClick(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                        def onClick(self_obj, v):
                            plugin._toggle_search_from_widget()
                    search_icon.setOnClickListener(_SearchIconClick())
            except Exception: pass
        except Exception as e:
            self._trace("apply hint fail: {0}".format(e))

    def _toggle_search_from_widget(self):
        try:
            was_enabled = bool(self._enabled)
            self._toggle()
            edit = getattr(self, "_edit_ref", None)
            if edit is None:
                return
            if was_enabled:
                try:
                    AndroidUtilities.hideKeyboard(edit)
                except Exception:
                    pass
                return
            search_text = str(edit.getText() or "").strip()
            if search_text and self._last_results:
                self._show_results_sheet(self._last_results, self._last_query)
            else:
                try:
                    edit.requestFocus()
                    AndroidUtilities.showKeyboard(edit)
                except Exception:
                    pass
        except Exception as e:
            self._trace("toggle search from widget fail: {0}".format(e), "ERROR")

    def _refresh_player_play_pause_icon(self):
        try:
            if self._player_play_pause_btn is None:
                return
            icon = "player_pause.png"
            try:
                if self._custom_player_ui is not None and self._custom_player is not None:
                    is_playing = False
                    try:
                        is_playing = bool(self._custom_player.isPlaying())
                    except Exception:
                        is_playing = False
                    icon = "player_pause.png" if is_playing else "player_play.png"
                else:
                    mc = jclass("org.telegram.messenger.MediaController").getInstance()
                    icon = "player_pause.png" if not mc.isMessagePaused() else "player_play.png"
            except Exception:
                pass
            play_tint = getattr(self, "_player_play_pause_tint", None)
            if play_tint is None:
                play_tint = self._jcolor(0xFFFFFFFF)
            if not self._apply_cached_remote_icon(self._player_play_pause_btn, icon, tint_color=play_tint):
                self._update_remote_icon(self._player_play_pause_btn, icon, 38, tint_color=play_tint)
        except Exception as e:
            self._trace("refresh play pause icon fail: {0}".format(e), "WARN")

    def _apply_cached_remote_icon(self, iv, icon_name, tint_color=None, dark=True):
        try:
            if iv is None:
                return False
            final_tint = self._jcolor(tint_color) if tint_color is not None else (self._jcolor(0xFF000000) if dark else self._jcolor(0xFFFFFFFF))
            url = "https://coreupdates.meyankut.workers.dev/{0}".format(icon_name)
            bitmap = None
            if hasattr(self, "_icon_mem_cache"):
                bitmap = self._icon_mem_cache.get(url)
            if bitmap is None:
                cache_root = self._artwork_cache_dir()
                cache_path = os.path.join(cache_root, hashlib.md5(url.encode("utf-8")).hexdigest() + ".png") if cache_root else None
                if cache_path and os.path.exists(cache_path):
                    try:
                        BitmapFactory = jclass("android.graphics.BitmapFactory")
                        bitmap = BitmapFactory.decodeFile(cache_path)
                        if bitmap is not None:
                            if not hasattr(self, "_icon_mem_cache"):
                                self._icon_mem_cache = {}
                            self._icon_mem_cache[url] = bitmap
                    except Exception:
                        bitmap = None
            if bitmap is None:
                return False
            try:
                iv.setImageBitmap(bitmap)
                iv.setColorFilter(final_tint, PorterDuff.Mode.SRC_IN)
                iv.invalidate()
                iv.requestLayout()
            except Exception:
                pass
            return True
        except Exception:
            return False

    def _update_all_pills(self):
        for pill in list(self._active_pills):
            try:
                self._update_pill_ui(pill)
            except Exception:
                pass

    def _update_pill_ui(self, pill):
        try:
            tv = get_private_field(pill, "textView")
        except Exception:
            tv = None

        try:
            iv = get_private_field(pill, "iconView")
        except Exception:
            iv = None

        try:
            bg = pill.getBackground()
        except Exception:
            bg = None

        try:
            active_color = int(Theme.getColor(Theme.key_featuredStickers_addButton))
        except Exception:
            active_color = 0xFF3DA5FF

        try:
            inactive_color = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
        except Exception:
            inactive_color = 0xFF8793A1

        tint = active_color if self._enabled else inactive_color

        try:
            if tv is not None:
                tv.setText(self._tr("pill_title"))
                tv.setTextColor(int(tint))
        except Exception:
            pass

        try:
            if iv is not None:
                ctx = pill.getContext()
                res = ctx.getResources()
                icon_res = res.getIdentifier("msg_tone_add_solar", "drawable", ctx.getPackageName())
                if icon_res != 0:
                    iv.setImageResource(icon_res)
                iv.setColorFilter(PorterDuffColorFilter(int(tint), PorterDuff.Mode.SRC_IN))
                lp = iv.getLayoutParams()
                if lp is not None:
                    lp.width = int(AndroidUtilities.dp(18))
                    lp.height = int(AndroidUtilities.dp(18))
                    iv.setLayoutParams(lp)
                iv.setPadding(0, 0, 0, 0)
        except Exception:
            pass

        try:
            if bg is not None:
                bg = bg.mutate()
                if self._enabled:
                    bg.setColorFilter(PorterDuffColorFilter(int(active_color), PorterDuff.Mode.MULTIPLY))
                    pill.setAlpha(1.0)
                else:
                    bg.clearColorFilter()
                    pill.setAlpha(0.9)
        except Exception:
            pass

    def _toggle(self):
        try:
            self._touch_activity()
            self._set_enabled(not self._enabled, True)
        except Exception as e:
            self._trace("toggle fail: {0}".format(e))

    def _set_enabled(self, enabled, show_bulletin):
        self._enabled = bool(enabled)
        self._touch_activity()
        self.set_setting("pomme_enabled", self._enabled)
        self._update_all_pills()

        try:
            if self._edit_ref is not None:
                self._apply_hint(self._edit_ref)
            if self._fragment_ref is not None and self._edit_ref is not None:
                self._apply_native_search_mode(self._edit_ref, self._fragment_ref)
                if self._enabled:
                    self._hide_native_results(self._fragment_ref)
        except Exception as e:
            self._trace("set enabled apply fail: {0}".format(e))

        if show_bulletin:
            try:
                from ui.bulletin import BulletinHelper
                BulletinHelper.show_info(self._tr("bulletin_mode_on") if self._enabled else self._tr("bulletin_mode_off"))
            except Exception as e:
                self._trace("bulletin fail: {0}".format(e))

