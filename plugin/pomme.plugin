    def _lyrics_cache_key(self, title, artist):
        try:
            raw = "{0}::{1}".format(str(artist or "").strip().lower(), str(title or "").strip().lower())
            return hashlib.md5(raw.encode("utf-8")).hexdigest()
        except Exception:
            return ""

    def _read_cached_lyrics(self, title, artist):
        try:
            cache_root = self._lyrics_cache_dir()
            cache_key = self._lyrics_cache_key(title, artist)
            if not cache_root or not cache_key:
                return None
            cache_path = os.path.join(cache_root, cache_key + ".json")
            if not os.path.exists(cache_path):
                return None
            with open(cache_path, "r", encoding="utf-8") as fh:
                payload = json.load(fh)
            status = str((payload or {}).get("status") or "").strip().lower()
            text = str((payload or {}).get("text") or "")
            updated_at = int((payload or {}).get("updated_at") or 0)
            now_ts = int(time.time())
            if status == "ok" and text.strip():
                return text
            if status == "miss":
                if updated_at and (now_ts - updated_at) < 21600:
                    return ""
                return None
            return None
        except Exception:
            return None

    def _write_cached_lyrics(self, title, artist, text, missing=False):
        try:
            cache_root = self._lyrics_cache_dir()
            cache_key = self._lyrics_cache_key(title, artist)
            if not cache_root or not cache_key:
                return False
            cache_path = os.path.join(cache_root, cache_key + ".json")
            payload = {
                "status": "miss" if missing else "ok",
                "text": "" if missing else str(text or ""),
                "updated_at": int(time.time()),
            }
            with open(cache_path, "w", encoding="utf-8") as fh:
                json.dump(payload, fh, ensure_ascii=False)
            return True
        except Exception:
            return False

    def _lyrics_item_cache_key(self, item):
        try:
            item = dict(item or {})
            raw = str(
                self._extract_video_id(item)
                or item.get("url")
                or "{0}::{1}".format(item.get("author") or "", item.get("title") or "")
            ).strip()
            if not raw:
                return ""
            return hashlib.md5(raw.lower().encode("utf-8")).hexdigest()
        except Exception:
            return ""

