            os.makedirs(path, exist_ok=True)
            return path
        except Exception:
            return None

    def _search_cache_dir(self):
        try:
            base = self._cache_dir()
            if not base:
                return None
            path = os.path.join(base, "search")
            os.makedirs(path, exist_ok=True)
            return path
        except Exception:
