            def _section_card(title_text, desc_text):
                card = LinearLayout(ctx)
                card.setOrientation(LinearLayout.VERTICAL)
                card_bg = GradientDrawable()
                card_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                card_bg.setColor(card_fill)
                try:
                    card_bg.setStroke(AndroidUtilities.dp(1), card_stroke)
                except Exception:
                    pass
                card.setBackground(card_bg)
                card.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14))
                ttl, ttl_lp = _label(title_text)
                card.addView(ttl, ttl_lp)
                dsc, dsc_lp = _label(desc_text, top_margin=4, small=True)
                card.addView(dsc, dsc_lp)
                return card

            def _card_lp(top_margin=0):
                lp0 = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp0.topMargin = AndroidUtilities.dp(top_margin)
                return lp0

            _section_title("panel_data_section_backup")

            backup_card = _section_card(self._tr("panel_data_backup_export"), self._tr("panel_data_backup_export_desc"))
            create_btn = TextView(ctx)
            create_btn.setText(self._tr("panel_data_backup_create"))
            create_btn.setTextSize(14)
            create_btn.setTypeface(None, 1)
            create_btn.setGravity(Gravity.CENTER)
            create_btn.setTextColor(int(button_text))
            create_btn.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(10), AndroidUtilities.dp(18), AndroidUtilities.dp(10))
            create_bg = GradientDrawable()
            create_bg.setCornerRadius(float(AndroidUtilities.dp(16)))
            create_bg.setColor(self._jcolor(button_fill))
            create_btn.setBackground(create_bg)
            create_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            create_lp.topMargin = AndroidUtilities.dp(12)
            backup_card.addView(create_btn, create_lp)
            outer.addView(backup_card, _card_lp(0))

            import_card = _section_card(self._tr("panel_data_backup_import"), self._tr("panel_data_backup_import_desc"))
            import_btn = TextView(ctx)
            import_btn.setText(self._tr("panel_data_backup_pick"))
            import_btn.setTextSize(14)
            import_btn.setTypeface(None, 1)
            import_btn.setGravity(Gravity.CENTER)
            import_btn.setTextColor(title_color)
            import_btn.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(10), AndroidUtilities.dp(18), AndroidUtilities.dp(10))
            import_bg = GradientDrawable()
            import_bg.setCornerRadius(float(AndroidUtilities.dp(16)))
            import_bg.setColor(self._jcolor(0x00000000))
            try:
                import_bg.setStroke(AndroidUtilities.dp(1), sub_color)
            except Exception:
                pass
            import_btn.setBackground(import_bg)
            import_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            import_lp.topMargin = AndroidUtilities.dp(12)
            import_card.addView(import_btn, import_lp)
            outer.addView(import_card, _card_lp(12))

            btn_row = LinearLayout(ctx)
            btn_row.setOrientation(LinearLayout.HORIZONTAL)
            btn_row.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
            btn_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            btn_lp.topMargin = AndroidUtilities.dp(16)
            outer.addView(btn_row, btn_lp)

            cancel_btn = TextView(ctx)
            cancel_btn.setText(self._tr("cancel"))
            cancel_btn.setTextSize(14)
            cancel_btn.setTypeface(None, 1)
            cancel_btn.setTextColor(sub_color)
            cancel_btn.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(10), AndroidUtilities.dp(16), AndroidUtilities.dp(10))
            btn_row.addView(cancel_btn)

            scroll.addView(outer)
            sheet.setCustomView(scroll)
            plugin = self

            def _clear_data_sheet_ref():
                try:
                    if getattr(plugin, "_data_sheet", None) is sheet:
                        plugin._data_sheet = None
                except Exception:
                    pass

            class _Cancel(dynamic_proxy(listener_cls)):
                def onClick(self_obj, _v):
                    try:
                        sheet.dismiss()
                    except Exception:
                        pass
                    _clear_data_sheet_ref()

            class _CreateBackup(dynamic_proxy(listener_cls)):
                def onClick(self_obj, _v):
                    try:
                        try:
                            plugin._dismiss_all_pomme_ui()
                        except Exception:
                            pass
                        _clear_data_sheet_ref()
                        path = plugin._write_backup_file()
                        if not path:
                            BulletinHelper.show_info(plugin._tr("panel_data_backup_create_failed"))
                            return
                        sent = plugin._send_backup_document(path)
                        if sent:
                            BulletinHelper.show_success(plugin._tr("panel_data_backup_sent"))
                        else:
                            BulletinHelper.show_success(plugin._tr("panel_data_backup_created"))
                    except Exception as e:
                        plugin._trace("create backup fail: {0}".format(e), "ERROR")
                        BulletinHelper.show_info(plugin._tr("panel_data_backup_create_failed"))

            class _ImportBackup(dynamic_proxy(listener_cls)):
                def onClick(self_obj, _v):
                    try:
                        plugin._open_backup_import_picker()
                    except Exception as e:
                        plugin._trace("import backup picker fail: {0}".format(e), "ERROR")
                        BulletinHelper.show_info(plugin._tr("panel_data_backup_restore_failed"))

            cancel_btn.setOnClickListener(_Cancel())
            create_btn.setOnClickListener(_CreateBackup())
            import_btn.setOnClickListener(_ImportBackup())
            self._data_sheet = sheet
            sheet.show()
            return True
        except Exception as e:
            self._trace("show data sheet fail: {0}".format(e), "ERROR")
            return False

    def _parse_spotify_reference(self, raw_value):
        try:
            raw = str(raw_value or "").strip()
            if not raw:
                return None
            if raw.startswith("spotify:"):
                parts = [str(x or "").strip() for x in raw.split(":")]
                if len(parts) == 3 and parts[1] in ("track", "album", "playlist", "artist") and parts[2]:
                    return {"type": parts[1], "id": parts[2], "url": raw}
                return None
            parsed = urllib.parse.urlparse(raw)
            host = str(parsed.netloc or parsed.hostname or "").strip().lower()
            if host == "embed.spotify.com":
                qs = urllib.parse.parse_qs(parsed.query or "")
                embedded = str((qs.get("uri") or [""])[0] or "").strip()
                return self._parse_spotify_reference(embedded)
            if host not in ("open.spotify.com", "play.spotify.com"):
                return None
            parts = [str(seg or "").strip() for seg in str(parsed.path or "").split("/") if str(seg or "").strip()]
            if parts and parts[0] == "embed":
                parts = parts[1:]
            if parts and parts[0].startswith("intl-"):
                parts = parts[1:]
            if len(parts) == 2 and parts[0] in ("track", "album", "playlist", "artist") and parts[1]:
                return {
                    "type": str(parts[0]),
                    "id": str(parts[1]).split("?", 1)[0].strip(),
                    "url": raw,
                }
            if len(parts) == 4 and parts[2] == "playlist" and parts[3]:
                return {"type": "playlist", "id": str(parts[3]).strip(), "url": raw}
            return None
        except Exception:
            return None

    def _parse_youtube_playlist_reference(self, raw_value):
        try:
            raw = self._clean_external_link_input(raw_value)
            if not raw:
                return None
            parsed = urllib.parse.urlparse(raw)
            host = str(parsed.netloc or parsed.hostname or "").strip().lower()
            if host.startswith("www."):
                host = host[4:]
            if host not in ("youtube.com", "m.youtube.com", "music.youtube.com", "youtu.be"):
                return None
            query = urllib.parse.parse_qs(str(parsed.query or ""))
            list_id = str((query.get("list") or [""])[0] or "").strip()
            if not list_id:
                return None
            return {"type": "playlist", "id": list_id, "url": raw}
        except Exception:
            return None

    def _youtube_playlist_meta(self, raw_value):
        try:
            ref = self._parse_youtube_playlist_reference(raw_value)
            if not ref:
                return {}
            cache_key = "yt_playlist_meta::{0}".format(str(ref.get("id") or "").strip())
            cached = self._spotify_meta_cache_get(cache_key)
            if isinstance(cached, dict) and cached:
                return dict(cached)
            ytdlp_cls = self._require_ytdlp()
            with ytdlp_cls({
                "quiet": True,
                "no_warnings": True,
                "skip_download": True,
                "extract_flat": True,
                "playlistend": 1,
                "lazy_playlist": True,
            }) as ydl:
                info = dict(ydl.extract_info(str(ref.get("url") or raw_value), download=False) or {})
            data = {
                "name": str(info.get("title") or info.get("playlist_title") or "").strip(),
                "url": str(info.get("webpage_url") or ref.get("url") or raw_value).strip(),
                "id": str(ref.get("id") or "").strip(),
                "source_platform": "youtube",
                "collection_type": "playlist",
            }
            self._spotify_meta_cache_put(cache_key, data, ttl_sec=1800)
            return data
        except Exception as e:
            self._trace("youtube playlist meta fail: {0}".format(e), "DEBUG")
            return {}

    def _youtube_collection_name(self, raw_value):
        try:
            return str((self._youtube_playlist_meta(raw_value) or {}).get("name") or "").strip()
        except Exception:
            return ""

    def _clean_external_link_input(self, raw_value):
        try:
            value = str(raw_value or "")
            value = re.sub(r"[\r\n\t]+", "", value).strip()
            return value
        except Exception:
            return str(raw_value or "").strip()

    def _spotify_meta_cache_file(self, cache_key):
        try:
            root = self._search_cache_dir()
            if not root:
                return ""
            return os.path.join(root, "spotify_{0}.json".format(str(cache_key or "").strip()))
        except Exception:
            return ""

    def _spotify_meta_cache_get(self, cache_key):
        try:
            key = str(cache_key or "").strip()
            if not key:
                return None
            memo = getattr(self, "_spotify_meta_memo", None)
            if not isinstance(memo, dict):
                memo = {}
                self._spotify_meta_memo = memo
            payload = dict(memo.get(key) or {})
            if payload and float(payload.get("exp") or 0.0) > time.time():
                data = payload.get("data")
                if isinstance(data, dict):
                    return dict(data)
            path = self._spotify_meta_cache_file(key)
            if not path or not os.path.exists(path):
                return None
            with open(path, "r", encoding="utf-8") as fh:
                payload = json.load(fh)
            if float((payload or {}).get("exp") or 0.0) <= time.time():
                return None
            data = dict((payload or {}).get("data") or {})
            memo[key] = {"exp": float(payload.get("exp") or 0.0), "data": dict(data)}
            return data
        except Exception:
            return None

    def _spotify_meta_cache_put(self, cache_key, data, ttl_sec=3600):
        try:
            key = str(cache_key or "").strip()
            payload_data = dict(data or {})
            if not key or not payload_data:
                return False
            exp = time.time() + max(120, int(ttl_sec or 3600))
            memo = getattr(self, "_spotify_meta_memo", None)
            if not isinstance(memo, dict):
                memo = {}
                self._spotify_meta_memo = memo
            if len(memo) > 48:
                memo.clear()
            memo[key] = {"exp": exp, "data": dict(payload_data)}
            path = self._spotify_meta_cache_file(key)
            if path:
                with open(path, "w", encoding="utf-8") as fh:
                    json.dump({"exp": exp, "data": payload_data}, fh, ensure_ascii=False)
            return True
        except Exception:
            return False

    def _spotify_spotfetch_base(self):
        return "https://sp.afkarxyz.qzz.io/api"

    def _spotify_spotfetch_get(self, raw_value):
        try:
            ref = self._parse_spotify_reference(raw_value)
            if not ref:
                return None
            cache_key = hashlib.md5("{0}:{1}".format(ref.get("type"), ref.get("id")).encode("utf-8")).hexdigest()
            cached = self._spotify_meta_cache_get(cache_key)
            if cached is not None:
                self._trace("spotify metadata cache hit | type={0} | id={1}".format(ref.get("type"), ref.get("id")), "INFO")
                return cached
            endpoint = "{0}/{1}/{2}".format(self._spotify_spotfetch_base().rstrip("/"), ref.get("type"), ref.get("id"))
            data = self._http_get_json(
                endpoint,
                headers={"Accept": "application/json"},
                timeout=30,
                cache_key="spotfetch::{0}:{1}".format(ref.get("type"), ref.get("id")),
                ttl_sec=60 * 60,
                allow_stale=True,
            )
            if isinstance(data, dict):
                self._spotify_meta_cache_put(cache_key, data, ttl_sec=3600)
                self._trace("spotify metadata fetched | type={0} | id={1}".format(ref.get("type"), ref.get("id")), "INFO")
                return data
            return None
        except Exception as e:
            self._trace("spotify metadata fetch fail: {0}".format(e), "WARN")
            return None

    def _extract_youtube_id_from_url(self, raw_url):
        try:
            url = str(raw_url or "").strip()
            if not url:
                return ""
            if "youtu.be/" in url:
                after = url.split("youtu.be/", 1)[1]
                return str(after.split("?", 1)[0].split("&", 1)[0].strip())
            parsed = urllib.parse.urlparse(url)
            qs = urllib.parse.parse_qs(parsed.query or "")
            if qs.get("v"):
                return str((qs.get("v") or [""])[0] or "").strip()
            path = str(parsed.path or "")
            if "/embed/" in path:
                after = path.split("/embed/", 1)[1]
                return str(after.split("/", 1)[0].strip())
            return ""
        except Exception:
            return ""

    def _spotify_songlink_lookup(self, track_meta):
        try:
            meta = dict(track_meta or {})
            spotify_id = str(meta.get("spotify_id") or "").strip()
            spotify_url = str(meta.get("external_urls") or meta.get("spotify_url") or "").strip()
            if not spotify_url and spotify_id:
                spotify_url = "https://open.spotify.com/track/{0}".format(spotify_id)
            if not spotify_url:
                return None
            cache_key = hashlib.md5("songlink::{0}".format(spotify_url).encode("utf-8")).hexdigest()
            cached = self._spotify_meta_cache_get(cache_key)
            if cached is not None:
                return cached
            endpoint = "https://api.song.link/v1-alpha.1/links?url={0}&userCountry=US".format(urllib.parse.quote(spotify_url, safe=""))
            payload = self._http_get_json(
                endpoint,
                headers={"Accept": "application/json"},
                timeout=18,
                cache_key="songlink::{0}".format(spotify_url),
                ttl_sec=12 * 60 * 60,
                allow_stale=True,
            )
            if not isinstance(payload, dict):
                return None
            links = dict(payload.get("linksByPlatform") or {})
            preferred = dict((links.get("youtubeMusic") or links.get("youtube") or {}) or {})
            yt_url = str(preferred.get("url") or "").strip()
            yt_id = self._extract_youtube_id_from_url(yt_url)
            result = {
                "youtube_url": yt_url,
                "youtube_id": yt_id,
            }
            if yt_id:
                self._trace("spotify songlink hit | spotify_id={0} | youtube_id={1}".format(spotify_id or "missing", yt_id), "INFO")
            self._spotify_meta_cache_put(cache_key, result, ttl_sec=1800)
            return result
        except Exception as e:
            self._trace("spotify songlink lookup fail: {0}".format(e), "DEBUG")
            return None

    def _spotify_direct_youtube_item(self, track_meta):
        try:
            meta = dict(track_meta or {})
            mapped = dict((self._spotify_songlink_lookup(meta) or {}))
            yt_id = str(mapped.get("youtube_id") or "").strip()
            if not yt_id:
                return None
            base = {
                "id": yt_id,
                "url": str(mapped.get("youtube_url") or "https://www.youtube.com/watch?v={0}".format(yt_id)).strip(),
                "thumbnail": "https://i.ytimg.com/vi/{0}/sddefault.jpg".format(yt_id),
                "length": int(round(float(meta.get("duration_ms") or 0) / 1000.0)) if str(meta.get("duration_ms") or "").strip() else 0,
            }
            return self._spotify_track_to_pomme_item(meta, base)
        except Exception:
            return None

    def _spotify_candidate_is_safe(self, track_meta, candidate, query_text=""):
        try:
            meta = dict(track_meta or {})
            item = dict(candidate or {})
            want_artist = str(meta.get("artists") or meta.get("album_artist") or "").strip()
            want_title = str(meta.get("name") or "").strip()
            want_duration = 0
            try:
                want_duration = int(round(float(meta.get("duration_ms") or 0) / 1000.0))
            except Exception:
                want_duration = 0
            cand_artist, cand_title = self._clean_music_metadata(item)
            title_ratio = SequenceMatcher(None, self._lyrics_norm(want_title), self._lyrics_norm(cand_title or item.get("title"))).ratio()
            artist_ratio = SequenceMatcher(None, self._lyrics_norm(want_artist), self._lyrics_norm(cand_artist or item.get("author"))).ratio()
            cand_duration = self._parse_duration_seconds(item.get("length"), 0)
            dur_diff = abs(int(cand_duration or 0) - int(want_duration or 0)) if int(want_duration or 0) > 0 and int(cand_duration or 0) > 0 else 0
            score = self._search_item_score(query_text or self._spotify_track_query(meta), item, want_title, want_artist, want_duration)
            if title_ratio >= 0.96 and artist_ratio >= 0.72 and (dur_diff == 0 or dur_diff <= 20):
                return True
            if title_ratio >= 0.90 and artist_ratio >= 0.82 and (dur_diff == 0 or dur_diff <= 12):
                return True
            if title_ratio >= 0.86 and artist_ratio >= 0.68 and (dur_diff == 0 or dur_diff <= 8) and score >= 95:
                return True
            self._trace(
                "spotify candidate rejected | title_ratio={0:.2f} | artist_ratio={1:.2f} | dur_diff={2} | score={3} | title={4} | author={5}".format(
                    float(title_ratio), float(artist_ratio), int(dur_diff), int(score), str(item.get("title") or ""), str(item.get("author") or "")
                ),
                "INFO",
            )
            return False
        except Exception as e:
            self._trace("spotify candidate safety check fail: {0}".format(e), "WARN")
            return False

    def _spotify_track_payloads(self, raw_value):
        try:
            ref = self._parse_spotify_reference(raw_value)
            if not ref:
                return []
            payload = self._spotify_spotfetch_get(ref.get("url") or raw_value)
            if not isinstance(payload, dict):
                return []
            rtype = str(ref.get("type") or "").strip()
            if rtype == "track":
                track = dict((payload.get("track") or payload) or {})
                return [track] if track else []
            if rtype in ("album", "playlist"):
                tracks = list(payload.get("track_list") or [])
                clean = []
                for entry in tracks[:30]:
                    if isinstance(entry, dict):
                        clean.append(dict(entry))
                return clean
            return []
        except Exception as e:
            self._trace("spotify track payload parse fail: {0}".format(e), "WARN")
            return []

    def _spotify_track_query(self, track_meta):
        try:
            meta = dict(track_meta or {})
            artist = str(meta.get("artists") or meta.get("album_artist") or "").strip()
            title = str(meta.get("name") or "").strip()
            query = "{0} - {1}".format(artist, title).strip(" -")
            return query or title
        except Exception:
            return ""

    def _spotify_display_query(self, raw_value, results=None):
        try:
            ref = self._parse_spotify_reference(raw_value)
            if ref is None:
                return str(raw_value or "").strip()
            payload = self._spotify_spotfetch_get(ref.get("url") or raw_value) or {}
            rtype = str(ref.get("type") or "").strip()
            if rtype == "track":
                meta = dict((payload.get("track") or payload) or {})
                text = self._spotify_track_query(meta)
                if text:
                    return text
            elif rtype == "album":
                album_info = dict(payload.get("album_info") or {})
                artist = str(album_info.get("artists") or "").strip()
                title = str(album_info.get("name") or "").strip()
                text = "{0} - {1}".format(artist, title).strip(" -")
                if text:
                    return text
            elif rtype == "playlist":
                playlist_info = dict(payload.get("playlist_info") or {})
                title = str(playlist_info.get("name") or "").strip()
                if title:
                    return title
            first = dict((list(results or [])[:1] or [{}])[0] or {})
            text = "{0} - {1}".format(str(first.get("author") or "").strip(), str(first.get("title") or "").strip()).strip(" -")
            return text or str(raw_value or "").strip()
        except Exception:
            return str(raw_value or "").strip()

    def _spotify_collection_name(self, raw_value):
        try:
            ref = self._parse_spotify_reference(raw_value)
            if ref is None:
                return ""
            payload = self._spotify_spotfetch_get(ref.get("url") or raw_value) or {}
            rtype = str(ref.get("type") or "").strip()
            if rtype == "playlist":
                playlist_info = dict(payload.get("playlist_info") or payload.get("playlist") or {})
                return str(playlist_info.get("name") or payload.get("name") or "").strip()
            if rtype == "album":
                album_info = dict(payload.get("album_info") or payload.get("album") or {})
                return str(album_info.get("name") or payload.get("name") or "").strip()
            return ""
        except Exception:
            return ""

    def _spotify_track_to_pomme_item(self, track_meta, matched=None):
        try:
            meta = dict(track_meta or {})
            item = dict(matched or {})
            title = str(meta.get("name") or item.get("title") or "Track").strip() or "Track"
            artist = str(meta.get("artists") or meta.get("album_artist") or item.get("author") or "Spotify").strip() or "Spotify"
            duration_sec = self._parse_duration_seconds(meta.get("duration_ms"), 0)
            if duration_sec <= 0:
                try:
                    duration_sec = int(round(float(meta.get("duration_ms") or 0) / 1000.0))
                except Exception:
                    duration_sec = self._parse_duration_seconds(item.get("length"), 0)
            cover_url = str(meta.get("images") or meta.get("thumbnail") or item.get("cover_url") or item.get("thumbnail") or "").strip()
            spotify_url = str(meta.get("external_urls") or meta.get("url") or "").strip()
            item["title"] = title
            item["author"] = artist
            if int(self._parse_duration_seconds(item.get("length"), 0) or 0) <= 0 and int(duration_sec or 0) > 0:
                item["length"] = int(duration_sec)
            if cover_url:
                item["cover_url"] = cover_url
                item["thumbnail"] = cover_url
            item["source_platform"] = "spotify"
            item["spotify_id"] = str(meta.get("spotify_id") or "").strip()
            item["spotify_url"] = spotify_url
            item["isrc"] = str(meta.get("isrc") or "").strip()
            item["album_name"] = str(meta.get("album_name") or "").strip()
            item["album_type"] = str(meta.get("album_type") or "").strip()
            item["release_date"] = str(meta.get("release_date") or "").strip()
            return item
        except Exception:
            return dict(matched or {})

    def _resolve_spotify_track_candidate(self, track_meta):
        try:
            meta = dict(track_meta or {})
            direct = self._spotify_direct_youtube_item(meta)
            if direct is not None:
                return direct
            title = str(meta.get("name") or "").strip()
            artist = str(meta.get("artists") or meta.get("album_artist") or "").strip()
            duration_sec = 0
            try:
                duration_sec = int(round(float(meta.get("duration_ms") or 0) / 1000.0))
            except Exception:
                duration_sec = self._parse_duration_seconds(meta.get("duration_ms"), 0)
            matched = self._resolve_playlist_candidate(title, artist, duration_sec)
            if not matched:
                return None
            if not self._spotify_candidate_is_safe(meta, matched, self._spotify_track_query(meta)):
                return None
            return self._spotify_track_to_pomme_item(meta, matched)
        except Exception as e:
            self._trace("spotify track candidate resolve fail: {0}".format(e), "WARN")
            return None

    def _resolve_spotify_search_items(self, raw_value):
        try:
            ref = self._parse_spotify_reference(raw_value)
            if not ref:
                return []
            tracks = self._spotify_track_payloads(raw_value)
            if not tracks:
                return []
            if str(ref.get("type") or "") == "track":
                meta = dict(tracks[0] or {})
                direct = self._spotify_direct_youtube_item(meta)
                if direct is not None:
                    return [direct]
                query = self._spotify_track_query(meta)
                duration_sec = 0
                try:
                    duration_sec = int(round(float(meta.get("duration_ms") or 0) / 1000.0))
                except Exception:
                    duration_sec = self._parse_duration_seconds(meta.get("duration_ms"), 0)
                yt_results = self._search_youtube_sync(
                    query,
                    target_title=str(meta.get("name") or ""),
                    target_artist=str(meta.get("artists") or meta.get("album_artist") or ""),
                    target_duration=duration_sec,
                )
                enriched = []
                for item in list(yt_results or []):
                    if not isinstance(item, dict):
                        continue
                    if self._spotify_candidate_is_safe(meta, item, query):
                        enriched.append(self._spotify_track_to_pomme_item(meta, item))
                if enriched:
                    return enriched
                single = self._resolve_spotify_track_candidate(meta)
                return [single] if single else []
            resolved = []
            for track in tracks[:18]:
                item = self._resolve_spotify_track_candidate(track)
                if item:
                    resolved.append(item)
            self._trace("spotify collection resolved | type={0} | total={1} | matched={2}".format(ref.get("type"), len(tracks), len(resolved)), "INFO")
            return self._prepare_search_results(str(raw_value or "").strip(), resolved)
        except Exception as e:
            self._trace("spotify search resolve fail: {0}".format(e), "WARN")
            return []

    def _resolve_playlist_entries(self, playlist_url, progress_cb=None):
        try:
            url = self._clean_external_link_input(playlist_url)
            if not url:
                return []
            spotify_ref = self._parse_spotify_reference(url)
            if spotify_ref is not None:
                results = []
                tracks = list(self._spotify_track_payloads(url) or [])
                total = len(tracks)
                for idx, track in enumerate(tracks):
                    item = self._resolve_spotify_track_candidate(track)
                    if item:
                        results.append(item)
                    try:
                        if callable(progress_cb):
                            progress_cb(int(idx + 1), int(total))
                    except Exception:
                        pass
                return results
            ytdlp_cls = self._require_ytdlp()
            ydl_opts = {
                "quiet": True,
                "no_warnings": True,
                "skip_download": True,
                "noplaylist": False,
                "playlistend": 30,
                "lazy_playlist": True,
                "extract_flat": "in_playlist",
                "ignoreerrors": True,
            }
            results = []
            with ytdlp_cls(ydl_opts) as ydl:
                info = ydl.extract_info(url, download=False)
            entries = list((info or {}).get("entries") or [])
            if not entries and isinstance(info, dict) and str(info.get("_type") or "") == "url":
                retry_url = str(info.get("url") or info.get("webpage_url") or "").strip()
                if retry_url:
                    with ytdlp_cls(ydl_opts) as ydl:
                        info = ydl.extract_info(retry_url, download=False)
                    entries = list((info or {}).get("entries") or [])
            total_entries = len(entries)
            for idx, entry in enumerate(entries):
                try:
                    if not entry:
                        continue
                    title = str(entry.get("title") or "").strip()
                    author = str(entry.get("uploader") or entry.get("channel") or "YouTube").strip()
                    duration = entry.get("duration")
                    dur_sec = self._parse_duration_seconds(duration, 0)
                    video_id = str(entry.get("id") or "").strip()
                    webpage = str(entry.get("url") or entry.get("webpage_url") or "").strip()
                    if not video_id and webpage:
                        qs = urllib.parse.parse_qs(urllib.parse.urlparse(webpage).query or "")
                        if qs.get("v"):
                            video_id = str(qs.get("v")[0] or "").strip()
                    if video_id:
                        results.append({
                            "id": video_id,
                            "title": title or "Track",
                            "author": author or "YouTube",
                            "length": dur_sec,
                            "thumbnail": "https://i.ytimg.com/vi/{0}/sddefault.jpg".format(video_id),
                            "url": "https://www.youtube.com/watch?v=" + video_id,
                        })
                        continue
                    clean_item = {"title": title or "Track", "author": author or "YouTube"}
                    match_artist, match_title = self._clean_music_metadata(clean_item)
                    matched = self._resolve_playlist_candidate(match_title or title, match_artist or author, dur_sec)
                    if matched:
                        results.append(matched)
                        continue
                    fallback_id = str(self._extract_video_id({"url": webpage}) or "").strip()
                    if fallback_id:
                        results.append({
                            "id": fallback_id,
                            "title": title or "Track",
                            "author": author or "YouTube",
                            "length": dur_sec,
                            "thumbnail": "https://i.ytimg.com/vi/{0}/sddefault.jpg".format(fallback_id),
                            "url": "https://www.youtube.com/watch?v=" + fallback_id,
                        })
                except Exception as entry_error:
                    self._trace("playlist entry skip: {0}".format(entry_error), "DEBUG")
                try:
                    if callable(progress_cb):
                        progress_cb(int(idx + 1), int(total_entries))
                except Exception:
                    pass
            return results
        except Exception as e:
            raise Exception("Playlist resolve failed: {0}".format(e))

    def _play_saved_playlist(self, playlist_url=None, shuffle=False, start_index=0):
        try:
            playlist_url = str(playlist_url or self._playlist_url()).strip()
            if not playlist_url:
                BulletinHelper.show_info(self._tr("panel_playlist_empty"))
                return False

            def _worker():
                try:
                                                                             
                    run_on_ui_thread(lambda: self._show_loading_sheet(title_key="playlist_preparing"))
                    
                    self._continue_token += 1
                    self._queue_items = []
                    self._clear_hard_stop()
                    try:
                                                                                                
                                                                                            
                                                                                           
                        pass
                    except Exception:
                        pass
                    run_on_ui_thread(lambda: self._dismiss_all_pomme_ui(keep_loading=True))
                    run_on_ui_thread(lambda: self._notify_info(self._tr("playlist_preparing")))
                    run_on_ui_thread(lambda: self._show_player_bulletin("playlist_loading"))
                    items = list(self._source_playlist_tracks(playlist_url) or [])
                    if (not items) and self._smart_cache_enabled():
                        items = self._playlist_listing_items(playlist_url)
                    try:
                        if not items:
                            items = self._resolve_playlist_entries(playlist_url)
                        else:
                            threading.Thread(
                                target=lambda: self._warm_playlist_cache_async({"name": "Playlist", "url": playlist_url}),
                                daemon=True,
                            ).start()
                    except Exception as resolve_error:
                        self._trace("playlist resolve failed, trying Smart Cache fallback: {0}".format(resolve_error), "WARN")
                        if self._smart_cache_enabled():
                            items = self._playlist_listing_items(playlist_url) or self._cached_playlist_items(playlist_url)
                        if not items:
                            raise
                    if not items:
                        run_on_ui_thread(lambda: self._show_error_sheet(self._tr("playlist_empty")))
                        return
                    
                                                                                     
                    shuffle_seed = 0
                    if shuffle:
                        import random
                        shuffle_seed = random.getrandbits(31)
                        rng = random.Random(shuffle_seed)
                        rng.shuffle(items)
                        
                    playlist_name = "Playlist"
                    for entry in self._playlists():
                        if str(entry.get("url") or "").strip() == playlist_url:
                            playlist_name = str(entry.get("name") or "Playlist").strip() or "Playlist"
                            break
                    self._remember_playlist_listing(playlist_url, items, playlist_name)
                    safe_start_index = max(0, min(int(start_index or 0), max(0, len(items) - 1)))
                    base_item = dict(items[safe_start_index] if items else items[0]) if items else {}
                    base_ctx = {
                        "query": "playlist",
                        "results": list(items),
                        "index": int(safe_start_index),
                        "item": dict(base_item or (items[0] if items else {})),
                        "playlist": True,
                        "playlist_url": playlist_url,
                        "playlist_name": playlist_name,
                        "shuffle": shuffle,
                        "play_seed": shuffle_seed if shuffle else 0,
                    }
                    base_ctx = self._hydrate_cached_playlist_item(base_ctx)
                    
                                                                      
                    run_on_ui_thread(lambda: self._dismiss_all_pomme_ui(keep_loading=True))
                    
                    if not str(((base_ctx.get("item") or {}).get("cached_file") or "")).strip():
                        try:
                            run_on_ui_thread(lambda: self._notify_info(self._tr("playlist_preparing")))
                        except Exception:
                            pass
                    try:
                        run_on_ui_thread(lambda: self._notify_info(self._tr("playlist_started").format(playlist_name)))
                    except Exception:
                        pass
                    self._queue_items = []
                    self._prefetch_playlist_cache(base_ctx)
                    start_item = dict((base_ctx.get("item") or items[safe_start_index]) or items[safe_start_index])
                    run_on_ui_thread(lambda: self._start_music_player(start_item, play_ctx=base_ctx, user_initiated=True))
                except Exception as e:
                    self._trace("playlist play fail: {0}".format(e), "ERROR")
                    run_on_ui_thread(lambda: self._show_error_sheet(str(e)))

            threading.Thread(target=_worker, daemon=True).start()
            return True
        except Exception as e:
            self._trace("playlist play bootstrap fail: {0}".format(e), "ERROR")
            self._show_error_sheet(str(e))
            return False

    def _current_track_meta(self):
        try:
                                                   
            if self._active_play_ctx and self._active_play_ctx.get("item"):
                item = self._active_play_ctx["item"]
                return str(item.get("title") or ""), str(item.get("author") or "")
            
            MediaController = jclass("org.telegram.messenger.MediaController")
            msg_obj = MediaController.getInstance().getPlayingMessageObject()
            
                                                                                    
                                             
            if msg_obj is None:
                if self._last_started_item:
                    return str(self._last_started_item.get("title") or ""), str(self._last_started_item.get("author") or "")
                return "", ""
            
            title = ""
            artist = ""
            try:
                title = str(msg_obj.getMusicTitle() or "").strip()
            except Exception:
                title = ""
            try:
                artist = str(msg_obj.getMusicAuthor() or "").strip()
            except Exception:
                artist = ""
            if not title:
                try:
                    title = str(msg_obj.getDocumentName() or "").strip()
                except Exception:
                    title = ""
            return title, artist
        except Exception:
            return "", ""

    def _current_track_item(self):
        try:
            if isinstance(self._active_play_ctx, dict) and isinstance(self._active_play_ctx.get("item"), dict):
                return dict(self._active_play_ctx.get("item") or {})
            if isinstance(self._last_started_item, dict):
                return dict(self._last_started_item or {})
            return {}
        except Exception:
            return {}

    def _lyrics_clean_title(self, title):
        try:
            cleaned = str(title or "").strip()
            if not cleaned:
                return ""
            patterns = [
                r"\s*\(.*?(official|video|audio|lyrics|lyric|visualizer|hd|hq|4k|remaster|remix|live|acoustic|version|edit|extended|radio|clean|explicit).*?\)",
                r"\s*\[.*?(official|video|audio|lyrics|lyric|visualizer|hd|hq|4k|remaster|remix|live|acoustic|version|edit|extended|radio|clean|explicit).*?\]",
                r"\s*ã€.*?ã€‘",
                r"\s*\|.*$",
                r"\s*-\s*(official|video|audio|lyrics|lyric|visualizer).*$",
                r"\s*\(feat\..*?\)",
                r"\s*\(ft\..*?\)",
                r"\s*feat\..*$",
                r"\s*ft\..*$",
            ]
            for pattern in patterns:
                cleaned = re.sub(pattern, "", cleaned, flags=re.I).strip()
            cleaned = re.sub(r"\s{2,}", " ", cleaned).strip(" -|")
            return cleaned
        except Exception:
            return str(title or "").strip()

    def _lyrics_clean_artist(self, artist):
        try:
            cleaned = str(artist or "").strip()
            if not cleaned:
                return ""
            for separator in [" & ", " and ", ", ", " x ", " X ", " feat. ", " feat ", " ft. ", " ft ", " featuring ", " with "]:
                if separator.lower() in cleaned.lower():
                    cleaned = re.split(re.escape(separator), cleaned, maxsplit=1, flags=re.I)[0]
                    break
            cleaned = re.sub(r"\s+\b(topic|official|vevo|presents|records|channel|music)\b.*$", "", cleaned, flags=re.I).strip(" -")
            cleaned = re.sub(r"\s{2,}", " ", cleaned).strip()
            return cleaned
        except Exception:
            return str(artist or "").strip()

    def _lyrics_norm(self, text):
        try:
            text = _html.unescape(str(text or ""))
            text = re.sub(r"\[[^\]]+\]", " ", text)
            text = re.sub(r"[^a-z0-9]+", " ", text.lower())
            return re.sub(r"\s{2,}", " ", text).strip()
        except Exception:
            return str(text or "").strip().lower()

    def _lyrics_match_score(self, want_title, want_artist, cand_title, cand_artist, cand_duration=0, target_duration=0):
        try:
            wt = self._lyrics_norm(want_title)
            wa = self._lyrics_norm(want_artist)
            ct = self._lyrics_norm(cand_title)
            ca = self._lyrics_norm(cand_artist)
            score = 0
            if wt and ct:
                if wt == ct:
                    score += 120
                elif wt in ct or ct in wt:
                    score += 80
                else:
                    score += max(0, 60 - (abs(len(wt) - len(ct)) * 2))
            if wa and ca:
                if wa == ca:
                    score += 90
                elif wa in ca or ca in wa:
                    score += 60
            td = int(target_duration or 0)
            cd = int(cand_duration or 0)
            if td > 0 and cd > 0:
                delta = abs(td - cd)
                if delta <= 2:
                    score += 40
                elif delta <= 5:
                    score += 26
                elif delta <= 8:
                    score += 12
            return int(score)
        except Exception:
            return 0

    def _lyrics_normalize_text(self, lyrics, keep_timestamps=False):
        try:
            text = _html.unescape(str(lyrics or ""))
            if not keep_timestamps:
                text = re.sub(r'\[\d{1,2}:\d{2}(?:\.\d+)?\]', '', text)
            text = text.replace('\r', '')
            text = re.sub(r'<[^>]+>', '\n', text)
            text = re.sub(r'\n{3,}', '\n\n', text).strip()
            return text if len(text) >= 20 else ""
        except Exception:
            return ""

    def _read_cached_lyrics_variants(self, title, artist):
        try:
            attempts = []
            raw_title = str(title or "").strip()
            raw_artist = str(artist or "").strip()
            clean_title = self._lyrics_clean_title(raw_title)
            clean_artist = self._lyrics_clean_artist(raw_artist)
            miss_pair = None
            for key_title, key_artist in (
                (raw_title, raw_artist),
                (clean_title, clean_artist),
                (clean_title, raw_artist),
                (raw_title, clean_artist),
            ):
                pair = (str(key_title or "").strip(), str(key_artist or "").strip())
                if pair in attempts:
                    continue
                attempts.append(pair)
                cached = self._read_cached_lyrics(pair[0], pair[1])
                if cached is not None:
                    if str(cached or "").strip():
                        return cached, pair[0], pair[1]
                    if miss_pair is None:
                        miss_pair = pair
            if miss_pair is not None:
                return "", miss_pair[0], miss_pair[1]
            return None, raw_title, raw_artist
        except Exception:
            return None, str(title or "").strip(), str(artist or "").strip()

    def _lyrics_attempt_pairs(self, title, artist, item=None):
        try:
            seen = set()
            pairs = []
            raw_title = str(title or "").strip()
            raw_artist = str(artist or "").strip()
            item = dict(item or {})
            item_title = str(item.get("title") or "").strip()
            item_artist = str(item.get("author") or "").strip()
            meta_artist, meta_title = self._clean_music_metadata({
                "title": item_title or raw_title,
                "author": item_artist or raw_artist,
            })

            candidates = [
                (raw_title, raw_artist),
                (self._lyrics_clean_title(raw_title), self._lyrics_clean_artist(raw_artist)),
                (self._lyrics_clean_title(raw_title), raw_artist),
                (raw_title, self._lyrics_clean_artist(raw_artist)),
                (item_title, item_artist),
                (self._lyrics_clean_title(item_title), self._lyrics_clean_artist(item_artist)),
                (meta_title, meta_artist),
                (self._lyrics_clean_title(meta_title), self._lyrics_clean_artist(meta_artist)),
                (meta_title, raw_artist),
                (self._lyrics_clean_title(meta_title), ""),
                (self._lyrics_clean_title(raw_title), ""),
            ]
            for cand_title, cand_artist in candidates:
                pair = (str(cand_title or "").strip(), str(cand_artist or "").strip())
                if not pair[0] or pair in seen:
                    continue
                seen.add(pair)
                pairs.append(pair)
            return pairs
        except Exception:
            return [(str(title or "").strip(), str(artist or "").strip())]

    def _cache_lyrics_for_pairs(self, pairs, text, missing=False):
        try:
            ok = False
            for pair in list(pairs or []):
                try:
                    if self._write_cached_lyrics(pair[0], pair[1], text, missing=missing):
                        ok = True
                except Exception:
                    pass
            return ok
        except Exception:
            return False

    def _fetch_lrclib_lyrics(self, title, artist, duration=0, item=None):
        try:
            title = str(title or "").strip()
            artist = str(artist or "").strip()
            duration = int(duration or 0)
            if not title:
                return ""

            attempt_pairs = self._lyrics_attempt_pairs(title, artist, item)
            item_cached = self._read_cached_lyrics_for_item(item)
            if item_cached is not None:
                return item_cached
            cached, cache_title, cache_artist = self._read_cached_lyrics_variants(title, artist)
            if cached is not None:
                try:
                    self._write_cached_lyrics_for_item(item, cached, missing=not bool(str(cached or "").strip()))
                except Exception:
                    pass
                return cached

            clean_title = self._lyrics_clean_title(title)
            clean_artist = self._lyrics_clean_artist(artist)
            had_network_error = False

            def _decode_json(req_url):
                req = Request(req_url, headers={"User-Agent": "Mozilla/5.0", "Accept": "application/json"})
                with urlopen(req, timeout=7) as resp:
                    raw = resp.read()
                return json.loads(raw.decode("utf-8", "ignore")) if raw else None

            for q_title, q_artist in list(attempt_pairs or []):
                params = urllib.parse.urlencode({
                    "track_name": q_title,
                    "artist_name": q_artist,
                })
                try:
                    data = _decode_json("https://lrclib.net/api/get?" + params)
                    lyrics = self._lyrics_normalize_text((data or {}).get("syncedLyrics") or (data or {}).get("plainLyrics") or "")
                    if lyrics:
                        self._trace("lyrics resolved from primary source (exact) | title={0} artist={1}".format(q_title, q_artist), "INFO")
                        self._cache_lyrics_for_pairs(attempt_pairs, lyrics)
                        self._write_cached_lyrics_for_item(item, lyrics)
                        return lyrics
                except Exception as e:
                    had_network_error = True
                    self._trace("lyrics primary exact skipped: {0}".format(e), "DEBUG")

            queries = []
            for query in (
                {"track_name": clean_title, "artist_name": clean_artist},
                {"track_name": clean_title},
                {"q": "{0} {1}".format(clean_artist, clean_title).strip()},
                {"q": clean_title},
                {"q": "{0} {1}".format(artist, title).strip()},
                {"q": "{0} {1}".format(cache_artist, cache_title).strip()},
            ):
                qkey = json.dumps(query, sort_keys=True)
                if qkey not in queries:
                    queries.append(qkey)

            best_lyrics = ""
            best_score = -1
            for qkey in queries:
                query = json.loads(qkey)
                try:
                    data = _decode_json("https://lrclib.net/api/search?" + urllib.parse.urlencode(query))
                except Exception as e:
                    had_network_error = True
                    self._trace("lyrics primary search skipped: {0}".format(e), "DEBUG")
                    data = None
                if not isinstance(data, list):
                    continue
                for item in data[:12]:
                    lyrics = self._lyrics_normalize_text((item or {}).get("syncedLyrics") or (item or {}).get("plainLyrics") or "")
                    if not lyrics:
                        continue
                    score = self._lyrics_match_score(
                        clean_title or title,
                        clean_artist or artist,
                        (item or {}).get("trackName") or (item or {}).get("name") or title,
                        (item or {}).get("artistName") or (item or {}).get("artist") or artist,
                        self._parse_duration_seconds((item or {}).get("duration"), 0),
                        duration,
                    )
                    if score > best_score:
                        best_score = score
                        best_lyrics = lyrics
                if best_score >= 145:
                    break

            if best_lyrics:
                self._trace("lyrics resolved from primary source (search) score={0}".format(best_score), "INFO")
                self._cache_lyrics_for_pairs(attempt_pairs, best_lyrics)
                self._write_cached_lyrics_for_item(item, best_lyrics)
                return best_lyrics

            if not had_network_error:
                self._cache_lyrics_for_pairs(attempt_pairs, "", missing=True)
                self._write_cached_lyrics_for_item(item, "", missing=True)
            return ""
        except Exception:
            try:
                pass
            except Exception:
                pass
            return ""

    def _fetch_alt_lyrics(self, title, artist, duration=0, item=None):
        try:
            title = str(title or "").strip()
            artist = str(artist or "").strip()
            duration = int(duration or 0)
            if not title:
                return ""
            item_cached = self._read_cached_lyrics_for_item(item)
            if item_cached is not None:
                return item_cached
            attempt_pairs = self._lyrics_attempt_pairs(title, artist, item)
            clean_title = self._lyrics_clean_title(title)
            clean_artist = self._lyrics_clean_artist(artist)

            def _decode_json(req_url):
                req = Request(req_url, headers={"User-Agent": "Mozilla/5.0", "Accept": "application/json,text/plain;q=0.9,*/*;q=0.8"})
                with urlopen(req, timeout=8) as resp:
                    raw = resp.read()
                return json.loads(raw.decode("utf-8", "ignore")) if raw else None

            for q_title, q_artist in list(attempt_pairs or []):
                try:
                    params = urllib.parse.urlencode({"s": q_title, "a": q_artist, "d": duration or 0})
                    data = _decode_json("https://lyrics-api.boidu.dev/getLyrics?" + params)
                    ttml = str((data or {}).get("ttml") or "").strip()
                    if not ttml:
                        continue
                    text = self._lyrics_normalize_text(re.sub(r"<br\s*/?>", "\n", re.sub(r"</p>", "\n", re.sub(r"<[^>]+>", "", ttml))), keep_timestamps=False)
                    if text:
                        self._trace("lyrics resolved from secondary source (timed) | title={0} artist={1}".format(q_title, q_artist), "INFO")
                        self._cache_lyrics_for_pairs(attempt_pairs, text)
                        self._write_cached_lyrics_for_item(item, text)
                        return text
                except Exception:
                    pass

            for q_title, q_artist in list(attempt_pairs or []):
                try:
                    req = Request(
                        "https://api.lyrics.ovh/v1/{0}/{1}".format(
                            urllib.parse.quote(q_artist or "", safe=""),
                            urllib.parse.quote(q_title or "", safe=""),
                        ),
                        headers={"User-Agent": "Mozilla/5.0", "Accept": "application/json"},
                    )
                    with urlopen(req, timeout=7) as resp:
                        data = json.loads(resp.read().decode("utf-8", "ignore"))
                    text = self._lyrics_normalize_text((data or {}).get("lyrics") or "")
                    if text:
                        self._trace("lyrics resolved from secondary source (plain) | title={0} artist={1}".format(q_title, q_artist), "INFO")
                        self._cache_lyrics_for_pairs(attempt_pairs, text)
                        self._write_cached_lyrics_for_item(item, text)
                        return text
                except Exception:
                    pass
            for q_title, _q_artist in list(attempt_pairs or []):
                try:
                    req = Request(
                        "https://api.textyl.co/api/lyrics?q={0}".format(
                            urllib.parse.quote(q_title or "", safe="")
                        ),
                        headers={"User-Agent": "Mozilla/5.0", "Accept": "application/json"},
                    )
                    with urlopen(req, timeout=7) as resp:
                        data = json.loads(resp.read().decode("utf-8", "ignore"))
                    text = self._lyrics_normalize_text((data or {}).get("lyrics") or (data or {}).get("text") or "")
                    if text:
                        self._trace("lyrics resolved from secondary source (query) | title={0}".format(q_title), "INFO")
                        self._cache_lyrics_for_pairs(attempt_pairs, text)
                        self._write_cached_lyrics_for_item(item, text)
                        return text
                except Exception:
                    pass
            return ""
        except Exception:
            return ""

    def _show_lyrics_sheet(self, ctx, title, artist, lyrics_text):
        try:
            sheet = BottomSheet(ctx, True)
            try:
                sheet.setCanDismissWithSwipe(False)
            except Exception:
                pass
            container = LinearLayout(ctx)
            container.setOrientation(LinearLayout.VERTICAL)
            container.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(20), AndroidUtilities.dp(20), AndroidUtilities.dp(16))

            header_row = LinearLayout(ctx)
            header_row.setOrientation(LinearLayout.HORIZONTAL)
            header_row.setGravity(Gravity.CENTER_VERTICAL)

            title_wrap = LinearLayout(ctx)
            title_wrap.setOrientation(LinearLayout.VERTICAL)
            title_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)

            title_view = TextView(ctx)
            title_view.setText(str(title or "Lyrics"))
            title_view.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
            title_view.setTextSize(20)
            title_view.setTypeface(None, 1)
            title_wrap.addView(title_view)

            subtitle = TextView(ctx)
            subtitle.setText(str(artist or ""))
            subtitle.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            subtitle.setTextSize(14)
            title_wrap.addView(subtitle)
            header_row.addView(title_wrap, title_lp)

            close_view = TextView(ctx)
            close_view.setText("×")
            close_view.setTextSize(22)
            close_view.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
            close_view.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(6), AndroidUtilities.dp(4), AndroidUtilities.dp(6))
            listener_cls = find_class("android.view.View$OnClickListener")
            if listener_cls is not None:
                class _Close(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        sheet.dismiss()
                close_view.setOnClickListener(_Close())
            header_row.addView(close_view)
            container.addView(header_row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            try:
                lyrics_text = lyrics_text.replace("\\n", "\n")
                lyrics_text = _html.unescape(lyrics_text)
                lyrics_text = re.sub(r'\[[^\]]+\]', '\n\n', lyrics_text)
                lyrics_text = re.sub(r'\n{3,}', '\n\n', lyrics_text).strip()
            except Exception:
                pass

            WebView = jclass("android.webkit.WebView")
            web = WebView(ctx)
            try:
                web.setBackgroundColor(0x00000000)
            except Exception:
                pass
            try:
                settings = web.getSettings()
                settings.setJavaScriptEnabled(True)
                settings.setDomStorageEnabled(True)
            except Exception:
                pass
            safe_text = str(lyrics_text or "").replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
            paras = [p for p in safe_text.split("\n\n") if p.strip()]
            html_body = "".join(["<p>{0}</p>".format(p.replace("\n", "<br>")) for p in paras]) or "<p>{0}</p>".format(safe_text.replace("\n", "<br>"))
            try:
                bg_color = int(Theme.getColor(Theme.key_dialogBackground))
            except Exception:
                bg_color = int(Theme.getColor(Theme.key_windowBackgroundWhite))
            text_color = int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            html = (
                "<html><head><style>"
                "body{background:#__BG__;color:#__FG__;font-family:'Google Sans','Roboto',sans-serif;padding:0;margin:0;}"
                ".wrap{padding:18px 18px 22px 18px;}"
                ".ly{line-height:2.1;font-size:34px;color:#__FG__;font-weight:800;letter-spacing:0.2px;}"
                ".ly p{margin:0 0 22px 0;}"
                "</style>"
                "<script>"
                "let pommeAuto=true;"
                "let pommeTouchTs=Date.now();"
                "const pommeDelay=2000;"
                "function pommeTick(){"
                " if(!pommeAuto) return;"
                " const max=document.documentElement.scrollHeight-window.innerHeight;"
                " if(max<=0) return;"
                " if((Date.now()-pommeTouchTs)<pommeDelay) return;"
                " window.scrollBy(0,1);"
                " if((window.scrollY+window.innerHeight)>=document.documentElement.scrollHeight-2){window.scrollTo(0,0);}"
                "}"
                "setInterval(pommeTick, 42);"
                "function pommePause(){pommeTouchTs=Date.now();}"
                "</script>"
                "</head><body><div class='wrap'><div class='ly'>__BODY__</div></div></body></html>"
            )
            html = html.replace("__BG__", "{0:06x}".format(bg_color & 0xFFFFFF))
            html = html.replace("__FG__", "{0:06x}".format(text_color & 0xFFFFFF))
            html = html.replace("__BODY__", html_body)
            web.loadDataWithBaseURL(None, html, "text/html", "utf-8", None)
            web_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(460))
            web_lp.topMargin = AndroidUtilities.dp(12)
            try:
                Listener = find_class("android.view.View$OnTouchListener")
            except Exception:
                Listener = None
            if Listener is not None:
                try:
                    class _Touch(dynamic_proxy(Listener)):
                        def onTouch(self, v, event):
                            try:
                                action = event.getAction()
                                if action in (0, 1, 2, 3):
                                    parent = v.getParent()
                                    if parent:
                                        parent.requestDisallowInterceptTouchEvent(True)
                                    try:
                                        v.evaluateJavascript("pommePause();", None)
                                    except Exception:
                                        pass
                            except Exception:
                                pass
                            return False
                    web.setOnTouchListener(_Touch())
                except Exception:
                    pass
            container.addView(web, web_lp)

            sheet.setCustomView(container)
            sheet.show()
        except Exception as e:
            tb = traceback.format_exc()
            self._trace("show lyrics sheet fail: {0}\n{1}".format(e, tb), "ERROR")
            self._show_error_sheet(self._tr("lyrics_error"), ctx)

    def _open_current_lyrics(self):
        try:
            if bool(getattr(self, "_lyrics_fetching", False)):
                return False
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                try:
                    ctx = self._last_player_alert.getContext() if self._last_player_alert is not None else None
                except Exception:
                    ctx = None
            if ctx is None:
                self._trace("lyrics open aborted: context unavailable", "ERROR")
                self._show_error_sheet(self._tr("lyrics_error"))
                return False
            title, artist = self._current_track_meta()
            if not title:
                self._trace("lyrics open aborted: title unavailable", "ERROR")
                self._show_error_sheet(self._tr("lyrics_error"))
                return False
            self._lyrics_fetching = True
            self._notify_info(self._tr("lyrics_started"))

            def _worker():
                try:
                    current_item = self._current_track_item()
                    duration = self._parse_duration_seconds((current_item or {}).get("length") or (current_item or {}).get("duration"), 0)
                    lyrics = self._fetch_lrclib_lyrics(title, artist, duration, current_item)
                    if not lyrics:
                        lyrics = self._fetch_alt_lyrics(title, artist, duration, current_item)
                    if not lyrics:
                        clean_artist, clean_title = self._clean_music_metadata(current_item or {"title": title, "author": artist})
                        retry_title = str(clean_title or title).strip()
                        retry_artist = str(clean_artist or artist).strip()
                        if retry_title and (retry_title != str(title or "").strip() or retry_artist != str(artist or "").strip()):
                            lyrics = self._fetch_lrclib_lyrics(retry_title, retry_artist, duration, current_item)
                            if not lyrics:
                                lyrics = self._fetch_alt_lyrics(retry_title, retry_artist, duration, current_item)
                    if not lyrics:
                        self._trace("lyrics not found | title={0} artist={1}".format(title, artist), "WARN")
                        run_on_ui_thread(lambda: self._show_error_sheet(self._tr("lyrics_not_found"), ctx))
                        return
                    run_on_ui_thread(lambda: self._show_lyrics_sheet(ctx, title, artist, lyrics))
                except Exception as e:
                    self._trace("open lyrics fail: {0}".format(e), "ERROR")
                    run_on_ui_thread(lambda: self._show_error_sheet(self._tr("lyrics_error"), ctx))
                finally:
                    self._lyrics_fetching = False

            threading.Thread(target=_worker, daemon=True).start()
            return True
        except Exception as e:
            self._trace("lyrics bootstrap fail: {0}".format(e), "ERROR")
            self._show_error_sheet(self._tr("lyrics_error"))
            return False

    def _player_alert_set_placeholder(self, title_text, subtitle_text):
        try:
            alert_obj = self._last_player_alert
            if alert_obj is None:
                return False
            title_view = None
            author_view = None
            try:
                title_view = get_private_field(alert_obj, "titleTextView")
            except Exception:
                title_view = None
            try:
                author_view = get_private_field(alert_obj, "authorTextView")
            except Exception:
                author_view = None
            if title_view is not None:
                try:
                    title_view.setText(str(title_text or ""))
                except Exception:
                    pass
            if author_view is not None:
                try:
                    author_view.setText(str(subtitle_text or ""))
                except Exception:
                    pass
            return bool(title_view is not None or author_view is not None)
        except Exception as e:
            self._trace("player placeholder fail: {0}".format(e), "ERROR")
            return False

    def _is_anything_playing(self):
        try:
                                          
            MediaController = jclass("org.telegram.messenger.MediaController")
            media = MediaController.getInstance()
            current = media.getPlayingMessageObject()
            
                                                                                    
                                                                     
            is_paused = True
            try: is_paused = bool(media.isMessagePaused())
            except Exception: pass
            
                                                    
            custom_playing = False
            if self._custom_player is not None:
                try:
                    if self._custom_player.isPlaying():
                        custom_playing = True
                except Exception: pass

            native_present = current is not None
            active_ctx = self._active_play_ctx is not None
            if native_present and is_paused and active_ctx and not bool(getattr(self, "_waiting_for_track_change", False)):
                self._recent_paused_stop_hint_until = float(time.time()) + 3.2
            native_playing = native_present and not is_paused
            res = native_playing or custom_playing
            self._trace("Is playing check: native={0} custom={1} paused={2} active_ctx={3} -> {4}".format(native_playing, custom_playing, is_paused, active_ctx, res), "DEBUG")
            return res
        except Exception as e:
            self._trace("Is playing check fail: {0}".format(e), "ERROR")
            return False

    def _handle_manual_stop(self):
        try:
            self._trace("media cleanup hook observed", "DEBUG")
            if not self._is_current_pomme_track():
                return False
            if self._is_hard_stop_active():
                self._trace("media cleanup observed during hard stop", "INFO")
                return True
            self._trace("media cleanup observed; preserving Pomme context", "INFO")
            return True
        except Exception as e:
            self._trace("manual stop handling fail: {0}".format(e), "ERROR")
            return False

    def _handle_pause_request_hint(self):
        try:
            self._trace("media pause hook observed", "DEBUG")
            if not self._is_current_pomme_track():
                return False
            if self._transport_skip_cleanup_active():
                self._trace("media pause ignored during transport skip cleanup", "DEBUG")
                return False
            if self._waiting_track_change_active():
                self._trace("media pause ignored during track change", "DEBUG")
                return False
            self._recent_manual_stop_hint_until = float(time.time()) + 2.5
            self._trace("manual stop hint armed from pause request", "INFO")
            return True
        except Exception as e:
            self._trace("pause hint fail: {0}".format(e), "ERROR")
            return False

    def _handle_cleanup_player_request(self, param=None):
        try:
            self._trace("media cleanupPlayer hook observed", "DEBUG")
            if not self._is_current_pomme_track():
                return False
            if self._transport_skip_cleanup_active():
                self._trace("cleanupPlayer ignored during transport skip cleanup", "DEBUG")
                return False
            if self._waiting_track_change_active():
                self._trace("cleanupPlayer ignored during track change", "DEBUG")
                return False
            arg0 = None
            arg1 = None
            try:
                args = list(getattr(param, "args", []) or [])
                if len(args) > 0:
                    arg0 = bool(args[0])
                if len(args) > 1:
                    arg1 = bool(args[1])
            except Exception:
                pass
            self._recent_manual_stop_hint_until = float(time.time()) + 2.8
            self._trace("manual stop hint armed from cleanupPlayer request flags={0},{1}".format(arg0, arg1), "INFO")
            return True
        except Exception as e:
            self._trace("cleanupPlayer hint fail: {0}".format(e), "ERROR")
            return False

    def _recent_manual_stop_hint_active(self):
        try:
            return float(getattr(self, "_recent_manual_stop_hint_until", 0.0) or 0.0) > float(time.time())
        except Exception:
            return False

    def _recent_paused_stop_hint_active(self):
        try:
            return float(getattr(self, "_recent_paused_stop_hint_until", 0.0) or 0.0) > float(time.time())
        except Exception:
            return False

    def _transport_skip_cleanup_active(self):
        try:
            return float(getattr(self, "_transport_skip_cleanup_until", 0.0) or 0.0) > float(time.time())
        except Exception:
            return False

    def _waiting_track_change_active(self):
        try:
            if not bool(getattr(self, "_waiting_for_track_change", False)):
                return False
            until = float(getattr(self, "_waiting_for_track_change_until", 0.0) or 0.0)
            if until <= 0.0:
                return True
            if until > float(time.time()):
                return True
            self._waiting_for_track_change = False
            self._waiting_for_track_change_until = 0.0
            self._trace("stale track change wait cleared", "DEBUG")
            return False
        except Exception:
            return bool(getattr(self, "_waiting_for_track_change", False))

    def _handle_player_sheet_closed(self, alert_obj=None):
        try:
            if not self._is_current_pomme_track():
                return False
            current_key = None
            try:
                current_key = int(alert_obj.hashCode()) if alert_obj is not None else int(self._last_player_alert.hashCode())
            except Exception:
                current_key = id(alert_obj) if alert_obj is not None else None
            if current_key is not None and current_key == self._explicit_close_alert_key:
                self._trace("player sheet dismissed after explicit close", "INFO")
                self._explicit_close_alert_key = None
            elif self._is_hard_stop_active():
                self._trace("player sheet dismissed during hard stop", "INFO")
            elif self._waiting_track_change_active():
                self._trace("player sheet dismissed during track change", "DEBUG")
                self._waiting_for_track_change = False
                self._waiting_for_track_change_until = 0.0
            else:
                self._trace("player sheet dismissed (context preserved)", "DEBUG")
                self._clear_player_present_request()
            try:
                if self._last_player_alert is not None:
                    self._player_actionbar_bound.discard(int(self._last_player_alert.hashCode()))
            except Exception:
                pass
            self._last_player_alert = None
            return True
        except Exception as e:
            self._trace("player sheet close handling fail: {0}".format(e), "ERROR")
            return False

    def _last_player_alert_visible(self):
        try:
            alert = getattr(self, "_last_player_alert", None)
            if alert is None:
                return False
            try:
                return bool(alert.isShowing())
            except Exception:
                pass
            try:
                return bool(alert.getWindow() is not None)
            except Exception:
                pass
            return True
        except Exception:
            return False

    def _show_playlist_progress_dialog(self, playlist_name):
        try:
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None: return None
            
            b = AlertDialogBuilder(ctx)
            b.set_title("Pomme Integration")
            
            layout = LinearLayout(ctx)
            layout.setOrientation(LinearLayout.VERTICAL)
            layout.setPadding(AndroidUtilities.dp(24), AndroidUtilities.dp(12), AndroidUtilities.dp(24), AndroidUtilities.dp(12))
            
            msg = TextView(ctx)
            msg.setText(str(playlist_name or "Playlist"))
            msg.setTextSize(16)
            msg.setTextColor(int(Theme.getColor(Theme.key_dialogTextBlack)))
            layout.addView(msg)
            
            prog = TextView(ctx)
            prog.setText("0%")
            prog.setTextSize(14)
            prog.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            prog.setPadding(0, AndroidUtilities.dp(8), 0, 0)
            layout.addView(prog)
            
            b.set_view(layout)
            dialog = b.show()
            
            def update(percent, text=None):
                def _upd():
                    try:
                        prog.setText("{0}%".format(int(percent)))
                        if text: msg.setText(str(text))
                    except Exception: pass
                run_on_ui_thread(_upd)
                
            return dialog, update
        except Exception:
            return None, lambda p, t=None: None

    def _warm_playlist_cache_async(self, playlist_entry, on_done=None):
        try:
            payload = dict(playlist_entry or {})
            playlist_url = str(payload.get("url") or "").strip()
            playlist_name = str(payload.get("name") or "Playlist").strip() or "Playlist"
            if not playlist_url or not self._smart_cache_enabled():
                try:
                    if callable(on_done):
                        run_on_ui_thread(lambda: on_done(False))
                except Exception:
                    pass
                return False

            dialog, update_progress = self._show_playlist_progress_dialog(playlist_name)

            def _worker():
                success = False
                try:
                    progress_state = {"total": 0}

                    def _on_resolve_progress(idx, total):
                        try:
                            total = max(1, int(total or 0))
                            current = max(0, min(int(idx or 0), total))
                            progress_state["total"] = total
                            percent = 5 + int((float(current) / float(total)) * 45.0)
                            update_progress(percent, self._tr("playlist_progress_reading").format(current, total))
                        except Exception:
                            pass

                    update_progress(5, self._tr("import_progress_fetch"))
                    items = self._resolve_playlist_entries(playlist_url, progress_cb=_on_resolve_progress)
                    if not items:
                        if dialog: run_on_ui_thread(dialog.dismiss)
                        return
                    
                    self._remember_playlist_listing(playlist_url, items, playlist_name)
                    base_ctx = {
                        "query": "playlist",
                        "results": list(items),
                        "index": 0,
                        "item": dict(items[0]),
                        "playlist": True,
                        "playlist_url": playlist_url,
                        "playlist_name": playlist_name,
                    }
                    
                    total = len(items)
                    def _on_track_cached(idx):
                        percent = 50 + int((float(idx + 1) / float(total)) * 50.0)
                        update_progress(percent, self._tr("playlist_progress_caching").format(idx + 1, total))

                    self._prefetch_playlist_cache(base_ctx, progress_cb=_on_track_cached)
                    
                    update_progress(100, self._tr("playlist_progress_done"))
                    success = True
                    time.sleep(1.0)
                    if dialog: run_on_ui_thread(dialog.dismiss)
                    
                    self._trace("playlist warm cache finished successfully", "INFO")
                except Exception as e:
                    self._trace("playlist warm cache skip: {0}".format(e), "WARN")
                    if dialog: run_on_ui_thread(dialog.dismiss)
                finally:
                    try:
                        if callable(on_done):
                            run_on_ui_thread(lambda s=bool(success): on_done(s))
                    except Exception:
                        pass

            threading.Thread(target=_worker, daemon=True).start()
            return True
        except Exception as e:
            self._trace("playlist warm cache fail: {0}".format(e), "ERROR")
            try:
                if callable(on_done):
                    run_on_ui_thread(lambda: on_done(False))
            except Exception:
                pass
            return False

    def _schedule_continue_playback(self, delay_ms=350):
        try:
                                                                      
            now = time.time()
            if hasattr(self, "_last_continue_schedule_ts") and (now - self._last_continue_schedule_ts) < 0.4:
                return False
            if self._manual_close_guard_active():
                self._trace("continue scheduling ignored due to manual close guard", "INFO")
                return False
            if self._recent_manual_stop_hint_active():
                self._trace("continue scheduling ignored due to recent manual stop hint", "INFO")
                return False
            if self._recent_paused_stop_hint_active():
                self._trace("continue scheduling ignored due to paused stop hint", "INFO")
                return False
            self._last_continue_schedule_ts = now
            
            if self._is_hard_stop_active():
                return False
            self._continue_token += 1
            token = int(self._continue_token)
            delay_s = max(0.0, float(delay_ms or 0) / 1000.0)
            timer = threading.Timer(delay_s, lambda: run_on_ui_thread(lambda: self._run_continue_playback(token)))
            timer.daemon = True
            timer.start()
            return True
        except Exception as e:
            self._trace("schedule continue bootstrap fail: {0}".format(e), "ERROR")
            return False

    def _run_continue_playback(self, token):
        try:
            if int(token) != int(self._continue_token):
                return
            self._maybe_continue_playback()
        except Exception as e:
            self._trace("run continue fail: {0}".format(e), "ERROR")

    def _ensure_playback_watch(self):
        try:
            if self._playback_watch_running:
                return
            self._playback_watch_running = True
            self._playback_watch_token += 1
            token = int(self._playback_watch_token)
            self._playback_watch_saw_playing = False
            self._playback_watch_idle_hits = 0

            def _tick():
                try:
                    if not self._playback_watch_running or int(self._playback_watch_token) != token:
                        return
                    still_relevant = bool(self._active_play_ctx or self._queue_items or self._is_anything_playing())
                    if not still_relevant:
                        self._playback_watch_running = False
                        return
                    playing = bool(self._is_anything_playing())
                    if playing:
                        self._playback_watch_saw_playing = True
                        self._playback_watch_idle_hits = 0
                    elif self._playback_watch_saw_playing:
                        self._playback_watch_idle_hits += 1
                        if self._transport_skip_cleanup_active():
                            self._trace("playback watch idle ignored during transport skip cleanup", "DEBUG")
                            timer = threading.Timer(1.0, _tick)
                            timer.daemon = True
                            timer.start()
                            return
                        if self._waiting_track_change_active():
                            self._trace("playback watch idle ignored during track change", "DEBUG")
                            timer = threading.Timer(1.0, _tick)
                            timer.daemon = True
                            timer.start()
                            return
                        if self._playback_watch_idle_hits >= 2:
                            if self._recent_manual_stop_hint_active() or self._recent_paused_stop_hint_active():
                                self._trace("playback watch end converted to manual stop via recent stop hint", "INFO")
                                self._arm_manual_close_guard(4.0)
                                self._activate_hard_stop(5.0)
                                self._manual_stop_requested = True
                                self._autoplay_blocked = True
                                self._playback_watch_running = False
                                return
                            if bool(self._active_play_ctx) and not self._waiting_track_change_active() and getattr(self, "_last_player_alert", None) is not None and not self._last_player_alert_visible():
                                self._trace("playback watch detected closed player alert -> stop", "INFO")
                                self._arm_manual_close_guard(4.0)
                                self._activate_hard_stop(5.0)
                                self._manual_stop_requested = True
                                self._autoplay_blocked = True
                                self._playback_watch_running = False
                                return
                            if self._manual_close_guard_active() or self._manual_stop_requested or self._autoplay_blocked or self._is_hard_stop_active() or self._explicit_close_alert_key is not None:
                                self._trace("playback watch end ignored due to manual close/stop", "INFO")
                                self._playback_watch_running = False
                                return
                            self._trace("playback watch detected end", "INFO")
                            self._playback_watch_running = False
                            run_on_ui_thread(lambda: self._maybe_continue_playback())
                            return
                    timer = threading.Timer(1.0, _tick)
                    timer.daemon = True
                    timer.start()
                except Exception as e:
                    self._playback_watch_running = False
                    self._trace("playback watch fail: {0}".format(e), "ERROR")

            timer = threading.Timer(1.0, _tick)
            timer.daemon = True
            timer.start()
        except Exception as e:
            self._playback_watch_running = False
            self._trace("playback watch bootstrap fail: {0}".format(e), "ERROR")

    def _playback_flags(self):
        try:
            SharedConfig = jclass("org.telegram.messenger.SharedConfig")
            repeat_mode = int(getattr(SharedConfig, "repeatMode", 0) or 0)
            if self._active_play_ctx and bool(self._active_play_ctx.get("playlist")):
                shuffle_enabled = bool(self._active_play_ctx.get("shuffle", False))
                reverse_enabled = False
                if shuffle_enabled:
                    reverse_enabled = False
                return repeat_mode, shuffle_enabled, reverse_enabled
            force_shuffle = bool((self._active_play_ctx or {}).get("shuffle", False))
            shuffle_enabled = bool(getattr(SharedConfig, "shuffleMusic", False)) or force_shuffle
            reverse_enabled = bool(getattr(SharedConfig, "playOrderReversed", False))
            if shuffle_enabled:
                reverse_enabled = False
            return repeat_mode, shuffle_enabled, reverse_enabled
        except Exception:
            return 0, False, False

    def _context_play_order(self, ctx):
        try:
            work = dict(ctx or {})
            results = list(work.get("results") or [])
            if not results:
                return work, []
            item_ids = [str((entry or {}).get("id") or "") for entry in results]
            repeat_mode, shuffle_enabled, reverse_enabled = self._playback_flags()
            current_index = int(work.get("index", 0) or 0)
            current_index = max(0, min(current_index, len(results) - 1))
            saved_order = list(work.get("play_order") or [])
            saved_ids = list(work.get("play_order_ids") or [])
            saved_flags = dict(work.get("play_order_flags") or {})
            valid_saved = (
                len(saved_order) == len(results)
                and sorted(saved_order) == list(range(len(results)))
                and saved_ids == item_ids
                and bool(saved_flags.get("shuffle")) == shuffle_enabled
                and bool(saved_flags.get("reverse")) == reverse_enabled
            )
            if not valid_saved:
                                                        
                order = list(range(len(results)))
                if shuffle_enabled:
                    if "play_seed" in work and work.get("play_seed") is not None:
                        seed = int(work.get("play_seed"))
                    else:
                        seed = int(random.getrandbits(31))
                    rng = random.Random(seed)
                                                                           
                                                                                       
                                                                               
                    rng.shuffle(order)
                                                                                        
                    if current_index in order:
                        order.remove(current_index)
                        order.insert(0, current_index)
                    work["play_seed"] = seed
                elif reverse_enabled:
                    order = list(reversed(order))
                work["play_order"] = order
                work["play_order_ids"] = item_ids
                work["play_order_flags"] = {
                    "shuffle": shuffle_enabled,
                    "reverse": reverse_enabled,
                    "repeat": repeat_mode,
                }
            return work, list(work.get("play_order") or [])
        except Exception:
            return dict(ctx or {}), []

    def _step_from_context(self, step, wrap=False):
        try:
            ctx, order = self._context_play_order(self._active_play_ctx or {})
            results = list(ctx.get("results") or [])
            if not results or not order:
                return None
            current_index = int(ctx.get("index", 0) or 0)
            try:
                pos = order.index(current_index)
            except Exception:
                current_id = str((ctx.get("item") or {}).get("id") or "")
                pos = -1
                for idx, order_index in enumerate(order):
                    candidate = results[order_index] if 0 <= order_index < len(results) else {}
                    if str((candidate or {}).get("id") or "") == current_id:
                        pos = idx
                        current_index = order_index
                        break
                if pos < 0:
                    pos = 0
            next_pos = int(pos) + int(step)
            if wrap and order:
                next_pos %= len(order)
            if next_pos < 0 or next_pos >= len(order):
                return None
            next_index = int(order[next_pos])
            nxt = dict(ctx)
            nxt["results"] = results
            nxt["item"] = dict(results[next_index])
            nxt["index"] = next_index
            nxt["play_order"] = list(order)
            nxt["play_order_ids"] = list(ctx.get("play_order_ids") or [])
            nxt["play_order_flags"] = dict(ctx.get("play_order_flags") or {})
            if "play_seed" in ctx:
                nxt["play_seed"] = ctx.get("play_seed")
            return self._hydrate_cached_playlist_item(nxt)
        except Exception:
            return None

    def _next_from_context(self):
        try:
            direct = self._step_from_context(1, wrap=False)
            if direct is not None:
                return direct
            
                                                             
                                                                      
                                                 
            ctx = dict(self._active_play_ctx or {})
            if bool(ctx.get("playlist")):
                self._trace("End of playlist reached. Stopping.", "INFO")
                return None
                
            results = list(ctx.get("results") or [])
            if not results:
                return None
                
            if self._auto_play_enabled():
                query = str((ctx.get("item") or {}).get("author") or ctx.get("query") or "").strip()
                if query:
                    refreshed = self._search_youtube_sync(query)
                    seen = set()
                    merged = []
                    for entry in list(results) + list(refreshed or []):
                        item_id = str((entry or {}).get("id") or self._extract_video_id(entry or {}) or "").strip()
                        if not item_id or item_id in seen:
                            continue
                        seen.add(item_id)
                        normalized = dict(entry or {})
                        normalized["id"] = item_id
                        if "thumbnail" not in normalized:
                            normalized["thumbnail"] = "https://i.ytimg.com/vi/{0}/sddefault.jpg".format(item_id)
                        merged.append(normalized)
                    current_id = str((ctx.get("item") or {}).get("id") or "")
                    current_index = int(ctx.get("index", -1))
                    for idx in range(max(current_index + 1, 0), len(merged)):
                        candidate = merged[idx]
                        if str(candidate.get("id") or "") != current_id:
                            nxt = dict(ctx)
                            nxt["results"] = merged
                            nxt["item"] = candidate
                            nxt["index"] = idx
                            nxt["play_order"] = []
                            nxt["play_order_ids"] = []
                            nxt["play_order_flags"] = {}
                            return self._hydrate_cached_playlist_item(nxt)
            return None
        except Exception:
            return None

    def _prev_from_context(self):
        try:
            return self._step_from_context(-1, wrap=False)
        except Exception:
            return None

    def _remember_history(self, play_ctx):
        try:
            ctx = dict(self._active_play_ctx or {})
            if not ctx:
                return False
            next_ctx = dict(play_ctx or {})
            current_id = str((ctx.get("item") or {}).get("id") or "")
            next_id = str((next_ctx.get("item") or {}).get("id") or "")
            if current_id and current_id == next_id:
                return False
            self._history_items.append(ctx)
            if len(self._history_items) > 30:
                self._history_items = self._history_items[-30:]
            return True
        except Exception:
            return False

    def _handle_transport_skip(self, direction):
        try:
            self._touch_activity()
            self._recent_manual_stop_hint_until = 0.0
            self._recent_paused_stop_hint_until = 0.0
            if self._is_hard_stop_active():
                self._trace("transport skip ignored: hard stop active | direction={0}".format(direction), "INFO")
                return True
            target = None
            if str(direction) == "next":
                target = self._next_from_context()
                if target is None and self._queue_items:
                    target = self._queue_items.pop(0)
            elif str(direction) == "prev":
                target = self._prev_from_context()
                if target is None and self._history_items:
                    target = self._history_items.pop()
            if not target:
                self._trace("transport skip has no target | direction={0}".format(direction), "INFO")
                return False
            target = self._hydrate_cached_playlist_item(target)
            try:
                placeholder = "Playing next..." if str(direction) == "next" else "Playing previous..."
                self._player_alert_set_placeholder(placeholder, "Powered by Pomme")
            except Exception:
                pass
            self._manual_stop_requested = False
            self._autoplay_blocked = False
            self._continue_token += 1
            self._waiting_for_track_change = True
            self._waiting_for_track_change_until = float(time.time()) + 2.6
            try:
                self._remember_history(target)
            except Exception:
                pass
            try:
                self._active_play_ctx = dict(target or {})
            except Exception:
                pass
            try:
                item = dict(target.get("item") or {})
                self._trace(
                    "transport skip accepted | direction={0} | title={1} | author={2}".format(
                        direction,
                        str(item.get("title") or "").strip(),
                        str(item.get("author") or "").strip(),
                    ),
                    "INFO",
                )
            except Exception:
                pass
            try:
                target["transport_skip"] = str(direction)
            except Exception:
                pass
            self._start_music_player(
                target.get("item") or {},
                queued=bool(target.get("queued")),
                play_ctx=target,
                present_player=False,
                user_initiated=True,
            )
            try:
                def _bg_prefetch():
                    try:
                        upcoming = self._next_from_context()
                        if upcoming:
                            self._prefetch_cover((upcoming.get("item") or {}))
                    except Exception:
                        pass
                threading.Thread(target=_bg_prefetch, daemon=True).start()
            except Exception:
                pass
            return True
        except Exception as e:
            self._trace("transport skip fail: {0}".format(e), "ERROR")
            return False

    def _interrupt_current_playback_for_skip(self, direction):
        try:
            self._trace("transport skip pre-clean start | direction={0}".format(direction), "DEBUG")
            self._transport_skip_cleanup_until = float(time.time()) + 3.0
            try:
                if self._custom_player is not None:
                    try:
                        self._custom_player.pause()
                    except Exception:
                        pass
                    try:
                        self._custom_player.stop()
                    except Exception:
                        pass
                    try:
                        self._custom_player.reset()
                    except Exception:
                        pass
            except Exception:
                pass
            MediaController = jclass("org.telegram.messenger.MediaController")
            media = MediaController.getInstance()
            try:
                current = media.getPlayingMessageObject()
            except Exception:
                current = None
            if current is not None:
                try:
                    media.pauseMessage(current)
                except Exception:
                    pass
            try:
                media.cleanupPlayer(True, True)
            except Exception:
                try:
                    media.cleanup()
                except Exception:
                    pass
            self._trace("transport skip pre-clean done | direction={0}".format(direction), "DEBUG")
            return True
        except Exception as e:
            self._transport_skip_cleanup_until = 0.0
            self._trace("interrupt current playback for skip fail: {0}".format(e), "WARN")
            return False

    def _start_custom_player(self, item, file_path, stream_info, play_ctx=None):
        try:
            if not NATIVE_PLAYER_AVAILABLE or self._custom_player is None:
                self._trace("Custom player MediaPlayer class not found.", "ERROR")
                return False
            
            title = str(item.get("title") or "Unknown")
            self._trace(">>> STARTING CUSTOM PLAYER: {0}".format(title), "INFO")
            self._trace("File path: {0}".format(file_path), "INFO")
            
                                                                    
            try:
                MediaController = jclass("org.telegram.messenger.MediaController")
                mc = MediaController.getInstance()
                mc.cleanup()
                self._trace("Native MediaController cleaned.", "DEBUG")
            except Exception as e:
                self._trace("Failed to clean native MediaController: {0}".format(e), "WARN")
            
                                            
            try:
                self._custom_player.reset()
                self._custom_player.setDataSource(file_path)
                
                plugin = self
                class _OnPrepared(dynamic_proxy(jclass("android.media.MediaPlayer$OnPreparedListener"))):
                    def onPrepared(self_obj, mp):
                        plugin._trace("MediaPlayer PREPARED. Calling start().", "INFO")
                        try:
                            mp.start()
                            plugin._trace("MediaPlayer.start() executed.", "INFO")
                                                                              
                            run_on_ui_thread(lambda: plugin._show_custom_player_overlay(item))
                        except Exception as start_err:
                            plugin._trace("MediaPlayer.start() FAILED: {0}".format(start_err), "ERROR")
                
                class _OnError(dynamic_proxy(jclass("android.media.MediaPlayer$OnErrorListener"))):
                    def onError(self_obj, mp, what, extra):
                        plugin._trace("MediaPlayer ERROR: what={0} extra={1}".format(what, extra), "ERROR")
                        return False

                class _OnComplete(dynamic_proxy(jclass("android.media.MediaPlayer$OnCompletionListener"))):
                    def onCompletion(self_obj, mp):
                        plugin._trace("Track FINISHED. Continuing to next...", "INFO")
                        run_on_ui_thread(lambda: plugin._maybe_continue_playback())

                self._custom_player.setOnPreparedListener(_OnPrepared())
                self._custom_player.setOnErrorListener(_OnError())
                self._custom_player.setOnCompletionListener(_OnComplete())
                
                self._trace("Calling prepareAsync()...", "DEBUG")
                self._custom_player.prepareAsync()
                
            except Exception as pe:
                self._trace("MediaPlayer Setup Error: {0}".format(pe), "ERROR")
                return False
            
            self._manual_stop_requested = False
            self._autoplay_blocked = False
            self._clear_manual_close_guard()
            self._active_play_ctx = dict(play_ctx or {"item": dict(item or {})})
            return True
        except Exception as e:
            self._trace("Critical Custom Player Failure: {0}".format(e), "ERROR")
            return False

    def _show_custom_player_overlay(self, item):
        try:
            self._trace("Attempting to show Music Panel for: {0}".format(item.get("title") if item else "None"), "INFO")
            def _show():
                try:
                    frag = get_last_fragment()
                    ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
                    if ctx is None: 
                        self._trace("Music Panel abort: no context", "ERROR")
                        return
                    
                    self._trace("Music Panel: Context found, building UI", "DEBUG")
                    self._last_started_item = dict(item or {})
                    if self._custom_player_ui:
                        try: 
                            self._trace("Music Panel: Dismissing previous UI (internal)", "DEBUG")
                            self._internal_dismiss = True
                            self._custom_player_ui.dismiss()
                        except Exception: pass
                    
                    current_performer, current_title = self._clean_music_metadata(item)
                    rebuilt_item = dict(item or {})
                    rebuilt_item["title"] = current_title
                    rebuilt_item["author"] = current_performer
                    rebuilt_item["cover_url"] = self._resolve_music_cover_url(rebuilt_item)
                    try:
                        if isinstance(self._active_play_ctx, dict) and isinstance(self._active_play_ctx.get("item"), dict):
                            self._active_play_ctx["item"]["cover_url"] = str(rebuilt_item.get("cover_url") or "").strip()
                    except Exception:
                        pass
                    
                    sheet = BottomSheet(ctx, False)
                    self._custom_player_ui = sheet
                    
                    try:
                        sheet.setBackgroundColor(0)
                        sheet.setApplyTopPadding(False)
                        sheet.setApplyBottomPadding(False)
                    except Exception: pass
                    
                                                                   
                    c_title = self._jcolor(self.get_setting("pomme_color_title", 0xFFFFFFFF))
                    c_controls = self._jcolor(self.get_setting("pomme_color_controls", 0xFF000000))
                    c_bg = self._jcolor(self.get_setting("pomme_color_bg", 0xFFF2F2F7))
                    c_artist = self._jcolor((int(c_title) & 0x00FFFFFF) | 0x8E000000)
                    panel_on_right = bool(self.get_setting("pomme_panel_right_side", False))
                    resize_enabled = bool(self.get_setting("pomme_music_panel_resize_enabled", True))
                    try:
                        panel_scale = float(self.get_setting("pomme_music_panel_scale", 1.0) or 1.0)
                    except Exception:
                        panel_scale = 1.0
                    panel_scale = max(1.0, panel_scale)
                    base_panel_width_dp = 186
                    base_art_size_dp = 162
                    base_transport_height_dp = 36
                    base_play_icon_dp = 28
                    base_transport_icon_dp = 20
                    base_card_radius_dp = 24
                    base_art_radius_dp = 22
                    base_chip_radius_dp = 20
                    base_resize_margin_dp = 2
                    base_resize_bar_long_dp = 13
                    base_resize_bar_short_dp = 3
                    base_resize_gap_dp = 5
                    base_resize_touch_dp = 30
                    base_resize_gutter_dp = 18
                    try:
                        display_width = int(ctx.getResources().getDisplayMetrics().widthPixels)
                    except Exception:
                        display_width = int(AndroidUtilities.dp(360))
                    base_panel_width_px = float(AndroidUtilities.dp(base_panel_width_dp))
                    max_allowed_width_px = float(max(AndroidUtilities.dp(base_panel_width_dp), display_width - AndroidUtilities.dp(72)))
                    max_panel_scale = max(1.0, min(1.42, max_allowed_width_px / max(1.0, base_panel_width_px)))
                    if panel_scale > max_panel_scale:
                        panel_scale = max_panel_scale
                    current_panel_width_dp = int(round(base_panel_width_dp * panel_scale))
                    current_art_size_dp = int(round(base_art_size_dp * panel_scale))
                    current_transport_height_dp = int(round(base_transport_height_dp * panel_scale))
                    current_play_icon_dp = int(round(base_play_icon_dp * panel_scale))
                    current_transport_icon_dp = int(round(base_transport_icon_dp * panel_scale))
                    current_card_radius_dp = int(round(base_card_radius_dp * min(panel_scale, 1.2)))
                    current_art_radius_dp = int(round(base_art_radius_dp * min(panel_scale, 1.2)))
                    current_chip_radius_dp = int(round(base_chip_radius_dp * min(panel_scale, 1.2)))
                    current_root_pad_dp = int(round(13 * panel_scale))
                    current_top_gap_dp = int(round(28 * panel_scale))
                    current_row_gap_dp = int(round(12 * panel_scale))
                    current_resize_gutter_dp = int(round(base_resize_gutter_dp * min(panel_scale, 1.15)))
                    self._trace(
                        "Music Panel metrics scale={0:.3f} width_dp={1} art_dp={2} transport_dp={3} max_scale={4:.3f}".format(
                            float(panel_scale),
                            int(current_panel_width_dp),
                            int(current_art_size_dp),
                            int(current_transport_height_dp),
                            float(max_panel_scale),
                        ),
                        "INFO",
                    )
                    
                    card_bg_color = c_bg
                    card_title_color = c_title
                    card_artist_color = c_artist
                    card_controls_color = c_controls
                    chip_fill_color = card_title_color
                    chip_text_color = card_controls_color

                    panel_shell = FrameLayout(ctx)
                    panel_shell.setBackgroundColor(0)
                    try:
                        panel_shell.setClipChildren(False)
                        panel_shell.setClipToPadding(False)
                    except Exception:
                        pass
                    root = LinearLayout(ctx)
                    root.setOrientation(LinearLayout.VERTICAL)
                    bg = GradientDrawable()
                    bg.setCornerRadius(float(AndroidUtilities.dp(current_card_radius_dp)))
                    bg.setColor(card_bg_color)
                    root.setBackground(bg)
                    root.setPadding(AndroidUtilities.dp(current_root_pad_dp), AndroidUtilities.dp(current_root_pad_dp), AndroidUtilities.dp(current_root_pad_dp), AndroidUtilities.dp(current_root_pad_dp))
                    try:
                        root.setGravity(Gravity.CENTER_HORIZONTAL)
                    except Exception:
                        pass
                    self._custom_player_root = root
                    self._player_card_bg_drawable = bg
                    self._player_control_icons = []
                    self._player_ui_control_tint = card_controls_color

                    self._player_title_view = None
                    self._player_artist_view = None
                    self._player_play_pause_btn = None
                    self._player_play_pause_tint = self._jcolor(0xFFFFFFFF)

                    art_container = FrameLayout(ctx)
                    art_frame = FrameLayout(ctx)
                    iv_art = ImageView(ctx)
                    iv_art.setScaleType(ImageView.ScaleType.CENTER_CROP)
                    self._player_hero_view = iv_art

                    art_bg = GradientDrawable()
                    art_bg.setCornerRadius(float(AndroidUtilities.dp(current_art_radius_dp)))
                    art_bg.setColor(0x00000000)
                    art_frame.setBackground(art_bg)
                    try:
                        ViewOutlineProvider = jclass("android.view.ViewOutlineProvider")
                        art_frame.setClipToOutline(True)
                        art_frame.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
                        art_frame.setClipChildren(True)
                        art_frame.setClipToPadding(True)
                    except Exception:
                        pass
                    iv_art_bg = GradientDrawable()
                    iv_art_bg.setCornerRadius(float(AndroidUtilities.dp(current_art_radius_dp)))
                    iv_art_bg.setColor(0x00000000)
                    iv_art.setBackground(iv_art_bg)
                    try:
                        iv_art.setClipToOutline(True)
                        iv_art.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
                    except Exception:
                        pass

                    flp_art = FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.MATCH_PARENT)
                    art_frame.addView(iv_art, flp_art)
                    art_container.addView(art_frame, flp_art)

                    plugin = self
                    def _make_chip_bg(fill_color, radius_dp):
                        drawable = GradientDrawable()
                        drawable.setCornerRadius(float(AndroidUtilities.dp(radius_dp)))
                        drawable.setColor(fill_color)
                        return drawable

                    def _clamp_panel_scale(scale_value):
                        return max(1.0, min(float(scale_value or 1.0), float(max_panel_scale)))

                    def _persist_and_reopen_scale(scale_value):
                        final_scale = _clamp_panel_scale(scale_value)
                        try:
                            plugin.set_setting("pomme_music_panel_scale", final_scale)
                        except Exception:
                            pass
                        plugin._trace("Music Panel resize saved scale={0:.3f}".format(float(final_scale)), "INFO")
                        try:
                            reopen_item = None
                            if isinstance(plugin._active_play_ctx, dict) and isinstance(plugin._active_play_ctx.get("item"), dict):
                                reopen_item = dict(plugin._active_play_ctx.get("item") or {})
                            if not reopen_item:
                                reopen_item = dict(getattr(plugin, "_last_started_item", {}) or {})
                            if reopen_item:
                                plugin._internal_dismiss = True
                                try:
                                    sheet.dismiss()
                                except Exception:
                                    pass
                                import threading
                                threading.Timer(0.16, lambda: run_on_ui_thread(lambda: plugin._show_custom_player_overlay(reopen_item))).start()
                        except Exception as reopen_err:
                            plugin._trace("Music Panel resize reopen fail: {0}".format(reopen_err), "WARN")
                        return final_scale

                    def _remote_btn(icon_name, action, size_dp=28, is_play_pause=False, is_lyrics=False, is_fav=False, tint_color=None):
                        btn = LinearLayout(ctx)
                        btn.setGravity(Gravity.CENTER)
                        pad_h_dp = 10
                        pad_v_dp = 10
                        if is_play_pause:
                            pad_h_dp = 7
                            pad_v_dp = 7
                        btn.setPadding(AndroidUtilities.dp(pad_h_dp), AndroidUtilities.dp(pad_v_dp), AndroidUtilities.dp(pad_h_dp), AndroidUtilities.dp(pad_v_dp))
                        iv = ImageView(ctx)
                        if (not is_fav) and (not is_play_pause):
                            try:
                                plugin._player_control_icons.append(iv)
                            except Exception:
                                pass
                        if is_play_pause: self._player_play_pause_btn = iv
                        if is_fav:
                            pkg = ApplicationLoader.applicationContext.getPackageName()
                            res = ApplicationLoader.applicationContext.getResources()
                            fav_icon_id = res.getIdentifier("msg_reactions_remix", "drawable", pkg)
                            if fav_icon_id:
                                iv.setImageResource(int(fav_icon_id))
                                iv.setColorFilter(self._jcolor(tint_color if tint_color is not None else card_controls_color), PorterDuff.Mode.SRC_IN)
                        else:
                            plugin._update_remote_icon(iv, icon_name, size_dp, tint_color=(tint_color if tint_color is not None else card_controls_color))
                        btn.addView(iv, LinearLayout.LayoutParams(AndroidUtilities.dp(size_dp), AndroidUtilities.dp(size_dp)))

                        class _C(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                            def onClick(self_obj, v):
                                if is_fav:
                                    try: sheet.dismiss()
                                    except Exception: pass
                                    plugin._show_track_playlist_sheet()
                                    return
                                
                                plugin._manual_stop_requested = False
                                action()
                                if not is_play_pause and not is_lyrics:
                                    try: 
                                        plugin._trace("Music Panel: Dismissing for track change", "DEBUG")
                                        plugin._internal_dismiss = True
                                        sheet.dismiss()
                                        plugin._waiting_for_track_change = True
                                        plugin._waiting_for_track_change_until = float(time.time()) + 2.2
                                    except Exception: pass
                        btn.setOnClickListener(_C())
                        return btn

                    def _transport_btn(icon_name, action):
                        btn = LinearLayout(ctx)
                        btn.setOrientation(LinearLayout.VERTICAL)
                        btn.setGravity(Gravity.CENTER)
                        btn.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(8), AndroidUtilities.dp(6), AndroidUtilities.dp(8))
                        iv = ImageView(ctx)
                        plugin._update_remote_icon(iv, icon_name, current_transport_icon_dp, tint_color=chip_text_color)
                        btn.addView(iv, LinearLayout.LayoutParams(AndroidUtilities.dp(current_transport_icon_dp), AndroidUtilities.dp(current_transport_icon_dp)))

                        class _TransportClick(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                            def onClick(self_obj, v):
                                try:
                                    plugin._manual_stop_requested = False
                                    accepted = bool(action())
                                    plugin._trace("Music Panel transport action accepted={0}".format(accepted), "INFO")
                                    if not accepted:
                                        return
                                    plugin._trace("Music Panel: dismissing after transport action", "DEBUG")
                                    plugin._internal_dismiss = True
                                    sheet.dismiss()
                                    plugin._waiting_for_track_change = True
                                    plugin._waiting_for_track_change_until = float(time.time()) + 2.2
                                except Exception as transport_err:
                                    plugin._trace("Music Panel transport action fail: {0}".format(transport_err), "ERROR")

                        btn.setOnClickListener(_TransportClick())
                        return btn

                    art_size = AndroidUtilities.dp(current_art_size_dp)
                    art_lp = LinearLayout.LayoutParams(art_size, art_size)
                    root.addView(art_container, art_lp)

                    fav_btn = _remote_btn("", None, 26, is_fav=True, tint_color=0xFFFF3B30)
                    fav_btn.setBackgroundColor(0)
                    fav_lp = FrameLayout.LayoutParams(FrameLayout.LayoutParams.WRAP_CONTENT, FrameLayout.LayoutParams.WRAP_CONTENT)
                    fav_lp.gravity = Gravity.TOP | Gravity.RIGHT
                    fav_lp.topMargin = AndroidUtilities.dp(8)
                    fav_lp.rightMargin = AndroidUtilities.dp(8)
                    art_container.addView(fav_btn, fav_lp)

                    icon = "player_pause.png"
                    try:
                        if plugin._custom_player is not None and plugin._custom_player_ui is not None:
                            is_playing = False
                            try:
                                is_playing = bool(plugin._custom_player.isPlaying())
                            except Exception:
                                is_playing = False
                            icon = "player_pause.png" if is_playing else "player_play.png"
                        else:
                            mc = jclass("org.telegram.messenger.MediaController").getInstance()
                            icon = "player_pause.png" if not mc.isMessagePaused() else "player_play.png"
                    except Exception:
                        pass
                    try:
                        plugin._update_remote_icon(ImageView(ctx), "player_pause.png", current_play_icon_dp, tint_color=0xFFFFFFFF)
                        plugin._update_remote_icon(ImageView(ctx), "player_play.png", current_play_icon_dp, tint_color=0xFFFFFFFF)
                    except Exception:
                        pass
                    def _toggle():
                        next_icon = ""
                        try:
                            # Prefer custom MediaPlayer state when Music Panel is open.
                            did_custom = False
                            if plugin._custom_player is not None and plugin._custom_player_ui is not None:
                                was_playing = False
                                try:
                                    was_playing = bool(plugin._custom_player.isPlaying())
                                except Exception:
                                    was_playing = False
                                try:
                                    if was_playing:
                                        plugin._custom_player.pause()
                                        next_icon = "player_play.png"
                                    else:
                                        plugin._custom_player.start()
                                        next_icon = "player_pause.png"
                                    did_custom = True
                                except Exception:
                                    did_custom = False

                            # Fallback to native controller
                            if not did_custom:
                                nmc = jclass("org.telegram.messenger.MediaController").getInstance()
                                obj = nmc.getPlayingMessageObject()
                                if obj is not None:
                                    was_paused = True
                                    try:
                                        was_paused = bool(nmc.isMessagePaused())
                                    except Exception:
                                        was_paused = True
                                    if not was_paused:
                                        nmc.pauseMessage(obj)
                                        next_icon = "player_play.png"
                                    else:
                                        nmc.playMessage(obj)
                                        next_icon = "player_pause.png"

                            tint_cc = getattr(plugin, "_player_play_pause_tint", None)
                            if tint_cc is None:
                                tint_cc = plugin._jcolor(0xFFFFFFFF)

                            # Update the icon deterministically (don't depend on polling state).
                            try:
                                if next_icon and plugin._player_play_pause_btn is not None:
                                    plugin._trace("Music Panel: play/pause icon -> {0}".format(next_icon), "INFO")
                                    if not plugin._apply_cached_remote_icon(plugin._player_play_pause_btn, next_icon, tint_color=tint_cc):
                                        plugin._update_remote_icon(plugin._player_play_pause_btn, next_icon, current_play_icon_dp, tint_color=tint_cc)
                                else:
                                    plugin._trace("Music Panel: play/pause icon refresh fallback", "DEBUG")
                                    plugin._refresh_player_play_pause_icon()
                            except Exception:
                                try:
                                    plugin._refresh_player_play_pause_icon()
                                except Exception:
                                    pass
                            try:
                                reopen_item = None
                                if isinstance(plugin._active_play_ctx, dict) and isinstance(plugin._active_play_ctx.get("item"), dict):
                                    reopen_item = dict(plugin._active_play_ctx.get("item") or {})
                                if not reopen_item:
                                    reopen_item = dict(getattr(plugin, "_last_started_item", {}) or {})
                                if reopen_item:
                                    plugin._trace("Music Panel: reopening after play/pause toggle", "DEBUG")
                                    plugin._internal_dismiss = True
                                    try:
                                        sheet.dismiss()
                                    except Exception:
                                        pass
                                    try:
                                        import threading
                                        threading.Timer(0.18, lambda: run_on_ui_thread(lambda: plugin._show_custom_player_overlay(reopen_item))).start()
                                    except Exception:
                                        threading.Timer(0.18, lambda: run_on_ui_thread(lambda: plugin._show_custom_player_overlay(reopen_item))).start()
                            except Exception as reopen_err:
                                plugin._trace("Music Panel reopen after toggle fail: {0}".format(reopen_err), "WARN")
                        except Exception:
                            try:
                                plugin._refresh_player_play_pause_icon()
                            except Exception:
                                pass

                    play_chip = _remote_btn(icon, _toggle, current_play_icon_dp, is_play_pause=True, tint_color=0xFFFFFFFF)
                    play_chip.setBackground(_make_chip_bg(self._jcolor(0x66000000), max(12, current_chip_radius_dp - 3)))
                    play_lp = FrameLayout.LayoutParams(FrameLayout.LayoutParams.WRAP_CONTENT, FrameLayout.LayoutParams.WRAP_CONTENT)
                    play_lp.gravity = Gravity.BOTTOM | Gravity.RIGHT
                    play_lp.bottomMargin = AndroidUtilities.dp(8)
                    play_lp.rightMargin = AndroidUtilities.dp(8)
                    art_container.addView(play_chip, play_lp)

                    controls_row = LinearLayout(ctx)
                    controls_row.setOrientation(LinearLayout.HORIZONTAL)
                    controls_row.setGravity(Gravity.CENTER)
                    row_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    row_lp.topMargin = AndroidUtilities.dp(current_row_gap_dp)

                    transport_chip = LinearLayout(ctx)
                    transport_chip.setOrientation(LinearLayout.HORIZONTAL)
                    transport_chip.setGravity(Gravity.CENTER)
                    transport_chip.setBackground(_make_chip_bg(chip_fill_color, current_chip_radius_dp))
                    transport_chip.setPadding(AndroidUtilities.dp(2), AndroidUtilities.dp(0), AndroidUtilities.dp(2), AndroidUtilities.dp(0))
                    try:
                        transport_chip.setMinimumHeight(AndroidUtilities.dp(current_transport_height_dp))
                    except Exception:
                        pass
                    transport_chip.addView(_transport_btn("player_skip_back.png", lambda: plugin._handle_transport_skip("prev")))
                    spacer = View(ctx)
                    transport_chip.addView(spacer, LinearLayout.LayoutParams(AndroidUtilities.dp(2), 1))
                    transport_chip.addView(_transport_btn("player_skip_forward.png", lambda: plugin._handle_transport_skip("next")))
                    transport_lp = LinearLayout.LayoutParams(0, AndroidUtilities.dp(current_transport_height_dp), 1.0)
                    transport_lp.rightMargin = AndroidUtilities.dp(6)
                    controls_row.addView(transport_chip, transport_lp)

                    lyrics_btn = TextView(ctx)
                    lyrics_btn.setText(self._tr("lyrics_button").upper())
                    lyrics_btn.setTextSize(14)
                    lyrics_btn.setTypeface(None, 1)
                    lyrics_btn.setTextColor(chip_text_color)
                    lyrics_btn.setGravity(Gravity.CENTER)
                    lyrics_btn.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10))
                    lyrics_btn.setBackground(_make_chip_bg(chip_fill_color, current_chip_radius_dp))
                    try:
                        lyrics_btn.setMinHeight(AndroidUtilities.dp(current_transport_height_dp))
                    except Exception:
                        pass

                    class _LyricsClick(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                        def onClick(self_obj, v):
                            plugin._open_current_lyrics()

                    lyrics_btn.setOnClickListener(_LyricsClick())
                    lyrics_lp = LinearLayout.LayoutParams(0, AndroidUtilities.dp(current_transport_height_dp), 1.0)
                    lyrics_lp.leftMargin = AndroidUtilities.dp(6)
                    controls_row.addView(lyrics_btn, lyrics_lp)

                    root.addView(controls_row, row_lp)

                    resize_touch = FrameLayout(ctx)
                    resize_touch.setBackgroundColor(0)
                    resize_icon = ImageView(ctx)
                    resize_icon_name = "resize_right.png" if panel_on_right else "resize.png"
                    try:
                        resize_tint = 0xA6F4F4F6 if bool(Theme.isCurrentThemeDark()) else 0x8C222326
                        if not plugin._apply_cached_remote_icon(resize_icon, resize_icon_name, tint_color=resize_tint):
                            plugin._update_remote_icon(resize_icon, resize_icon_name, 18, tint_color=resize_tint)
                    except Exception:
                        pass
                    resize_touch.addView(resize_icon, FrameLayout.LayoutParams(AndroidUtilities.dp(18), AndroidUtilities.dp(18), Gravity.CENTER))

                    class _ResizeTouch(dynamic_proxy(find_class("android.view.View$OnTouchListener"))):
                        def __init__(self_obj):
                            super().__init__()
                            self_obj.start_x = 0.0
                            self_obj.start_y = 0.0
                            self_obj.start_scale = nonlocal_panel_scale[0]
                            self_obj.dragging = False
                        def onTouch(self_obj, _v, event):
                            try:
                                action = int(event.getAction())
                                if action == MotionEvent.ACTION_DOWN:
                                    self_obj.start_x = float(event.getRawX())
                                    self_obj.start_y = float(event.getRawY())
                                    self_obj.start_scale = float(nonlocal_panel_scale[0])
                                    self_obj.dragging = False
                                    try:
                                        resize_touch.setAlpha(1.0)
                                    except Exception:
                                        pass
                                    plugin._trace("Music Panel resize gesture start scale={0:.3f}".format(float(self_obj.start_scale)), "INFO")
                                    return True
                                if action == MotionEvent.ACTION_MOVE:
                                    dx = float(event.getRawX()) - float(self_obj.start_x)
                                    dy = float(self_obj.start_y) - float(event.getRawY())
                                    horizontal = (-dx) if panel_on_right else dx
                                    growth_signal = (float(horizontal) + float(dy)) / 2.0
                                    if abs(growth_signal) > float(AndroidUtilities.dp(3)):
                                        self_obj.dragging = True
                                    next_scale = float(self_obj.start_scale) + (float(growth_signal) / max(1.0, float(AndroidUtilities.dp(150))))
                                    new_scale = _clamp_panel_scale(next_scale)
                                    try:
                                        nonlocal_panel_scale[0] = new_scale
                                    except Exception:
                                        pass
                                    try:
                                        preview_shift_x = max(-float(AndroidUtilities.dp(18)), min(float(AndroidUtilities.dp(18)), float(growth_signal) / 5.5))
                                        if panel_on_right:
                                            preview_shift_x = -preview_shift_x
                                        preview_shift_y = max(-float(AndroidUtilities.dp(8)), min(float(AndroidUtilities.dp(8)), float(growth_signal) / 9.0))
                                        resize_touch.setTranslationX(preview_shift_x)
                                        resize_touch.setTranslationY(-preview_shift_y)
                                    except Exception:
                                        pass
                                    return True
                                if action == MotionEvent.ACTION_UP or action == MotionEvent.ACTION_CANCEL:
                                    try:
                                        resize_touch.setTranslationX(0.0)
                                        resize_touch.setTranslationY(0.0)
                                    except Exception:
                                        pass
                                    if not self_obj.dragging:
                                        plugin._trace("Music Panel resize gesture ignored: no drag", "DEBUG")
                                        return True
                                    plugin._trace(
                                        "Music Panel resize release start={0:.3f} end={1:.3f}".format(
                                            float(self_obj.start_scale),
                                            float(nonlocal_panel_scale[0]),
                                        ),
                                        "INFO",
                                    )
                                    final_scale = _persist_and_reopen_scale(nonlocal_panel_scale[0])
                                    try:
                                        nonlocal_panel_scale[0] = final_scale
                                    except Exception:
                                        pass
                                    try:
                                        _v.performClick()
                                    except Exception:
                                        pass
                                    return True
                            except Exception:
                                return False
                            return False

                    nonlocal_panel_scale = [panel_scale]
                    resize_touch.setOnTouchListener(_ResizeTouch())
                    resize_touch_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(base_resize_touch_dp), AndroidUtilities.dp(base_resize_touch_dp))
                    resize_touch_lp.gravity = (Gravity.TOP | Gravity.LEFT) if panel_on_right else (Gravity.TOP | Gravity.RIGHT)
                    resize_touch_lp.topMargin = AndroidUtilities.dp(10)
                    if panel_on_right:
                        resize_touch_lp.leftMargin = AndroidUtilities.dp(0)
                    else:
                        resize_touch_lp.rightMargin = AndroidUtilities.dp(0)
                    shell_total_width_dp = current_panel_width_dp + current_resize_gutter_dp
                    shell_content_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(current_panel_width_dp), FrameLayout.LayoutParams.WRAP_CONTENT)
                    shell_content_lp.topMargin = max(AndroidUtilities.dp(current_top_gap_dp), AndroidUtilities.dp(10))
                    shell_content_lp.gravity = Gravity.TOP | (Gravity.RIGHT if panel_on_right else Gravity.LEFT)
                    if panel_on_right:
                        shell_content_lp.leftMargin = AndroidUtilities.dp(current_resize_gutter_dp)
                    else:
                        shell_content_lp.rightMargin = AndroidUtilities.dp(current_resize_gutter_dp)
                    panel_shell.addView(root, shell_content_lp)
                    if resize_enabled:
                        panel_shell.addView(resize_touch, resize_touch_lp)

                    container = FrameLayout(ctx)
                    try:
                        container.setClipChildren(False)
                        container.setClipToPadding(False)
                    except Exception:
                        pass
                    root_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(shell_total_width_dp), -2)
                    if panel_on_right:
                        root_lp.gravity = Gravity.RIGHT | Gravity.BOTTOM
                        root_lp.rightMargin = AndroidUtilities.dp(18)
                    else:
                        root_lp.gravity = Gravity.LEFT | Gravity.BOTTOM
                        root_lp.leftMargin = AndroidUtilities.dp(18)
                    root_lp.bottomMargin = AndroidUtilities.dp(16)
                    container.addView(panel_shell, root_lp)
                    
                    self._trace("Music Panel: setting custom view", "DEBUG")
                    sheet.setCustomView(container)
                    
                    class _OnDismiss(dynamic_proxy(find_class("android.content.DialogInterface$OnDismissListener"))):
                        def onDismiss(self_obj, d):
                                                                                  
                            is_internal = getattr(plugin, "_internal_dismiss", False)
                            plugin._trace("Music Panel: onDismiss (internal={0})".format(is_internal), "DEBUG")
                            if not is_internal:
                                plugin._trace("Music Panel: dismissed by user interface only", "DEBUG")
                            
                            plugin._internal_dismiss = False 
                            plugin._custom_player_ui = None
                            plugin._custom_player_root = None
                            plugin._player_card_bg_drawable = None
                            plugin._player_control_icons = None
                            plugin._player_title_view = None
                            plugin._player_artist_view = None
                            plugin._player_play_pause_btn = None
                            plugin._player_play_pause_tint = None
                            plugin._player_hero_view = None
                            plugin._player_ui_control_tint = None
                    sheet.setOnDismissListener(_OnDismiss())
                    
                    self._trace("Music Panel: showing sheet", "INFO")
                    sheet.show()
                    self._load_remote_hero(iv_art, str(rebuilt_item.get("cover_url") or POMME_PLACEHOLDER_COVER).strip())
                except Exception as e:
                    tb = traceback.format_exc()
                    self._trace("Music Panel error: {0}\n{1}".format(e, tb), "ERROR")
                    self._show_error_sheet("Music Panel render failed:\n{0}".format(e))
            run_on_ui_thread(_show)
        except Exception as e:
            self._trace("Music Panel bootstrap error: {0}".format(e), "ERROR")

    def _update_remote_icon(self, iv, icon_name, size_dp, tint_color=None, dark=True):
        try:
                                           
            if iv is None: return
            
                                                                       
            final_tint = self._jcolor(tint_color) if tint_color is not None else (self._jcolor(0xFF000000) if dark else self._jcolor(0xFFFFFFFF))
            
            url = "https://coreupdates.meyankut.workers.dev/{0}".format(icon_name)
            if not hasattr(self, "_icon_mem_cache"): self._icon_mem_cache = {}
            if url in self._icon_mem_cache:
                bitmap = self._icon_mem_cache[url]
                def _ui_cached():
                    try:
                        iv.setImageBitmap(bitmap)
                        iv.setColorFilter(final_tint, PorterDuff.Mode.SRC_IN)
                        try:
                            iv.invalidate()
                            iv.requestLayout()
                        except Exception:
                            pass
                    except Exception:
                        pass
                run_on_ui_thread(_ui_cached)
                return
            plugin = self
            def _load():
                data = None
                cache_root = plugin._artwork_cache_dir()
                cache_path = os.path.join(cache_root, hashlib.md5(url.encode("utf-8")).hexdigest() + ".png") if cache_root else None
                if cache_path and os.path.exists(cache_path):
                    try:
                        with open(cache_path, "rb") as f: data = f.read()
                    except Exception: pass
                if not data:
                    try:
                        req = Request(url, headers={"User-Agent": "Mozilla/5.0"})
                        with urlopen(req, timeout=10) as resp: data = resp.read()
                        if data and cache_path:
                            with open(cache_path, "wb") as f: f.write(data)
                    except Exception: pass
                if data:
                    BitmapFactory = jclass("android.graphics.BitmapFactory")
                    bitmap = BitmapFactory.decodeByteArray(data, 0, len(data))
                    if bitmap:
                        plugin._icon_mem_cache[url] = bitmap
                        def _ui():
                            try:
                                iv.setImageBitmap(bitmap)
                                iv.setColorFilter(final_tint, PorterDuff.Mode.SRC_IN)
                                try:
                                    iv.invalidate()
                                    iv.requestLayout()
                                except Exception:
                                    pass
                            except Exception:
                                pass
                        run_on_ui_thread(_ui)
            threading.Thread(target=_load, daemon=True).start()
        except Exception: pass

    def _hero_mem_key(self, thumb_url):
        return "{0}\0h2".format(str(thumb_url or "").strip())

    def _row_mostly_uniform(self, bitmap, y, tol=22):
        try:
            w = int(bitmap.getWidth())
            h = int(bitmap.getHeight())
            if y < 0 or y >= h or w <= 0:
                return False
            step = max(1, w // 56)
            p0 = int(bitmap.getPixel(0, y))
            r0, g0, b0 = (p0 >> 16) & 0xFF, (p0 >> 8) & 0xFF, p0 & 0xFF
            for x in range(0, w, step):
                p = int(bitmap.getPixel(min(x, w - 1), y))
                r, g, b = (p >> 16) & 0xFF, (p >> 8) & 0xFF, p & 0xFF
                if abs(r - r0) > tol or abs(g - g0) > tol or abs(b - b0) > tol:
                    return False
            return True
        except Exception:
            return False

    def _col_mostly_uniform(self, bitmap, x, tol=22):
        try:
            w = int(bitmap.getWidth())
            h = int(bitmap.getHeight())
            if x < 0 or x >= w or h <= 0:
                return False
            step = max(1, h // 56)
            p0 = int(bitmap.getPixel(x, 0))
            r0, g0, b0 = (p0 >> 16) & 0xFF, (p0 >> 8) & 0xFF, p0 & 0xFF
            for y in range(0, h, step):
                p = int(bitmap.getPixel(x, min(y, h - 1)))
                r, g, b = (p >> 16) & 0xFF, (p >> 8) & 0xFF, p & 0xFF
                if abs(r - r0) > tol or abs(g - g0) > tol or abs(b - b0) > tol:
                    return False
            return True
        except Exception:
            return False

    def _row_mostly_transparent(self, bitmap, y, alpha_tol=18):
        try:
            w = int(bitmap.getWidth())
            h = int(bitmap.getHeight())
            if y < 0 or y >= h or w <= 0:
                return False
            step = max(1, w // 56)
            for x in range(0, w, step):
                p = int(bitmap.getPixel(min(x, w - 1), y))
                a = (p >> 24) & 0xFF
                if a > alpha_tol:
                    return False
            return True
        except Exception:
            return False

    def _col_mostly_transparent(self, bitmap, x, alpha_tol=18):
        try:
            w = int(bitmap.getWidth())
            h = int(bitmap.getHeight())
            if x < 0 or x >= w or h <= 0:
                return False
            step = max(1, h // 56)
            for y in range(0, h, step):
                p = int(bitmap.getPixel(x, min(y, h - 1)))
                a = (p >> 24) & 0xFF
                if a > alpha_tol:
                    return False
            return True
        except Exception:
            return False

    def _trim_transparent_edges_bitmap(self, bitmap):
        try:
            Bitmap = jclass("android.graphics.Bitmap")
            w, h = int(bitmap.getWidth()), int(bitmap.getHeight())
            if w < 8 or h < 8:
                return bitmap
            max_frac = 0.45
            max_v = int(h * max_frac)
            top = 0
            while top < max_v and self._row_mostly_transparent(bitmap, top):
                top += 1
            bottom = 0
            while bottom < max_v and self._row_mostly_transparent(bitmap, h - 1 - bottom):
                bottom += 1
            max_h = int(w * max_frac)
            left = 0
            while left < max_h and self._col_mostly_transparent(bitmap, left):
                left += 1
            right = 0
            while right < max_h and self._col_mostly_transparent(bitmap, w - 1 - right):
                right += 1
            nw = w - left - right
            nh = h - top - bottom
            if nw < int(w * 0.55) or nh < int(h * 0.55):
                return bitmap
            if nw <= 2 or nh <= 2 or (nw == w and nh == h):
                return bitmap
            return Bitmap.createBitmap(bitmap, left, top, nw, nh)
        except Exception:
            return bitmap

    def _shave_uniform_edges_bitmap(self, bitmap):
        try:
            Bitmap = jclass("android.graphics.Bitmap")
            w, h = int(bitmap.getWidth()), int(bitmap.getHeight())
            if w < 8 or h < 8:
                return bitmap
            max_frac = 0.45
            max_v = int(h * max_frac)
            top = 0
            while top < max_v and self._row_mostly_uniform(bitmap, top):
                top += 1
            bottom = 0
            while bottom < max_v and self._row_mostly_uniform(bitmap, h - 1 - bottom):
                bottom += 1
            max_h = int(w * max_frac)
            left = 0
            while left < max_h and self._col_mostly_uniform(bitmap, left):
                left += 1
            right = 0
            while right < max_h and self._col_mostly_uniform(bitmap, w - 1 - right):
                right += 1
            nw = w - left - right
            nh = h - top - bottom
            if nw < int(w * 0.55) or nh < int(h * 0.55):
                return bitmap
            if nw <= 2 or nh <= 2 or (nw == w and nh == h):
                return bitmap
            return Bitmap.createBitmap(bitmap, left, top, nw, nh)
        except Exception:
            return bitmap

    def _square_center_crop_bitmap(self, bitmap):
        try:
            Bitmap = jclass("android.graphics.Bitmap")
            w, h = int(bitmap.getWidth()), int(bitmap.getHeight())
            if w <= 0 or h <= 0:
                return bitmap
            if w == h:
                return bitmap
            side = min(w, h)
            x0 = (w - side) // 2
            y0 = (h - side) // 2
            return Bitmap.createBitmap(bitmap, x0, y0, side, side)
        except Exception:
            return bitmap

    def _round_bitmap_corners(self, bitmap, radius_px):
        try:
            Bitmap = jclass("android.graphics.Bitmap")
            Canvas = jclass("android.graphics.Canvas")
            Paint = jclass("android.graphics.Paint")
            RectF = jclass("android.graphics.RectF")
            BitmapShader = jclass("android.graphics.BitmapShader")
            TileMode = jclass("android.graphics.Shader$TileMode")
            PorterDuffXfermode = jclass("android.graphics.PorterDuffXfermode")
            PorterDuffMode = jclass("android.graphics.PorterDuff$Mode")

            w = int(bitmap.getWidth())
            h = int(bitmap.getHeight())
            if w <= 0 or h <= 0:
                return bitmap
            out = Bitmap.createBitmap(w, h, Bitmap.Config.ARGB_8888)
            canvas = Canvas(out)
            paint = Paint(1)
            paint.setAntiAlias(True)
            paint.setDither(True)
            paint.setFilterBitmap(True)
            rect = RectF(0.0, 0.0, float(w), float(h))
            canvas.drawARGB(0, 0, 0, 0)
            rr = float(max(1, int(radius_px or 1)))
            canvas.drawRoundRect(rect, rr, rr, paint)
            shader = BitmapShader(bitmap, TileMode.CLAMP, TileMode.CLAMP)
            paint.setShader(shader)
            paint.setXfermode(PorterDuffXfermode(PorterDuffMode.SRC_IN))
            canvas.drawRoundRect(rect, rr, rr, paint)
            return out
        except Exception:
            return bitmap

    def _prepare_cover_bitmap_for_ui(self, bitmap):
        try:
            b = bitmap
            b0 = self._trim_transparent_edges_bitmap(b)
            if b0 is not b:
                try:
                    b.recycle()
                except Exception:
                    pass
                b = b0
            b2 = self._shave_uniform_edges_bitmap(b)
            if b2 is not b:
                try:
                    b.recycle()
                except Exception:
                    pass
                b = b2
            b3 = self._square_center_crop_bitmap(b)
            if b3 is not b:
                try:
                    b.recycle()
                except Exception:
                    pass
                b = b3
            try:
                radius_px = max(10, int(min(int(b.getWidth()), int(b.getHeight())) * 0.14))
            except Exception:
                radius_px = 24
            b4 = self._round_bitmap_corners(b, radius_px)
            if b4 is not b:
                try:
                    b.recycle()
                except Exception:
                    pass
                b = b4
            return b
        except Exception:
            return bitmap

    def _statsfm_pair_key(self, artist, title):
        try:
            def norm(s):
                return re.sub(r"\s+", " ", str(s or "").lower().strip())
            return "{0}|{1}".format(norm(title), norm(artist))
        except Exception:
            return "{0}|{1}".format(str(title or "").lower(), str(artist or "").lower())

    def _statsfm_refresh_index(self, user):
        user = str(user or "").strip().lstrip("@")
        if not user:
            return
        url = "https://api.stats.fm/api/v1/users/{0}/streams/recent?limit=50".format(urllib.parse.quote(user, safe=""))
        req = Request(
            url,
            headers={"Accept": "application/json", "User-Agent": "Mozilla/5.0 (PommePlugin)"},
        )
        with urlopen(req, timeout=14) as resp:
            data = json.loads(resp.read().decode("utf-8", "ignore"))
        items = list((data or {}).get("items") or [])
        idx = {}
        for it in items:
            if not isinstance(it, dict):
                continue
            trk = it.get("track")
            if not isinstance(trk, dict):
                continue
            title = str(trk.get("name") or "").strip()
            if not title:
                continue
            anames = []
            for a in list(trk.get("artists") or []):
                if isinstance(a, dict):
                    n = str(a.get("name") or "").strip()
                    if n:
                        anames.append(n)
            artist_s = ", ".join(anames)
            img = ""
            albums = trk.get("albums") if isinstance(trk.get("albums"), list) else []
            if albums and isinstance(albums[0], dict):
                img = str(albums[0].get("image") or "").strip()
            if img.startswith("//"):
                img = "https:" + img
            elif img.startswith("http://"):
                img = "https://" + img[7:]
            if not img:
                continue
            k = self._statsfm_pair_key(artist_s, title)
            idx[k] = img
        with self._statsfm_index_lock:
            self._statsfm_index_by_key = idx
            self._statsfm_index_meta = {"user": user, "ts": time.time()}

    def _statsfm_lookup_cover(self, artist, title):
        try:
            user = str(self.get_setting("pomme_statsfm_username", "") or "").strip().lstrip("@")
            if not user or not str(title or "").strip():
                return ""
            idx = getattr(self, "_statsfm_index_by_key", None)
            if not isinstance(idx, dict) or not idx:
                return ""
            k = self._statsfm_pair_key(artist, title)
            hit = idx.get(k)
            if hit:
                return str(hit or "").strip()
            nt = re.sub(r"\s+", " ", str(title or "").lower()).strip()
            na = re.sub(r"\s+", " ", str(artist or "").lower()).strip()
            for kk, url in idx.items():
                parts = str(kk or "").split("|", 1)
                if len(parts) != 2:
                    continue
                kt, ka = parts[0], parts[1]
                if nt and kt and (nt == kt or nt in kt or kt in nt):
                    if not na:
                        return str(url or "").strip()
                    if ka and (na in ka or ka in na or na == ka):
                        return str(url or "").strip()
            return ""
        except Exception:
            return ""

    def _statsfm_touch_index_background(self):
        try:
            user = str(self.get_setting("pomme_statsfm_username", "") or "").strip().lstrip("@")
            if not user:
                return
            meta = getattr(self, "_statsfm_index_meta", None)
            ttl = float(4 * 3600)
            now = time.time()
            need = True
            if isinstance(meta, dict) and str(meta.get("user") or "") == user:
                if float(meta.get("ts") or 0) + ttl > now:
                    idx = getattr(self, "_statsfm_index_by_key", None)
                    if isinstance(idx, dict) and idx:
                        need = False
            if not need:
                return
            plugin = self

            def _run():
                try:
                    plugin._statsfm_refresh_index(user)
                except Exception as e:
                    plugin._trace("statsfm index refresh fail: {0}".format(e), "DEBUG")

            threading.Thread(target=_run, daemon=True).start()
        except Exception:
            pass

    def _load_remote_hero(self, iv, thumb_url):
        try:
            if not thumb_url:
                return
            if not hasattr(self, "_hero_mem_cache"):
                self._hero_mem_cache = {}
            hk = self._hero_mem_key(thumb_url)
            if hk in self._hero_mem_cache:
                bitmap = self._hero_mem_cache[hk]
                run_on_ui_thread(lambda: iv.setImageBitmap(bitmap))
                return

            plugin = self

            def _load():
                try:
                    data = plugin._cached_remote_bytes(thumb_url, cache_key="pomme_hero_{0}".format(hash(thumb_url)))
                    if not data:
                        return
                    BitmapFactory = jclass("android.graphics.BitmapFactory")
                    bitmap = BitmapFactory.decodeByteArray(data, 0, len(data))
                    if not bitmap:
                        return
                    bmp_ui = plugin._prepare_cover_bitmap_for_ui(bitmap)
                    if bmp_ui is None:
                        bmp_ui = bitmap
                    elif bmp_ui is not bitmap:
                        try:
                            bitmap.recycle()
                        except Exception:
                            pass
                    plugin._hero_mem_cache[hk] = bmp_ui

                    def _ui():
                        try:
                            iv.setImageBitmap(bmp_ui)
                        except Exception:
                            pass

                    run_on_ui_thread(_ui)
                except Exception:
                    pass

            threading.Thread(target=_load, daemon=True).start()
        except Exception:
            pass

    def _maybe_continue_playback(self, reverse=False):
        try:
            if self._queue_running:
                return
            if self._manual_close_guard_active():
                self._trace("continue playback ignored due to manual close guard", "INFO")
                return
            if self._recent_paused_stop_hint_active():
                self._trace("continue playback ignored due to paused stop hint", "INFO")
                return
             
            if self._manual_stop_requested or self._autoplay_blocked:
                self._trace("continue playback skipped: stop requested={0} autoplay_blocked={1} hard_stop={2}".format(
                    bool(self._manual_stop_requested),
                    bool(self._autoplay_blocked),
                    bool(self._is_hard_stop_active()),
                ), "INFO")
                return
            
            self._queue_running = True
            
                                                               
            if self._custom_player is not None:
                try:
                    self._custom_player.stop()
                    self._custom_player.reset()
                except Exception: pass

                                                                                 
                                                               
                                                                                                  
            if self._custom_player_ui:
                try:
                                                                                                      
                                                                                              
                    pass
                except Exception: pass

            nxt = None
            if bool(reverse):
                nxt = self._step_from_context(-1, wrap=True)
            elif self._queue_items:
                nxt = self._queue_items.pop(0)
            elif bool((self._active_play_ctx or {}).get("playlist")) or self._auto_play_enabled():
                nxt = self._next_from_context()
            
            if not nxt:
                repeat_mode, _, _ = self._playback_flags()
                ctx = dict(self._active_play_ctx or {})
                if repeat_mode == 2 and ctx.get("item"):
                    nxt = dict(ctx)
                elif repeat_mode == 1:
                    nxt = self._step_from_context(1, wrap=True)
            
            if not nxt:
                self._active_play_ctx = None
                return
            
            nxt = self._hydrate_cached_playlist_item(nxt)
            
            def _go():
                try:
                    item = nxt.get("item") or {}
                    cached_file = str(item.get("cached_file") or "").strip()
                    
                    if cached_file and os.path.exists(cached_file):
                        self._trace("Instant Skip: using cached file {0}".format(cached_file), "INFO")
                        stream_info = dict(item.get("cached_stream") or {})
                        started = bool(self._start_custom_player(item, cached_file, stream_info, play_ctx=nxt))
                        if not started:
                            self._trace("Instant Skip fallback: custom player unavailable, using standard start path", "INFO")
                            self._start_music_player(
                                item,
                                queued=bool(nxt.get("queued")),
                                play_ctx=nxt,
                                present_player=True,
                            )
                    else:
                        self._start_music_player(
                            item,
                            queued=bool(nxt.get("queued")),
                            play_ctx=nxt,
                            present_player=True,                    
                        )
                finally:
                    self._queue_running = False
            
            run_on_ui_thread(_go)
        except Exception as e:
            self._queue_running = False
            self._trace("continue playback fail: {0}".format(e), "ERROR")

    def _handle_notification_event(self, event_id, extra_args):
        try:
            if self._is_hard_stop_active() or self._manual_close_guard_active():
                self._trace("notification ignored during hard stop", "INFO")
                return
            NC = jclass("org.telegram.messenger.NotificationCenter")
            reset_id = int(getattr(NC, "messagePlayingDidReset", -1))
            state_id = int(getattr(NC, "messagePlayingPlayStateChanged", -1))
            start_id = int(getattr(NC, "messagePlayingDidStart", -1))
            if event_id == reset_id:
                self._trace("playback reset observed", "INFO")
                if self._recent_manual_stop_hint_active() or self._recent_paused_stop_hint_active():
                    self._trace("playback reset converted to manual stop via cleanup hint", "INFO")
                    self._arm_manual_close_guard(4.0)
                    self._activate_hard_stop(5.0)
                    self._manual_stop_requested = True
                    self._autoplay_blocked = True
                    return
                self._schedule_continue_playback(450)
                return
            if event_id == state_id:
                self._trace("playback state changed", "INFO")
                                                                   
                if self._custom_player_ui:
                    mc = jclass("org.telegram.messenger.MediaController").getInstance()
                    if self._player_play_pause_btn:
                        try:
                            self._refresh_player_play_pause_icon()
                        except Exception:
                            icon = "player_pause.png" if not mc.isMessagePaused() else "player_play.png"
                            self._update_remote_icon(self._player_play_pause_btn, icon, 38, dark=True)
                
                                                                                   
                if self._queue_items or self._auto_play_enabled():
                    mc = jclass("org.telegram.messenger.MediaController").getInstance()
                                                                                      
                    current_obj = mc.getPlayingMessageObject()
                    try:
                        paused_now = bool(mc.isMessagePaused())
                    except Exception:
                        paused_now = False
                    is_playing_any = (current_obj is not None) and (not paused_now)
                    if not is_playing_any and not self._manual_stop_requested:
                        if self._recent_manual_stop_hint_active() or self._recent_paused_stop_hint_active():
                            self._trace("state change converted to manual stop via cleanup hint", "INFO")
                            self._arm_manual_close_guard(4.0)
                            self._activate_hard_stop(5.0)
                            self._manual_stop_requested = True
                            self._autoplay_blocked = True
                            return
                                                    
                        custom_active = False
                        try:
                            if self._custom_player and self._custom_player.isPlaying():
                                custom_active = True
                        except Exception: pass
                        
                        if not custom_active:
                            self._trace("Song ended naturally, scheduling continuation.", "INFO")
                            self._schedule_continue_playback(400)
                    else:
                        self._trace("Playback paused or manual stop ({0}).".format(self._manual_stop_requested), "DEBUG")
                return
            if event_id == start_id:
                self._trace("playback started", "INFO")
                self._recent_paused_stop_hint_until = 0.0
                self._transport_skip_cleanup_until = 0.0
                self._waiting_for_track_change_until = 0.0
                                                              
                if self._custom_player_ui or getattr(self, "_waiting_for_track_change", False):
                    self._waiting_for_track_change = False
                    if extra_args and len(extra_args) > 0:
                        try:
                            msg_obj = extra_args[0]
                                                                        
                            doc = msg_obj.messageOwner.media.document
                            title = ""
                            performer = ""
                            for attr in self._iter_java_list(getattr(doc, "attributes", None)):
                                if jclass("org.telegram.tgnet.TLRPC$TL_documentAttributeAudio").isInstance(attr):
                                    title = str(attr.title or "")
                                    performer = str(attr.performer or "")
                                    break
                            
                            new_item = {
                                "title": title,
                                "author": performer,
                                "thumbnail": self._last_started_item.get("thumbnail") if self._last_started_item else ""
                            }
                            run_on_ui_thread(lambda: self._show_custom_player_overlay(new_item))
                        except Exception as e:
                            self._trace("native start refresh fail: {0}".format(e), "WARN")
                            run_on_ui_thread(lambda: self._show_custom_player_overlay(self._last_started_item))
                    else:
                        run_on_ui_thread(lambda: self._show_custom_player_overlay(self._last_started_item))
                return
        except Exception as e:
            self._trace("handle notification fail: {0}".format(e), "ERROR")

    def _enqueue_item(self, item, play_ctx):
        try:
            ctx = dict(play_ctx or {})
            ctx["item"] = dict(item or {})
            ctx["queued"] = True
            self._queue_items.append(ctx)
            self._notify_success(self._tr("queue_added"))
            return True
        except Exception:
            return False

    def _ask_queue_or_play(self, item, play_ctx, host_ctx=None):
        try:
            ctx = host_ctx
            if ctx is None:
                frag = get_last_fragment()
                ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return self._start_music_player(item, host_ctx, play_ctx=play_ctx, user_initiated=True)
            
            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("queue_prompt_title"))
            b.set_message(self._tr("queue_prompt_text"))
            b.set_positive_button(self._tr("queue_add"), lambda dialog, _w: (dialog.dismiss(), self._enqueue_item(item, play_ctx)))
            
                                                                        
            def _play_now(dialog, _w):
                dialog.dismiss()
                                                                    
                self._show_loading_sheet(title_key="playlist_preparing")
                self._start_music_player(item, host_ctx, play_ctx=play_ctx, user_initiated=True)
                
            b.set_negative_button(self._tr("queue_play_now"), _play_now)
            b.set_neutral_button("Cancel", lambda dialog, _w: dialog.dismiss())
            b.show()
            return True
        except Exception as e:
            self._trace("queue prompt fail: {0}".format(e), "ERROR")
            return self._start_music_player(item, host_ctx, play_ctx=play_ctx, user_initiated=True)

    def _wire_editor_action(self, edit):
        try:
            if self._attached_edit is edit and self._editor_proxy is not None:
                return
        except Exception:
            pass

        listener_cls = find_class("android.widget.TextView$OnEditorActionListener")
        if listener_cls is None:
            self._trace("editor listener class unavailable")
            return

        plugin = self

        class _EditorListener(dynamic_proxy(listener_cls)):
            def onEditorAction(self, v, actionId, event):
                try:
                    if not plugin._enabled:
                        return False

                    aid = int(actionId)
                    search_action = aid in (
                        EditorInfo.IME_ACTION_SEARCH,
                        EditorInfo.IME_ACTION_DONE,
                        EditorInfo.IME_ACTION_GO
                    )

                    enter_key = False
                    try:
                        if event is not None:
                            enter_key = int(event.getKeyCode()) == KeyEvent.KEYCODE_ENTER
                    except Exception:
                        pass

                    if (not search_action) and (not enter_key):
                        return False

                    txt = v.getText() if v is not None else None
                    query = str(txt.toString() or "").strip() if txt is not None else ""
                    if not query:
                        return False

                                                                             
                    if plugin._edit_ref:
                        try:
                            AndroidUtilities.hideKeyboard(plugin._edit_ref)
                        except Exception as e:
                            plugin._trace("Failed to hide keyboard: {0}".format(e), "WARN")

                    plugin._results_page = 0
                    plugin._hide_native_results(plugin._fragment_ref)
                    try:
                        run_on_ui_thread(lambda: plugin._show_loading_sheet())
                    except Exception:
                        run_on_ui_thread(lambda: plugin._show_loading_sheet())
                    try:
                        v.setText("")
                    except Exception:
                        pass
                    plugin._search_youtube_async(query)
                    return True
                except Exception as e:
                    plugin._trace("editor action fail: {0}".format(e))
                    return False

        try:
            self._editor_proxy = _EditorListener()
            edit.setOnEditorActionListener(self._editor_proxy)
            self._attached_edit = edit
        except Exception as e:
            self._trace("setOnEditorActionListener fail: {0}".format(e))

    def _wire_touch_action(self, edit):
        try:
            if self._touch_edit is edit and self._touch_proxy is not None:
                return
        except Exception:
            pass

        listener_cls = find_class("android.view.View$OnTouchListener")
        if listener_cls is None:
            return

        plugin = self

        class _TouchListener(dynamic_proxy(listener_cls)):
            def onTouch(self, v, event):
                try:
                    if not plugin._enabled:
                        return False
                    action = int(event.getAction()) if event is not None else -1
                    if action in (MotionEvent.ACTION_DOWN, MotionEvent.ACTION_UP):
                        plugin._hide_native_results(plugin._fragment_ref)
                        try:
                            threading.Timer(0.04, lambda: run_on_ui_thread(lambda: plugin._hide_native_results(plugin._fragment_ref))).start()
                            threading.Timer(0.14, lambda: run_on_ui_thread(lambda: plugin._hide_native_results(plugin._fragment_ref))).start()
                        except Exception:
                            pass
                except Exception:
                    pass
                return False

        try:
            self._touch_proxy = _TouchListener()
            edit.setOnTouchListener(self._touch_proxy)
            self._touch_edit = edit
        except Exception as e:
            self._trace("setOnTouchListener fail: {0}".format(e))

    def _hide_native_results(self, frag):
        try:
            if not self._enabled or frag is None:
                return
            svp = get_private_field(frag, "searchViewPager")
        except Exception:
            svp = None

        if svp is None:
            return

        try:
            svp.clear()
        except Exception:
            pass
        try:
            svp.setAlpha(0.0)
        except Exception:
            pass
        try:
            svp.setVisibility(View.GONE)
        except Exception:
            pass

    def _apply_native_search_mode(self, edit, frag):
        try:
            if self._native_watcher is None:
                try:
                    self._native_watcher = get_private_field(frag, "fragmentSearchFieldWatcher")
                except Exception:
                    self._native_watcher = None

            watcher = self._native_watcher
            if watcher is None:
                return

            if self._enabled:
                if not self._native_watcher_removed:
                    try:
                        edit.removeTextChangedListener(watcher)
                        self._native_watcher_removed = True
                    except Exception:
                        pass
                try:
                    watcher.toggleSearch(False)
                except Exception:
                    pass
            else:
                if self._native_watcher_removed:
                    try:
                        edit.addTextChangedListener(watcher)
                        self._native_watcher_removed = False
                    except Exception:
                        pass
        except Exception as e:
            self._trace("apply native search mode fail: {0}".format(e))

    def _show_loading_sheet(self, text_key="loading", title_key="playlist_preparing"):
        try:
            if getattr(self, "_loading_dialog", None) is not None:
                try:
                    self._loading_dialog.dismiss()
                except Exception:
                    pass
                self._loading_dialog = None
            old_sheet = getattr(self, "_results_sheet", None)
            if old_sheet is not None:
                try:
                    old_sheet.dismiss()
                except Exception:
                    pass
            self._results_sheet = None
            
            try:
                frag = get_last_fragment()
                ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
                if ctx is None:
                    ctx = getattr(self, "_fragment_ref", None)
                    ctx = ctx.getParentActivity() if ctx and ctx.getParentActivity() else None
                if ctx is None: return
                
                dialog = AlertDialogBuilder(ctx, AlertDialogBuilder.ALERT_TYPE_SPINNER)
                dialog.set_title(self._tr(title_key))
                dialog.set_message(self._tr(text_key))
                dialog.set_cancelable(True)
                dialog.set_canceled_on_touch_outside(True)
                
                self._loading_dialog = dialog
                dialog.show()
            except Exception as e:
                self._trace("show loading fail: {0}".format(e), "ERROR")
        except Exception as e:
            self._trace("show loading sheet fail: {0}".format(e), "ERROR")

    def _pocket_mode_local_paths(self):
        try:
            base_dir = None
            try:
                base_dir = os.path.dirname(os.path.abspath(__file__))
            except Exception:
                base_dir = None
            if not base_dir:
                base_dir = os.getcwd()
            main_path = os.path.join(base_dir, "pomme.plugin")
            normal_cached = os.path.join(base_dir, "pomme.plugin.cache.normal")
            pocket_cached = os.path.join(base_dir, "pomme.plugin.cache.pocket")
            return main_path, normal_cached, pocket_cached
        except Exception:
            try:
                self._trace("Pocket Mode: couldn't resolve local plugin paths", "WARN")
            except Exception:
                pass
            return None, None, None

    def _pocket_mode_requirements_line(self):
        return '__requirements__ = "yt-dlp"'

    def _plugin_version_from_bytes(self, data):
        try:
            if not data:
                return ""
            text = data.decode("utf-8-sig", "ignore")
            m = re.search(r'^\s*__version__\s*=\s*["\']([^"\']+)["\']', text, re.M)
            return str(m.group(1) or "").strip() if m else ""
        except Exception:
            return ""

    def _pocket_mode_normalize_bytes(self, data, want_pocket):
        try:
            if not data:
                return b""
            text = data.decode("utf-8-sig", "ignore")
            lines = text.splitlines()
            req_line = self._pocket_mode_requirements_line()
            clean_lines = [line for line in lines if not re.match(r"^\s*__requirements__\s*=", str(line or ""))]
            if not want_pocket:
                insert_at = 0
                for idx, line in enumerate(clean_lines):
                    if str(line or "").startswith("__name__"):
                        insert_at = idx + 1
                        break
                clean_lines.insert(insert_at, req_line)
            normalized = "\n".join(clean_lines).strip() + "\n"
            return normalized.encode("utf-8")
        except Exception:
            return data

    def _pocket_mode_file_matches(self, file_path, want_pocket):
        try:
            if not file_path or not os.path.exists(file_path) or os.path.getsize(file_path) <= 0:
                return False
            with open(file_path, "rb") as fh:
                raw = fh.read()
            text = raw.decode("utf-8-sig", "ignore")
            has_requirements = bool(re.search(r"^\s*__requirements__\s*=\s*[\"']yt-dlp[\"']", text, re.M))
            return (not has_requirements) if want_pocket else has_requirements
        except Exception:
            return False

    def _pocket_mode_write_variant(self, out_path, data, want_pocket):
        try:
            normalized = self._pocket_mode_normalize_bytes(data, want_pocket)
            tmp = str(out_path or "") + ".tmp"
            if os.path.exists(tmp):
                try:
                    os.remove(tmp)
                except Exception:
                    pass
            with open(tmp, "wb") as fh:
                fh.write(normalized)
            try:
                os.replace(tmp, out_path)
            except Exception:
                shutil.move(tmp, out_path)
            return True
        except Exception:
            return False

    def _sync_pocket_mode_setting_from_file(self):
        try:
            main_path, _normal_cached, _pocket_cached = self._pocket_mode_local_paths()
            if not main_path or not os.path.exists(main_path):
                return False
            self.set_setting("pomme_pocket_mode", bool(self._pocket_mode_file_matches(main_path, True)))
            return True
        except Exception as e:
            self._trace("Pocket Mode: setting sync failed: {0}".format(e), "WARN")
            return False

    def _reload_installed_plugin(self):
        try:
            PluginsController = jclass("com.exteragram.messenger.plugins.PluginsController")
            NotificationCenter = jclass("org.telegram.messenger.NotificationCenter")
            controller = PluginsController.getInstance() if PluginsController else None
            if controller and hasattr(controller, "engines"):
                try:
                    engine = controller.engines.get("python")
                except Exception:
                    engine = None
                if engine is not None:
                    try:
                        engine.loadPlugins(None)
                    except Exception:
                        pass
                try:
                    controller.loadPluginSettings(__id__)
                except Exception:
                    pass
                try:
                    controller.setPluginEnabled(__id__, True, None)
                except Exception:
                    pass
            try:
                NotificationCenter.getGlobalInstance().postNotificationName(NotificationCenter.pluginsUpdated)
            except Exception:
                pass
            return True
        except Exception as e:
            self._trace("Pocket Mode: reload failed: {0}".format(e), "WARN")
            return False

    def _pocket_mode_remote_urls(self, want_pocket):
        try:
            base = "https://coreupdates.meyankut.workers.dev"
            github_raw = "https://raw.githubusercontent.com/smdcontent/mode/refs/heads/main/plugin/pomme.plugin"
            normal = [
                "{0}/pomme.plugin".format(base),
                github_raw,
            ]
            pocket = [
                "{0}/pomme.plugin".format(base),
                github_raw,
                "{0}/pomme_pocket.plugin".format(base),
                "{0}/pomme_pocket_mode.plugin".format(base),
                "{0}/pomme-pocket.plugin".format(base),
                "{0}/pomme_pocketmode.plugin".format(base),
                "{0}/pomme_no_requirements.plugin".format(base),
                "{0}/pomme_no_reqs.plugin".format(base),
            ]
            return normal if not want_pocket else pocket
        except Exception:
            return []

    def _pocket_mode_download_first_ok(self, urls, out_path, want_pocket):
        last_err = ""
        for u in list(urls or []):
            try:
                if not u:
                    continue
                try:
                    self._trace("Pocket Mode: trying remote file", "INFO")
                except Exception:
                    pass
                tmp = str(out_path or "") + ".tmp"
                if os.path.exists(tmp):
                    try:
                        os.remove(tmp)
                    except Exception:
                        pass
                fetch_url = str(u)
                sep = "&" if "?" in fetch_url else "?"
                fetch_url = "{0}{1}_pomme_ts={2}".format(fetch_url, sep, int(time.time() * 1000))
                req = Request(
                    fetch_url,
                    headers={
                        "User-Agent": "Mozilla/5.0 (PommePlugin)",
                        "Cache-Control": "no-cache, no-store, must-revalidate",
                        "Pragma": "no-cache",
                        "Expires": "0",
                    },
                )
                with urlopen(req, timeout=20) as resp:
                    data = resp.read() or b""
                if not data:
                    last_err = "Empty response"
                    continue
                try:
                    version = str(self._plugin_version_from_bytes(data) or "unknown").strip()
                    variant = "pocket" if bool(want_pocket) else "normal"
                    self._trace("Pocket Mode: remote candidate ok | variant={0} | version={1} | url={2}".format(variant, version, str(u)), "INFO")
                except Exception:
                    pass
                if not self._pocket_mode_write_variant(out_path, data, want_pocket):
                    last_err = "Write failed"
                    continue
                try:
                    self._trace("Pocket Mode: remote file ready", "INFO")
                except Exception:
                    pass
                return True
            except Exception as e:
                last_err = str(e)
                try:
                    self._trace("Pocket Mode: remote candidate fail | url={0} | error={1}".format(str(u), str(e)), "WARN")
                except Exception:
                    pass
                continue
        return False if last_err else False

    def _pocket_mode_prepare_install_file(self, want_pocket):
        main_path, normal_cached, pocket_cached = self._pocket_mode_local_paths()
        if not main_path:
            raise Exception("Pocket Mode: local path unavailable")
        target_cached = pocket_cached if want_pocket else normal_cached
        try:
            self._trace(
                "Pocket Mode: preparing local switch",
                "INFO",
            )
        except Exception:
            pass
        urls = self._pocket_mode_remote_urls(want_pocket)
        try:
            self._trace("Pocket Mode: fetching latest remote file", "INFO")
        except Exception:
            pass
        try:
            if target_cached and os.path.exists(target_cached):
                os.remove(target_cached)
        except Exception:
            pass
        ok = self._pocket_mode_download_first_ok(urls, target_cached, want_pocket)
        if not ok:
            try:
                self._trace("Pocket Mode: remote fetch failed, falling back to installed plugin", "WARN")
            except Exception:
                pass
            try:
                if not os.path.exists(main_path):
                    raise Exception("installed plugin missing")
                with open(main_path, "rb") as fh:
                    raw = fh.read()
                try:
                    self._trace(
                        "Pocket Mode: fallback uses installed file | version={0}".format(
                            str(self._plugin_version_from_bytes(raw) or "unknown")
                        ),
                        "WARN",
                    )
                except Exception:
                    pass
                if not self._pocket_mode_write_variant(target_cached, raw, want_pocket):
                    raise Exception("fallback write failed")
            except Exception:
                try:
                    tried = ", ".join([str(x or "") for x in list(urls or []) if x])
                except Exception:
                    tried = ""
                raise Exception("Pocket Mode: remote download failed" + ("; tried: " + tried if tried else ""))

        install_base = self._cache_dir() or os.path.dirname(str(main_path))
        if not install_base:
            raise Exception("Pocket Mode: temp directory unavailable")
        tmp_install = os.path.join(install_base, ".temp_pomme_install.plugin")
        with open(target_cached, "rb") as src:
            if not self._pocket_mode_write_variant(tmp_install, src.read(), want_pocket):
                raise Exception("Pocket Mode: install file prepare failed")
        try:
            self._trace("Pocket Mode: install package ready", "INFO")
        except Exception:
            pass
        return tmp_install

    def _pocket_mode_install_silently(self, install_path, want_pocket, done_cb=None):
        try:
            if not install_path or not os.path.exists(install_path):
                raise Exception("Pocket Mode: install file missing")
            PluginsController = jclass("com.exteragram.messenger.plugins.PluginsController")
            PluginsConstants = jclass("com.exteragram.messenger.plugins.PluginsConstants")
            Callback = jclass("org.telegram.messenger.Utilities$Callback")
            NotificationCenter = jclass("org.telegram.messenger.NotificationCenter")
            controller = PluginsController.getInstance() if PluginsController else None
            if controller is None:
                raise Exception("Pocket Mode: plugins controller unavailable")
            python_engine = None
            try:
                python_engine = PluginsController.engines.get(PluginsConstants.PYTHON)
            except Exception:
                python_engine = None
            if python_engine is None:
                try:
                    python_engine = controller.engines.get("python")
                except Exception:
                    python_engine = None
            if python_engine is None:
                raise Exception("Pocket Mode: python engine unavailable")

            plugin = self

            class _InstallCallback(dynamic_proxy(Callback)):
                def run(self_cb, error):
                    def _finish():
                        try:
                            plugin._pocket_mode_install_in_progress = False
                        except Exception:
                            pass
                        try:
                            if getattr(plugin, "_loading_dialog", None):
                                plugin._loading_dialog.dismiss()
                                plugin._loading_dialog = None
                        except Exception:
                            pass

                        success = not bool(error)
                        final_enabled = bool(want_pocket) if success else bool(plugin.get_setting("pomme_pocket_mode", False))

                        if success:
                            try:
                                plugin.set_setting("pomme_pocket_mode", bool(want_pocket))
                            except Exception:
                                pass
                            try:
                                controller.loadPluginSettings(__id__)
                            except Exception:
                                pass
                            try:
                                controller.setPluginEnabled(__id__, True, None)
                            except Exception:
                                pass
                            try:
                                NotificationCenter.getGlobalInstance().postNotificationName(NotificationCenter.pluginsUpdated)
                            except Exception:
                                pass
                            try:
                                BulletinHelper.show_success("Pocket Mode enabled." if want_pocket else "Pocket Mode disabled.")
                            except Exception:
                                pass
                        else:
                            try:
                                BulletinHelper.show_error(str(error) or "Pocket Mode installation failed.")
                            except Exception:
                                pass

                        try:
                            if callable(done_cb):
                                done_cb(bool(success), bool(final_enabled))
                        except Exception:
                            pass

                        try:
                            if install_path and os.path.exists(install_path):
                                os.remove(install_path)
                        except Exception:
                            pass

                    run_on_ui_thread(_finish)

            try:
                self._trace("Pocket Mode: silent install started", "INFO")
            except Exception:
                pass
            python_engine.loadPluginFromFile(str(install_path), None, _InstallCallback())
            return True
        except Exception as e:
            self._trace("Pocket Mode: silent install failed: {0}".format(e), "WARN")
            return False

    def _pocket_mode_sync_icon_visual(self, icon_view):
        try:
            if icon_view is None:
                return
            enabled = bool(self.get_setting("pomme_pocket_mode", False))
            alpha = 0.55 if bool(getattr(self, "_pocket_mode_install_in_progress", False)) else 1.0
            icon_view.setAlpha(float(alpha))
            col = int(Theme.getColor(Theme.key_featuredStickers_addButton)) if enabled else int(Theme.getColor(Theme.key_player_button))
            icon_view.setColorFilter(PorterDuffColorFilter(int(col), PorterDuff.Mode.MULTIPLY))
        except Exception:
            pass

    def _toggle_pocket_mode(self, icon_view=None, desired_enabled=None, done_cb=None):
        try:
            with self._pocket_mode_install_lock:
                if bool(self._pocket_mode_install_in_progress):
                    return
                current_enabled = bool(self.get_setting("pomme_pocket_mode", False))
                want_pocket = not current_enabled if desired_enabled is None else bool(desired_enabled)
                self._pocket_mode_install_in_progress = True
                try:
                    self._trace("Pocket Mode: switching mode", "INFO")
                except Exception:
                    pass

            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                try:
                    ctx = ApplicationLoader.applicationContext
                except Exception:
                    ctx = None
            if ctx is None:
                self._pocket_mode_install_in_progress = False
                raise Exception("Pocket Mode: UI context missing")

            def _set_icon_busy(busy):
                try:
                    if icon_view is not None:
                        icon_view.setEnabled(not busy)
                        self._pocket_mode_sync_icon_visual(icon_view)
                except Exception:
                    pass

            _set_icon_busy(True)
            try:
                if getattr(self, "_loading_dialog", None) is not None:
                    try:
                        self._loading_dialog.dismiss()
                    except Exception:
                        pass
                    self._loading_dialog = None
            except Exception:
                pass

            dialog = AlertDialogBuilder(ctx, AlertDialogBuilder.ALERT_TYPE_SPINNER)
            dialog.set_title("Pocket Mode")
            dialog.set_message("Applying changes...")
            dialog.set_cancelable(True)
            dialog.set_canceled_on_touch_outside(True)
            self._loading_dialog = dialog
            dialog.show()

            def _worker():
                ok = False
                err = ""
                install_path = None
                try:
                    try:
                        self._trace("Pocket Mode: starting update", "INFO")
                    except Exception:
                        pass
                    install_path = self._pocket_mode_prepare_install_file(want_pocket)
                    ok = True
                except Exception as e:
                    err = str(e)
                    ok = False

                def _done():
                    if ok:
                        try:
                            started = self._pocket_mode_install_silently(
                                install_path,
                                want_pocket,
                                done_cb=lambda success, final_enabled: (_set_icon_busy(False), done_cb(success, final_enabled) if callable(done_cb) else None),
                            )
                        except Exception:
                            started = False
                        if not started:
                            try:
                                self._pocket_mode_install_in_progress = False
                            except Exception:
                                pass
                            try:
                                if getattr(self, "_loading_dialog", None) is dialog:
                                    dialog.dismiss()
                                    self._loading_dialog = None
                            except Exception:
                                pass
                            try:
                                _set_icon_busy(False)
                            except Exception:
                                pass
                            try:
                                BulletinHelper.show_error("Pocket Mode installation failed to start.")
                            except Exception:
                                pass
                            try:
                                if callable(done_cb):
                                    done_cb(False, bool(current_enabled))
                            except Exception:
                                pass
                    else:
                        try:
                            self._pocket_mode_install_in_progress = False
                        except Exception:
                            pass
                        try:
                            if getattr(self, "_loading_dialog", None) is dialog:
                                dialog.dismiss()
                                self._loading_dialog = None
                        except Exception:
                            pass
                        try:
                            _set_icon_busy(False)
                        except Exception:
                            pass
                        try:
                            BulletinHelper.show_error(err or "Pocket Mode installation failed.")
                        except Exception:
                            pass
                        try:
                            if callable(done_cb):
                                done_cb(False, bool(current_enabled))
                        except Exception:
                            pass

                run_on_ui_thread(_done)

            threading.Thread(target=_worker, daemon=True).start()
        except Exception as e:
            try:
                self._pocket_mode_install_in_progress = False
            except Exception:
                pass
            try:
                BulletinHelper.show_error(str(e) or "Pocket Mode error.")
            except Exception:
                pass

    def _show_settings_sheet(self, forced_ctx=None):
        run_on_ui_thread(lambda: self._show_settings_sheet_ui(forced_ctx))

    def _show_settings_sheet_ui(self, forced_ctx=None):
        try:
            ctx = forced_ctx
            frag = get_last_fragment() or self._fragment_ref
            if ctx is None:
                ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                self._trace("show settings sheet fail: context unavailable", "ERROR")
                return False
            listener_cls = find_class("android.view.View$OnClickListener")
            try:
                if getattr(self, "_settings_sheet", None) is not None:
                    self._settings_sheet.dismiss()
            except Exception:
                pass
            self._settings_sheet = None

            sheet = BottomSheet(ctx, True)
            scroll = jclass("android.widget.ScrollView")(ctx)
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(18))

            title_color = int(Theme.getColor(Theme.key_dialogTextBlack))
            sub_color = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))

            handle_wrap = LinearLayout(ctx)
            handle_wrap.setGravity(Gravity.CENTER)
            handle = View(ctx)
            bg = GradientDrawable()
            bg.setCornerRadius(float(AndroidUtilities.dp(3)))
            bg.setColor(self._jcolor((int(sub_color) & 0x66FFFFFF) or 0x66AAB4C2))
            handle.setBackground(bg)
            handle_wrap.addView(handle, LinearLayout.LayoutParams(AndroidUtilities.dp(42), AndroidUtilities.dp(6)))
            lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp.bottomMargin = AndroidUtilities.dp(18)
            outer.addView(handle_wrap, lp)

            title = TextView(ctx)
            title.setText(self._tr("panel_settings"))
            title.setTextSize(22)
            title.setTypeface(None, 1)
            title.setTextColor(int(title_color))
            title.setGravity(Gravity.CENTER_HORIZONTAL)
            outer.addView(title)

            desc = TextView(ctx)
            desc.setText(self._tr("panel_settings_desc"))
            desc.setTextSize(14)
            desc.setTextColor(int(sub_color))
            desc.setGravity(Gravity.CENTER_HORIZONTAL)
            desc_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            desc_lp.topMargin = AndroidUtilities.dp(8)
            desc_lp.bottomMargin = AndroidUtilities.dp(16)
            outer.addView(desc, desc_lp)

            plugin = self
            active_card_color = self._jcolor(0xFFEB3F44)
            active_text_color = self._jcolor(0xFFFFFFFF)
            inactive_card_color = int(Theme.getColor(Theme.key_dialogBackgroundGray))

            def _settings_switch_row(icon_name, title_key, desc_key, checked_getter, on_change, top_margin_dp=0):
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(8), AndroidUtilities.dp(14), AndroidUtilities.dp(8))
                row_bg = GradientDrawable()
                row_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                row.setBackground(row_bg)

                pic = LinearLayout(ctx)
                pic.setGravity(Gravity.CENTER_VERTICAL)
                piv = None
                try:
                    piv = ImageView(ctx)
                    res = ApplicationLoader.applicationContext.getResources()
                    pkg = ApplicationLoader.applicationContext.getPackageName()
                    pid = res.getIdentifier(str(icon_name or ""), "drawable", pkg)
                    if pid:
                        piv.setImageResource(int(pid))
                    pic.addView(piv, LinearLayout.LayoutParams(AndroidUtilities.dp(22), AndroidUtilities.dp(22)))
                except Exception:
                    pass
                row.addView(pic)

                info = LinearLayout(ctx)
                info.setOrientation(LinearLayout.VERTICAL)
                info_lp = LinearLayout.LayoutParams(0, -2, 1.0)
                info_lp.leftMargin = AndroidUtilities.dp(8)
                t1 = TextView(ctx)
                title_text = str(title_key or "")
                if title_text.startswith("literal:"):
                    title_text = title_text.split(":", 1)[1]
                else:
                    title_text = self._tr(title_text)
                t1.setText(title_text)
                t1.setTextSize(15)
                t1.setTypeface(None, 1)
                info.addView(t1)
                t2 = TextView(ctx)
                t2.setText(self._tr(desc_key))
                t2.setTextSize(11)
                t2.setPadding(0, AndroidUtilities.dp(2), 0, 0)
                info.addView(t2)
                row.addView(info, info_lp)

                state = {"value": bool(checked_getter())}

                def _apply_state():
                    active = bool(state["value"])
                    try:
                        row_bg.setColor(int(active_card_color if active else inactive_card_color))
                    except Exception:
                        pass
                    try:
                        t1.setTextColor(int(active_text_color if active else title_color))
                    except Exception:
                        pass
                    try:
                        t2.setTextColor(int(active_text_color if active else sub_color))
                    except Exception:
                        pass
                    try:
                        if piv is not None:
                            piv.setColorFilter(int(active_text_color if active else title_color), PorterDuff.Mode.SRC_IN)
                    except Exception:
                        pass

                _apply_state()

                if listener_cls is not None:
                    class _RowClick(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            try:
                                new_value = not bool(state["value"])
                                on_change(bool(new_value))
                                state["value"] = bool(checked_getter())
                                _apply_state()
                            except Exception as ex:
                                plugin._trace("settings toggle fail ({0}): {1}".format(title_key, ex), "ERROR")

                    row.setOnClickListener(_RowClick())

                row_lp = LinearLayout.LayoutParams(-1, -2)
                row_lp.topMargin = AndroidUtilities.dp(int(top_margin_dp or 0))
                outer.addView(row, row_lp)

            _settings_switch_row(
                "msg_tone_add_solar",
                "panel_menu_shortcuts_enabled",
                "panel_menu_shortcuts_enabled_desc",
                lambda: plugin._menu_shortcuts_enabled(),
                lambda is_checked: (plugin._set_menu_shortcuts_enabled(bool(is_checked)), plugin._ensure_dialogs_menu_item(), plugin._ensure_chat_menu_item()),
                0,
            )
            _settings_switch_row(
                "filter_note",
                "literal:Button for Pomme",
                "panel_compose_button_desc",
                lambda: plugin._compose_button_enabled(),
                lambda is_checked: (plugin._set_compose_button_enabled(bool(is_checked)), plugin._refresh_chat_compose_button_visibility()),
                12,
            )
            _settings_switch_row(
                "msg_notifications_remix",
                "panel_notifications_enabled",
                "panel_notifications_enabled_desc",
                lambda: plugin._notifications_enabled(),
                lambda is_checked: plugin._set_notifications_enabled(bool(is_checked)),
                12,
            )
            _settings_switch_row(
                "plugins_safe_mode",
                "safe_mode_title",
                "safe_mode_sub",
                lambda: plugin._safe_mode_enabled(),
                lambda is_checked: plugin.set_setting("pomme_safe_mode_enabled", bool(is_checked)),
                12,
            )
            _settings_switch_row(
                "msg_filled_datausage",
                "network_compat_title",
                "network_compat_desc",
                lambda: plugin._network_compat_enabled(),
                lambda is_checked: plugin.set_setting("pomme_network_compat_enabled", bool(is_checked)),
                12,
            )

            btn_row = LinearLayout(ctx)
            btn_row.setOrientation(LinearLayout.HORIZONTAL)
            btn_row.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
            btn_row_lp = LinearLayout.LayoutParams(-1, LinearLayout.LayoutParams.WRAP_CONTENT)
            btn_row_lp.topMargin = AndroidUtilities.dp(16)
            btn_row.setLayoutParams(btn_row_lp)

            close_btn = TextView(ctx)
            close_btn.setText(self._tr("cancel"))
            close_btn.setTextSize(14)
            close_btn.setTypeface(None, 1)
            close_btn.setTextColor(sub_color)
            close_btn.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(10), AndroidUtilities.dp(16), AndroidUtilities.dp(10))

            if listener_cls is not None:
                class _Close(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        try:
                            sheet.dismiss()
                        except Exception:
                            pass
                        plugin._settings_sheet = None

                close_btn.setOnClickListener(_Close())

            btn_row.addView(close_btn)
            outer.addView(btn_row)

            scroll.addView(outer)
            sheet.setCustomView(scroll)
            sheet.show()
            self._settings_sheet = sheet
            return True
        except Exception as e:
            self._trace("show settings sheet fail: {0}".format(e), "ERROR")
            return False

