            m.setAccessible(True)
            self._hooks.append(self.hook_method(m, PommeDialogsCreateHook(self)))
        except Exception as e:
            self._trace("hook createView fail: {0}".format(e))

        try:
            m = dialogs_cls.getDeclaredMethod("onResume")
            m.setAccessible(True)
            self._hooks.append(self.hook_method(m, PommeDialogsResumeHook(self)))
