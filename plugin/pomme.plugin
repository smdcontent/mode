    def _stable_artwork_cache_path(self, url):
        try:
            url = str(url or "").strip()
            cache_root = self._artwork_cache_dir()
            if not url or not cache_root:
                return ""
            ext = os.path.splitext(urllib.parse.urlparse(url).path or "")[1].lower()
            if ext not in (".jpg", ".jpeg", ".png", ".webp"):
                ext = ".img"
            return os.path.join(cache_root, hashlib.md5(url.encode("utf-8")).hexdigest() + ext)
        except Exception:
            return ""

    def _cached_remote_bytes(self, url, cache_key=None):
        try:
            url = str(url or "").strip()
            if not url:
                return None
            cache_path = self._stable_artwork_cache_path(url)
            if not cache_path:
                return None
            if os.path.exists(cache_path) and os.path.getsize(cache_path) > 0:
                with open(cache_path, "rb") as fh:
                    return fh.read()
            stable_key = hashlib.md5(str(cache_key or url).encode("utf-8")).hexdigest()
            data = self._http_get_bytes(
                url,
                headers={"Accept": "image/*"},
                timeout=8,
                cache_key="art::{0}".format(stable_key),
                ttl_sec=7 * 24 * 60 * 60,
                allow_stale=True,
                profile="image",
            )
            if data:
                with open(cache_path, "wb") as fh:
                    fh.write(data)
                return data
            return None
        except Exception as e:
            try:
                now = time.time()
                msg = str(e or "")
                if ("No address associated with hostname" in msg) or ("urlopen error [Errno 7]" in msg):
                    if (now - float(self._last_artwork_fetch_warn_ts or 0.0)) >= 60.0:
                        self._last_artwork_fetch_warn_ts = now
                        self._trace("Artwork cache is offline right now", "INFO")
                else:
                    self._trace("Artwork cache fetch skipped: {0}".format(msg), "WARN")
            except Exception:
                pass
            return None

    def _download_asset(self, url, out_path):
        try:
            if not out_path:
                return False
            req = Request(str(url), headers={"User-Agent": "Mozilla/5.0"})
            with urlopen(req, timeout=12) as resp:
                data = resp.read()
            if not data:
                return False
            with open(out_path, "wb") as fh:
                fh.write(data)
            return True
        except Exception:
            return False

    def _ensure_about_assets(self, sync=False):
        try:
            avatar_file = self._about_avatar_cache_file()
            dark_file = self._about_ext_icon_cache_file(True)
            light_file = self._about_ext_icon_cache_file(False)

            def _worker():
                try:
                    if avatar_file and not os.path.exists(avatar_file):
                        self._download_asset(ABOUT_AVATAR_URL, avatar_file)
                    if dark_file and not os.path.exists(dark_file):
                        self._download_asset(EXTENDED_ICON_URL_DARK, dark_file)
                    if light_file and not os.path.exists(light_file):
                        self._download_asset(EXTENDED_ICON_URL_LIGHT, light_file)
                except Exception as e:
                    self._trace("ensure about assets fail: {0}".format(e), "WARN")
            if sync:
                _worker()
            else:
                threading.Thread(target=_worker, daemon=True).start()
            return True
        except Exception as e:
            self._trace("ensure about assets bootstrap fail: {0}".format(e), "WARN")
            return False

    def _open_url(self, url):
        try:
            browser_cls = find_class("org.telegram.messenger.browser.Browser")
            ctx = ApplicationLoader.applicationContext
            if browser_cls is None or ctx is None:
                return False
            run_on_ui_thread(lambda: browser_cls.openUrl(ctx, str(url)))
            return True
        except Exception as e:
            self._trace("open url fail: {0}".format(e), "ERROR")
            return False

    def _search_itunes_artwork(self, artist, title):
        try:
            term = urllib.parse.quote_plus("{0} {1}".format(str(artist or ""), str(title or "")).strip())
            data = self._http_get_json(
                "https://itunes.apple.com/search?term={0}&entity=song&limit=1".format(term),
                headers={"Accept": "application/json"},
                timeout=6,
                cache_key="itunes::{0}".format(term),
                ttl_sec=6 * 60 * 60,
                allow_stale=True,
            )
            results = list((data or {}).get("results") or [])
            if not results:
                return ""
            url = str(results[0].get("artworkUrl100") or "").strip()
            if not url:
                return ""
            return url.replace("100x100", "600x600")
        except Exception:
            return ""

    def _is_youtube_art_url(self, url):
        try:
            u = str(url or "").strip().lower()
            if not u:
                return False
            if "i.ytimg.com" in u or "img.youtube.com" in u:
                return True
            if "ytimg.com/vi/" in u:
                return True
            return False
        except Exception:
            return False

    def _spotify_client_credentials_token(self):
        try:
            cid = str(self.get_setting("pomme_spotify_client_id", "") or "").strip()
            csec = str(self.get_setting("pomme_spotify_client_secret", "") or "").strip()
            if not cid or not csec:
                return ""
            now = time.time()
            c = getattr(self, "_spotify_cc_cache", None)
            if isinstance(c, dict) and float(c.get("exp") or 0) > now + 60:
                t = str(c.get("token") or "")
                if t:
                    return t
            body = urllib.parse.urlencode({"grant_type": "client_credentials"}).encode("utf-8")
            auth = base64.b64encode("{0}:{1}".format(cid, csec).encode("utf-8")).decode("ascii")
            req = Request(
                "https://accounts.spotify.com/api/token",
                data=body,
                headers={
                    "Authorization": "Basic {0}".format(auth),
                    "Content-Type": "application/x-www-form-urlencoded",
                    "User-Agent": "Mozilla/5.0 (PommePlugin)",
                },
            )
            with urlopen(req, timeout=12) as resp:
                data = json.loads(resp.read().decode("utf-8", "ignore"))
            tok = str(data.get("access_token") or "").strip()
            if not tok:
                return ""
            exp = now + float(data.get("expires_in") or 3500)
            self._spotify_cc_cache = {"token": tok, "exp": exp}
            return tok
        except Exception as e:
            self._trace("spotify client_credentials token fail: {0}".format(e), "DEBUG")
            return ""

    def _search_spotify_cover_webapi(self, artist, title):
        try:
            tok = self._spotify_client_credentials_token()
            if not tok:
                return ""
            artist = str(artist or "").strip()
            title = str(title or "").strip()
            if not title:
                return ""
            q = "{0} {1}".format(title, artist).strip()
            params = urllib.parse.urlencode({"q": q, "type": "track", "limit": "8"})
            req = Request(
                "https://api.spotify.com/v1/search?{0}".format(params),
                headers={
                    "Authorization": "Bearer {0}".format(tok),
                    "Accept": "application/json",
                    "User-Agent": "Mozilla/5.0 (PommePlugin)",
                },
            )
            with urlopen(req, timeout=12) as resp:
                data = json.loads(resp.read().decode("utf-8", "ignore"))
            items = list((((data or {}).get("tracks") or {}).get("items")) or [])
            if not items:
                return ""

            def _norm(s):
                try:
                    return re.sub(r"\s+", " ", str(s or "").lower().strip())
                except Exception:
                    return str(s or "").lower().strip()

            nt = _norm(title)
            na = _norm(artist)
            best = None
            best_sc = -1
            for it in items:
                it_title = _norm((it or {}).get("name"))
                arts = ", ".join([str((x or {}).get("name") or "") for x in list((it or {}).get("artists") or [])])
                it_art = _norm(arts)
                sc = 0
                if nt and (it_title == nt or nt in it_title):
                    sc += 4
                elif nt and it_title and (it_title in nt):
                    sc += 2
                if na and it_art and (na in it_art or it_art in na):
                    sc += 3
                if sc > best_sc:
                    best_sc = sc
                    best = it
            pick = best or items[0]
            album = (pick or {}).get("album") or {}
            for img in list(album.get("images") or []):
                u = str((img or {}).get("url") or "").strip()
                if u:
                    return u
        except Exception as e:
            self._trace("spotify web api cover fail: {0}".format(e), "DEBUG")
        return ""

    def _search_deezer_cover_url(self, artist, title):
        try:
            artist = str(artist or "").strip()
            title = str(title or "").strip()
            if not title:
                return ""
            key = "{0}\t{1}".format(artist.lower(), title.lower())
            memo = self._deezer_cover_memo
            if key in memo:
                return str(memo.get(key) or "")
            queries = []
            if artist:
                queries.append('artist:"{0}" track:"{1}"'.format(artist.replace('"', ""), title.replace('"', "")))
            queries.append("{0} {1}".format(artist, title).strip())
            queries.append(title)
            out = ""
            headers = {"Accept": "application/json"}
            for qstr in queries:
                qs = str(qstr or "").strip()
                if not qs:
                    continue
                url = "https://api.deezer.com/search/track?q=" + urllib.parse.quote(qs, safe="")
                data = self._http_get_json(
                    url,
                    headers=headers,
                    timeout=10,
                    cache_key="deezer::{0}".format(qs.lower()),
                    ttl_sec=3 * 60 * 60,
                    allow_stale=True,
                )
                items = list((data or {}).get("data") or [])
                if not items:
                    continue
                alb = (items[0] or {}).get("album") or {}
                out = str(alb.get("cover_xl") or alb.get("cover_big") or alb.get("cover") or "").strip()
                if out:
                    break
            if len(memo) > 48:
                memo.clear()
            memo[key] = str(out or "")
            return str(out or "")
        except Exception as e:
            self._trace("deezer cover fail: {0}".format(e), "DEBUG")
            return ""

    def _search_spotify_track_url_public(self, artist, title):
        try:
            artist = str(artist or "").strip()
            title = str(title or "").strip()
            if not title:
                return ""
            q = "site:open.spotify.com/track {0} {1}".format(title, artist).strip()
            url = "https://duckduckgo.com/html/?q={0}".format(urllib.parse.quote(q))
            body = self._http_get_text(
                url,
                headers={
                    "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
                },
                timeout=8,
                cache_key="ddg::{0}".format(q.lower()),
                ttl_sec=20 * 60,
                allow_stale=True,
                profile="web",
            )
            m = re.search(r"https://open\.spotify\.com/track/[A-Za-z0-9]+", body)
            if m:
                return str(m.group(0) or "").strip()
        except Exception as e:
            self._trace("spotify ddg search fail: {0}".format(e), "DEBUG")
        return ""

    def _get_spotify_oembed_thumbnail(self, spotify_track_url):
        try:
            u = str(spotify_track_url or "").strip()
            if not u:
                return ""
            headers = {"Accept": "application/json,text/html;q=0.9,*/*;q=0.8"}
            oembed = "https://open.spotify.com/oembed?url={0}".format(urllib.parse.quote(u, safe=""))
            raw = self._http_get_text(
                oembed,
                headers=headers,
                timeout=8,
                cache_key="spotify_oembed::{0}".format(u),
                ttl_sec=12 * 60 * 60,
                allow_stale=True,
            )
            data = json.loads(raw)
            thumb = str((data or {}).get("thumbnail_url") or "").strip()
            if thumb:
                return thumb
        except Exception:
            pass
        try:
            html = self._http_get_text(
                u,
                headers=headers,
                timeout=8,
                cache_key="spotify_page::{0}".format(u),
                ttl_sec=12 * 60 * 60,
                allow_stale=True,
            )
            m = re.search(r'<meta property="og:image" content="([^"]+)"', html)
            if m:
                return str(m.group(1) or "").strip()
        except Exception:
            pass
        return ""

    def _search_spotify_cover_art_url(self, artist, title):
        try:
            artist = str(artist or "").strip()
            title = str(title or "").strip()
            if not title:
                return ""
            key = "{0}\t{1}".format(artist.lower(), title.lower())
            memo = self._spotify_cover_memo
            if key in memo:
                return str(memo.get(key) or "")
            out = self._search_spotify_cover_webapi(artist, title)
            if not out:
                track_url = self._search_spotify_track_url_public(artist, title)
                if track_url:
                    out = self._get_spotify_oembed_thumbnail(track_url)
            if len(memo) > 48:
                memo.clear()
            memo[key] = str(out or "")
            return str(out or "")
        except Exception as e:
            self._trace("spotify cover resolve fail: {0}".format(e), "DEBUG")
            return ""

    def _search_lastfm_artwork(self, artist, title):
        try:
            artist = str(artist or "").strip()
            title = str(title or "").strip()
            if not artist or not title:
                return ""
            params = urllib.parse.urlencode({
                "method": "track.getInfo",
                "artist": artist,
                "track": title,
                "api_key": "1d0f37b9d1a3c1f1f4aaf4be5f97d95d",
                "format": "json",
            })
            req = Request(
                "https://ws.audioscrobbler.com/2.0/?{0}".format(params),
                headers={"User-Agent": "Mozilla/5.0", "Accept": "application/json"},
            )
            with urlopen(req, timeout=6) as resp:
                data = json.loads(resp.read().decode("utf-8", "ignore"))
            album = ((data or {}).get("track") or {}).get("album") or {}
            images = list(album.get("image") or [])
            chosen = ""
            for entry in images:
                candidate = str((entry or {}).get("#text") or "").strip()
                if candidate:
                    chosen = candidate
            if chosen.startswith("http://"):
                chosen = "https://" + chosen[7:]
            return chosen
        except Exception:
            return ""

    def _search_musicbrainz_cover(self, artist, title):
        try:
            artist = str(artist or "").strip()
            title = str(title or "").strip()
            if not title:
                return ""
            key = "{0}\t{1}".format(artist.lower(), title.lower())
            memo = self._musicbrainz_cover_memo
            if key in memo:
                return str(memo.get(key) or "")
            query = 'recording:"{0}" AND artist:"{1}"'.format(title.replace('"', ""), artist.replace('"', "")) if artist else 'recording:"{0}"'.format(title.replace('"', ""))
            req = Request(
                "https://musicbrainz.org/ws/2/recording?query={0}&fmt=json&limit=6".format(urllib.parse.quote(query, safe="")),
                headers={"User-Agent": "PommePlugin/1.0 (metadata fallback)", "Accept": "application/json"},
            )
            with urlopen(req, timeout=8) as resp:
                data = json.loads(resp.read().decode("utf-8", "ignore"))
            recordings = list((data or {}).get("recordings") or [])
            best_release_id = ""
            best_score = -1
            for recording in recordings:
                rels = list((recording or {}).get("releases") or [])
                if not rels:
                    continue
                cand_title = str((recording or {}).get("title") or "").strip()
                cand_artist = ", ".join([str((x or {}).get("name") or "").strip() for x in list((recording or {}).get("artist-credit") or []) if str((x or {}).get("name") or "").strip()])
                score = self._lyrics_match_score(title, artist, cand_title, cand_artist, 0, 0)
                release_id = str((rels[0] or {}).get("id") or "").strip()
                if release_id and score > best_score:
                    best_score = score
                    best_release_id = release_id
            out = ""
            if best_release_id:
                out = "https://coverartarchive.org/release/{0}/front-500".format(best_release_id)
            if len(memo) > 48:
                memo.clear()
            memo[key] = str(out or "")
            return str(out or "")
        except Exception as e:
            self._trace("musicbrainz cover fail: {0}".format(e), "DEBUG")
            return ""

    def _cover_candidates(self, item):
        try:
            item = dict(item or {})
            try:
                if str(self.get_setting("pomme_statsfm_username", "") or "").strip():
                    self._statsfm_touch_index_background()
            except Exception:
                pass
            performer, clean_title = self._clean_music_metadata(item)
            video_id = self._extract_video_id(item)
            stored = str(item.get("cover_url") or "").strip()
            thumb = str(item.get("thumbnail") or "").strip()
            seen = set()
            prio = []
            tail = []

            def add_prio(u):
                u = str(u or "").strip()
                if not u or u in seen:
                    return
                if self._is_youtube_art_url(u):
                    return
                seen.add(u)
                prio.append(u)

            def add_tail(u):
                u = str(u or "").strip()
                if not u or u in seen:
                    return
                seen.add(u)
                tail.append(u)

                                                                                                            
                                                                                                  
            add_prio(stored)
            add_prio(self._search_itunes_artwork(performer, clean_title))
            add_prio(self._search_deezer_cover_url(performer, clean_title))
            add_prio(self._search_spotify_cover_art_url(performer, clean_title))
            add_prio(self._statsfm_lookup_cover(performer, clean_title))
            add_prio(self._search_lastfm_artwork(performer, clean_title))
            add_prio(self._search_musicbrainz_cover(performer, clean_title))
            add_prio(thumb)

            if video_id:
                for tmpl in (
                    "https://i.ytimg.com/vi/{0}/maxresdefault.jpg",
                    "https://i.ytimg.com/vi/{0}/sddefault.jpg",
                    "https://i.ytimg.com/vi/{0}/hqdefault.jpg",
                    "https://i.ytimg.com/vi/{0}/mqdefault.jpg",
                    "https://i.ytimg.com/vi/{0}/default.jpg",
                ):
                    add_tail(tmpl.format(video_id))
            if thumb and self._is_youtube_art_url(thumb):
                add_tail(thumb)
            if stored and self._is_youtube_art_url(stored):
                add_tail(stored)
            add_tail(POMME_PLACEHOLDER_COVER)
            return prio + tail
        except Exception:
            return [POMME_PLACEHOLDER_COVER]

    def _resolve_music_cover_url(self, item):
        try:
            for url in self._cover_candidates(item):
                url = str(url or "").strip()
                if url:
                    return url
            return POMME_PLACEHOLDER_COVER
        except Exception:
            return POMME_PLACEHOLDER_COVER

    def _prefetch_cover(self, item):
        try:
            if not isinstance(item, dict):
                return
            existing_cover = self._cover_file_for_item(item)
            if existing_cover and os.path.exists(existing_cover):
                item["cover_cached_file"] = existing_cover
                return
            if self._offline_listening_enabled():
                return
            cover_url = self._resolve_music_cover_url(item)
            item["cover_url"] = cover_url
            def _load():
                try:
                    self._statsfm_touch_index_background()
                except Exception:
                    pass
                for candidate in self._cover_candidates(item):
                    cache_key = "pomme_cover::{0}".format(hashlib.md5(str(candidate or "").encode("utf-8")).hexdigest())
                    data = self._cached_remote_bytes(candidate, cache_key=cache_key)
                    if data:
                        item["cover_url"] = candidate
                        try:
                            stable_path = self._stable_artwork_cache_path(candidate)
                            if stable_path:
                                item["cover_cached_file"] = stable_path
                                try:
                                    video_id = str(self._extract_video_id(item or {}) or "").strip()
                                    if video_id:
                                        idx = self._track_index_read()
                                        entry = dict(idx.get(video_id) or {})
                                        if entry:
                                            entry["cover_url"] = str(candidate or "").strip()
                                            entry["cover_cached_file"] = str(stable_path or "").strip()
                                            idx[video_id] = entry
                                            self._track_index_write(idx)
                                except Exception:
                                    pass
                        except Exception:
                            pass
                        break
            threading.Thread(target=_load, daemon=True).start()
        except Exception:
            pass

    def _extract_video_id(self, item):
        try:
            vid = str(item.get("id") or "").strip()
            if vid:
                return vid
            url = str(item.get("url") or "").strip()
            parsed = urllib.parse.urlparse(url)
            try:
                host = str(parsed.netloc or "").lower()
                if "youtu.be" in host:
                    seg = str(parsed.path or "").strip("/").split("/")[0].strip()
                    if len(seg) >= 11:
                        return seg[:11]
            except Exception:
                pass
            qs = urllib.parse.parse_qs(parsed.query or "")
            if qs.get("v"):
                return str(qs.get("v")[0] or "").strip()
            if parsed.path.startswith("/watch/"):
                return parsed.path.rsplit("/", 1)[-1].strip()
            return ""
        except Exception:
            return ""

    def _music_file_name(self, item, ext):
        try:
            title = re.sub(r'[^A-Za-z0-9._ -]+', '', str(item.get("title") or "").strip()).strip()
            if not title:
                title = self._extract_video_id(item) or "track"
            return "{0}.{1}".format(title[:80], ext)
        except Exception:
            return "track.{0}".format(ext)

    def _clean_music_metadata(self, item):
        raw_title = str(item.get("title") or "").strip()
        raw_author = str(item.get("author") or "").strip()
        
                                                            
        performer = raw_author or "YouTube"
                                                                                             
        for sep in [" & ", ",", " feat. ", " ft. ", " x ", " / ", " with ", " | "]:
            if sep in performer.lower():
                performer = performer.lower().split(sep, 1)[0].strip().title()
                break
        
                                                                  
        performer = re.sub(r"\s+\b(topic|official|vevo|presents|records|channel|music)\b.*$", "", performer, flags=re.I).strip(" -")
        
        title = raw_title
        if raw_author:
            lowered = raw_title.lower()
            prefix = (raw_author + " - ").lower()
            if lowered.startswith(prefix):
                title = raw_title[len(raw_author) + 3 :].strip()
            elif " | " in raw_title:
                parts = raw_title.split(" | ", 1)
                title = parts[1].strip()
        
                                     
                                                                           
        clean_patterns = [
            r"\((official video|official audio|lyrics?|lyric video|audio|video|hq|hd|4k|high definition)\)",
            r"\[(official video|official audio|lyrics?|lyric video|audio|video|hq|hd|4k|high definition)\]",
            r"\s*[-|]\s*(official video|official audio|lyrics?|lyric video|audio|video|hq|hd|4k|high definition|music video|official)\s*$",
            r"\s+\b(official video|official audio|lyrics?|lyric video|audio|video|hq|hd|4k|high definition|music video|official)\b.*$",
            r"\s+\b(feat\.?|ft\.|featuring|participação|part\.|with)\b.*$",
            r"\s+\b(prod\.?|produced by|by)\b.*$",
            r"\s+\b(remaster(ed)?|live|visualizer|official|music video|lyric video|original mix|radio edit)\b.*$",
        ]
        
        for p in clean_patterns:
            title = re.sub(p, "", title, flags=re.I).strip()
            
                                                             
        title = re.sub(r"\(\s*\)|\[\s*\]", "", title).strip()
        title = re.sub(r"\s{2,}", " ", title).strip(" -|")
        if not title:
            title = raw_title or "Track"
            
        return performer.strip(), title.strip()

    def _cover_file_for_item(self, item):
        try:
            cached_file = str((item or {}).get("cover_cached_file") or "").strip()
            if cached_file and os.path.exists(cached_file):
                return cached_file
            video_id = str(self._extract_video_id(item or {}) or "").strip()
            if video_id:
                entry = dict((self._track_index_read().get(video_id) or {}))
                idx_cover = str(entry.get("cover_cached_file") or "").strip()
                if idx_cover and os.path.exists(idx_cover):
                    return idx_cover
            cover_url = str((item or {}).get("cover_url") or (item or {}).get("thumbnail") or "").strip()
            if cover_url:
                cache_root = self._artwork_cache_dir()
                if cache_root:
                    stable_key = hashlib.md5(cover_url.encode("utf-8")).hexdigest()
                    for ext in (".jpg", ".jpeg", ".png", ".webp", ".img"):
                        potential = os.path.join(cache_root, stable_key + ext)
                        if os.path.exists(potential):
                            return potential
            return ""
        except Exception:
            return ""

    def _prepare_native_cover_thumb(self, item, max_edge=640, max_bytes=196608):
        try:
            item = dict(item or {})
            memo_key = str(item.get("cover_url") or item.get("cover_cached_file") or item.get("thumbnail") or self._extract_video_id(item) or "").strip()
            payload = dict((self._native_cover_thumb_memo or {}).get(memo_key) or {})
            if payload and int(payload.get("exp") or 0) > int(time.time()) and payload.get("data"):
                return payload

            source_path = self._cover_file_for_item(item)
            raw_data = None
            if source_path and os.path.exists(source_path):
                with open(source_path, "rb") as fh:
                    raw_data = fh.read()
            if not raw_data and self._offline_listening_enabled():
                return None
            if not raw_data:
                for cover_url in self._cover_candidates(item):
                    data = self._cached_remote_bytes(cover_url, cache_key="pomme_doc::{0}".format(hashlib.md5(str(cover_url or "").encode("utf-8")).hexdigest()))
                    if data:
                        raw_data = data
                        item["cover_url"] = cover_url
                        try:
                            stable_path = self._stable_artwork_cache_path(cover_url)
                            if stable_path:
                                item["cover_cached_file"] = stable_path
                        except Exception:
                            pass
                        break
            if not raw_data:
                return None

            BitmapFactory = jclass("android.graphics.BitmapFactory")
            Bitmap = jclass("android.graphics.Bitmap")
            ByteArrayOutputStream = jclass("java.io.ByteArrayOutputStream")
            bitmap = BitmapFactory.decodeByteArray(raw_data, 0, len(raw_data))
            if bitmap is None:
                return None
            width = int(bitmap.getWidth() or 0)
            height = int(bitmap.getHeight() or 0)
            if width <= 0 or height <= 0:
                return None

            work_bmp = bitmap
            max_side = max(width, height)
            if max_side > int(max_edge or 640):
                scale = float(max_edge or 640) / float(max_side)
                new_w = max(1, int(round(width * scale)))
                new_h = max(1, int(round(height * scale)))
                try:
                    work_bmp = Bitmap.createScaledBitmap(bitmap, new_w, new_h, True)
                    width, height = new_w, new_h
                except Exception:
                    work_bmp = bitmap

            compress_format = getattr(jclass("android.graphics.Bitmap$CompressFormat"), "JPEG")
            out = None
            final_bytes = None
            for quality in (92, 88, 84, 80, 76, 72, 68):
                out = ByteArrayOutputStream()
                work_bmp.compress(compress_format, int(quality), out)
                candidate = bytes(out.toByteArray())
                if candidate and len(candidate) <= int(max_bytes or 196608):
                    final_bytes = candidate
                    break
            if final_bytes is None and out is not None:
                final_bytes = bytes(out.toByteArray())
            if not final_bytes:
                return None

            result = {
                "data": final_bytes,
                "w": int(width),
                "h": int(height),
                "size": int(len(final_bytes)),
                "exp": int(time.time()) + 3600,
            }
            if memo_key:
                if len(self._native_cover_thumb_memo) > 48:
                    self._native_cover_thumb_memo.clear()
                self._native_cover_thumb_memo[memo_key] = dict(result)
            return result
        except Exception as e:
            self._trace("prepare native cover thumb fail: {0}".format(e), "WARN")
            return None

    def _attach_document_thumb(self, document, item):
        try:
            thumb_payload = self._prepare_native_cover_thumb(item)
            if not thumb_payload:
                return
            try:
                TL_photoCachedSize = jclass("org.telegram.tgnet.TLRPC$TL_photoCachedSize")
                cached = TL_photoCachedSize()
                cached.type = "m"
                cached.w = int(thumb_payload.get("w") or 0)
                cached.h = int(thumb_payload.get("h") or 0)
                cached.bytes = thumb_payload.get("data")
                cached.size = int(thumb_payload.get("size") or 0)
                document.thumbs.add(cached)
                return
            except Exception:
                pass
            TL_photoStrippedSize = jclass("org.telegram.tgnet.TLRPC$TL_photoStrippedSize")
            stripped = TL_photoStrippedSize()
            stripped.type = "i"
            stripped.bytes = thumb_payload.get("data")
            document.thumbs.add(stripped)
        except Exception as e:
            self._trace("attach thumb fail: {0}".format(e), "WARN")

    def _pick_audio_format(self, formats):
        try:
            audio_formats = []
            for fmt in list(formats or []):
                mime = str(fmt.get("mimeType") or "")
                if not mime.startswith("audio/"):
                    continue
                audio_formats.append(fmt)
            if not audio_formats:
                return None
            mp4_formats = [f for f in audio_formats if "audio/mp4" in str(f.get("mimeType") or "")]
            if mp4_formats:
                return sorted(mp4_formats, key=lambda x: self._safe_int(x.get("bitrate"), 0))[0]
            return sorted(audio_formats, key=lambda x: self._safe_int(x.get("bitrate"), 0))[0]
        except Exception:
            return None

    def _stream_cache_key(self, item):
        try:
            return str(self._extract_video_id(item) or "").strip()
        except Exception:
            return ""

    def _stream_cache_get(self, item):
        try:
            key = self._stream_cache_key(item)
            if not key:
                return None
            payload = (self._stream_info_memo or {}).get(key)
            if not isinstance(payload, dict):
                return None
            if float(payload.get("exp") or 0) < time.time():
                self._stream_info_memo.pop(key, None)
                return None
            info = dict(payload.get("info") or {})
            if str(info.get("url") or "").strip():
                return info
            return None
        except Exception:
            return None

    def _stream_cache_put(self, item, info, ttl_sec=900):
        try:
            key = self._stream_cache_key(item)
            if not key or not isinstance(info, dict):
                return False
            if len(self._stream_info_memo) > 96:
                self._stream_info_memo.clear()
            self._stream_info_memo[key] = {
                "exp": time.time() + float(ttl_sec or 900),
                "info": dict(info or {}),
            }
            return True
        except Exception:
            return False

    def _extract_stream_url_from_cipher(self, fmt):
        try:
            fmt = dict(fmt or {})
            direct = str(fmt.get("url") or "").strip()
            if direct:
                return direct
            cipher = str(fmt.get("signatureCipher") or fmt.get("cipher") or "").strip()
            if not cipher:
                return ""
            params = urllib.parse.parse_qs(cipher, keep_blank_values=True)
            candidate = str((params.get("url") or [""])[0] or "").strip()
            if candidate:
                return urllib.parse.unquote(candidate)
            return ""
        except Exception:
            return ""

    def _resolve_audio_stream_via_ytdlp(self, item):
        try:
            video_id = self._extract_video_id(item)
            if not video_id:
                return None
            ytdlp_cls = self._require_ytdlp()
            watch_url = "https://www.youtube.com/watch?v={0}".format(video_id)
            opts = {
                "quiet": True,
                "no_warnings": True,
                "noplaylist": True,
                "skip_download": True,
                "format": "bestaudio[ext=m4a]/bestaudio/best",
            }
            with ytdlp_cls(opts) as ydl:
                info = ydl.extract_info(watch_url, download=False)
            formats = list((info or {}).get("formats") or [])
            chosen = None
            for fmt in reversed(formats):
                vcodec = str(fmt.get("vcodec") or "none").lower()
                if vcodec != "none":
                    continue
                url = str(fmt.get("url") or "").strip()
                if not url:
                    continue
                chosen = fmt
                break
            if chosen is None:
                chosen = info or {}
            out = {
                "video_id": video_id,
                "mime": str(chosen.get("ext") or "m4a"),
                "url": str(chosen.get("url") or "").strip(),
                "size": self._safe_int(chosen.get("filesize") or chosen.get("filesize_approx"), 0),
                "duration": self._parse_duration_seconds(chosen.get("duration") or (info or {}).get("duration"), 0),
                "bitrate": self._safe_int(chosen.get("abr") or chosen.get("tbr"), 0),
            }
            if not out["url"]:
                return None
            if "audio/mp4" not in out["mime"] and "audio/webm" not in out["mime"]:
                ext = str(chosen.get("ext") or "").lower()
                out["mime"] = "audio/mp4" if ext in ("m4a", "mp4") else ("audio/webm" if ext == "webm" else "audio/mp4")
            self._trace("stream resolved via fallback extractor | id={0}".format(video_id), "INFO")
            return out
        except Exception as e:
            self._trace("fallback extractor stream resolve fail: {0}".format(e), "DEBUG")
            return None

    def _resolve_audio_stream(self, item):
        if self._offline_listening_enabled():
            raise Exception("Offline mode requires cached audio")
        cached = self._stream_cache_get(item)
        if cached is not None:
            return cached

        video_id = self._extract_video_id(item)
        if not video_id:
            raise Exception("Missing video id")

        client_variants = [
            {
                "clientName": "IOS",
                "clientVersion": "20.10.4",
                "osVersion": "18.3.2.22D82",
                "gl": "US",
                "hl": "en-US",
            },
            {
                "clientName": "ANDROID",
                "clientVersion": "19.09.37",
                "androidSdkVersion": 33,
                "osName": "Android",
                "osVersion": "13",
                "gl": "US",
                "hl": "en",
            },
            {
                "clientName": "TVHTML5_SIMPLY_EMBEDDED_PLAYER",
                "clientVersion": "2.0",
                "gl": "US",
                "hl": "en",
            },
        ]
        failures = []

        for client in client_variants:
            try:
                body = {"context": {"client": dict(client)}, "videoId": video_id}
                req = Request(YOUTUBE_PLAYER_URL, data=json.dumps(body).encode("utf-8"), headers=YOUTUBE_PLAYER_HEADERS)
                obj = json.loads(urlopen(req, timeout=20).read().decode("utf-8", "ignore"))
                status = str((obj.get("playabilityStatus") or {}).get("status") or "")
                if status not in ("OK", "LIVE_STREAM_OFFLINE"):
                    failures.append("{0}:{1}".format(client.get("clientName"), status or "UNKNOWN"))
                    continue
                adaptive = list(((obj.get("streamingData") or {}).get("adaptiveFormats")) or [])
                if not adaptive:
                    failures.append("{0}:no_adaptive".format(client.get("clientName")))
                    continue
                fmt = self._pick_audio_format(adaptive)
                if not fmt:
                    failures.append("{0}:no_audio_fmt".format(client.get("clientName")))
                    continue
                mime = str(fmt.get("mimeType") or "audio/mp4").split(";")[0].strip().lower()
                stream_url = self._extract_stream_url_from_cipher(fmt)
                if not stream_url:
                    failures.append("{0}:no_stream_url".format(client.get("clientName")))
                    continue
                approx_ms = self._safe_int(fmt.get("approxDurationMs"), 0)
                if approx_ms <= 0:
                    approx_ms = self._parse_duration_seconds(item.get("length"), 0) * 1000
                out = {
                    "video_id": video_id,
                    "mime": mime,
                    "url": stream_url,
                    "size": self._safe_int(fmt.get("contentLength"), 0),
                    "duration": int(max(0, approx_ms) / 1000),
                    "bitrate": self._safe_int(fmt.get("bitrate"), 0),
                }
                self._stream_cache_put(item, out)
                self._trace("stream resolved via primary client={0} | id={1}".format(client.get("clientName"), video_id), "INFO")
                return out
            except Exception as e:
                failures.append("{0}:{1}".format(client.get("clientName"), str(e)))

        fallback = self._resolve_audio_stream_via_ytdlp(item)
        if fallback is not None:
            self._stream_cache_put(item, fallback, ttl_sec=600)
            return fallback

        raise Exception("Audio stream unavailable | {0}".format(" | ".join([str(x) for x in failures[:6]])))

    def _download_audio_file(self, item, stream_info):
        cache_dir = self._cache_dir()
        if not cache_dir:
            raise Exception("Cache directory unavailable")

        mime = str(stream_info.get("mime") or "audio/mp4")
        ext = "m4a" if "audio/mp4" in mime else ("webm" if "audio/webm" in mime else "mp3")
        safe_name = self._music_file_name(item, ext)
        file_path = os.path.join(cache_dir, "{0}_{1}".format(stream_info.get("video_id"), safe_name))
        if os.path.exists(file_path) and os.path.getsize(file_path) > 0:
            return file_path

        tmp_path = file_path + ".part"
        req = Request(stream_info.get("url"), headers={"User-Agent": YOUTUBE_PLAYER_HEADERS["User-Agent"]})
        try:
            with urlopen(req, timeout=30) as response, open(tmp_path, "wb") as out:
                while True:
                    chunk = response.read(256 * 1024)
                    if not chunk:
                        break
                    out.write(chunk)
        except HTTPError as http_error:
            if int(getattr(http_error, "code", 0) or 0) != 403:
                raise
            self._trace("direct audio stream returned 403, falling back to yt-dlp", "WARN")
            return self._download_audio_file_via_ytdlp(item, cache_dir)
        if os.path.exists(file_path):
            try:
                os.remove(file_path)
            except Exception:
                pass
        os.replace(tmp_path, file_path)
        return file_path

    def _download_audio_file_via_ytdlp(self, item, cache_dir):
        video_id = self._extract_video_id(item)
        if not video_id:
            raise Exception("Missing video id for yt-dlp fallback")
        ytdlp_cls = self._require_ytdlp()
        watch_url = "https://www.youtube.com/watch?v={0}".format(video_id)
        outtmpl = os.path.join(cache_dir, "%(title)s-{0}.%(ext)s".format(int(time.time())))
        ydl_opts = {
            "outtmpl": outtmpl,
            "quiet": True,
            "no_warnings": True,
            "noplaylist": True,
            "format": "bestaudio[ext=m4a]/bestaudio/best",
        }
        with ytdlp_cls(ydl_opts) as ydl:
            info = ydl.extract_info(watch_url, download=True)
            downloaded_file = ydl.prepare_filename(info)
        if not downloaded_file or not os.path.exists(downloaded_file):
            raise Exception("yt-dlp fallback did not produce a file")
        self._trace("yt-dlp fallback downloaded {0}".format(downloaded_file), "INFO")
        return downloaded_file

    def _build_local_audio_message(self, item, file_path, stream_info):
        try:
            UserConfig = jclass("org.telegram.messenger.UserConfig")
            MessageObject = jclass("org.telegram.messenger.MessageObject")
            TLRPC = jclass("org.telegram.tgnet.TLRPC")
            TL_message = jclass("org.telegram.tgnet.TLRPC$TL_message")
            TL_peerUser = jclass("org.telegram.tgnet.TLRPC$TL_peerUser")
            TL_messageMediaDocument = jclass("org.telegram.tgnet.TLRPC$TL_messageMediaDocument")
            TL_document = jclass("org.telegram.tgnet.TLRPC$TL_document")
            TL_documentAttributeAudio = jclass("org.telegram.tgnet.TLRPC$TL_documentAttributeAudio")
            TL_documentAttributeFilename = jclass("org.telegram.tgnet.TLRPC$TL_documentAttributeFilename")

            frag = get_last_fragment()
            account = int(frag.getCurrentAccount()) if frag is not None else int(getattr(UserConfig, "selectedAccount", 0))
            client_uid = int(UserConfig.getInstance(account).getClientUserId())
            now = int(time.time())
            ext = os.path.splitext(str(file_path or ""))[1].lower().lstrip(".") or "mp3"
            mime = "audio/{0}".format(ext)
            file_size = int(os.path.getsize(file_path)) if os.path.exists(file_path) else int(stream_info.get("size") or 0)
            duration = self._parse_duration_seconds(stream_info.get("duration"), 0)
            unique_id = max(1, int(time.time()) % 2147483647)
            ext_name = os.path.basename(file_path)

            message = TL_message()
            message.out = True
            message.id = unique_id
            message.dialog_id = client_uid
            message.date = now
            try:
                message.flags |= int(getattr(TLRPC, "MESSAGE_FLAG_HAS_MEDIA"))
            except Exception:
                message.flags |= 512
            try:
                message.flags |= int(getattr(TLRPC, "MESSAGE_FLAG_HAS_FROM_ID"))
            except Exception:
                message.flags |= 256
            message.message = ""
            message.attachPath = file_path
            message.peer_id = TL_peerUser()
            message.peer_id.user_id = client_uid
            message.from_id = TL_peerUser()
            message.from_id.user_id = client_uid
            message.media = TL_messageMediaDocument()
            message.media.flags |= 3
            message.media.document = TL_document()
            message.media.document.id = 0
            message.media.document.access_hash = 0
            message.media.document.file_reference = b""
            message.media.document.date = now
            message.media.document.mime_type = mime
            message.media.document.size = file_size
            message.media.document.dc_id = 0
            try:
                message.media.document.file_name = ext_name
            except Exception:
                pass

            performer, clean_title = self._clean_music_metadata(item)

            audio = TL_documentAttributeAudio()
            audio.flags |= 3
            audio.duration = duration
            audio.title = clean_title
            audio.performer = performer
            message.media.document.attributes.add(audio)

            file_name = TL_documentAttributeFilename()
            file_name.file_name = ext_name
            message.media.document.attributes.add(file_name)
            
            self._attach_document_thumb(message.media.document, item)

            msg_obj = MessageObject(account, message, False, False)
            try:
                msg_obj.mediaExists = True
            except Exception as media_exists_error:
                self._trace("mediaExists flag unavailable: {0}".format(media_exists_error), "WARN")
            try:
                msg_obj.attachPathExists = True
            except Exception:
                pass
            try:
                msg_obj.audioPlayerDuration = duration
            except Exception:
                pass
            return msg_obj
        except Exception as e:
            raise Exception("Local message build failed: {0}".format(e))

    def _open_native_player_sheet(self, forced_ctx=None):
        try:
            frag = get_last_fragment()
            if frag is None:
                frag = getattr(self, "_fragment_ref", None)
            if frag is None:
                raise Exception("Fragment unavailable")
            ctx = forced_ctx or (frag.getParentActivity() if frag.getParentActivity() else None)
            if ctx is None:
                raise Exception("Activity unavailable")
            AudioPlayerAlert = jclass("org.telegram.ui.Components.AudioPlayerAlert")
            run_on_ui_thread(lambda: frag.showDialog(AudioPlayerAlert(ctx, None)))
        except Exception as e:
            self._trace("player sheet open fail: {0}".format(e), "WARN")

    def _mark_player_present_requested(self, request_token):
        try:
            self._player_present_request_token = int(request_token or 0)
        except Exception:
            self._player_present_request_token = 0

    def _clear_player_present_request(self):
        try:
            self._player_present_request_token = 0
        except Exception:
            pass

    def _player_diag_lines(self, item, stream_info=None, file_path=None, started=None, extra=None):
        lines = []
        try:
            lines.append("Query item: {0}".format(str(item.get("title") or "")))
            lines.append("Video id: {0}".format(self._extract_video_id(item) or "missing"))
            if stream_info:
                lines.append("Mime: {0}".format(stream_info.get("mime")))
                lines.append("Duration: {0}".format(stream_info.get("duration")))
                lines.append("Bitrate: {0}".format(stream_info.get("bitrate")))
            if file_path:
                exists = os.path.exists(file_path)
                lines.append("File: {0}".format(file_path))
                lines.append("File exists: {0}".format(exists))
                if exists:
                    lines.append("File size: {0}".format(os.path.getsize(file_path)))
            if started is not None:
                lines.append("playMessage returned: {0}".format(bool(started)))
            if extra:
                lines.append(str(extra))
        except Exception as diag_error:
            lines.append("Diag build failed: {0}".format(diag_error))
        return lines

    def _start_music_player(self, item, host_ctx=None, queued=False, play_ctx=None, present_player=True, user_initiated=False):
        self._touch_activity()
        
                                                                      
                                                                             
        try:
            if play_ctx and bool((play_ctx or {}).get("playlist")):
                hydrated_ctx = self._hydrate_cached_playlist_item(play_ctx)
                play_ctx = hydrated_ctx
                hydrated_item = dict((hydrated_ctx or {}).get("item") or {})
                if hydrated_item:
                    item = hydrated_item
        except Exception:
            pass
        
        self._play_request_token += 1
        request_token = int(self._play_request_token)
        if bool(present_player) and bool(user_initiated):
            self._mark_player_present_requested(request_token)
        elif not bool(present_player):
            self._clear_player_present_request()
        if self._is_hard_stop_active() and not bool(user_initiated):
            self._trace("start blocked by hard stop", "INFO")
            return False
        if bool(user_initiated):
            self._clear_hard_stop()
            self._manual_stop_requested = False
            self._autoplay_blocked = False
        
                                                                              
                                                   
        if bool(user_initiated) and not bool(queued):
            cached_file = str((item or {}).get("cached_file") or "").strip()
            if not cached_file or not os.path.exists(cached_file):
                run_on_ui_thread(lambda: self._show_loading_sheet(title_key="playlist_preparing"))

                                                                          
        if play_ctx and play_ctx.get("playlist"):
            try:
                self._prefetch_playlist_cache(play_ctx)
            except Exception:
                pass

        def worker():
            try:
                if request_token != int(self._play_request_token):
                    return
                current_item = dict(item or {})
                cached_file = str((current_item or {}).get("cached_file") or "").strip()
                cached_stream = dict((current_item or {}).get("cached_stream") or {})
                if cached_file and os.path.exists(cached_file):
                    if request_token != int(self._play_request_token):
                        return
                    len_hint = self._parse_duration_seconds((current_item or {}).get("length"), 0)
                    stream_info = {
                        "video_id": self._extract_video_id(current_item),
                        "mime": str(cached_stream.get("mime") or mimetypes.guess_type(cached_file)[0] or "audio/mp4"),
                        "duration": self._parse_duration_seconds(cached_stream.get("duration"), len_hint),
                        "bitrate": self._safe_int(cached_stream.get("bitrate"), 0),
                        "size": int(os.path.getsize(cached_file) if os.path.exists(cached_file) else 0),
                    }
                    file_path = cached_file
                    self._remember_playlist_track_cache(play_ctx, current_item, file_path, stream_info)
                    self._remember_global_track_cache(current_item, file_path, stream_info)
                    if not bool((play_ctx or {}).get("playlist")):
                        self._save_track_to_auto_cache(current_item, file_path, stream_info)
                    run_on_ui_thread(lambda: self._show_player_bulletin("player_stage_open"))
                else:
                    current_item = self._hydrate_global_cached_item(current_item)
                    cached_file = str((current_item or {}).get("cached_file") or "").strip()
                    cached_stream = dict((current_item or {}).get("cached_stream") or {})
                    if cached_file and os.path.exists(cached_file):
                        len_hint = self._parse_duration_seconds((current_item or {}).get("length"), 0)
                        stream_info = {
                            "video_id": self._extract_video_id(current_item),
                            "mime": str(cached_stream.get("mime") or mimetypes.guess_type(cached_file)[0] or "audio/mp4"),
                            "duration": self._parse_duration_seconds(cached_stream.get("duration"), len_hint),
                            "bitrate": self._safe_int(cached_stream.get("bitrate"), 0),
                            "size": int(os.path.getsize(cached_file) if os.path.exists(cached_file) else 0),
                        }
                        file_path = cached_file
                        self._remember_playlist_track_cache(play_ctx, current_item, file_path, stream_info)
                        self._remember_global_track_cache(current_item, file_path, stream_info)
                        if not bool((play_ctx or {}).get("playlist")):
                            self._save_track_to_auto_cache(current_item, file_path, stream_info)
                        run_on_ui_thread(lambda: self._show_player_bulletin("player_stage_open"))
                    else:
                        if request_token != int(self._play_request_token):
                            return
                        run_on_ui_thread(lambda: self._show_player_bulletin("player_stage_resolve"))
                        stream_info = self._resolve_audio_stream(current_item)
                        self._trace("stream resolved | id={0} mime={1} duration={2} bitrate={3}".format(
                            stream_info.get("video_id"), stream_info.get("mime"), stream_info.get("duration"), stream_info.get("bitrate")
                        ), "INFO")
                        if request_token != int(self._play_request_token):
                            return
                        run_on_ui_thread(lambda: self._show_player_bulletin("player_stage_download"))
                        file_path = self._download_audio_file(current_item, stream_info)
                        if request_token != int(self._play_request_token):
                            return
                        self._remember_playlist_track_cache(play_ctx, current_item, file_path, stream_info)
                        self._remember_global_track_cache(current_item, file_path, stream_info)
                        if not bool((play_ctx or {}).get("playlist")):
                            self._save_track_to_auto_cache(current_item, file_path, stream_info)
                self._trace("audio downloaded | path={0} size={1}".format(
                    file_path, os.path.getsize(file_path) if os.path.exists(file_path) else "missing"
                ), "INFO")
                if request_token != int(self._play_request_token):
                    return
                try:
                    skip_direction = str((play_ctx or {}).get("transport_skip") or "").strip()
                except Exception:
                    skip_direction = ""
                if skip_direction:
                    try:
                        self._interrupt_current_playback_for_skip(skip_direction)
                    except Exception as interrupt_err:
                        self._trace("transport skip pre-clean fail: {0}".format(interrupt_err), "WARN")
                 
                                                                  
                if NATIVE_PLAYER_AVAILABLE:
                                                                                                
                    run_on_ui_thread(lambda: self._dismiss_all_pomme_ui(keep_loading=True))
                    
                    started = self._start_custom_player(current_item, file_path, stream_info, play_ctx=play_ctx)
                    if started:
                        self._trace(">>> CUSTOM PLAYER ACTIVE. COMPLETELY BYPASSING TELEGRAM OBJECTS.", "INFO")
                                                                                                
                        self._last_started_item = dict(current_item or {})
                        return
                    else:
                        self._trace("Custom player failed; fallback to native.", "WARN")

                                                                                
                msg_obj = self._build_local_audio_message(item, file_path, stream_info)

                def _play():
                    try:
                        if request_token != int(self._play_request_token):
                            return
                        self._show_player_bulletin("player_stage_open")
                        MediaController = jclass("org.telegram.messenger.MediaController")
                        media = MediaController.getInstance()
                        started = bool(media.playMessage(msg_obj))
                        self._trace("playMessage returned {0}".format(started), "INFO")
                        if not started:
                            diag = self._player_diag_lines(item, stream_info, file_path, started, "MediaController rejected the local audio item")
                            self._trace("player diagnostics | {0}".format(" | ".join([str(x) for x in diag])), "ERROR")
                            raise Exception("MediaController rejected the local audio item")
                        self._show_player_bulletin("player_stage_ready")
                        
                                                                                     
                        run_on_ui_thread(self._dismiss_results_sheet)
                        
                        self._manual_stop_requested = False
                        self._autoplay_blocked = False
                        self._clear_manual_close_guard()
                        self._last_started_item = dict(item or {})
                        self._remember_history(play_ctx)
                        self._active_play_ctx = dict(play_ctx or {"item": dict(item or {})})
                        self._active_play_ctx["queued"] = bool(queued)
                        try:
                            self._active_play_ctx["item"]["cover_url"] = self._resolve_music_cover_url(self._active_play_ctx.get("item") or item)
                        except Exception:
                            pass
                        try:
                            def _bg_cover_work():
                                try:
                                    self._prefetch_cover(item)
                                except Exception:
                                    pass
                                try:
                                    upcoming = self._next_from_context()
                                    if upcoming:
                                        self._prefetch_cover(upcoming.get("item") or {})
                                except Exception:
                                    pass
                            threading.Thread(target=_bg_cover_work, daemon=True).start()
                        except Exception:
                            pass
                        self._ensure_playback_watch()
                        if bool(present_player) and int(self._player_present_request_token or 0) == int(request_token):
                            self._open_native_player_sheet(host_ctx)
                        def _verify():
                            try:
                                current_playing = media.getPlayingMessageObject()
                                if current_playing is None:
                                    diag = self._player_diag_lines(item, stream_info, file_path, started, "Telegram player did not start playback.")
                                    self._trace("player diagnostics | {0}".format(" | ".join([str(x) for x in diag])), "ERROR")
                            except Exception as verify_error:
                                diag = self._player_diag_lines(item, stream_info, file_path, started, "Verify error: {0}".format(verify_error))
                                self._trace("player diagnostics | {0}".format(" | ".join([str(x) for x in diag])), "ERROR")
                        threading.Timer(1.2, lambda: run_on_ui_thread(_verify)).start()
                    except Exception as e:
                        self._trace("native player start fail: {0}".format(e), "ERROR")
                        diag = self._player_diag_lines(item, stream_info, file_path, False, e)
                        self._trace("player diagnostics | {0}".format(" | ".join([str(x) for x in diag])), "ERROR")

                run_on_ui_thread(_play)
            except Exception as e:
                self._trace("prepare player fail: {0}".format(e), "ERROR")
                diag = self._player_diag_lines(item, None, None, None, e)
                self._trace("player diagnostics | {0}".format(" | ".join([str(x) for x in diag])), "ERROR")
                run_on_ui_thread(self._dismiss_results_sheet)

        run_on_ui_thread(lambda: self._show_player_bulletin("loading_player"))
        try:
            threading.Thread(target=worker, daemon=True).start()
        except Exception as e:
            self._trace("music player thread fail: {0}".format(e), "ERROR")
            run_on_ui_thread(self._dismiss_results_sheet)

    def _search_cache_key(self, query, target_title="", target_artist="", target_duration=0):
        try:
            raw = "{0}::{1}::{2}::{3}".format(
                self._lyrics_norm(query),
                self._lyrics_norm(target_title),
                self._lyrics_norm(target_artist),
                int(target_duration or 0),
            )
            return hashlib.md5(raw.encode("utf-8")).hexdigest()
        except Exception:
            return ""

    def _persistent_search_cache_get(self, cache_key):
        try:
            cache_key = str(cache_key or "").strip()
            root = self._search_cache_dir()
            if not cache_key or not root:
                return None
            path = os.path.join(root, cache_key + ".json")
            if not os.path.exists(path):
                return None
            with open(path, "r", encoding="utf-8") as fh:
                payload = json.load(fh)
            exp = float((payload or {}).get("exp") or 0.0)
            if exp <= time.time():
                return None
            items = list((payload or {}).get("items") or [])
            return [dict(x or {}) for x in items if isinstance(x, dict)] or None
        except Exception:
            return None

    def _persistent_search_cache_put(self, cache_key, items, ttl_sec=180):
        try:
            cache_key = str(cache_key or "").strip()
            root = self._search_cache_dir()
            if not cache_key or not root:
                return False
            path = os.path.join(root, cache_key + ".json")
            payload = {
                "exp": time.time() + max(30, int(ttl_sec or 180)),
                "items": [dict(x or {}) for x in list(items or []) if isinstance(x, dict)],
            }
            with open(path, "w", encoding="utf-8") as fh:
                json.dump(payload, fh, ensure_ascii=False)
            return True
        except Exception:
            return False

    def _search_cache_get(self, query, target_title="", target_artist="", target_duration=0):
        try:
            key = self._search_cache_key(query, target_title, target_artist, target_duration)
            if not key:
                return None
            payload = (self._search_results_memo or {}).get(key)
            items = None
            if isinstance(payload, dict):
                exp = float(payload.get("exp") or 0.0)
                if exp > time.time():
                    items = list(payload.get("items") or [])
                else:
                    self._search_results_memo.pop(key, None)
            if items is None:
                items = self._persistent_search_cache_get(key)
                if items:
                    self._search_results_memo[key] = {
                        "exp": time.time() + 90.0,
                        "items": [dict(x or {}) for x in items if isinstance(x, dict)],
                    }
            if items:
                self._trace("search cache hit | query={0} | items={1}".format(str(query or "").strip(), len(items)), "INFO")
            return items or None
        except Exception:
            return None

    def _search_cache_put(self, query, items, target_title="", target_artist="", target_duration=0, ttl_sec=180):
        try:
            key = self._search_cache_key(query, target_title, target_artist, target_duration)
            if not key:
                return False
            if len(self._search_results_memo) > 48:
                self._search_results_memo.clear()
            self._search_results_memo[key] = {
                "exp": time.time() + max(30, int(ttl_sec or 180)),
                "items": [dict(x or {}) for x in list(items or []) if isinstance(x, dict)],
            }
            self._persistent_search_cache_put(key, items, ttl_sec=ttl_sec)
            return True
        except Exception:
            return False

    def _search_query_parts(self, query):
        try:
            raw = str(query or "").strip()
            artist = ""
            title = raw
            if " - " in raw:
                left, right = raw.split(" - ", 1)
                if left.strip() and right.strip():
                    artist = left.strip()
                    title = right.strip()
            elif " | " in raw:
                left, right = raw.split(" | ", 1)
                if left.strip() and right.strip():
                    artist = left.strip()
                    title = right.strip()
            return self._lyrics_clean_artist(artist), self._lyrics_clean_title(title)
        except Exception:
            return "", str(query or "").strip()

    def _search_item_score(self, query, item, target_title="", target_artist="", target_duration=0):
        try:
            raw_query = str(query or "").strip()
            raw_title = str(target_title or "").strip()
            raw_artist = str(target_artist or "").strip()
            if not raw_title:
                raw_artist, raw_title = self._search_query_parts(raw_query)
            want_title = self._lyrics_clean_title(raw_title or raw_query)
            want_artist = self._lyrics_clean_artist(raw_artist)
            item_author, item_title = self._clean_music_metadata(item or {})
            cand_title = str(item_title or item.get("title") or "").strip()
            cand_artist = str(item_author or item.get("author") or "").strip()
            cand_duration = self._parse_duration_seconds((item or {}).get("length") if (item or {}).get("length") is not None else (item or {}).get("duration"), 0)
            full_query = self._lyrics_norm(raw_query)
            full_cand = self._lyrics_norm("{0} {1}".format(cand_artist, cand_title))
            score = self._lyrics_match_score(want_title or raw_query, want_artist, cand_title, cand_artist, cand_duration, target_duration)
            if full_query and full_cand:
                if full_query == full_cand:
                    score += 90
                elif full_query in full_cand:
                    score += 54
                else:
                    score += int(SequenceMatcher(None, full_query, full_cand).ratio() * 50.0)
            query_tokens = set([t for t in full_query.split(" ") if len(t) > 1])
            cand_tokens = set([t for t in full_cand.split(" ") if len(t) > 1])
            if query_tokens and cand_tokens:
                overlap = len(query_tokens & cand_tokens)
                score += overlap * 8
                if overlap == len(query_tokens):
                    score += 24
            want_noise = self._lyrics_norm("{0} {1} {2}".format(raw_query, want_title, want_artist))
            for noisy in ("karaoke", "instrumental", "nightcore", "sped up", "speed up", "slowed", "reverb", "8d", "remix", "live", "cover"):
                if noisy in full_cand and noisy not in want_noise:
                    score -= 26
            if "topic" in self._lyrics_norm(str(item.get("author") or "")):
                score += 8
            return int(score)
        except Exception:
            return 0

    def _prepare_search_results(self, query, results, target_title="", target_artist="", target_duration=0, limit=24):
        try:
            ranked = []
            seen_ids = set()
            seen_meta = set()
            for entry in list(results or []):
                if not isinstance(entry, dict):
                    continue
                item = dict(entry)
                video_id = str(item.get("id") or "").strip()
                if video_id:
                    if video_id in seen_ids:
                        continue
                    seen_ids.add(video_id)
                clean_artist, clean_title = self._clean_music_metadata(item)
                if clean_artist and (not str(item.get("author") or "").strip() or str(item.get("author") or "").strip().lower() == "youtube"):
                    item["author"] = clean_artist
                if clean_title:
                    item["title"] = clean_title
                meta_key = "{0}::{1}".format(self._lyrics_norm(item.get("title")), self._lyrics_norm(item.get("author")))
                if meta_key.strip(":") and meta_key in seen_meta:
                    continue
                seen_meta.add(meta_key)
                item["_score"] = self._search_item_score(query, item, target_title, target_artist, target_duration)
                ranked.append(item)
            ranked.sort(key=lambda x: (-int(x.get("_score") or 0), -int(self._parse_duration_seconds(x.get("length"), 0) or 0), str(x.get("title") or "")))
            trimmed = ranked[: max(1, int(limit or 24))]
            for item in trimmed:
                try:
                    item.pop("_score", None)
                except Exception:
                    pass
            self._trace("search ranking ready | query={0} | kept={1}".format(str(query or "").strip(), len(trimmed)), "INFO")
            return trimmed
        except Exception as e:
            self._trace("prepare search results fail: {0}".format(e), "WARN")
            return [dict(x or {}) for x in list(results or []) if isinstance(x, dict)]

    def _track_index_read(self):
        try:
            path = self._track_index_file()
            if not path or not os.path.exists(path):
                return {}
            with open(path, "r", encoding="utf-8") as fh:
                data = json.load(fh)
            return data if isinstance(data, dict) else {}
        except Exception:
            return {}

    def _track_index_write(self, data):
        try:
            path = self._track_index_file()
            if not path:
                return False
            payload = data if isinstance(data, dict) else {}
            if len(payload) > 256:
                ordered = sorted(payload.items(), key=lambda kv: int((kv[1] or {}).get("updated_at") or 0), reverse=True)[:256]
                payload = {str(k): dict(v or {}) for k, v in ordered}
            with open(path, "w", encoding="utf-8") as fh:
                json.dump(payload, fh, ensure_ascii=False)
            return True
        except Exception:
            return False

    def _remember_global_track_cache(self, item, file_path, stream_info):
        try:
            video_id = str(self._extract_video_id(item or {}) or "").strip()
            path = str(file_path or "").strip()
            if not video_id or not path or not os.path.exists(path):
                return False
            data = self._track_index_read()
            data[video_id] = {
                "file_path": path,
                "mime": str((stream_info or {}).get("mime") or mimetypes.guess_type(path)[0] or "audio/mp4"),
                "duration": self._parse_duration_seconds((stream_info or {}).get("duration"), self._parse_duration_seconds((item or {}).get("length"), 0)),
                "bitrate": self._safe_int((stream_info or {}).get("bitrate"), 0),
                "title": str((item or {}).get("title") or "").strip(),
                "author": str((item or {}).get("author") or "").strip(),
                "thumbnail": str((item or {}).get("thumbnail") or "").strip(),
                "cover_url": str((item or {}).get("cover_url") or "").strip(),
                "cover_cached_file": str((item or {}).get("cover_cached_file") or "").strip(),
                "url": str((item or {}).get("url") or "").strip(),
                "updated_at": int(time.time()),
            }
            saved = self._track_index_write(data)
            try:
                self._prefetch_lyrics_for_cached_item(item, stream_info)
            except Exception:
                pass
            return saved
        except Exception as e:
            self._trace("remember global track cache fail: {0}".format(e), "WARN")
            return False

    def _prefetch_lyrics_for_cached_item(self, item, stream_info=None):
        try:
            item = dict(item or {})
            title = str(item.get("title") or "").strip()
            if not title:
                return False
            if self._read_cached_lyrics_for_item(item) is not None:
                return True
            artist = str(item.get("author") or "").strip()
            duration = self._parse_duration_seconds(
                (stream_info or {}).get("duration"),
                self._parse_duration_seconds(item.get("length") or item.get("duration"), 0),
            )

            def _worker():
                try:
                    if self._read_cached_lyrics_for_item(item) is not None:
                        return
                    lyrics = self._fetch_lrclib_lyrics(title, artist, duration, item)
                    if not lyrics:
                        lyrics = self._fetch_alt_lyrics(title, artist, duration, item)
                    if lyrics:
                        self._trace("lyrics cached for offline track | title={0}".format(title), "INFO")
                except Exception as e:
                    self._trace("lyrics prefetch for cache fail: {0}".format(e), "DEBUG")

            threading.Thread(target=_worker, daemon=True).start()
            return True
        except Exception:
            return False

    def _hydrate_global_cached_item(self, item):
        try:
            target = dict(item or {})
            if str(target.get("cached_file") or "").strip() and os.path.exists(str(target.get("cached_file") or "").strip()):
                return target
            video_id = str(self._extract_video_id(target) or "").strip()
            if not video_id:
                return target
            entry = dict((self._track_index_read().get(video_id) or {}))
            path = str(entry.get("file_path") or "").strip()
            if not path or not os.path.exists(path):
                return target
            target["cached_file"] = path
            target["cached_stream"] = {
                "mime": str(entry.get("mime") or mimetypes.guess_type(path)[0] or "audio/mp4"),
                "duration": self._parse_duration_seconds(entry.get("duration"), self._parse_duration_seconds(target.get("length"), 0)),
                "bitrate": self._safe_int(entry.get("bitrate"), 0),
                "video_id": video_id,
            }
            if not str(target.get("thumbnail") or "").strip():
                target["thumbnail"] = str(entry.get("thumbnail") or "").strip()
            if not str(target.get("cover_url") or "").strip():
                target["cover_url"] = str(entry.get("cover_url") or "").strip()
            if not str(target.get("cover_cached_file") or "").strip():
                target["cover_cached_file"] = str(entry.get("cover_cached_file") or "").strip()
            if not str(target.get("url") or "").strip():
                target["url"] = str(entry.get("url") or "").strip()
            return target
        except Exception:
            return dict(item or {})

    def _resolve_playlist_candidate(self, title, artist, duration=0):
        try:
            query = "{0} - {1}".format(str(artist or "").strip(), str(title or "").strip()).strip(" -")
            if not query:
                query = str(title or "").strip()
            if not query:
                return None
            results = self._search_youtube_sync(query, target_title=title, target_artist=artist, target_duration=duration)
            if not results:
                return None
            best = dict(results[0] or {})
            best["title"] = str(best.get("title") or title or "Track").strip() or "Track"
            best["author"] = str(best.get("author") or artist or "YouTube").strip() or "YouTube"
            if int(self._parse_duration_seconds(best.get("length"), 0) or 0) <= 0 and int(duration or 0) > 0:
                best["length"] = int(duration)
            return best
        except Exception as e:
            self._trace("playlist candidate resolve fail: {0}".format(e), "WARN")
            return None

    def _search_youtube_async(self, query):
        query = self._clean_external_link_input(query)
        def worker():
            self._trace("Starting search for: '{0}'".format(query), "INFO")
            
            try:
                spotify_ref = self._parse_spotify_reference(query)
                youtube_playlist_ref = self._parse_youtube_playlist_reference(query)
                if spotify_ref is not None:
                    video_results = self._search_cache_get(query) or self._resolve_spotify_search_items(query)
                    present_query = self._spotify_display_query(query, video_results)
                    results_meta = {
                        "source_query": query,
                        "display_query": present_query,
                        "collection_name": self._spotify_collection_name(query) or present_query,
                        "source_platform": "spotify",
                        "collection_type": str(spotify_ref.get("type") or "").strip(),
                    }
                    if video_results:
                        self._search_cache_put(query, video_results, ttl_sec=900)
                        self._trace("spotify link resolved | type={0} | items={1}".format(spotify_ref.get("type"), len(video_results)), "INFO")
                    else:
                        self._trace("spotify link resolved empty | type={0}".format(spotify_ref.get("type")), "WARN")
                elif youtube_playlist_ref is not None:
                    video_results = self._search_cache_get(query) or self._prepare_search_results(query, self._resolve_playlist_entries(query))
                    present_query = self._youtube_collection_name(query) or query
                    results_meta = {
                        "source_query": query,
                        "display_query": present_query,
                        "collection_name": self._youtube_collection_name(query) or present_query,
                        "source_platform": "youtube",
                        "collection_type": "playlist",
                    }
                    if video_results:
                        self._search_cache_put(query, video_results, ttl_sec=900)
                        self._trace("youtube playlist link resolved | items={0}".format(len(video_results)), "INFO")
                    else:
                        self._trace("youtube playlist link resolved empty", "WARN")
                else:
                    video_results = self._search_youtube_sync(query)
                    present_query = query
                    results_meta = {}

                if video_results:
                    self._trace("Success: {0} videos found".format(len(video_results)), "INFO")
                else:
                    self._trace("No videos found for query: {0}".format(query), "WARN")

                def _present():
                    try:
                        if bool(self._quick_dismiss_enabled()):
                            self._dismiss_results_sheet()
                    except Exception:
                        pass
                    self._last_results_meta = dict(results_meta or {})
                    self._show_results_sheet(video_results, present_query)

                run_on_ui_thread(_present)

            except Exception as e:
                err_msg = str(e)
                self._trace("Critical Search Error: {0}".format(err_msg), "ERROR")
                run_on_ui_thread(lambda: self._show_error_sheet(err_msg))

        try:
            threading.Thread(target=worker, daemon=True).start()
        except Exception as e:
            self._trace("thread start fail: {0}".format(e))
            self._show_error_sheet(self._tr("error"))

    def _search_youtube_sync(self, query, target_title="", target_artist="", target_duration=0):
        query = str(query or "").strip()
        cached = self._search_cache_get(query, target_title, target_artist, target_duration)
        if cached is not None:
            return cached
        self._trace("Fetching YouTube mobile search page...", "INFO")
        url = "https://m.youtube.com/results?search_query=" + urllib.parse.quote(query)
        headers = {
            "Upgrade-Insecure-Requests": "1",
            "Referer": "https://m.youtube.com/",
            "Origin": "https://m.youtube.com",
        }
        raw = self._http_get_text(
            url,
            headers=headers,
            timeout=15,
            cache_key="yt_search_html::{0}".format(query),
            ttl_sec=180,
            allow_stale=True,
            profile="web",
            encoding="utf-8",
        )
        final_url = url
        if not raw:
            raise Exception("YouTube search page unavailable.")
        self._trace("Page fetched, size: {0} chars. URL: {1}".format(len(raw), final_url), "INFO")
        if "consent.youtube.com" in final_url or "google.com/sorry" in final_url:
            raise Exception("YouTube blocked the request (Bot Check).")
        video_results = []
        match = re.search(r'ytInitialData\s*=\s*(\{.*?\});', raw)
        if not match:
            match = re.search(r'var\s+ytInitialData\s*=\s*(\{.*?\});', raw)
        if match:
            try:
                data = json.loads(match.group(1))
                sections = data.get("contents", {}).get("sectionListRenderer", {}).get("contents", [])
                if not sections:
                    sections = data.get("contents", {}).get("twoColumnSearchResultsRenderer", {}).get("primaryContents", {}).get("sectionListRenderer", {}).get("contents", [])
                for section in sections:
                    items = section.get("itemSectionRenderer", {}).get("contents", [])
                    for item in items:
                        v = item.get("videoRenderer")
                        if not v:
                            continue
                        vid = v.get("videoId")
                        title_obj = v.get("title", {})
                        title = title_obj.get("simpleText") or (title_obj.get("runs", [{}])[0].get("text"))
                        author_obj = v.get("longBylineText", {}) or v.get("shortBylineText", {})
                        author = author_obj.get("runs", [{}])[0].get("text")
                        duration = v.get("lengthText", {}).get("simpleText")
                        endpoint_url = str((((v.get("navigationEndpoint") or {}).get("commandMetadata") or {}).get("webCommandMetadata") or {}).get("url") or "").strip().lower()
                        overlay_style = ""
                        try:
                            overlays = list(v.get("thumbnailOverlays") or [])
                            for ov in overlays:
                                candidate = ((ov or {}).get("thumbnailOverlayTimeStatusRenderer") or {}).get("style")
                                if candidate:
                                    overlay_style = str(candidate or "").strip().lower()
                                    break
                        except Exception:
                            overlay_style = ""
                        len_sec = self._parse_duration_seconds(duration, 0)
                        if "/shorts/" in endpoint_url or overlay_style == "shorts":
                            continue
                        if vid and title:
                            video_results.append({
                                "id": str(vid),
                                "title": str(title),
                                "author": str(author or "Unknown"),
                                "length": len_sec,
                                "thumbnail": "https://i.ytimg.com/vi/{0}/sddefault.jpg".format(vid),
                                "url": "https://www.youtube.com/watch?v=" + vid
                            })
            except Exception as je:
                self._trace("JSON parse error: {0}".format(je), "ERROR")
        if not video_results:
            regex_list = [
                r'\"videoId\":\"([a-zA-Z0-9_-]{11})\"[^{}]*?\"text\":\"(.*?)\"',
                r'videoId\":\"([a-zA-Z0-9_-]{11})\",.*?\"title\":\{.*?\"text\":\"(.*?)\"',
                r'\"videoRenderer\":\{.*?\"videoId\":\"(.*?)\".*?\"text\":\"(.*?)\"'
            ]
            for pattern in regex_list:
                blocks = re.findall(pattern, raw)
                for vid, title in blocks:
                    if len(vid) == 11 and len(title) > 1 and not any(r.get("id") == vid for r in video_results):
                        title = title.replace('\\u0026', '&').replace('\\"', '"').replace('\\u0027', "'")
                        video_results.append({
                            "id": vid,
                            "title": title,
                            "author": "YouTube",
                            "length": 0,
                            "thumbnail": "https://i.ytimg.com/vi/{0}/sddefault.jpg".format(vid),
                            "url": "https://www.youtube.com/watch?v=" + vid
                        })
                if video_results:
                    break
        prepared = self._prepare_search_results(query, video_results, target_title, target_artist, target_duration)
        self._search_cache_put(query, prepared, target_title, target_artist, target_duration)
        return prepared

    def _format_duration(self, seconds_total):
        try:
            s = int(seconds_total or 0)
            if s <= 0:
                return ""
            h = s // 3600
            m = (s % 3600) // 60
            sec = s % 60
            if h > 0:
                return "{0}:{1:02d}:{2:02d}".format(h, m, sec)
            return "{0}:{1:02d}".format(m, sec)
        except Exception:
            return ""

    def _build_subtitle(self, item):
        try:
                                                                                      
            author = str(item.get("author") or "").strip()
            if author:
                return author
            return self._tr("open_video")
        except Exception:
            return self._tr("open_video")

    def _show_results_sheet(self, results, query=""):
        try:
            self._last_query = str(query or "").strip()
            self._last_results = list(results or [])
            meta = dict(getattr(self, "_last_results_meta", {}) or {})
            loading_dialog = getattr(self, "_loading_dialog", None)
            if loading_dialog is not None:
                try:
                    loading_dialog.dismiss()
                except Exception:
                    pass
                self._loading_dialog = None
            old_sheet = getattr(self, "_results_sheet", None)
            if old_sheet is not None:
                try:
                    old_sheet.dismiss()
                except Exception:
                    pass

            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                return
            listener_cls = find_class("android.view.View$OnClickListener")

            sheet = BottomSheet(ctx, True)
            try:
                sheet.setCanDismissWithSwipe(False)
            except Exception:
                pass
            
                                                   
            from android.widget import ScrollView
            scroll = ScrollView(ctx)
            
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(
                AndroidUtilities.dp(16),
                AndroidUtilities.dp(16),
                AndroidUtilities.dp(16),
                AndroidUtilities.dp(12)
            )

            header_row = LinearLayout(ctx)
            header_row.setOrientation(LinearLayout.HORIZONTAL)
            header_row.setGravity(Gravity.CENTER_VERTICAL)

            title_wrap = LinearLayout(ctx)
            title_wrap.setOrientation(LinearLayout.VERTICAL)
            title_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)

            title_view = TextView(ctx)
            title_view.setText(str(query or "").strip() or self._tr("search_videos"))
            title_view.setTextSize(20)
            title_view.setTypeface(None, 1)
            try:
                title_view.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
            except Exception:
                pass
            title_wrap.addView(title_view)

            subtitle_view = TextView(ctx)
            subtitle_view.setText(self._tr("results_for") + " " + (str(query or "").strip() or ""))
            subtitle_view.setTextSize(13)
            try:
                subtitle_view.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            except Exception:
                pass
            title_wrap.addView(subtitle_view)
            header_row.addView(title_wrap, title_lp)

            close_view = TextView(ctx)
            close_view.setText("×")
            close_view.setTextSize(22)
            try:
                close_view.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
            except Exception:
                pass
            close_view.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(6), AndroidUtilities.dp(4), AndroidUtilities.dp(6))
            if listener_cls is not None:
                class _Close(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        sheet.dismiss()
                close_view.setOnClickListener(_Close())
            header_row.addView(close_view)
            outer.addView(header_row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            header_break = View(ctx)
            header_break.setLayoutParams(LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(14)))
            outer.addView(header_break)

            if str(meta.get("collection_type") or "").strip() in ("album", "playlist"):
                actions = LinearLayout(ctx)
                actions.setOrientation(LinearLayout.HORIZONTAL)
                actions.setGravity(Gravity.CENTER_VERTICAL)
                actions_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                actions_lp.bottomMargin = AndroidUtilities.dp(14)

                def _action_btn(text_value, fill_key=None):
                    btn = TextView(ctx)
                    btn.setText(str(text_value or "").strip())
                    btn.setTextSize(14)
                    btn.setTypeface(None, 1)
                    btn.setGravity(Gravity.CENTER)
                    btn.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(11), AndroidUtilities.dp(16), AndroidUtilities.dp(11))
                    bg = GradientDrawable()
                    bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                    try:
                        if fill_key:
                            bg.setColor(int(Theme.getColor(fill_key)))
                            btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                        else:
                            bg.setColor(int(Theme.getColor(Theme.key_dialogBackgroundGray)))
                            btn.setTextColor(int(Theme.getColor(Theme.key_dialogTextBlack)))
                    except Exception:
                        if fill_key:
                            bg.setColor(0xFF2AABEE)
                            btn.setTextColor(0xFFFFFFFF)
                        else:
                            bg.setColor(0x1AFFFFFF)
                            btn.setTextColor(0xFFFFFFFF)
                    btn.setBackground(bg)
                    return btn

                play_all_btn = _action_btn(self._tr("spotify_collection_play_all"), Theme.key_featuredStickers_addButton)
                save_btn = _action_btn(self._tr("spotify_collection_save"))
                play_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                save_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                save_lp.leftMargin = AndroidUtilities.dp(10)
                actions.addView(play_all_btn, play_lp)
                actions.addView(save_btn, save_lp)

                if listener_cls is not None:
                    class _PlayAll(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            try:
                                all_items = list(plugin._last_results or [])
                                if not all_items:
                                    return
                                play_ctx = {
                                    "query": str(meta.get("display_query") or query or "").strip(),
                                    "results": list(all_items),
                                    "index": 0,
                                    "item": dict(all_items[0] or {}),
                                    "playlist": True,
                                    "playlist_url": str(meta.get("source_query") or "").strip(),
                                    "playlist_name": str(meta.get("display_query") or query or "Playlist").strip() or "Playlist",
                                }
                                sheet.dismiss()
                                plugin._start_music_player(dict(all_items[0] or {}), ctx, play_ctx=play_ctx, user_initiated=True)
                            except Exception as e:
                                plugin._trace("collection play all fail: {0}".format(e), "ERROR")

                    class _SavePlaylist(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            try:
                                target_name = str(meta.get("collection_name") or meta.get("display_query") or query or "Playlist").strip() or "Playlist"
                                target_url = str(meta.get("source_query") or "").strip()
                                if plugin._save_external_playlist_entry(target_name, target_url):
                                    BulletinHelper.show_success(plugin._tr("playlist_save_done"))
                                else:
                                    BulletinHelper.show_info(plugin._tr("error"))
                            except Exception as e:
                                plugin._trace("collection save fail: {0}".format(e), "ERROR")

                    play_all_btn.setOnClickListener(_PlayAll())
                    save_btn.setOnClickListener(_SavePlaylist())

                outer.addView(actions, actions_lp)

            all_results = self._last_results
            if not all_results:
                empty = TextView(ctx)
                empty.setText(self._tr("empty"))
                empty.setTextSize(18)
                empty.setTypeface(None, 1)
                empty.setPadding(0, AndroidUtilities.dp(14), 0, AndroidUtilities.dp(8))
                try:
                    empty.setTextColor(0xFFF44336)                
                except Exception:
                    pass
                outer.addView(empty)
                
                scroll.addView(outer)
                sheet.setCustomView(scroll)
                sheet.show()
                self._results_sheet = sheet
                return

            plugin = self
            page = max(0, int(getattr(self, "_results_page", 0) or 0))
            page_size = 5
            total_pages = max(1, (len(all_results) + page_size - 1) // page_size)
            if page >= total_pages:
                page = total_pages - 1
                self._results_page = page
            start = page * page_size
            end = start + page_size
            visible_results = all_results[start:end]
            try:
                card_fill = int(Theme.getColor(Theme.key_dialogBackgroundGray))
            except Exception:
                card_fill = 0x1AFFFFFF

            for idx, item in enumerate(visible_results, start):
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.VERTICAL)
                row.setPadding(
                    AndroidUtilities.dp(12),
                    AndroidUtilities.dp(12),
                    AndroidUtilities.dp(12),
                    AndroidUtilities.dp(12)
                )
                try:
                    row_bg = GradientDrawable()
                    row_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                    row_bg.setColor(self._jcolor(card_fill))
                    row.setBackground(row_bg)
                except Exception:
                    pass

                title = TextView(ctx)
                title.setText(item.get("title") or "")
                title.setTextSize(16)
                try:
                    title.setMaxLines(2)
                    title.setEllipsize(TextUtils.TruncateAt.END)
                except Exception:
                    pass
                try:
                    title.setTextColor(int(Theme.getColor(Theme.key_dialogTextBlack)))
                except Exception:
                    pass
                row.addView(title)

                subtitle = TextView(ctx)
                subtitle.setText(plugin._build_subtitle(item))
                subtitle.setPadding(0, AndroidUtilities.dp(4), 0, 0)
                subtitle.setTextSize(13)
                try:
                    subtitle.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
                except Exception:
                    pass
                row.addView(subtitle)

                class _OpenClick(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                    def __init__(self_obj, video_item, video_index):
                        super().__init__()
                        self_obj.video_item = video_item
                        self_obj.video_index = int(video_index)

                    def onClick(self_obj, v):
                        try:
                            plugin._touch_activity()
                            plugin._ensure_idle_watch()
                            plugin._clear_hard_stop()
                            play_ctx = {
                                "query": str(query or ""),
                                "results": list(all_results),
                                "index": int(self_obj.video_index),
                                "item": dict(self_obj.video_item or {}),
                            }
                            if plugin._is_anything_playing():
                                plugin._ask_queue_or_play(self_obj.video_item, play_ctx, ctx)
                            else:
                                plugin._start_music_player(self_obj.video_item, ctx, play_ctx=play_ctx, user_initiated=True)
                        except Exception as e:
                            plugin._trace("open video fail: {0}".format(e), "ERROR")

                row.setOnClickListener(_OpenClick(item, idx))

                lp = LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.MATCH_PARENT,
                    LinearLayout.LayoutParams.WRAP_CONTENT
                )
                lp.bottomMargin = AndroidUtilities.dp(8)
                outer.addView(row, lp)

            nav = LinearLayout(ctx)
            nav.setOrientation(LinearLayout.HORIZONTAL)
            nav.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
            nav_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            nav_lp.topMargin = AndroidUtilities.dp(12)

            def _nav_btn(text_key, click_fn):
                btn = TextView(ctx)
                btn.setText(self._tr(text_key))
                btn.setTextSize(14)
                btn.setTypeface(None, 1)
                try:
                    btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                except Exception:
                    pass
                btn.setGravity(Gravity.CENTER)
                btn.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(10), AndroidUtilities.dp(14), AndroidUtilities.dp(10))
                try:
                    btn_bg = GradientDrawable()
                    btn_bg.setCornerRadius(float(AndroidUtilities.dp(16)))
                    btn_bg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                    btn.setBackground(btn_bg)
                except Exception:
                    pass
                if listener_cls is not None:
                    class _Click(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            click_fn()
                    btn.setOnClickListener(_Click())
                return btn

            if page > 0:
                prev_btn = _nav_btn("playlist_prev_page", lambda: (setattr(self, "_results_page", max(0, int(self._results_page or 0) - 1)), sheet.dismiss(), self._show_results_sheet(self._last_results, self._last_query)))
                nav.addView(prev_btn)
            if page < total_pages - 1:
                next_btn = _nav_btn("playlist_next_page", lambda: (setattr(self, "_results_page", int(self._results_page or 0) + 1), sheet.dismiss(), self._show_results_sheet(self._last_results, self._last_query)))
                next_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                if page > 0:
                    next_lp.leftMargin = AndroidUtilities.dp(10)
                nav.addView(next_btn, next_lp)
            if nav.getChildCount() > 0:
                outer.addView(nav, nav_lp)

            scroll.addView(outer)
            sheet.setCustomView(scroll)
            sheet.show()
            self._results_sheet = sheet
        except Exception as e:
            tb = traceback.format_exc()
            self._trace(f"show results sheet render FAIL: {e}\n{tb}", "CRITICAL")
            run_on_ui_thread(lambda: self._show_error_sheet(f"UI Render Error: {e}"))

    def _show_error_sheet(self, text, forced_ctx=None):
        run_on_ui_thread(lambda: self._show_error_sheet_ui(text, forced_ctx))

    def _show_error_sheet_ui(self, text, forced_ctx=None):
        try:
            self._dismiss_error_sheet()
            dialog = getattr(self, "_loading_dialog", None)
            if dialog is not None:
                try:
                    dialog.dismiss()
                except Exception:
                    pass
                self._loading_dialog = None

            frag = get_last_fragment()
            ctx = forced_ctx or (frag.getParentActivity() if frag and frag.getParentActivity() else None)
            if ctx is None:
                self._trace("error sheet skipped: ctx is None | {0}".format(text), "ERROR")
                return

            sheet = BottomSheet(ctx, True)
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(
                AndroidUtilities.dp(16),
                AndroidUtilities.dp(16),
                AndroidUtilities.dp(16),
                AndroidUtilities.dp(16)
            )

            tv = TextView(ctx)
            tv.setText(self._tr("error"))
            tv.setTextSize(18)
            tv.setTypeface(None, 1)       
            try:
                tv.setTextColor(int(Theme.getColor(Theme.key_dialogTextBlack)))
            except Exception:
                pass
            outer.addView(tv)

            detail = TextView(ctx)
            detail.setText(str(text or ""))
            detail.setPadding(0, AndroidUtilities.dp(8), 0, AndroidUtilities.dp(16))
            detail.setTextSize(14)
            try:
                detail.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            except Exception:
                pass
            outer.addView(detail)

            sheet.setCustomView(outer)
            sheet.show()
            self._error_sheet = sheet
        except Exception as e:
            self._trace("show error sheet fail: {0}".format(e))

    def _show_about_sheet(self):
        run_on_ui_thread(self._show_about_sheet_ui)

    def _show_smart_cache_sheet(self):
        run_on_ui_thread(self._show_smart_cache_sheet_ui)

    def _show_notifications_sheet(self):
        run_on_ui_thread(self._show_notifications_sheet_ui)

    def _show_menu_shortcuts_sheet(self):
        run_on_ui_thread(self._show_menu_shortcuts_sheet_ui)

    def _show_appearance_sheet(self):
                                                                             
        def _go():
            try:
                self._show_appearance_sheet_ui()
            except Exception as e:
                tb = traceback.format_exc()
                self._trace("appearance bootstrap error: {0}\n{1}".format(e, tb), "ERROR")
        run_on_ui_thread(_go)

    def _show_language_sheet(self):
        run_on_ui_thread(self._show_language_sheet_ui)

    def _show_language_sheet_ui(self):
        try:
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                try:
                    ctx = ApplicationLoader.applicationContext
                except Exception: return
            
            sheet = BottomSheet(ctx, True)
            try:
                sheet.setBackgroundColor(0)
            except Exception:
                pass
                                                                   
            ScrollViewClass = jclass("android.widget.ScrollView")
            scroll = ScrollViewClass(ctx)
            try:
                scroll.setFillViewport(True)
            except Exception:
                pass
            
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(12), AndroidUtilities.dp(18), AndroidUtilities.dp(20))
            try:
                is_dark_sheet = bool(Theme.isCurrentThemeDark())
            except Exception:
                is_dark_sheet = True
            sheet_bg_primary = self._jcolor(0xFF2E1E25 if is_dark_sheet else 0xFFFFEEF0)
            sheet_bg_secondary = self._jcolor(0xFF212124 if is_dark_sheet else 0xFFF9F4F2)
            card_fill = self._jcolor(0x1CFFFFFF if is_dark_sheet else 0xCCFFFFFF)
            card_stroke = self._jcolor(0x20FFFFFF if is_dark_sheet else 0x14EB3F44)
            active_fill = self._jcolor(0xFFEB3F44 if is_dark_sheet else 0xFFF26B74)
            sheet_bg = GradientDrawable(GradientDrawable.Orientation.TL_BR, [sheet_bg_primary, sheet_bg_secondary])
            try:
                radius = float(AndroidUtilities.dp(24))
                sheet_bg.setCornerRadii([radius, radius, radius, radius, radius, radius, radius, radius])
            except Exception:
                pass
            try:
                scroll.setBackground(sheet_bg)
            except Exception:
                outer.setBackground(sheet_bg)
            try:
                title_color = self._jcolor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception:
                title_color = self._jcolor(0xFF000000)
            try:
                sub_color = self._jcolor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            except Exception:
                sub_color = self._jcolor(0xFF9AA6B2)
            
                            
            handle_wrap = LinearLayout(ctx)
            handle_wrap.setGravity(Gravity.CENTER_HORIZONTAL)
            handle = View(ctx)
            h_bg = GradientDrawable()
            h_bg.setCornerRadius(float(AndroidUtilities.dp(3)))
            h_bg.setColor(self._jcolor((int(sub_color) & 0x66FFFFFF) or 0x66AAB4C2))
            handle.setBackground(h_bg)
            handle_wrap.addView(handle, LinearLayout.LayoutParams(AndroidUtilities.dp(42), AndroidUtilities.dp(6)))
            h_lp = LinearLayout.LayoutParams(-1, -2)
            h_lp.bottomMargin = AndroidUtilities.dp(18)
            outer.addView(handle_wrap, h_lp)

            title = TextView(ctx)
            title.setText(self._tr("panel_language"))
            title.setTextSize(22)
            title.setTypeface(None, 1)
            title.setTextColor(title_color)
            outer.addView(title)
            
            desc = TextView(ctx)
            desc.setText(self._tr("panel_language_desc"))
            desc.setTextSize(14)
            desc.setTextColor(sub_color)
            desc_lp = LinearLayout.LayoutParams(-1, -2)
            desc_lp.topMargin = AndroidUtilities.dp(6)
            desc_lp.bottomMargin = AndroidUtilities.dp(18)
            outer.addView(desc, desc_lp)
            
            langs = [
                ("Português (Brasil)", "pt"),
                ("English", "en"),
                ("Русский", "ru")
            ]
            
            current_lang = str(self.get_setting("pomme_language", "en"))
            
            for name, code in langs:
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
                
                is_active = (code == current_lang)
                
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                if is_active:
                    bg.setColor(active_fill)
                    try:
                        bg.setStroke(AndroidUtilities.dp(1), self._jcolor(0x26FFFFFF if is_dark_sheet else 0x22B82E35))
                    except Exception:
                        pass
                else:
                    bg.setColor(card_fill)
                    try:
                        bg.setStroke(AndroidUtilities.dp(1), card_stroke)
                    except Exception:
                        pass
                row.setBackground(bg)
                
                t1 = TextView(ctx)
                t1.setText(name)
                t1.setTextSize(16)
                t1.setTypeface(None, 1 if is_active else 0)
                if is_active:
                    t1.setTextColor(self._contrast_text_color(int(active_fill)))
                else:
                    t1.setTextColor(title_color)
                
                row.addView(t1, LinearLayout.LayoutParams(0, -2, 1.0))
                
                if is_active:
                    check = jclass("android.widget.ImageView")(ctx)
                    try:
                        check_id = ApplicationLoader.applicationContext.getResources().getIdentifier("msg_check", "drawable", ApplicationLoader.applicationContext.getPackageName())
                        if check_id:
                            check.setImageResource(int(check_id))
                        check.setColorFilter(t1.getCurrentTextColor(), PorterDuff.Mode.SRC_IN)
                    except Exception: pass
                    row.addView(check, LinearLayout.LayoutParams(AndroidUtilities.dp(20), AndroidUtilities.dp(20)))
                
                class _LangClick(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                    def __init__(self_obj, lang_code):
                        super().__init__()
                        self_obj.lang_code = lang_code
                    def onClick(self_obj, _v):
                        self.set_setting("pomme_language", self_obj.lang_code)
                        sheet.dismiss()
                        try:
                            if self._panel_sheet: self._panel_sheet.dismiss()
                        except Exception: pass
                        
                                                                                     
                        def _reopen():
                            self._show_about_sheet()
                            self._notify_success(self._tr("lang_changed"))
                        
                        import threading
                        threading.Timer(0.2, _reopen).start()
                
                row.setOnClickListener(_LangClick(code))
                lp = LinearLayout.LayoutParams(-1, -2)
                lp.bottomMargin = AndroidUtilities.dp(10)
                outer.addView(row, lp)
            
            scroll.addView(outer)
            sheet.setCustomView(scroll)
            sheet.show()
        except Exception as e:
            self._trace("show language fail: {0}".format(e))

    def _show_appearance_sheet_ui(self):
        try:
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                try:
                    ctx = ApplicationLoader.applicationContext
                except Exception: return
            
            sheet = BottomSheet(ctx, True)
            try:
                sheet.setBackgroundColor(0)
            except Exception:
                pass
                                                                   
            ScrollViewClass = jclass("android.widget.ScrollView")
            scroll = ScrollViewClass(ctx)
            try:
                scroll.setFillViewport(True)
            except Exception:
                pass
            
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(12), AndroidUtilities.dp(18), AndroidUtilities.dp(20))
            try:
                is_dark_sheet = bool(Theme.isCurrentThemeDark())
            except Exception:
                is_dark_sheet = True
            sheet_bg_primary = self._jcolor(0xFF2F2026 if is_dark_sheet else 0xFFFFF0F2)
            sheet_bg_secondary = self._jcolor(0xFF212226 if is_dark_sheet else 0xFFF8F4F3)
            card_fill = self._jcolor(0x1CFFFFFF if is_dark_sheet else 0xCCFFFFFF)
            card_stroke = self._jcolor(0x20FFFFFF if is_dark_sheet else 0x14EB3F44)
            sheet_bg = GradientDrawable(GradientDrawable.Orientation.TL_BR, [sheet_bg_primary, sheet_bg_secondary])
            try:
                radius = float(AndroidUtilities.dp(24))
                sheet_bg.setCornerRadii([radius, radius, radius, radius, radius, radius, radius, radius])
            except Exception:
                pass
            try:
                scroll.setBackground(sheet_bg)
            except Exception:
                outer.setBackground(sheet_bg)
            try:
                title_color = self._jcolor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception:
                title_color = self._jcolor(0xFF000000)
            try:
                sub_color = self._jcolor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            except Exception:
                sub_color = self._jcolor(0xFF9AA6B2)
            
                            
            handle_wrap = LinearLayout(ctx)
            handle_wrap.setGravity(Gravity.CENTER_HORIZONTAL)
            handle = View(ctx)
            h_bg = GradientDrawable()
            h_bg.setCornerRadius(float(AndroidUtilities.dp(3)))
            h_bg.setColor(self._jcolor((sub_color & 0x66FFFFFF) or 0x66AAB4C2))
            handle.setBackground(h_bg)
            handle_wrap.addView(handle, LinearLayout.LayoutParams(AndroidUtilities.dp(42), AndroidUtilities.dp(6)))
            h_lp = LinearLayout.LayoutParams(-1, -2)
            h_lp.bottomMargin = AndroidUtilities.dp(18)
            outer.addView(handle_wrap, h_lp)

            title = TextView(ctx)
            title.setText(self._tr("panel_appearance"))
            title.setTextSize(22)
            title.setTypeface(None, 1)
            title.setTextColor(title_color)
            title.setGravity(Gravity.CENTER_HORIZONTAL)
            outer.addView(title)
            
            desc = TextView(ctx)
            desc.setText(self._tr("panel_appearance_desc"))
            desc.setTextSize(14)
            desc.setTextColor(sub_color)
            desc.setGravity(Gravity.CENTER_HORIZONTAL)
            desc_lp = LinearLayout.LayoutParams(-1, -2)
            desc_lp.topMargin = AndroidUtilities.dp(6)
            desc_lp.bottomMargin = AndroidUtilities.dp(18)
            outer.addView(desc, desc_lp)

            def _switch_row(icon_name, title_key, desc_key, setting_key):
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(8), AndroidUtilities.dp(14), AndroidUtilities.dp(8))
                pic = LinearLayout(ctx)
                pic.setGravity(Gravity.CENTER_VERTICAL)
                try:
                    piv = ImageView(ctx)
                    res = ApplicationLoader.applicationContext.getResources()
                    pkg = ApplicationLoader.applicationContext.getPackageName()
                    pid = res.getIdentifier(str(icon_name), "drawable", pkg)
                    if pid:
                        piv.setImageResource(int(pid))
                        piv.setColorFilter(title_color, PorterDuff.Mode.SRC_IN)
                    pic.addView(piv, LinearLayout.LayoutParams(AndroidUtilities.dp(22), AndroidUtilities.dp(22)))
                except Exception:
                    pass
                row.addView(pic)
                info = LinearLayout(ctx)
                info.setOrientation(LinearLayout.VERTICAL)
                info_lp = LinearLayout.LayoutParams(0, -2, 1.0)
                info_lp.leftMargin = AndroidUtilities.dp(8)
                t1 = TextView(ctx)
                t1.setText(self._tr(title_key))
                t1.setTextSize(15)
                t1.setTypeface(None, 1)
                t1.setTextColor(title_color)
                info.addView(t1)
                t2 = TextView(ctx)
                t2.setText(self._tr(desc_key))
                t2.setTextSize(11)
                t2.setPadding(0, AndroidUtilities.dp(2), 0, 0)
                t2.setTextColor(sub_color)
                info.addView(t2)
                row.addView(info, info_lp)
                plugin = self
                try:
                    Switch = jclass("android.widget.Switch")
                    sw = Switch(ctx)
                    ign = [False]

                    def _sync_sw():
                        ign[0] = True
                        try:
                            sw.setChecked(bool(plugin.get_setting(setting_key, True if setting_key == "pomme_music_panel_resize_enabled" else False)))
                        finally:
                            ign[0] = False

                    _sync_sw()
                    CC = jclass("android.widget.CompoundButton$OnCheckedChangeListener")

                    class _Sw(dynamic_proxy(CC)):
                        def onCheckedChanged(self_obj, _button_view, is_checked):
                            if ign[0]:
                                return
                            try:
                                plugin.set_setting(setting_key, bool(is_checked))
                            except Exception as ex:
                                plugin._trace("appearance switch fail ({0}): {1}".format(setting_key, ex), "ERROR")

                    sw.setOnCheckedChangeListener(_Sw())
                    row.addView(sw, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
                except Exception:
                    pass
                lp_s = LinearLayout.LayoutParams(-1, -2)
                lp_s.bottomMargin = AndroidUtilities.dp(10)
                outer.addView(row, lp_s)

            _switch_row("msg_voice_pip_solar", "panel_right_side", "panel_right_side_desc", "pomme_panel_right_side")
            _switch_row("msg_maxvideo", "panel_resize_handle", "panel_resize_handle_desc", "pomme_music_panel_resize_enabled")
            
            def _color_row(label_key, sub_key, setting_key, default_color):
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
                
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                bg.setColor(card_fill)
                try:
                    bg.setStroke(AndroidUtilities.dp(1), card_stroke)
                except Exception:
                    pass
                row.setBackground(bg)
                
                info = LinearLayout(ctx)
                info.setOrientation(LinearLayout.VERTICAL)
                info_lp = LinearLayout.LayoutParams(0, -2, 1.0)
                
                t1 = TextView(ctx)
                t1.setText(self._tr(label_key))
                t1.setTextSize(16)
                t1.setTypeface(None, 1)
                t1.setTextColor(title_color)
                info.addView(t1)
                
                t2 = TextView(ctx)
                t2.setText(self._tr(sub_key))
                t2.setTextSize(12)
                t2.setTextColor(sub_color)
                info.addView(t2)
                row.addView(info, info_lp)
                
                preview = View(ctx)
                current = self._jcolor(self.get_setting(setting_key, default_color))
                p_bg = GradientDrawable()
                p_bg.setShape(GradientDrawable.OVAL)
                p_bg.setColor(current)
                p_bg.setStroke(AndroidUtilities.dp(1), self._jcolor(0x33000000))
                preview.setBackground(p_bg)
                row.addView(preview, LinearLayout.LayoutParams(AndroidUtilities.dp(28), AndroidUtilities.dp(28)))
                
                class _Click(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                    def onClick(self_obj, _v):
                        try:
                            plugin = self
                            def _on_color_selected(color):
                                plugin.set_setting(setting_key, int(plugin._jcolor(color)))
                                run_on_ui_thread(lambda: (p_bg.setColor(plugin._jcolor(color)), preview.invalidate()))
                            self._open_color_picker(ctx, current, _on_color_selected)
                        except Exception as e:
                            self._trace("color pick fail: {0}".format(e))
                
                row.setOnClickListener(_Click())
                lp = LinearLayout.LayoutParams(-1, -2)
                lp.bottomMargin = AndroidUtilities.dp(10)
                outer.addView(row, lp)

            _color_row("color_title", "color_title_desc", "pomme_color_title", 0xFFFFFFFF)
            _color_row("color_controls", "color_controls_desc", "pomme_color_controls", 0xFF000000)
            _color_row("color_bg", "color_bg_desc", "pomme_color_bg", 0xFFF2F2F7)
            
            reset = TextView(ctx)
            reset.setText(self._tr("reset"))
            reset.setGravity(Gravity.CENTER)
            reset.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(12))
            reset.setTextSize(16)
            reset.setTypeface(None, 1)
            reset.setTextColor(self._jcolor(0xFFFF5252))
            
            class _ResetClick(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                def onClick(self_obj, _v):
                    self.set_setting("pomme_color_title", 0xFFFFFFFF)
                    self.set_setting("pomme_color_controls", 0xFF000000)
                    self.set_setting("pomme_color_bg", 0xFFF2F2F7)
                    sheet.dismiss()
                    self._notify_success(self._tr("color_reset"))
            reset.setOnClickListener(_ResetClick())
            outer.addView(reset)
            
            scroll.addView(outer)
            sheet.setCustomView(scroll)
            sheet.show()
        except Exception as e:
            tb = traceback.format_exc()
            self._trace("show appearance fail: {0}\n{1}".format(e, tb), "ERROR")
            self._show_error_sheet("Appearance panel render failed:\n{0}".format(e))


    def _open_color_picker(self, ctx, initial_color, callback):
        try:
            b = AlertDialogBuilder(ctx)
            b.set_title(self._tr("picker_title"))
            
            grid = jclass("android.widget.GridLayout")(ctx)
            grid.setColumnCount(4)
            grid.setPadding(AndroidUtilities.dp(20), AndroidUtilities.dp(10), AndroidUtilities.dp(20), AndroidUtilities.dp(10))
            
            colors = [
                0xFF000000, 0xFFFFFFFF, 0xFFF44336, 0xFFE91E63,
                0xFF9C27B0, 0xFF673AB7, 0xFF3F51B5, 0xFF2196F3,
                0xFF03A9F4, 0xFF00BCD4, 0xFF009688, 0xFF4CAF50,
                0xFF8BC34A, 0xFFCDDC39, 0xFFFFEB3B, 0xFFFFC107,
                0xFFFF9800, 0xFFFF5722, 0xFF795548, 0xFF9E9E9E
            ]
            
            for c in colors:
                v = View(ctx)
                v_bg = GradientDrawable()
                v_bg.setShape(GradientDrawable.OVAL)
                v_bg.setColor(self._jcolor(c))
                v_bg.setStroke(AndroidUtilities.dp(1), self._jcolor(0x22000000))
                v.setBackground(v_bg)
                
                lp = jclass("android.widget.GridLayout$LayoutParams")()
                lp.width = AndroidUtilities.dp(45)
                lp.height = AndroidUtilities.dp(45)
                lp.setMargins(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
                
                class _ColorClick(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                    def __init__(self_obj, selected_color):
                        super().__init__()
                        self_obj.selected_color = selected_color
                    def onClick(self_obj, _v):
                        callback(self_obj.selected_color)
                        try:
                            dialog.dismiss()
                        except Exception:
                            pass
                v.setOnClickListener(_ColorClick(c))
                grid.addView(v, lp)
            
                             
            adv = TextView(ctx)
            adv.setText(self._tr("picker_advanced"))
            adv.setGravity(Gravity.CENTER)
            adv.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(12))
            adv.setTextSize(14)
            adv.setTypeface(None, 1)
            adv.setTextColor(self._jcolor(Theme.getColor(Theme.key_featuredStickers_addButton)))
            
            class _AdvClick(dynamic_proxy(find_class("android.view.View$OnClickListener"))):
                def onClick(self_obj, _v):
                    try:
                        dialog.dismiss()
                        
                        try:
                            from org.telegram.ui.Components.Paint import ColorPickerBottomSheet
                            from androidx.core.util import Consumer
                            PipetteDelegate = find_class("org.telegram.ui.Components.Paint.ColorPickerBottomSheet$PipetteDelegate")
                            PipetteDelegateProxy = dynamic_proxy(PipetteDelegate)

                            class _PipetteDelegate(PipetteDelegateProxy):
                                def __init__(self_obj2): super().__init__()
                                def onStartColorPipette(self_obj2): return None
                                def onStopColorPipette(self_obj2): return None
                                def getContainerView(self_obj2): return None
                                def getSnapshotDrawingView(self_obj2): return None
                                def onDrawImageOverCanvas(self_obj2, bitmap, canvas): return None
                                def isPipetteVisible(self_obj2): return False
                                def isPipetteAvailable(self_obj2): return False
                                def onColorSelected(self_obj2, color): return None

                            ConsumerProxy = dynamic_proxy(Consumer)
                            class _ColorConsumer(ConsumerProxy):
                                def __init__(self_obj2): super().__init__()
                                def accept(self_obj2, color):
                                    try: callback(int(color))
                                    except Exception: pass

                            frag = get_last_fragment()
                            resources_provider = frag.getResourceProvider() if frag else None
                            sheet = ColorPickerBottomSheet(ctx, resources_provider)
                            sheet.setPipetteDelegate(_PipetteDelegate())
                            sheet.setColor(int(initial_color))
                            sheet.setColorListener(_ColorConsumer())
                            run_on_ui_thread(sheet.show)
                            return
                        except Exception:
                            pass

                        from org.telegram.ui.Components import ColorPicker
                        ColorPickerDelegate = find_class("org.telegram.ui.Components.ColorPicker$ColorPickerDelegate")
                        ColorPickerDelegateProxy = dynamic_proxy(ColorPickerDelegate)
                        selected = {"color": initial_color}

                        class _PickerDelegate(ColorPickerDelegateProxy):
                            def __init__(self_obj2): super().__init__()
                            def setColor(self_obj2, color, num, applyNow):
                                try: selected["color"] = int(color)
                                except Exception: pass

                        picker = ColorPicker(ctx, False, _PickerDelegate())
                        try: picker.setColor(int(initial_color), 0)
                        except Exception: pass

                        def _save(b, _w):
                            try:
                                b.dismiss()
                                callback(int(selected["color"]))
                            except Exception: pass

                        builder = AlertDialogBuilder(ctx)
                        builder.set_title(self._tr("picker_title"))
                        builder.set_view(picker)
                        builder.set_positive_button("OK", _save)
                        builder.set_negative_button(self._tr("cancel"), lambda b, _w: b.dismiss())
                        builder.show()
                    except Exception as e:
                        self._trace("advanced color picker fail: {0}".format(e), "ERROR")
            adv.setOnClickListener(_AdvClick())
            
            container = LinearLayout(ctx)
            container.setOrientation(LinearLayout.VERTICAL)
            container.addView(grid)
            container.addView(adv)
            
            b.set_view(container)
            dialog = b.show()
        except Exception as e:
            self._trace("color picker fail: {0}".format(e))

    def _show_menu_shortcuts_sheet_ui(self):
        try:
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                self._show_error_sheet("Menu shortcuts panel could not open: context unavailable.")
                return
            try:
                if getattr(self, "_menu_shortcuts_sheet", None) is not None:
                    self._menu_shortcuts_sheet.dismiss()
            except Exception:
                pass
            self._menu_shortcuts_sheet = None
            sheet = BottomSheet(ctx, True)
            scroll = jclass("android.widget.ScrollView")(ctx)
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(18))

