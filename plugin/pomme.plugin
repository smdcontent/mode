class PommeDialogsCreateHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            frag = param.thisObject
            run_on_ui_thread(lambda: (self.plugin._attach_or_refresh(frag), self.plugin._ensure_dialogs_menu_item(frag), self.plugin._push_on_dialogs_shown(frag)))
        except Exception as e:
            self.plugin._trace("createView hook error: {0}".format(e))


class PommeDialogsResumeHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            frag = param.thisObject
            run_on_ui_thread(lambda: (self.plugin._attach_or_refresh(frag), self.plugin._ensure_dialogs_menu_item(frag), self.plugin._push_on_dialogs_shown(frag)))
        except Exception as e:
            self.plugin._trace("onResume hook error: {0}".format(e))


class PommeDialogsPauseHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            run_on_ui_thread(lambda: (self.plugin._detach_state(), self.plugin._push_on_dialogs_hidden()))
        except Exception as e:
            self.plugin._trace("onPause hook error: {0}".format(e))


