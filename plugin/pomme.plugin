    def _copy_text_to_clipboard(self, text):
        try:
            ctx = ApplicationLoader.applicationContext
            if ctx is None:
                return False
            ClipData = jclass("android.content.ClipData")
            Context = jclass("android.content.Context")
            svc = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
            if svc is None:
                return False
            clip = ClipData.newPlainText("Pomme", str(text or ""))
            svc.setPrimaryClip(clip)
            return True
        except Exception as e:
            self._trace("clipboard copy fail: {0}".format(e), "WARN")
            return False

