        try:
            media_cls = JClass.forName("org.telegram.messenger.MediaController")
            m = media_cls.getDeclaredMethod("cleanup")
            m.setAccessible(True)
            self._hooks.append(self.hook_method(m, PommeMediaCleanupHook(self)))
        except Exception as e:
            self._trace("hook media cleanup fail: {0}".format(e))

        try:
            media_cls = JClass.forName("org.telegram.messenger.MediaController")
            m = media_cls.getDeclaredMethod("cleanupPlayer", Boolean.TYPE, Boolean.TYPE)
            m.setAccessible(True)
            self._hooks.append(self.hook_method(m, PommeMediaCleanupPlayerHook(self)))
        except Exception as e:
