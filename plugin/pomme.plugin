                    finally:
                        notif_sw_ign[0] = False

                _sync_notif_sw()
                CC = jclass("android.widget.CompoundButton$OnCheckedChangeListener")

                class _NotifSw(dynamic_proxy(CC)):
                    def onCheckedChanged(self_obj, _button_view, is_checked):
                        if notif_sw_ign[0]:
                            return
                        try:
                            plugin._set_notifications_enabled(bool(is_checked))
                        except Exception as e:
                            plugin._trace("notifications switch fail: {0}".format(e), "ERROR")

                notif_sw.setOnCheckedChangeListener(_NotifSw())
                row.addView(notif_sw, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            except Exception:
                pass

            outer.addView(row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            scroll.addView(outer)
            sheet.setCustomView(scroll)
            sheet.show()
            self._notifications_sheet = sheet
        except Exception as e:
            self._trace("show notifications sheet fail: {0}".format(e), "ERROR")
            self._show_error_sheet("Notifications panel render failed:\n{0}".format(e))

    def _show_playlist_sheet(self):
        run_on_ui_thread(self._show_playlist_sheet_ui)

    def _show_playlist_sheet_ui(self):
        try:
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                self._show_error_sheet("Playlist panel could not open: context unavailable.")
                return
            try:
                if self._playlist_sheet is not None:
                    self._playlist_sheet.dismiss()
            except Exception:
                pass
            self._playlist_sheet = None
            listener_cls = find_class("android.view.View$OnClickListener")
            long_listener_cls = find_class("android.view.View$OnLongClickListener")
            sheet = BottomSheet(ctx, True)
            try:
                sheet.setBackgroundColor(0)
            except Exception:
                pass
            scroll = jclass("android.widget.ScrollView")(ctx)
            try:
                scroll.setFillViewport(True)
            except Exception:
                pass
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(18))
            try:
                is_dark_sheet = bool(Theme.isCurrentThemeDark())
            except Exception:
                is_dark_sheet = True
            sheet_bg_primary = self._jcolor(0xFF20302E if is_dark_sheet else 0xFFF2FBF9)
            sheet_bg_secondary = self._jcolor(0xFF202224 if is_dark_sheet else 0xFFF8F5F2)
            card_fill = self._jcolor(0x1CFFFFFF if is_dark_sheet else 0xCCFFFFFF)
            card_stroke = self._jcolor(0x1FFFFFFF if is_dark_sheet else 0x1432A898)
            action_fill = self._jcolor(0xFF23897E if is_dark_sheet else 0xFF32A898)
            action_text = self._contrast_text_color(int(action_fill))
            sub_chip_fill = self._jcolor(0x18000000 if is_dark_sheet else 0x0FF0F4F8)
            sub_chip_stroke = self._jcolor(0x2BFFFFFF if is_dark_sheet else 0x1832A898)
            sheet_bg = GradientDrawable(GradientDrawable.Orientation.TL_BR, [sheet_bg_primary, sheet_bg_secondary])
            try:
                radius = float(AndroidUtilities.dp(24))
                sheet_bg.setCornerRadii([radius, radius, radius, radius, radius, radius, radius, radius])
            except Exception:
                pass
            try:
                scroll.setBackground(sheet_bg)
            except Exception:
                outer.setBackground(sheet_bg)
            title_color = int(Theme.getColor(Theme.key_dialogTextBlack))
            sub_color = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            button_fill = int(action_fill)
            button_text = int(action_text)

            head = LinearLayout(ctx)
            head.setOrientation(LinearLayout.HORIZONTAL)
            head.setGravity(Gravity.CENTER_VERTICAL)

            title_box = LinearLayout(ctx)
            title_box.setOrientation(LinearLayout.VERTICAL)
            title_box_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)

            title = TextView(ctx)
            title.setText(self._tr("playlist_panel_title"))
            title.setTextSize(18)
            title.setTypeface(None, 1)
            title.setTextColor(int(title_color))
            title_box.addView(title)

            desc = TextView(ctx)
            desc.setText(self._tr("panel_playlist_sheet_desc"))
            desc.setTextSize(13)
            desc.setTextColor(int(sub_color))
            desc.setPadding(0, AndroidUtilities.dp(6), 0, 0)
            title_box.addView(desc)
            head.addView(title_box, title_box_lp)

            add_btn = TextView(ctx)
            add_btn.setText(self._tr("playlist_add_new"))
            add_btn.setTextSize(14)
            add_btn.setTypeface(None, 1)
            add_btn.setTextColor(int(button_text))
            add_btn.setGravity(Gravity.CENTER)
            add_btn.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(10), AndroidUtilities.dp(16), AndroidUtilities.dp(10))
            add_bg = GradientDrawable()
            add_bg.setCornerRadius(float(AndroidUtilities.dp(17)))
            add_bg.setColor(self._jcolor(button_fill))
            add_btn.setBackground(add_bg)
            head.addView(add_btn)
            outer.addView(head)

            liked_name = self._liked_playlist_name()

            def _row(item_name, item_url, index, user_playlist=False, track_count=0):
                is_liked = bool(user_playlist and self._is_liked_playlist_entry(item_name))
                is_auto_cache = bool(user_playlist and self._is_auto_cache_playlist_entry(item_name))
                service_kind = "" if user_playlist else self._playlist_service_kind(item_url)
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                bg.setColor(card_fill)
                try:
                    bg.setStroke(AndroidUtilities.dp(1), card_stroke)
                except Exception:
                    pass
                row.setBackground(bg)

                if not user_playlist:
                    icon_wrap = LinearLayout(ctx)
                    icon_wrap.setGravity(Gravity.CENTER)
                    icon_bg = GradientDrawable()
                    icon_bg.setCornerRadius(float(AndroidUtilities.dp(13)))
                    icon_bg.setColor(self._playlist_service_chip_fill(item_url, is_dark_sheet))
                    try:
                        icon_bg.setStroke(AndroidUtilities.dp(1), self._playlist_service_chip_stroke(item_url, is_dark_sheet))
                    except Exception:
                        pass
                    icon_wrap.setBackground(icon_bg)
                    icon_wrap_lp = LinearLayout.LayoutParams(AndroidUtilities.dp(30), AndroidUtilities.dp(30))
                    icon_wrap_lp.rightMargin = AndroidUtilities.dp(10)
                    try:
                        bmp = self._playlist_service_display_bitmap(item_url, 15, is_dark_sheet)
                        if bmp is not None:
                            icon_view = ImageView(ctx)
                            icon_view.setImageBitmap(bmp)
                            try:
                                icon_view.setScaleType(jclass("android.widget.ImageView$ScaleType").FIT_CENTER)
                            except Exception:
                                pass
                            icon_wrap.addView(icon_view, LinearLayout.LayoutParams(AndroidUtilities.dp(16), AndroidUtilities.dp(16)))
                        else:
                            rid = int(self._playlist_service_icon_drawable_id(item_url) or 0)
                        if bmp is None and rid:
                            icon_view = ImageView(ctx)
                            icon_view.setImageResource(int(rid))
                            try:
                                if not bool(is_dark_sheet):
                                    icon_view.setColorFilter(int(0xFF2B2B2B), PorterDuff.Mode.SRC_IN)
                                else:
                                    icon_view.clearColorFilter()
                            except Exception:
                                icon_view.setColorFilter(int(title_color), PorterDuff.Mode.SRC_IN)
                            icon_wrap.addView(icon_view, LinearLayout.LayoutParams(AndroidUtilities.dp(16), AndroidUtilities.dp(16)))
                        elif bmp is None and not rid:
                            badge = TextView(ctx)
                            badge.setText(str(self._playlist_service_badge_text(item_url) or "").strip())
                            badge.setTextSize(9)
                            badge.setTypeface(None, 1)
                            badge.setTextColor(int(title_color))
                            badge.setGravity(Gravity.CENTER)
                            icon_wrap.addView(badge, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
                    except Exception:
                        pass
                    row.addView(icon_wrap, icon_wrap_lp)

                text_box = LinearLayout(ctx)
                text_box.setOrientation(LinearLayout.VERTICAL)
                text_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                t1 = TextView(ctx)
                t1.setText(str(item_name or "Playlist"))
                t1.setTextSize(16)
                t1.setTypeface(None, 1)
                t1.setTextColor(int(title_color))
                text_box.addView(t1)
                t2 = TextView(ctx)
                if user_playlist:
                    count_text = self._tr("track_count_fmt").format(int(track_count or 0))
                    if is_liked:
                        hint = self._tr("playlist_item_liked_hint").format(count_text)
                    elif is_auto_cache:
                        hint = self._tr("playlist_item_auto_cache_hint").format(count_text)
                    else:
                        hint = self._tr("playlist_item_tracks_hint").format(count_text)
                    t2.setText(hint)
                else:
                    source_tracks = int(track_count or len(self._source_playlist_tracks(item_url) or self._playlist_listing_items(item_url) or []))
                    if source_tracks > 0:
                        t2.setText(self._tr("playlist_item_tracks_hint").format(self._tr("track_count_fmt").format(source_tracks)))
                    else:
                        t2.setText(self._tr("playlist_item_hint"))
                t2.setTextSize(12)
                t2.setPadding(0, AndroidUtilities.dp(3), 0, 0)
                t2.setTextColor(int(sub_color))
                text_box.addView(t2)
                row.addView(text_box, text_lp)

                play_tv = TextView(ctx)
                play_tv.setText("Play")
                play_tv.setTextSize(13)
                play_tv.setTypeface(None, 1)
                play_tv.setTextColor(int(title_color))
                play_tv.setGravity(Gravity.CENTER)
                play_tv.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(7), AndroidUtilities.dp(12), AndroidUtilities.dp(7))
                play_bg = GradientDrawable()
                play_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                play_bg.setColor(sub_chip_fill)
                play_bg.setStroke(AndroidUtilities.dp(1), sub_chip_stroke)
                play_tv.setBackground(play_bg)
                play_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                play_lp.leftMargin = AndroidUtilities.dp(12)
                row.addView(play_tv, play_lp)

                shuffle_tv = TextView(ctx)
                shuffle_tv.setText("Shuffle")
                shuffle_tv.setTextSize(13)
                shuffle_tv.setTypeface(None, 1)
                shuffle_tv.setTextColor(int(title_color))
                shuffle_tv.setGravity(Gravity.CENTER)
                shuffle_tv.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(7), AndroidUtilities.dp(12), AndroidUtilities.dp(7))
                shuffle_bg = GradientDrawable()
                shuffle_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                shuffle_bg.setColor(sub_chip_fill)
                shuffle_bg.setStroke(AndroidUtilities.dp(1), sub_chip_stroke)
                shuffle_tv.setBackground(shuffle_bg)
                shuffle_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                shuffle_lp.leftMargin = AndroidUtilities.dp(8)
                row.addView(shuffle_tv, shuffle_lp)

                if listener_cls is not None:
                    plugin = self
                    class _PlayClick(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            try:
                                if user_playlist:
                                    plugin._play_user_saved_playlist(item_name)
                                else:
                                    plugin._play_saved_playlist(item_url)
                            except Exception as e:
                                plugin._trace("play playlist item fail: {0}".format(e), "ERROR")
                    class _ShuffleClick(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            try:
                                if user_playlist:
                                    plugin._play_user_saved_playlist(item_name, shuffle=True)
                                else:
                                    plugin._play_saved_playlist(item_url, shuffle=True)
                            except Exception as e:
                                plugin._trace("shuffle playlist item fail: {0}".format(e), "ERROR")
                    class _EditClick(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            try:
                                if user_playlist:
                                    plugin._show_user_playlist_tracks_sheet(item_name)
                                else:
                                    plugin._show_source_playlist_tracks_sheet(item_name, item_url)
                            except Exception as e:
                                plugin._trace("edit playlist item fail: {0}".format(e), "ERROR")
                    play_tv.setOnClickListener(_PlayClick())
                    shuffle_tv.setOnClickListener(_ShuffleClick())
                    row.setOnClickListener(_EditClick())
                    if index is None and not user_playlist:
                        row.setOnClickListener(_PlayClick())
                if long_listener_cls is not None and (index is not None or user_playlist):
                    plugin = self
                    class _LongClick(dynamic_proxy(long_listener_cls)):
                        def onLongClick(self_obj, _v):
                            try:
                                if user_playlist:
                                    if is_liked or is_auto_cache:
                                        plugin._show_user_playlist_tracks_sheet(item_name)
                                        return True
                                    plugin._confirm_action(
                                        ctx,
                                        plugin._tr("playlist_remove_confirm_title"),
                                        plugin._tr("playlist_remove_confirm_desc"),
                                        lambda: (
                                            plugin._remove_user_saved_playlist(item_name) and (
                                                plugin._notify_success(plugin._tr("playlist_remove_done")),
                                                sheet.dismiss(),
                                                plugin._show_playlist_sheet()
                                            )
                                        ),
                                    )
                                    return True
                                items = plugin._playlists()
                                if 0 <= int(index) < len(items):
                                    try:
                                        overrides = plugin._source_playlist_overrides()
                                        overrides.pop(str(item_url or "").strip(), None)
                                        plugin._set_source_playlist_overrides(overrides)
                                    except Exception:
                                        pass
                                    items.pop(int(index))
                                    plugin._set_playlists(items)
                                    plugin._notify_success(plugin._tr("playlist_remove_done"))
                                    try:
                                        sheet.dismiss()
                                    except Exception:
                                        pass
                                    plugin._show_playlist_sheet()
                                return True
                            except Exception as e:
                                plugin._trace("playlist remove fail: {0}".format(e), "ERROR")
                                return True
                    row.setOnLongClickListener(_LongClick())

                lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp.topMargin = AndroidUtilities.dp(10)
                outer.addView(row, lp)

            if listener_cls is not None:
                plugin = self
                class _AddClick(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        plugin._open_playlist_editor()
                add_btn.setOnClickListener(_AddClick())

            self._ensure_liked_playlist()
            self._ensure_auto_cache_playlist()
            normal_rows = []
            for idx, item in enumerate(self._playlists()):
                row_url = str(item.get("url") or "")
                row_count = int(len(self._source_playlist_tracks(row_url) or self._playlist_listing_items(row_url) or []))
                normal_rows.append(("normal", idx, str(item.get("name") or "Playlist"), row_url, row_count))
            for entry in self._user_saved_playlists():
                normal_rows.append(("user", None, str(entry.get("name") or "Playlist"), "", len(list(entry.get("tracks") or []))))

            liked_row = None
            auto_cache_row = None
            regular_rows = []
            for row in normal_rows:
                if row[0] == "user" and self._is_liked_playlist_entry(row[2]):
                    liked_row = row
                elif row[0] == "user" and self._is_auto_cache_playlist_entry(row[2]):
                    auto_cache_row = row
                else:
                    regular_rows.append(row)

            page_size = 5
            page = max(0, int(self._playlist_page or 0))
            total_pages = max(1, int((len(regular_rows) + page_size - 1) / page_size) if regular_rows else 1)
            if page >= total_pages:
                page = total_pages - 1
                self._playlist_page = page
            start = page * page_size
            end = start + page_size
            visible_rows = regular_rows[start:end]

            if liked_row is not None:
                _row(liked_row[2], liked_row[3], liked_row[1], True, liked_row[4])
            if auto_cache_row is not None:
                _row(auto_cache_row[2], auto_cache_row[3], auto_cache_row[1], True, auto_cache_row[4])
            for row_type, row_index, row_name, row_url, row_count in visible_rows:
                _row(row_name, row_url, row_index, row_type == "user", row_count)

            nav = LinearLayout(ctx)
            nav.setOrientation(LinearLayout.HORIZONTAL)
            nav.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
            nav_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            nav_lp.topMargin = AndroidUtilities.dp(12)

            def _nav_btn(text_key, click_fn):
                btn = TextView(ctx)
                btn.setText(self._tr(text_key))
                btn.setTextSize(14)
                btn.setTypeface(None, 1)
                btn.setTextColor(int(button_text))
                btn.setGravity(Gravity.CENTER)
                btn.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(10), AndroidUtilities.dp(14), AndroidUtilities.dp(10))
                btn_bg = GradientDrawable()
                btn_bg.setCornerRadius(float(AndroidUtilities.dp(16)))
                btn_bg.setColor(self._jcolor(button_fill))
                btn.setBackground(btn_bg)
                if listener_cls is not None:
                    class _Click(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            click_fn()
                    btn.setOnClickListener(_Click())
                return btn

            if page > 0:
                prev_btn = _nav_btn("playlist_prev_page", lambda: (setattr(self, "_playlist_page", max(0, int(self._playlist_page or 0) - 1)), sheet.dismiss(), self._show_playlist_sheet()))
                nav.addView(prev_btn)
            if page < total_pages - 1:
                next_btn = _nav_btn("playlist_next_page", lambda: (setattr(self, "_playlist_page", int(self._playlist_page or 0) + 1), sheet.dismiss(), self._show_playlist_sheet()))
                next_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                if page > 0:
                    next_lp.leftMargin = AndroidUtilities.dp(10)
                nav.addView(next_btn, next_lp)
            if nav.getChildCount() > 0:
                outer.addView(nav, nav_lp)

            scroll.addView(outer)
            sheet.setCustomView(scroll)
            sheet.show()
            self._playlist_sheet = sheet
        except Exception as e:
            self._trace("show playlist sheet fail: {0}".format(e), "ERROR")
            self._show_error_sheet("Playlist panel render failed:\n{0}".format(e))

    def _show_smart_cache_sheet_ui(self):
        try:
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                self._show_error_sheet("Smart Cache panel could not open: context unavailable.")
                return
            try:
                if self._smart_cache_sheet is not None:
                    self._smart_cache_sheet.dismiss()
            except Exception:
                pass
            self._smart_cache_sheet = None
            listener_cls = find_class("android.view.View$OnClickListener")
            sheet = BottomSheet(ctx, True)
            scroll = jclass("android.widget.ScrollView")(ctx)
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(18))

            title_color = int(Theme.getColor(Theme.key_dialogTextBlack))
            sub_color = int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            button_fill = int(Theme.getColor(Theme.key_featuredStickers_addButton))
            button_text = int(Theme.getColor(Theme.key_featuredStickers_buttonText))

            head = LinearLayout(ctx)
            head.setOrientation(LinearLayout.HORIZONTAL)
            head.setGravity(Gravity.CENTER_VERTICAL)

            title_box = LinearLayout(ctx)
            title_box.setOrientation(LinearLayout.VERTICAL)
            title_box_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)

            header = TextView(ctx)
            header.setText(self._tr("panel_smart_cache"))
            header.setTextSize(18)
            header.setTypeface(None, 1)
            header.setTextColor(int(title_color))
            title_box.addView(header)

            desc = TextView(ctx)
            desc.setText(self._tr("panel_smart_cache_sheet_desc"))
            desc.setTextSize(13)
            desc.setTextColor(int(sub_color))
            desc.setPadding(0, AndroidUtilities.dp(6), 0, 0)
            title_box.addView(desc)
            head.addView(title_box, title_box_lp)

            clear_btn = TextView(ctx)
            clear_btn.setText(self._tr("smart_cache_clear_all"))
            clear_btn.setTextSize(14)
            clear_btn.setTypeface(None, 1)
            clear_btn.setTextColor(int(button_text))
            clear_btn.setGravity(Gravity.CENTER)
            clear_btn.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(10), AndroidUtilities.dp(16), AndroidUtilities.dp(10))
            clear_bg = GradientDrawable()
            clear_bg.setCornerRadius(float(AndroidUtilities.dp(17)))
            clear_bg.setColor(self._jcolor(button_fill))
            clear_btn.setBackground(clear_bg)
            head.addView(clear_btn)
            outer.addView(head)

            plugin = self
            toggle_row = self._build_settings_switch_row(
                ctx,
                title_color,
                sub_color,
                "chats_archive_remix",
                self._tr("auto_cache_enabled"),
                self._tr("auto_cache_enabled_desc"),
                self._auto_cache_enabled(),
                lambda value, _sw, _guard: (
                    plugin.set_setting("pomme_auto_cache_enabled", bool(value)),
                    plugin._ensure_auto_cache_playlist(),
                ),
                row_fill=self._jcolor(0x1AFFFFFF),
                icon_fill=self._jcolor(0x14EB3F44),
                icon_tint=self._jcolor(0xFFEB3F44),
            )
            toggle_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            toggle_lp.topMargin = AndroidUtilities.dp(16)
            outer.addView(toggle_row, toggle_lp)

                                                      
            cache_rows = self._smart_cache_summary()
            cache_value = "{0} • {1}".format(
                self._tr("playlist_count_fmt").format(len(cache_rows)) if cache_rows else self._tr("playlist_count_fmt").format(0),
                self._format_cache_size(sum([int(row.get("bytes") or 0) for row in cache_rows]))
            )
            
            status_row = LinearLayout(ctx)
            status_row.setOrientation(LinearLayout.HORIZONTAL)
            status_row.setGravity(Gravity.CENTER_VERTICAL)
            status_row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
            status_bg = GradientDrawable()
            status_bg.setCornerRadius(float(AndroidUtilities.dp(20)))
            status_bg.setColor(self._jcolor(0x1AFFFFFF))
            status_row.setBackground(status_bg)

            s_info = LinearLayout(ctx)
            s_info.setOrientation(LinearLayout.VERTICAL)
            s_info_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)

            s_t1 = TextView(ctx)
            s_t1.setText(self._tr("panel_cache_status"))
            s_t1.setTextSize(17)
            s_t1.setTypeface(None, 1)
            s_t1.setTextColor(int(title_color))
            s_info.addView(s_t1)

            s_t2 = TextView(ctx)
            s_t2.setText(self._tr("panel_cache_status_desc"))
            s_t2.setTextSize(12)
            s_t2.setTextColor(int(sub_color))
            s_info.addView(s_t2)
            status_row.addView(s_info, s_info_lp)

            s_v = TextView(ctx)
            s_v.setText(str(cache_value))
            s_v.setTextSize(13)
            s_v.setTypeface(None, 1)
            s_v.setTextColor(int(title_color))
            s_v_lp = LinearLayout.LayoutParams(-2, -2)
            s_v_lp.leftMargin = AndroidUtilities.dp(12)
            status_row.addView(s_v, s_v_lp)

            status_lp = LinearLayout.LayoutParams(-1, -2)
            status_lp.topMargin = AndroidUtilities.dp(16)
            outer.addView(status_row, status_lp)

            divider = View(ctx)

            def _row(title_text, desc_text, click, danger=False):
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.VERTICAL)
                row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
                row_bg = GradientDrawable()
                row_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
                row_bg.setColor(self._jcolor(0x1AFFFFFF if not danger else 0x10FF6B6B))
                row.setBackground(row_bg)

                title = TextView(ctx)
                title.setText(str(title_text or ""))
                title.setTextSize(16)
                title.setTypeface(None, 1)
                title.setTextColor(int(title_color if not danger else self._jcolor(0xFFFF9A9A)))
                row.addView(title)

                if desc_text:
                    sub = TextView(ctx)
                    sub.setText(str(desc_text))
                    sub.setTextSize(12)
                    sub.setPadding(0, AndroidUtilities.dp(4), 0, 0)
                    sub.setTextColor(int(sub_color))
                    row.addView(sub)

                if click is not None and listener_cls is not None:
                    class _Click(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            click()
                    row.setOnClickListener(_Click())

                lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp.topMargin = AndroidUtilities.dp(8)
                outer.addView(row, lp)

            if listener_cls is not None:
                plugin = self
                class _ClearClick(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        plugin._confirm_action(
                            ctx,
                            plugin._tr("smart_cache_clear_all"),
                            plugin._tr("smart_cache_clear_all_desc"),
                            lambda: (
                                plugin._clear_all_smart_cache() and (
                                    sheet.dismiss(),
                                    plugin._show_smart_cache_sheet()
                                )
                            )
                        )
                clear_btn.setOnClickListener(_ClearClick())

            summaries = self._smart_cache_summary()
            if not summaries:
                _row(self._tr("smart_cache_empty"), "", None)
            else:
                for item in summaries:
                    _row(
                        item.get("name"),
                        "{0} • {1}".format(
                            self._tr("smart_cache_playlist_desc").format(int(item.get("count") or 0), int(item.get("total") or 0)),
                            self._format_cache_size(int(item.get("bytes") or 0))
                        ),
                        lambda cache_key=item.get("key"), playlist_name=item.get("name"): self._confirm_action(
                            ctx,
                            playlist_name,
                            self._tr("smart_cache_clear_all_desc"),
                            lambda: (
                                self._clear_playlist_cache(cache_key),
                                sheet.dismiss(),
                                self._show_smart_cache_sheet()
                            )
                        ),
                        danger=True,
                    )

            scroll.addView(outer)
            sheet.setCustomView(scroll)
            sheet.show()
            self._smart_cache_sheet = sheet
        except Exception as e:
            self._trace("show smart cache sheet fail: {0}".format(e), "ERROR")
            self._show_error_sheet("Smart Cache panel render failed:\n{0}".format(e))

    def _show_about_sheet_ui(self):
        try:
            self._trace("opening pomme panel", "INFO")
            frag = get_last_fragment() or self._fragment_ref
            ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                self._trace("pomme panel ctx unavailable", "ERROR")
                self._show_error_sheet("Pomme panel could not open: context unavailable.")
                return

            try:
                if self._panel_sheet is not None:
                    self._panel_sheet.dismiss()
            except Exception:
                pass
            self._panel_sheet = None

            listener_cls = find_class("android.view.View$OnClickListener")
            sheet = BottomSheet(ctx, True)
            FrameLayout = jclass("android.widget.FrameLayout")
            ScrollView = jclass("android.widget.ScrollView")
            sheet_root = FrameLayout(ctx)
            scroll = ScrollView(ctx)
            try:
                scroll.setFillViewport(True)
            except Exception:
                pass
            try:
                scroll.setBackgroundColor(0)
            except Exception:
                pass
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(
                AndroidUtilities.dp(18),
                AndroidUtilities.dp(8),
                AndroidUtilities.dp(18),
                AndroidUtilities.dp(18)
            )

            try:
                title_color = self._jcolor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception:
                title_color = self._jcolor(0xFFF2F5FA)
            try:
                sub_color = self._jcolor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            except Exception:
                sub_color = self._jcolor(0xFF9AA6B2)
            try:
                active_card_color = self._jcolor(Theme.getColor(Theme.key_featuredStickers_addButton))
            except Exception:
                active_card_color = self._jcolor(0xFF4B9EF7)
            inactive_card_color = self._jcolor(0x1AFFFFFF)
            brand_red = self._jcolor(0xFFEB3F44)
            try:
                is_dark_panel = bool(Theme.isCurrentThemeDark())
            except Exception:
                is_dark_panel = True
            try:
                native_panel_base = int(Theme.getColor(Theme.key_dialogBackground))
            except Exception:
                native_panel_base = 0xFF202124 if is_dark_panel else 0xFFFAF7F7
            if is_dark_panel:
                try:
                    soft_red_top = self._blend_colors(native_panel_base, 0xFFEA3C42, 0.26)
                    soft_red_bottom = self._blend_colors(native_panel_base, 0xFFEA3C42, 0.10)
                    panel_bg_primary = self._blend_colors(native_panel_base, int(soft_red_top), 0.60)
                    panel_bg_secondary = self._blend_colors(native_panel_base, int(soft_red_bottom), 0.82)
                except Exception:
                    panel_bg_primary = self._jcolor(0xFF30262A)
                    panel_bg_secondary = self._jcolor(0xFF242326)
            else:
                panel_bg_primary = self._jcolor(0xFFF8F1F2)
                panel_bg_secondary = self._jcolor(0xFFF3EEEF)
            footer_bg_primary = self._jcolor(0xFF43393C if is_dark_panel else 0xFFFFFFFF)
            footer_bg_secondary = self._jcolor(0xFF2F2D2E if is_dark_panel else 0xFFF3EDEE)
            footer_stroke = self._jcolor(0x24FF8A8F if is_dark_panel else 0x18EB3F44)

            try:
                sheet.setBackgroundColor(0)
            except Exception:
                pass

            panel_bg = GradientDrawable(GradientDrawable.Orientation.TL_BR, [panel_bg_primary, panel_bg_secondary])
            try:
                radius = float(AndroidUtilities.dp(28))
                panel_bg.setCornerRadii([radius, radius, radius, radius, radius, radius, radius, radius])
            except Exception:
                pass
            sheet_root.setBackground(panel_bg)

            def _triple_card_bg(colors, active=False):
                try:
                    palette = [self._jcolor(int(x)) for x in list(colors or [])[:3]]
                    while len(palette) < 3:
                        palette.append(brand_red)
                    bg = GradientDrawable(GradientDrawable.Orientation.TL_BR, palette)
                    bg.setCornerRadius(float(AndroidUtilities.dp(20)))
                    if active:
                        try:
                            bg.setStroke(AndroidUtilities.dp(1), self._jcolor(0x2EFFFFFF))
                        except Exception:
                            pass
                    return bg
                except Exception:
                    fallback = GradientDrawable()
                    fallback.setCornerRadius(float(AndroidUtilities.dp(20)))
                    fallback.setColor(int(active_card_color if active else inactive_card_color))
                    return fallback

            chip_gradients = {
                "panel_auto_play": (0xFFEB3F44, 0xFFF06B70, 0xFFF6A09A),
                "panel_playlist": (0xFF177E74, 0xFF32A898, 0xFF8AD4C6),
                "panel_language": (0xFF3559B7, 0xFF6B86D6, 0xFFB4C1F1),
                "panel_data": (0xFFB86A2E, 0xFFD69057, 0xFFF0C39A),
            }
            chip_active_gradients = {
                "panel_auto_play": (0xFFB81223, 0xFFEB3F44, 0xFFFF8A80),
                "panel_playlist": (0xFF0F6D64, 0xFF1F9384, 0xFF67C4B2),
                "panel_language": (0xFF2648A1, 0xFF4D6BC0, 0xFF96ABE7),
                "panel_data": (0xFF9C5822, 0xFFBF7A3E, 0xFFE6AF77),
            }

            def _make_handle():
                wrap = FrameLayout(ctx)
                
                                     
                handle = View(ctx)
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(3)))
                bg.setColor(self._jcolor((sub_color & 0x66FFFFFF) or 0x66AAB4C2))
                handle.setBackground(bg)
                h_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(42), AndroidUtilities.dp(6), Gravity.CENTER)
                wrap.addView(handle, h_lp)
                
                                          
                search_btn = ImageView(ctx)
                try:
                    search_icon_id = ApplicationLoader.applicationContext.getResources().getIdentifier("msg_search", "drawable", ApplicationLoader.applicationContext.getPackageName())
                    if search_icon_id:
                        search_btn.setImageResource(int(search_icon_id))
                        search_btn.setColorFilter(sub_color, PorterDuff.Mode.SRC_IN)
                    search_btn.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10))
                except Exception: pass
                
                if listener_cls is not None:
                    class _SearchClick(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            sheet.dismiss()
                            self._show_search_prompt()
                    search_btn.setOnClickListener(_SearchClick())
                
                s_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(42), AndroidUtilities.dp(42), Gravity.END | Gravity.CENTER_VERTICAL)
                wrap.addView(search_btn, s_lp)
                
                lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp.bottomMargin = AndroidUtilities.dp(8)
                outer.addView(wrap, lp)

            def _section(key):
                tv = TextView(ctx)
                tv.setText(self._tr(key))
                tv.setTextSize(15)
                tv.setTypeface(None, 1)
                tv.setTextColor(title_color)
                lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp.topMargin = AndroidUtilities.dp(14)
                lp.bottomMargin = AndroidUtilities.dp(6)
                outer.addView(tv, lp)

            def _row(title_key, desc_key=None, value_text="", click=None, icon_name=None, danger=False, active=False):
                row = LinearLayout(ctx)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12))
                row_bg = GradientDrawable()
                row_bg.setCornerRadius(float(AndroidUtilities.dp(20)))
                if danger:
                    row_bg.setColor(self._jcolor(0x10FF6B6B))
                elif active:
                    row_bg.setColor(active_card_color)
                else:
                    row_bg.setColor(inactive_card_color)
                row.setBackground(row_bg)
                active_text_color = self._contrast_text_color(active_card_color)

                info = LinearLayout(ctx)
                info.setOrientation(LinearLayout.VERTICAL)
                info_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)

                if icon_name:
                    icon_wrap = LinearLayout(ctx)
                    icon_wrap.setGravity(Gravity.CENTER)
                    ibg = GradientDrawable()
                    ibg.setCornerRadius(float(AndroidUtilities.dp(999)))
                    ibg.setColor(self._jcolor(0x1FFFFFFF if not danger else 0x22FF6B6B))
                    icon_wrap.setBackground(ibg)
                    icon_lp = LinearLayout.LayoutParams(AndroidUtilities.dp(30), AndroidUtilities.dp(30))
                    icon_lp.rightMargin = AndroidUtilities.dp(12)
                    icon = ImageView(ctx)
                    try:
                        icon_id = ApplicationLoader.applicationContext.getResources().getIdentifier(str(icon_name), "drawable", ApplicationLoader.applicationContext.getPackageName())
                        if icon_id:
                            icon.setImageResource(int(icon_id))
                        icon_tint = active_text_color if active and not danger else (title_color if not danger else self._jcolor(0xFFFF8F8F))
                        icon.setColorFilter(icon_tint, PorterDuff.Mode.SRC_IN)
                    except Exception:
                        pass
                    icon_wrap.addView(icon, LinearLayout.LayoutParams(AndroidUtilities.dp(16), AndroidUtilities.dp(16)))
                    row.addView(icon_wrap, icon_lp)

                t1 = TextView(ctx)
                t1.setText(self._tr(title_key))
                t1.setTextSize(17)
                t1.setTypeface(None, 1)
                if danger:
                    title_tint = self._jcolor(0xFFFF9A9A)
                elif active:
                    title_tint = active_text_color
                else:
                    title_tint = title_color
                t1.setTextColor(title_tint)
                info.addView(t1)

                if desc_key:
                    t2 = TextView(ctx)
                    t2.setText(self._tr(desc_key))
                    t2.setTextSize(12)
                    t2.setPadding(0, AndroidUtilities.dp(3), 0, 0)
                    if active and not danger:
                        active_sub = self._jcolor(0xCC18212B) if active_text_color == self._jcolor(0xFF18212B) else self._jcolor(0xD9FFFFFF)
                        t2.setTextColor(active_sub)
                    elif danger:
                        t2.setTextColor(self._jcolor(0xCCFF9A9A))
                    else:
                        t2.setTextColor(sub_color)
                    info.addView(t2)

                row.addView(info, info_lp)

                if value_text:
                    value = TextView(ctx)
                    value.setText(str(value_text))
                    value.setTextSize(13)
                    value.setTypeface(None, 1)
                    value.setGravity(Gravity.CENTER)
                    value.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(7), AndroidUtilities.dp(12), AndroidUtilities.dp(7))
                    value.setTextColor(title_color)
                    value_bg = GradientDrawable()
                    value_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                    value_bg.setColor(self._jcolor(0x00000000))
                    value_bg.setStroke(AndroidUtilities.dp(1), sub_color)
                    value.setBackground(value_bg)
                    try:
                        value.setSingleLine(True)
                        value.setMaxLines(1)
                        value.setEllipsize(jclass("android.text.TextUtils$TruncateAt").END)
                        value.setMaxWidth(AndroidUtilities.dp(140))
                    except Exception:
                        pass
                    value_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    value_lp.leftMargin = AndroidUtilities.dp(12)
                    row.addView(value, value_lp)

                if click is not None and listener_cls is not None:
                    class _Click(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v):
                            try:
                                click()
                            except Exception as e:
                                self._trace("panel row click fail: {0}".format(e), "ERROR")
                    row.setOnClickListener(_Click())

                lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                lp.topMargin = AndroidUtilities.dp(8)
                outer.addView(row, lp)

            _make_handle()

            title = TextView(ctx)
            title.setText("Pomme")
            title.setTextSize(24)
            title.setTypeface(None, 1)
            title.setTextColor(title_color)
            title.setGravity(Gravity.CENTER_HORIZONTAL)
            title_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            title_lp.bottomMargin = AndroidUtilities.dp(4)
            outer.addView(title, title_lp)

            hero_row = LinearLayout(ctx)
            hero_row.setOrientation(LinearLayout.HORIZONTAL)
            hero_row.setGravity(Gravity.CENTER_VERTICAL)
            hero_row.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))

            desc = TextView(ctx)
            desc.setText(self._tr("about_desc"))
            desc.setTextSize(15)
            desc.setTextColor(sub_color)
            desc_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            desc_lp.leftMargin = AndroidUtilities.dp(2)
            hero_row.addView(desc, desc_lp)
            outer.addView(hero_row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            actions = LinearLayout(ctx)
            actions.setOrientation(LinearLayout.HORIZONTAL)
            actions.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
            actions_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            actions_lp.topMargin = AndroidUtilities.dp(10)

            appearance_btn = TextView(ctx)
            appearance_btn.setGravity(Gravity.CENTER)
            try:
                                                    
                app_icon_id = ApplicationLoader.applicationContext.getResources().getIdentifier("menu_profile_colors_solar", "drawable", ApplicationLoader.applicationContext.getPackageName())
                if not app_icon_id:
                    app_icon_id = ApplicationLoader.applicationContext.getResources().getIdentifier("msg_palette", "drawable", ApplicationLoader.applicationContext.getPackageName())
                
                if app_icon_id:
                    app_icon = ApplicationLoader.applicationContext.getResources().getDrawable(int(app_icon_id))
                    app_icon.setColorFilter(title_color, PorterDuff.Mode.SRC_IN)
                    appearance_btn.setCompoundDrawablesWithIntrinsicBounds(app_icon, None, None, None)
                appearance_btn.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(10), AndroidUtilities.dp(8), AndroidUtilities.dp(10))
            except Exception:
                pass
            if listener_cls is not None:
                class _AppClick(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        self._show_appearance_sheet()
                appearance_btn.setOnClickListener(_AppClick())
            app_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            app_lp.rightMargin = AndroidUtilities.dp(10)
            actions.addView(appearance_btn, app_lp)

                                  
            pocket_btn = TextView(ctx)
            pocket_btn.setGravity(Gravity.CENTER)
            try:
                settings_icon_id = ApplicationLoader.applicationContext.getResources().getIdentifier("msg_settings", "drawable", ApplicationLoader.applicationContext.getPackageName())
                if settings_icon_id:
                    settings_icon = ApplicationLoader.applicationContext.getResources().getDrawable(int(settings_icon_id))
                    settings_icon.setColorFilter(title_color, PorterDuff.Mode.SRC_IN)
                    pocket_btn.setCompoundDrawablesWithIntrinsicBounds(settings_icon, None, None, None)
            except Exception:
                pass
            pocket_btn.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(10), AndroidUtilities.dp(8), AndroidUtilities.dp(10))
            if listener_cls is not None:
                class _PocketClick(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        try:
                            self._trace("Settings button clicked", "INFO")
                            host_ctx = None
                            try:
                                panel_sheet = getattr(self, "_panel_sheet", None)
                                if panel_sheet is not None and hasattr(panel_sheet, "getContext"):
                                    host_ctx = panel_sheet.getContext()
                            except Exception:
                                host_ctx = None
                            try:
                                threading.Timer(0.06, lambda: run_on_ui_thread(lambda: self._show_settings_sheet(host_ctx))).start()
                            except Exception:
                                self._show_settings_sheet(host_ctx)
                        except Exception as e:
                            self._trace("Settings button click fail: {0}".format(e), "ERROR")
                pocket_btn.setOnClickListener(_PocketClick())
            pocket_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            pocket_lp.rightMargin = AndroidUtilities.dp(10)
            actions.addView(pocket_btn, pocket_lp)

            head_btn = TextView(ctx)
            head_btn.setText(self._tr("about_button"))
            head_btn.setGravity(Gravity.CENTER)
            head_btn.setTextSize(16)
            head_btn.setTypeface(None, 1)
            try:
                head_btn.setTextColor(self._jcolor(0xFFFFFFFF))
                btn_bg = GradientDrawable()
                btn_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                btn_bg.setColor(self._jcolor(0xFFEB3F44))
                head_btn.setBackground(btn_bg)
                head_btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            except Exception:
                pass
            if listener_cls is not None:
                class _HeadClick(dynamic_proxy(listener_cls)):
                    def onClick(self_obj, _v):
                        self._show_smart_cache_sheet()
                head_btn.setOnClickListener(_HeadClick())
            actions.addView(head_btn, LinearLayout.LayoutParams(AndroidUtilities.dp(140), LinearLayout.LayoutParams.WRAP_CONTENT))
            outer.addView(actions, actions_lp)

                                          

            row_container = LinearLayout(ctx)
            row_container.setOrientation(LinearLayout.HORIZONTAL)
            row_container_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            row_container_lp.topMargin = AndroidUtilities.dp(8)

            def _small_card(title_key, desc_key, icon_name, active, click):
                card = LinearLayout(ctx)
                card.setOrientation(LinearLayout.VERTICAL)
                card.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14))
                card_colors = (chip_active_gradients if active else chip_gradients).get(title_key, (0xFFE53935, 0xFFD32F2F, 0xFFAD1457))
                card_bg = _triple_card_bg(card_colors, active=active)
                card.setBackground(card_bg)
                
                                                          
                card_lp = LinearLayout.LayoutParams(0, AndroidUtilities.dp(118), 1.0)
                
                txt_color = self._jcolor(0xFFFFFFFF)
                sub_txt_color = self._jcolor(0xD9FFFFFF)

                top = LinearLayout(ctx)
                top.setOrientation(LinearLayout.HORIZONTAL)
                top.setGravity(Gravity.CENTER_VERTICAL)

                icon_wrap = LinearLayout(ctx)
                icon_wrap.setGravity(Gravity.CENTER)
                ibg = GradientDrawable()
                ibg.setCornerRadius(float(AndroidUtilities.dp(999)))
                ibg.setColor(self._jcolor(0x20000000))
                icon_wrap.setBackground(ibg)
                icon = ImageView(ctx)
                try:
                    icon_id = ApplicationLoader.applicationContext.getResources().getIdentifier(str(icon_name), "drawable", ApplicationLoader.applicationContext.getPackageName())
                    if icon_id:
                        icon.setImageResource(int(icon_id))
                    icon.setColorFilter(int(self._jcolor(0xFFFFFFFF)), PorterDuff.Mode.SRC_IN)
                except Exception:
                    pass
                icon_wrap.addView(icon, LinearLayout.LayoutParams(AndroidUtilities.dp(16), AndroidUtilities.dp(16)))
                top.addView(icon_wrap, LinearLayout.LayoutParams(AndroidUtilities.dp(30), AndroidUtilities.dp(30)))

                if active:
                    active_badge = TextView(ctx)
                    active_badge.setText("ON")
                    active_badge.setTextSize(10)
                    active_badge.setTypeface(None, 1)
                    active_badge.setTextColor(self._jcolor(0xFFFFFFFF))
                    active_badge.setGravity(Gravity.CENTER)
                    active_badge.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(4), AndroidUtilities.dp(8), AndroidUtilities.dp(4))
                    active_badge_bg = GradientDrawable()
                    active_badge_bg.setCornerRadius(float(AndroidUtilities.dp(999)))
                    active_badge_bg.setColor(self._jcolor(0x26000000))
                    active_badge_bg.setStroke(AndroidUtilities.dp(1), self._jcolor(0x30FFFFFF))
                    active_badge.setBackground(active_badge_bg)
                    badge_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT)
                    badge_lp.leftMargin = AndroidUtilities.dp(8)
                    top.addView(active_badge, badge_lp)
                card.addView(top)

                t1 = TextView(ctx)
                t1.setText(self._tr(title_key))
                t1.setTextSize(16)
                t1.setTypeface(None, 1)
                t1.setTextColor(int(txt_color))
                t1_lp = LinearLayout.LayoutParams(-1, -2)
                t1_lp.topMargin = AndroidUtilities.dp(10)
                card.addView(t1, t1_lp)

                if desc_key:
                    t2 = TextView(ctx)
                    t2.setText(self._tr(desc_key))
                    t2.setTextSize(12)
                    t2.setTextColor(int(sub_txt_color))
                    try:
                        t2.setMaxLines(2)
                    except Exception:
                        pass
                    t2_lp = LinearLayout.LayoutParams(-1, -2)
                    t2_lp.topMargin = AndroidUtilities.dp(2)
                    card.addView(t2, t2_lp)

                if listener_cls is not None:
                    class _CardClick(dynamic_proxy(listener_cls)):
                        def onClick(self_obj, _v): click()
                    card.setOnClickListener(_CardClick())
                
                return card, card_lp

                                   
                                          
            row1 = LinearLayout(ctx)
            row1.setOrientation(LinearLayout.HORIZONTAL)
            
            c1, lp1 = _small_card("panel_auto_play", "panel_auto_play_desc", "filled_gift_play_24", self._auto_play_enabled(), lambda: (self._set_auto_play_enabled(not self._auto_play_enabled()), sheet.dismiss(), self._show_about_sheet()))
            row1.addView(c1, lp1)
            
            row1.addView(View(ctx), LinearLayout.LayoutParams(AndroidUtilities.dp(10), 1))
            
            c2, lp2 = _small_card("panel_playlist", "panel_playlist_desc", "profile_list", False, lambda: self._show_playlist_sheet())
            row1.addView(c2, lp2)
            
            outer.addView(row1, row_container_lp)
            
                                                                
            row2 = LinearLayout(ctx)
            row2.setOrientation(LinearLayout.HORIZONTAL)
            row2_lp = LinearLayout.LayoutParams(-1, -2)
            row2_lp.topMargin = AndroidUtilities.dp(10)
            
                           
            c3, lp3 = _small_card("panel_language", "panel_language_desc", "msg_translate_remix", False, lambda: self._show_language_sheet())
            row2.addView(c3, lp3)
            
            row2.addView(View(ctx), LinearLayout.LayoutParams(AndroidUtilities.dp(10), 1))
            
            c4, lp4 = _small_card("panel_data", "panel_data_chip", "msg2_data", False, lambda: self._show_data_sheet())
            row2.addView(c4, lp4)
            
            outer.addView(row2, row2_lp)

            plugin = self

            footer = LinearLayout(ctx)
            footer.setOrientation(LinearLayout.VERTICAL)
            footer_bg = GradientDrawable(GradientDrawable.Orientation.TL_BR, [footer_bg_primary, footer_bg_secondary])
            footer_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
            try:
                footer_bg.setStroke(AndroidUtilities.dp(1), footer_stroke)
            except Exception:
                pass
            footer.setBackground(footer_bg)
            footer.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14))
            footer_lp = LinearLayout.LayoutParams(-1, -2)
            footer_lp.topMargin = AndroidUtilities.dp(20)
            footer_outer = LinearLayout(ctx)
            footer_outer.setOrientation(LinearLayout.HORIZONTAL)
            footer_outer.setGravity(Gravity.CENTER_VERTICAL)

            footer_avatar = ImageView(ctx)
            try:
                footer_avatar.setScaleType(ImageView.ScaleType.CENTER_CROP)
                BitmapFactory = jclass("android.graphics.BitmapFactory")

                def _footer_avatar_bmp(url, cache_key):
                    try:
                        data = self._cached_remote_bytes(url, cache_key=cache_key)
                        if not data:
                            return None
                        return BitmapFactory.decodeByteArray(data, 0, len(data))
                    except Exception:
                        return None

                footer_file = self._footer_avatar_cache_file()
                if footer_file and os.path.exists(footer_file):
                    fb = BitmapFactory.decodeFile(footer_file)
                    if fb is not None:
                        footer_avatar.setImageBitmap(fb)
                if footer_avatar.getDrawable() is None:
                    fb2 = _footer_avatar_bmp(FOOTER_AVATAR_URL, "pomme_footer_avatar")
                    if fb2 is not None:
                        footer_avatar.setImageBitmap(fb2)
            except Exception:
                pass
            try:
                av_bg = GradientDrawable()
                r = float(AndroidUtilities.dp(12))
                av_bg.setCornerRadius(r)
                av_bg.setColor(self._jcolor(0x14000000))
                footer_avatar.setBackground(av_bg)
                ViewOutlineProvider = jclass("android.view.ViewOutlineProvider")
                footer_avatar.setClipToOutline(True)
                footer_avatar.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
            except Exception:
                pass
            footer_outer.addView(footer_avatar, LinearLayout.LayoutParams(AndroidUtilities.dp(44), AndroidUtilities.dp(44)))

            brand_col = LinearLayout(ctx)
            brand_col.setOrientation(LinearLayout.VERTICAL)
            bcol_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            bcol_lp.leftMargin = AndroidUtilities.dp(12)

            b_title = TextView(ctx)
            b_title.setText(self._tr("panel_footer_brand"))
            b_title.setTextSize(17)
            b_title.setTypeface(None, 1)
            b_title.setTextColor(title_color)
            brand_col.addView(b_title)

            b_ver = TextView(ctx)
            b_ver.setText(self._tr("panel_footer_version_fmt").format(str(__version__)))
            b_ver.setTextSize(13)
            b_ver.setTextColor(sub_color)
            brand_col.addView(b_ver)

            b_by = TextView(ctx)
            b_by.setText(self._tr("panel_footer_by_fmt").format(str(__author__)))
            b_by.setTextSize(12)
            b_by.setPadding(0, AndroidUtilities.dp(2), 0, 0)
            b_by.setTextColor(sub_color)
            brand_col.addView(b_by)
            footer_outer.addView(brand_col, bcol_lp)
            footer.addView(footer_outer)

            log_row = LinearLayout(ctx)
            log_row.setOrientation(LinearLayout.HORIZONTAL)
            log_row.setGravity(Gravity.CENTER_VERTICAL)
            log_row.setPadding(0, AndroidUtilities.dp(12), 0, 0)

            log_icon_wrap = LinearLayout(ctx)
            log_icon_wrap.setGravity(Gravity.CENTER_VERTICAL)
            liv = ImageView(ctx)
            try:
                res = ApplicationLoader.applicationContext.getResources()
                pkg = ApplicationLoader.applicationContext.getPackageName()
                log_id = res.getIdentifier("device_phone_ios", "drawable", pkg)
                if not log_id:
                    log_id = res.getIdentifier("msg_log", "drawable", pkg)
                if log_id:
                    liv.setImageResource(int(log_id))
                    liv.setColorFilter(sub_color, PorterDuff.Mode.SRC_IN)
            except Exception:
                pass
            log_icon_wrap.addView(liv, LinearLayout.LayoutParams(AndroidUtilities.dp(22), AndroidUtilities.dp(22)))
            log_row.addView(log_icon_wrap)

            log_labels = LinearLayout(ctx)
            log_labels.setOrientation(LinearLayout.VERTICAL)
            llab_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            llab_lp.leftMargin = AndroidUtilities.dp(8)

            lt1 = TextView(ctx)
            lt1.setText(self._tr("panel_footer_live_logs"))
            lt1.setTextSize(15)
            lt1.setTypeface(None, 1)
            lt1.setTextColor(title_color)
            log_labels.addView(lt1)

            lt2 = TextView(ctx)
            lt2.setText(self._tr("panel_footer_live_logs_sub"))
            lt2.setTextSize(11)
            lt2.setPadding(0, AndroidUtilities.dp(2), 0, 0)
            lt2.setTextColor(sub_color)
            log_labels.addView(lt2)
            log_row.addView(log_labels, llab_lp)

            try:
                Switch = jclass("android.widget.Switch")
                log_sw = Switch(ctx)
                plugin._live_log_ignore_switch = True
                try:
                    log_sw.setChecked(bool(plugin._live_log_enabled))
                finally:
                    plugin._live_log_ignore_switch = False
                CC = jclass("android.widget.CompoundButton$OnCheckedChangeListener")

                class _LogSw(dynamic_proxy(CC)):
                    def onCheckedChanged(self, buttonView, isChecked):
                        if getattr(plugin, "_live_log_ignore_switch", False):
                            return
                        plugin._set_live_log_enabled(bool(isChecked))

                log_sw.setOnCheckedChangeListener(_LogSw())
                log_row.addView(log_sw, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            except Exception:
                pass

            footer.addView(log_row)

            def _on_pocket_changed(is_checked, sw, sw_ign):
                if bool(plugin._pocket_mode_install_in_progress):
                    sw_ign[0] = True
                    try:
                        sw.setChecked(bool(plugin.get_setting("pomme_pocket_mode", False)))
                    finally:
                        sw_ign[0] = False
                    return
                try:
                    sw.setEnabled(False)
                    sw.setClickable(False)
                except Exception:
                    pass

                want = bool(is_checked)

                def _done(success, final_enabled):
                    try:
                        sw_ign[0] = True
                        try:
                            sw.setEnabled(True)
                            sw.setClickable(True)
                            sw.setChecked(bool(final_enabled))
                        finally:
                            sw_ign[0] = False
                    except Exception:
                        pass

                try:
                    if getattr(plugin, "_panel_sheet", None) is not None:
                        plugin._panel_sheet.dismiss()
                        plugin._panel_sheet = None
                except Exception:
                    pass

                plugin._toggle_pocket_mode(icon_view=None, desired_enabled=want, done_cb=_done)

            pocket_row_lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            pocket_row_lp.topMargin = AndroidUtilities.dp(12)
            pocket_row = self._build_settings_switch_row(
                ctx,
                title_color,
                sub_color,
                "menu_download_round",
                self._tr("panel_pocket_mode_switch_title"),
                self._tr("panel_pocket_mode_switch_desc"),
                bool(self.get_setting("pomme_pocket_mode", False)),
                _on_pocket_changed,
                row_fill=self._jcolor(0xFF243743),
                icon_fill=self._jcolor(0xFF35535F),
                icon_tint=self._jcolor(0xFFC8F1FF),
                text_tint=self._jcolor(0xFFF1FAFF),
                desc_tint=self._jcolor(0xFF9FB6C2),
            )
            footer.addView(pocket_row, pocket_row_lp)

            outer.addView(footer, footer_lp)

            scroll.addView(outer)
            sheet_root.addView(scroll, FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT))
            sheet.setCustomView(sheet_root)
            sheet.show()
            self._panel_sheet = sheet
        except Exception as e:
            tb = traceback.format_exc()
            self._trace("show about fail: {0}\n{1}".format(e, tb), "ERROR")
            self._show_error_sheet("Pomme panel render failed:\n{0}".format(e))


plugin = PommePlugin()
