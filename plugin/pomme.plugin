    def on_plugin_load(self):
        self._enabled = bool(self.get_setting("pomme_enabled", self.get_setting("etgmusic_enabled", self.get_setting("etgyt_enabled", False))))
        self._trace("Plugin loaded. Version: {0}".format(__version__), "INFO")
        self._setup_hooks()
        self._register_widget_pill()
        self._ensure_idle_watch()
        self._load_telemetry_queue()
        try:
            self._telemetry_queue_event("session_start", feature="", count=1, force_flush=True)
            if not bool(self.get_setting("pomme_stats_install_event_sent_v1", False)):
                self._telemetry_queue_event("install", feature="", count=1, force_flush=True)
                self.set_setting("pomme_stats_install_event_sent_v1", True)
        except Exception:
            pass
        self._sync_user_playlists_to_cache()
        if bool(getattr(self, "_live_log_enabled", False)):
            try:
                self._show_live_log()
            except Exception:
                pass

    def on_plugin_unload(self):
        self._trace("Plugin unloading...", "WARN")
        try:
            self._push_on_dialogs_hidden()
        except Exception:
            pass
        try:
            self._remove_live_log()
        except Exception:
            pass
        self._idle_watch_started = False
        self._playback_watch_running = False
        self._idle_watch_token += 1
        self._playback_watch_token += 1
        try:
            for h in list(self._hooks):
                try:
                    self.unhook_method(h)
                except Exception:
                    pass
        except Exception:
            pass
        self._hooks = []
        try:
            if self._edit_ref is not None and self._native_watcher is not None and bool(self._native_watcher_removed):
                self._edit_ref.addTextChangedListener(self._native_watcher)
                self._native_watcher_removed = False
        except Exception:
            pass
        run_on_ui_thread(self._detach_state)

    def _trace(self, msg, level="INFO"):
        try:
            ts = time.strftime("%H:%M:%S")
            full_msg = "[{0}][{1}] {2}".format(ts, level, msg)
            
                          
            log("[{0}][ETGMUSIC] {1}".format(level, msg))
            
                                                        
            if hasattr(self, "_log_buffer"):
                self._log_buffer.append(full_msg)
            
                                                 
            if getattr(self, "_live_log_enabled", False):
                self._update_live_log(full_msg)
            
                                                 
            if hasattr(self, "_debug_logs"):
                self._debug_logs.append(full_msg)
        except Exception:
            pass

    def _safe_mode_enabled(self):
        try:
            v = self.get_setting("pomme_safe_mode_enabled", False)
            if isinstance(v, bool):
                return v
            if isinstance(v, (int, float)):
                return bool(int(v))
            s = str(v or "").strip().lower()
            if s in ("1", "true", "on", "yes", "enabled"):
                return True
            if s in ("0", "false", "off", "no", "disabled"):
                return False
            return bool(v)
        except Exception:
            return False

    def _remove_live_log(self):
        try:
            def _rem():
                try:
                    if self._live_log_view is not None:
                        par = self._live_log_view.getParent()
                        if par is not None and hasattr(par, "removeView"):
                            par.removeView(self._live_log_view)
                except Exception:
                    pass
                self._live_log_view = None
                self._log_text_view = None
                self._log_scroll_view = None
                self._live_log_expanded = None
                self._live_log_chip = None
            run_on_ui_thread(_rem)
        except Exception:
            pass

    def _set_live_log_enabled(self, enabled):
        try:
            enabled = bool(enabled)
            self._live_log_enabled = enabled
            self.set_setting("pomme_live_log", enabled)
            if not enabled:
                self._remove_live_log()
            else:
                self._show_live_log()
        except Exception:
            pass

    def _toggle_live_log(self):
        try:
            self._set_live_log_enabled(not bool(getattr(self, "_live_log_enabled", False)))
        except Exception:
            pass

    def _load_telemetry_queue(self):
        try:
            raw = self.get_setting("pomme_stats_queue_v1", "[]")
            arr = raw if isinstance(raw, list) else json.loads(str(raw or "[]"))
            self._telemetry_queue = arr if isinstance(arr, list) else []
        except Exception:
            self._telemetry_queue = []

    def _save_telemetry_queue(self):
        try:
            self.set_setting("pomme_stats_queue_v1", json.dumps(list(self._telemetry_queue or []), ensure_ascii=True, separators=(",", ":")))
        except Exception:
            pass

    def _telemetry_install_id_get(self):
        try:
            if self._telemetry_install_id:
                return str(self._telemetry_install_id)
            cached = str(self.get_setting("pomme_stats_install_id", "") or "").strip()
            if cached:
                self._telemetry_install_id = cached
                return cached
            sid = "pmm_{0:x}{1:x}".format(int(time.time() * 1000), random.randint(0, 0xFFFFFF))
            self.set_setting("pomme_stats_install_id", sid)
            self._telemetry_install_id = sid
            return sid
        except Exception:
            return "pmm_unknown"

    def _telemetry_app_snapshot(self):
        out = {
            "app_id": "unknown",
            "app_variant": "unknown",
            "app_version": "unknown",
            "plugin_version": str(__version__),
        }
        try:
            ctx = ApplicationLoader.applicationContext
            if ctx is None:
                return out
            pkg = str(ctx.getPackageName() or "unknown").strip() or "unknown"
            out["app_id"] = pkg
            l = pkg.lower()
            if "ayu" in l:
                out["app_variant"] = "ayugram"
            elif "extera" in l:
                out["app_variant"] = "exteragram"
            try:
                pm = ctx.getPackageManager()
                pi = pm.getPackageInfo(pkg, 0)
                out["app_version"] = str(getattr(pi, "versionName", "") or getattr(pi, "versionCode", "unknown"))
            except Exception:
                pass
        except Exception:
            pass
        return out

    def _telemetry_queue_event(self, event_name, feature=None, count=1, force_flush=False):
        try:
            name = str(event_name or "").strip()
            if not name:
                return
            ev = {
                "ts": int(time.time()),
                "event": name,
                "feature": str(feature or "").strip(),
                "count": int(count or 1),
            }
            with self._telemetry_lock:
                q = list(self._telemetry_queue or [])
                q.append(ev)
                if len(q) > 180:
                    q = q[-180:]
                self._telemetry_queue = q
            self._save_telemetry_queue()
            now_ts = int(time.time())
            if force_flush or (now_ts - int(self._telemetry_last_flush_ts or 0) >= 20):
                self._telemetry_flush_async()
        except Exception:
            pass

    def _telemetry_flush_async(self):
        try:
            with self._telemetry_lock:
                if self._telemetry_sending:
                    return
                queue = list(self._telemetry_queue or [])
                if not queue:
                    return
                self._telemetry_sending = True
            payload = {
                "plugin": "pomme",
                "install_id": self._telemetry_install_id_get(),
                "sent_at": int(time.time()),
                "app": self._telemetry_app_snapshot(),
                "events": queue[:120],
            }

            def _worker():
                ok = False
                try:
                    ok = self._telemetry_post(payload)
                except Exception:
                    ok = False
                try:
                    with self._telemetry_lock:
                        if ok:
                            cur = list(self._telemetry_queue or [])
                            drop = min(len(cur), len(payload.get("events", []) or []))
                            self._telemetry_queue = cur[drop:]
                            self._telemetry_last_flush_ts = int(time.time())
                            self._save_telemetry_queue()
                        self._telemetry_sending = False
                except Exception:
                    self._telemetry_sending = False

            threading.Thread(target=_worker, daemon=True).start()
        except Exception:
            self._telemetry_sending = False

    def _telemetry_post(self, payload):
        try:
            raw = json.dumps(payload, ensure_ascii=True, separators=(",", ":")).encode("utf-8")
            headers = {
                "User-Agent": "PommeStats/1.0",
                "Content-Type": "application/json",
                "Cache-Control": "no-cache",
            }
            token = str(GEEKSTATS_INGEST_TOKEN or "").strip()
            if token:
                headers["X-Ingest-Token"] = token
            req = Request(GEEKSTATS_INGEST_URL, data=raw, headers=headers, method="POST")
            with urlopen(req, timeout=6) as resp:
                code = int(getattr(resp, "status", 200) or 200)
                return 200 <= code < 300
        except Exception:
            return False

    def _plugin_icon_drawable_id(self):
        """Brand icon in the main panel footer (`PommePlugin` drawable — same slot as the old dev avatar)."""
        try:
            pkg = ApplicationLoader.applicationContext.getPackageName()
            res = ApplicationLoader.applicationContext.getResources()
            for name in ("PommePlugin", "pommeplugin", "pomme_plugin"):
                for kind in ("drawable", "mipmap"):
                    rid = res.getIdentifier(str(name), kind, pkg)
                    if rid:
                        return rid
            return 0
        except Exception:
            return 0

    def _clamp_live_log_margins(self, root=None):
        try:
            root = root or self._live_log_view
            if root is None:
                return
            par = root.getParent()
            if par is None:
                return
            lp = root.getLayoutParams()
            if lp is None:
                return
            dw = int(par.getWidth())
            dh = int(par.getHeight())
            w = int(lp.width)
            h = int(lp.height)
            if dw <= 0 or dh <= 0 or w <= 0 or h <= 0:
                return
            rm = int(getattr(lp, "rightMargin", 0) or 0)
            tm = int(getattr(lp, "topMargin", 0) or 0)
            rm = max(0, min(rm, dw - w))
            tm = max(0, min(tm, dh - h))
            lp.rightMargin = rm
            lp.topMargin = tm
            root.setLayoutParams(lp)
        except Exception:
            pass

    def _attach_live_log_drag_listener(self, target_view, drag_mode):
        try:
            touch_cls = find_class("android.view.View$OnTouchListener")
            if touch_cls is None or target_view is None:
                return
            plugin = self

            class _Drag(dynamic_proxy(touch_cls)):
                def onTouch(self_obj, v, event):
                    try:
                        action = int(event.getActionMasked())
                        root = plugin._live_log_view
                        if root is None:
                            return False
                        par = root.getParent()
                        if par is None:
                            return False
                        dw = int(par.getWidth())
                        dh = int(par.getHeight())
                        lp = root.getLayoutParams()
                        if lp is None:
                            return False
                        if action == MotionEvent.ACTION_DOWN:
                            plugin._log_drag_moved = False
                            plugin._log_drag_sx = float(event.getRawX())
                            plugin._log_drag_sy = float(event.getRawY())
                            plugin._log_drag_rm0 = int(getattr(lp, "rightMargin", 0) or 0)
                            plugin._log_drag_tm0 = int(getattr(lp, "topMargin", 0) or 0)
                            return True
                        if action == MotionEvent.ACTION_MOVE:
                            dx = float(event.getRawX()) - plugin._log_drag_sx
                            dy = float(event.getRawY()) - plugin._log_drag_sy
                            if abs(dx) > 6 or abs(dy) > 6:
                                plugin._log_drag_moved = True
                            w = int(lp.width)
                            h = int(lp.height)
                            nrm = int(plugin._log_drag_rm0 - dx)
                            ntm = int(plugin._log_drag_tm0 + dy)
                            if dw > 0 and dh > 0:
                                nrm = max(0, min(nrm, dw - w))
                                ntm = max(0, min(ntm, dh - h))
                            lp.rightMargin = nrm
                            lp.topMargin = ntm
                            root.setLayoutParams(lp)
                            return True
                        if action in (MotionEvent.ACTION_UP, MotionEvent.ACTION_CANCEL):
                            if plugin._log_drag_moved:
                                try:
                                    plugin.set_setting("pomme_live_log_rm", int(lp.rightMargin))
                                    plugin.set_setting("pomme_live_log_tm", int(lp.topMargin))
                                except Exception:
                                    pass
                            elif drag_mode == "chip" and action == MotionEvent.ACTION_UP:
                                plugin._set_live_log_collapsed(False)
                            return True
                    except Exception:
                        pass
                    return False

            target_view.setOnTouchListener(_Drag())
        except Exception:
            pass

    def _set_live_log_collapsed(self, collapsed):
        try:
            collapsed = bool(collapsed)
            self._live_log_collapsed = collapsed
            self.set_setting("pomme_live_log_collapsed", collapsed)

            def _ui():
                try:
                    if self._live_log_view is None:
                        return
                    c = bool(collapsed)
                    if self._live_log_expanded is not None:
                        self._live_log_expanded.setVisibility(View.GONE if c else View.VISIBLE)
                    if self._live_log_chip is not None:
                        self._live_log_chip.setVisibility(View.VISIBLE if c else View.GONE)
                    lp = self._live_log_view.getLayoutParams()
                    if lp is not None:
                        if c:
                            lp.width = AndroidUtilities.dp(48)
                            lp.height = AndroidUtilities.dp(48)
                        else:
                            lp.width = AndroidUtilities.dp(272)
                            lp.height = AndroidUtilities.dp(204)
                        self._live_log_view.setLayoutParams(lp)
                        self._clamp_live_log_margins(self._live_log_view)
                except Exception:
                    pass

            run_on_ui_thread(_ui)
        except Exception:
            pass

    def _update_live_log(self, message):
        try:
            def _upd():
                try:
                    if self._live_log_view is None:
                        self._show_live_log()

                    if self._log_text_view is not None:
                        current = str(self._log_text_view.getText() or "")
                        lines = current.split("\n")
                        if len(lines) > 20:
                            lines = lines[-20:]
                        new_text = "\n".join(lines) + "\n" + message
                        self._log_text_view.setText(new_text)

                        if self._log_scroll_view is not None:
                            self._log_scroll_view.post(lambda: self._log_scroll_view.fullScroll(View.FOCUS_DOWN))
                except Exception:
                    pass

            run_on_ui_thread(_upd)
        except Exception:
            pass

    def _show_live_log(self):
        try:
            def _show():
                try:
                    frag = get_last_fragment()
                    ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
                    if ctx is None:
                        return

                    if self._live_log_view is not None:
                        return

                    listener_cls = find_class("android.view.View$OnClickListener")
                    collapsed = bool(getattr(self, "_live_log_collapsed", False))
                    plugin = self

                    root = FrameLayout(ctx)

                    expanded = LinearLayout(ctx)
                    expanded.setOrientation(LinearLayout.VERTICAL)
                    bg = GradientDrawable()
                    bg.setColor(self._jcolor(0xAA000000))
                    bg.setCornerRadius(float(AndroidUtilities.dp(10)))
                    expanded.setBackground(bg)
                    expanded.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(8), AndroidUtilities.dp(10), AndroidUtilities.dp(10))

                    header_row = LinearLayout(ctx)
                    header_row.setOrientation(LinearLayout.HORIZONTAL)
                    header_row.setGravity(Gravity.CENTER_VERTICAL)

                    header = TextView(ctx)
                    header.setText(self._tr("live_log_title"))
                    header.setTextSize(11)
                    header.setTypeface(None, 1)
                    header.setTextColor(self._jcolor(0xFF00FF00))
                    hlp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
                    header_row.addView(header, hlp)

                    min_btn = TextView(ctx)
                    min_btn.setText("−")
                    min_btn.setTextSize(18)
                    min_btn.setTextColor(self._jcolor(0xFFBBBBBB))
                    min_btn.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4))
                    try:
                        min_btn.setContentDescription(self._tr("live_log_minimize"))
                    except Exception:
                        pass
                    try:
                        res = ApplicationLoader.applicationContext.getResources()
                        pkg = ApplicationLoader.applicationContext.getPackageName()
                        min_id = res.getIdentifier("ic_ab_new", "drawable", pkg)
                        if min_id:
                            min_btn.setText("")
                            min_icon = res.getDrawable(int(min_id))
                            min_icon.setColorFilter(self._jcolor(0xFFBBBBBB), PorterDuff.Mode.SRC_IN)
                            min_btn.setCompoundDrawablesWithIntrinsicBounds(min_icon, None, None, None)
                    except Exception:
                        pass
                    if listener_cls is not None:
                        class _Min(dynamic_proxy(listener_cls)):
                            def onClick(self_obj, _v):
                                plugin._set_live_log_collapsed(True)

                        min_btn.setOnClickListener(_Min())
                    header_row.addView(min_btn)
                    expanded.addView(header_row)

                    scroll = AndroidScrollView(ctx)
                    self._log_scroll_view = scroll
                    log_tv = TextView(ctx)
                    log_tv.setTextSize(9)
                    log_tv.setTextColor(self._jcolor(0xFFE8E8E8))
                    log_tv.setText("\n".join(list(self._log_buffer)))
                    try:
                        log_tv.setMinimumHeight(AndroidUtilities.dp(148))
                    except Exception:
                        pass
                    try:
                        log_tv.setClickable(True)
                    except Exception:
                        pass
                    self._log_text_view = log_tv
                    scroll.addView(log_tv)
                    if listener_cls is not None:

                        class _CopyLogs(dynamic_proxy(listener_cls)):
                            def onClick(self_obj, _v):
                                try:
                                    tv = plugin._log_text_view
                                    txt = str(tv.getText() or "").strip() if tv is not None else ""
                                    if not txt:
                                        return
                                    if plugin._copy_text_to_clipboard(txt):
                                        BulletinHelper.show_info(plugin._tr("log_copied_clipboard"))
                                except Exception:
                                    pass

                        log_tv.setOnClickListener(_CopyLogs())
                    try:
                        long_listener_cls = find_class("android.view.View$OnLongClickListener")
                    except Exception:
                        long_listener_cls = None
                    if long_listener_cls is not None:
                        class _ClearLogs(dynamic_proxy(long_listener_cls)):
                            def onLongClick(self_obj, _v):
                                try:
                                    plugin._log_buffer.clear()
                                    tv = plugin._log_text_view
                                    if tv is not None:
                                        tv.setText("")
                                    BulletinHelper.show_info(plugin._tr("log_cleared"))
                                    return True
                                except Exception:
                                    return False

                        log_tv.setOnLongClickListener(_ClearLogs())
                    expanded.addView(scroll, LinearLayout.LayoutParams(-1, AndroidUtilities.dp(148)))
                    self._live_log_expanded = expanded

                    chip = FrameLayout(ctx)
                    chip_bg = GradientDrawable()
                    chip_bg.setColor(self._jcolor(0xDD101010))
                    chip_bg.setCornerRadius(float(AndroidUtilities.dp(24)))
                    chip.setBackground(chip_bg)
                    chip.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
                    log_icon = ImageView(ctx)
                    try:
                        res = ApplicationLoader.applicationContext.getResources()
                        pkg = ApplicationLoader.applicationContext.getPackageName()
                        lid = res.getIdentifier("device_phone_ios", "drawable", pkg)
                        if not lid:
                            lid = res.getIdentifier("msg_log", "drawable", pkg)
                        if lid:
                            log_icon.setImageResource(int(lid))
                            log_icon.setColorFilter(self._jcolor(0xFFE24444), PorterDuff.Mode.SRC_IN)
                    except Exception:
                        pass
                    chip.addView(log_icon, FrameLayout.LayoutParams(AndroidUtilities.dp(30), AndroidUtilities.dp(30), Gravity.CENTER))
                    try:
                        chip.setContentDescription(self._tr("live_log_title"))
                    except Exception:
                        pass
                    self._live_log_chip = chip

                    expanded.setVisibility(View.GONE if collapsed else View.VISIBLE)
                    chip.setVisibility(View.VISIBLE if collapsed else View.GONE)

                    exp_lp = FrameLayout.LayoutParams(-1, -1, Gravity.TOP | Gravity.LEFT)
                    root.addView(expanded, exp_lp)
                    chip_lp = FrameLayout.LayoutParams(AndroidUtilities.dp(48), AndroidUtilities.dp(48), Gravity.TOP | Gravity.RIGHT)
                    root.addView(chip, chip_lp)

                    window = ctx.getWindow()
                    if window:
                        decor = window.getDecorView()
                        if hasattr(decor, "addView"):
                            tw = AndroidUtilities.dp(272) if not collapsed else AndroidUtilities.dp(48)
                            th = AndroidUtilities.dp(204) if not collapsed else AndroidUtilities.dp(48)
                            try:
                                dw = int(decor.getWidth())
                                dh = int(decor.getHeight())
                            except Exception:
                                dw, dh = 0, 0
                            if dw <= 0:
                                dw = AndroidUtilities.dp(360)
                            if dh <= 0:
                                dh = AndroidUtilities.dp(720)
                            rm = plugin.get_setting("pomme_live_log_rm", None)
                            tm = plugin.get_setting("pomme_live_log_tm", None)
                            if rm is None or tm is None:
                                rm = AndroidUtilities.dp(10)
                                tm = AndroidUtilities.dp(60)
                            else:
                                rm = int(rm)
                                tm = int(tm)
                            rm = max(0, min(rm, dw - tw))
                            tm = max(0, min(tm, dh - th))
                            lp = FrameLayout.LayoutParams(tw, th)
                            lp.gravity = Gravity.TOP | Gravity.RIGHT
                            lp.topMargin = tm
                            lp.rightMargin = rm
                            decor.addView(root, lp)
                            self._live_log_view = root
                            plugin._attach_live_log_drag_listener(chip, "chip")
                            plugin._attach_live_log_drag_listener(header_row, "header")

                            def _post_clamp():
                                try:
                                    plugin._clamp_live_log_margins(root)
                                except Exception:
                                    pass

                            try:
                                decor.post(_post_clamp)
                            except Exception:
                                try:
                                    run_on_ui_thread(_post_clamp)
                                except Exception:
                                    pass
                except Exception:
                    pass

            run_on_ui_thread(_show)
        except Exception:
            pass

    def _touch_activity(self):
        try:
            self._last_plugin_activity_ts = time.time()
        except Exception:
            pass

    def _detect_report_app(self):
        try:
            ctx = ApplicationLoader.applicationContext
            pkg = str(ctx.getPackageName() or "").strip().lower() if ctx is not None else ""
            if "ayugram" in pkg:
                return "AyuGram"
            if "exteragram" in pkg:
                return "exteraGram"
            return "Unknown"
        except Exception:
            return "Unknown"

    def _detect_app_version(self):
        try:
            ctx = ApplicationLoader.applicationContext
            if ctx is None:
                return ""
            pm = ctx.getPackageManager()
            pkg = ctx.getPackageName()
            info = pm.getPackageInfo(pkg, 0)
            return str(getattr(info, "versionName", "") or "")
        except Exception:
            return ""

    def _send_install_ping_once(self):
        try:
            token = str(GEEKSTATS_INGEST_TOKEN or "").strip()
            if not token:
                return False
            app_name = self._detect_report_app()
            app_version = self._detect_app_version()
            sent_key = "pomme_geekstats_install_sent::{0}::{1}::{2}".format(app_name, app_version, __version__)
            if bool(self.get_setting(sent_key, False)):
                return False

            def _worker():
                try:
                    payload = {
                        "plugin": "Pomme",
                        "plugin_version": str(__version__),
                        "event": "install",
                        "app": str(app_name),
                        "app_version": str(app_version),
                        "sent_at": int(time.time()),
                    }
                    raw = json.dumps(payload, ensure_ascii=True, separators=(",", ":")).encode("utf-8")
                    headers = {
                        "Content-Type": "application/json",
                        "Cache-Control": "no-cache",
                        "X-Ingest-Token": token,
                    }
                    req = Request(GEEKSTATS_INGEST_URL, data=raw, headers=headers, method="POST")
                    with urlopen(req, timeout=6) as resp:
                        code = int(getattr(resp, "status", 200) or 200)
                    if 200 <= code < 300:
                        self.set_setting(sent_key, True)
                except Exception as e:
                    self._trace("GeekStats install ping fail: {0}".format(e), "WARN")

            threading.Thread(target=_worker, daemon=True).start()
            return True
        except Exception as e:
            self._trace("GeekStats install bootstrap fail: {0}".format(e), "WARN")
            return False

    def _ensure_idle_watch(self):
        try:
            if self._idle_watch_started:
                return
            self._idle_watch_started = True
            self._idle_watch_token += 1
            token = int(self._idle_watch_token)

            def _tick():
                try:
                    if not self._idle_watch_started or int(self._idle_watch_token) != token:
                        return
                    if bool(self._enabled) and not self._is_anything_playing() and not self._active_play_ctx and not self._queue_items:
                        idle_for = time.time() - float(self._last_plugin_activity_ts or 0.0)
                        if idle_for >= 600.0:
                            self._trace("idle auto-disable after 10 minutes", "INFO")
                            run_on_ui_thread(lambda: self._set_enabled(False, False))
                    timer = threading.Timer(60.0, _tick)
                    timer.daemon = True
                    timer.start()
                except Exception as tick_error:
                    self._idle_watch_started = False
                    self._trace("idle watch tick fail: {0}".format(tick_error), "ERROR")

            timer = threading.Timer(60.0, _tick)
            timer.daemon = True
            timer.start()
        except Exception as e:
            self._idle_watch_started = False
            self._trace("idle watch bootstrap fail: {0}".format(e), "ERROR")

    def _jcolor(self, value):
        try:
            if hasattr(value, "intValue"):
                iv = value.intValue()
            else:
                iv = int(value)
            iv = iv & 0xFFFFFFFF
            if iv > 0x7FFFFFFF:
                iv -= 0x100000000
            return iv
        except Exception:
            return 0

    def _contrast_text_color(self, bg_color):
        try:
            if hasattr(bg_color, "intValue"):
                value = bg_color.intValue() & 0xFFFFFFFF
            else:
                value = int(bg_color) & 0xFFFFFFFF
            r = (value >> 16) & 0xFF
            g = (value >> 8) & 0xFF
            b = value & 0xFF
            luminance = (0.299 * r) + (0.587 * g) + (0.114 * b)
            return self._jcolor(0xFF18212B) if luminance > 160 else self._jcolor(0xFFFFFFFF)
        except Exception:
            return self._jcolor(0xFFFFFFFF)

    def _tr(self, key):
        try:
            lang = str(self.get_setting("pomme_language", "en")).lower()
        except Exception:
            lang = "en"
        table = TRANSLATIONS.get(key, {})
        return table.get(lang) or table.get("en") or key

    def _safe_int(self, value, default=0):
        try:
            if value is None:
                return int(default)
            if isinstance(value, bool):
                return int(value)
            if isinstance(value, int):
                return value
            if isinstance(value, float):
                return int(round(value))
            s = str(value).strip()
            if not s:
                return int(default)
            return int(float(s))
        except Exception:
            return int(default)

    def _iter_java_list(self, obj):
        if obj is None:
            return
        try:
            for x in obj:
                yield x
        except TypeError:
            try:
                n = int(obj.size())
            except Exception:
                return
            for i in range(n):
                try:
                    yield obj.get(i)
                except Exception:
                    break

    def _is_tl_document_attribute_audio(self, attr):
        try:
            if attr is None:
                return False
            try:
                name = str(attr.getClass().getName() or "")
            except Exception:
                name = ""
            return ("TL_documentAttributeAudio" in name) or name.endswith("$TL_documentAttributeAudio")
        except Exception:
            return False

    def _parse_duration_seconds(self, value, default=0):
        try:
            if value is None:
                return int(default)
            if isinstance(value, (int, float)) and not isinstance(value, bool):
                v = float(value)
                if v > 46000:
                    return int(round(v / 1000.0))
                return int(round(v))
            s = str(value).strip()
            if not s:
                return int(default)
            if ":" in s:
                parts = [p.strip() for p in s.split(":") if str(p).strip() != ""]
                nums = []
                for p in parts:
                    try:
                        nums.append(int(float(p)))
                    except Exception:
                        return self._safe_int(s, default)
                if not nums:
                    return int(default)
                if len(nums) == 1:
                    return nums[0]
                if len(nums) == 2:
                    return nums[0] * 60 + nums[1]
                return nums[-3] * 3600 + nums[-2] * 60 + nums[-1]
            return self._safe_int(s, default)
        except Exception:
            return int(default)

    def _setup_hooks(self):
        try:
            dialogs_cls = JClass.forName("org.telegram.ui.DialogsActivity")
