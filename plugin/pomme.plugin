class PommeMediaNextHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if self.plugin._is_hard_stop_active():
                param.setResult(None)
                return
            if not self.plugin._is_current_pomme_track():
                return
            if self.plugin._handle_transport_skip("next"):
                param.setResult(None)
        except Exception as e:
            self.plugin._trace("media next hook fail: {0}".format(e), "ERROR")


class PommeMediaPrevHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if self.plugin._is_hard_stop_active():
                param.setResult(None)
                return
            if not self.plugin._is_current_pomme_track():
                return
            if self.plugin._handle_transport_skip("prev"):
                param.setResult(None)
        except Exception as e:
            self.plugin._trace("media prev hook fail: {0}".format(e), "ERROR")


class PommeBackupPickerHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if not bool(getattr(self.plugin, "_backup_picker_active", False)):
                return
            req_code, res_code, data = param.args
            if req_code != getattr(self.plugin, "_backup_picker_request", -1):
                return
            param.setResult(None)
            self.plugin._handle_backup_picker_result(res_code, data)
        except Exception:
            pass


