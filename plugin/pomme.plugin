    def _show_debug_sheet_ui(self, lines, forced_ctx=None):
        try:
            frag = get_last_fragment()
            ctx = forced_ctx or (frag.getParentActivity() if frag and frag.getParentActivity() else None)
            if ctx is None:
                self._trace("debug sheet skipped: ctx is None | {0}".format(lines), "ERROR")
                return

            sheet = BottomSheet(ctx, True)
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(
                AndroidUtilities.dp(16),
                AndroidUtilities.dp(16),
                AndroidUtilities.dp(16),
                AndroidUtilities.dp(16)
            )

            title = TextView(ctx)
            title.setText(self._tr("player_debug_title"))
            title.setTextSize(18)
            title.setTypeface(None, 1)
            try:
                title.setTextColor(int(Theme.getColor(Theme.key_dialogTextBlack)))
            except Exception:
                pass
            outer.addView(title)

            detail = TextView(ctx)
            detail.setText("\n".join([str(x) for x in list(lines or []) if x is not None]))
            detail.setPadding(0, AndroidUtilities.dp(8), 0, 0)
            detail.setTextSize(13)
            try:
                detail.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            except Exception:
                pass
            outer.addView(detail)

            sheet.setCustomView(outer)
            sheet.show()
        except Exception as e:
            self._trace("show debug sheet fail: {0}".format(e), "ERROR")

    def _cache_dir(self):
        try:
            File = jclass("java.io.File")
            base_dir = ApplicationLoader.getFilesDirFixed()
            if base_dir is None:
                raise Exception("Files dir unavailable")
            temp_dir = File(base_dir, "Pomme_Temp")
            
            if not temp_dir.exists():
                temp_dir.mkdirs()
            base = str(temp_dir.getAbsolutePath())
            os.makedirs(base, exist_ok=True)
            return base
        except Exception as e:
            self._trace("cache dir fail: {0}".format(e), "ERROR")
            return None

    def _artwork_cache_dir(self):
        try:
            base = self._cache_dir()
            if not base:
                return None
            path = os.path.join(base, "artwork")
            os.makedirs(path, exist_ok=True)
            return path
        except Exception:
            return None

