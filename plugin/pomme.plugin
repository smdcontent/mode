        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            self.plugin._trace("player dismiss hook observed", "DEBUG")
            self.plugin._handle_player_sheet_closed(getattr(param, "thisObject", None))
        except Exception as e:
            self.plugin._trace("player dismiss hook fail: {0}".format(e), "ERROR")


class PommePlayerSaveToProfileHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            path = str(self.plugin._current_playing_audio_path() or "")
            looks_pomme = bool(self.plugin._is_current_pomme_track()) or "Pomme_Temp" in path
            if not looks_pomme:
                return
            param.setResult(None)
            self.plugin._trace("native saveToProfile suppressed for Pomme track", "INFO")
        except Exception as e:
            self.plugin._trace("player saveToProfile hook fail: {0}".format(e), "ERROR")


